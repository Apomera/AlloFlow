1,226.64,228.68],[272,228.68,230.2],[273,230.2,230.56],[274,230.56,231.08],[275,231.08,232.56],[276,232.56,233.72],[277,233.72,233.96],[278,233.96,234.28],[279,234.28,234.72],[280,234.72,236.04],[281,236.04,236.76],[282,236.76,237.12],[283,237.12,237.44],[284,237.44,238.72],[285,238.72,239.56],[286,239.56,240.56],[287,240.56,241.56],[288,241.56,241.84],[289,241.84,242.8],[290,242.8,243.44],[291,243.44,244.52],[292,244.52,245.4],[293,245.4,245.96],[294,245.96,248.08],[295,248.08,248.52],[296,248.52,249.2],[297,249.2,250.28],[298,250.28,250.68],[299,250.68,252],[300,252,252.84],[301,252.84,253.64],[302,253.64,254.32],[303,254.32,255.6],[304,255.6,255.76],[305,255.76,255.96],[306,255.96,256.28],[307,256.28,257.36],[308,257.36,257.72],[309,257.72,258.16],[310,258.16,318.16]]},"pages":[{"n":1,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/1584/size6/8f2ad771eae7b81887aa8a7feeba18ed.jpg","text":"तशा अनूला बाबाच्या खूप गोष्टी आवडतात. बाबानं केलेला आकाशकंदील, त्यानं तळलेली कांद्याची भजी, त्यानं केलेलं कागदाचं कासव...\nशिवाय तो उड्या मारत जिने चढतो, मामाबरोबर कुस्ती खेळतो, पाहुणे आले की सगळ्यांना खूप हसवतो, ते सगळंच अनूला आवडतं.\nपण तिला सगळ्यात जास्त काय आवडतं?\nबाबाच्या मिश्या.","words":[[1,"तशा"],[2,"अनूला"],[3,"बाबाच्या"],[4,"खूप"],[5,"गोष्टी"],[6,"आवडतात."],[7,"बाबानं"],[8,"केलेला"],[9,"आकाशकंदील,"],[10,"त्यानं"],[11,"तळलेली"],[12,"कांद्याची"],[13,"भजी,"],[14,"त्यानं"],[15,"केलेलं"],[16,"कागदाचं"],[17,"कासव..."],[18,"शिवाय"],[19,"तो"],[20,"उड्या"],[21,"मारत"],[22,"जिने"],[23,"चढतो,"],[24,"मामाबरोबर"],[25,"कुस्ती"],[26,"खेळतो,"],[27,"पाहुणे"],[28,"आले"],[29,"की"],[30,"सगळ्यांना"],[31,"खूप"],[32,"हसवतो,"],[33,"ते"],[34,"सगळंच"],[35,"अनूला"],[36,"आवडतं."],[37,"पण"],[38,"तिला"],[39,"सगळ्यात"],[40,"जास्त"],[41,"काय"],[42,"आवडतं?"],[43,"बाबाच्या"],[44,"मिश्या."]]},{"n":2,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/1585/size6/1f2069911dc3649839d81cb4f60fa20c.jpg","text":"रोज सकाळी बाबा दाढी करतो. अनू शेजारी बसते आणि मन लावून बघते. आपली छोटीशी कात्री दोन बोटांमध्ये पकडून चुक् चुक् आवाज करत बाबा आपली मिशी कातरतो.\nअनू म्हणते, “आता इकडे थोडंसं....!\nआता थोडंस्सं त्या बाजूला...\nआं! बाबा, छोटी नाही करायची मिशी! कट्टी करीन मग!” बाबा अंघोळ करून येतो.","words":[[45,"रोज"],[46,"सकाळी"],[47,"बाबा"],[48,"दाढी"],[49,"करतो."],[50,"अनू"],[51,"शेजारी"],[52,"बसते"],[53,"आणि"],[54,"मन"],[55,"लावून"],[56,"बघते."],[57,"आपली"],[58,"छोटीशी"],[59,"कात्री"],[60,"दोन"],[61,"बोटांमध्ये"],[62,"पकडून"],[63,"चुक्"],[64,"चुक्"],[65,"आवाज"],[66,"करत"],[67,"बाबा"],[68,"आपली"],[69,"मिशी"],[70,"कातरतो."],[71,"अनू"],[72,"म्हणते,"],[73,"“आता"],[74,"इकडे"],[75,"थोडंसं....!"],[76,"आता"],[77,"थोडंस्सं"],[78,"त्या"],[79,"बाजूला..."],[80,"आं!"],[81,"बाबा,"],[82,"छोटी"],[83,"नाही"],[84,"करायची"],[85,"मिशी!"],[86,"कट्टी"],[87,"करीन"],[88,"मग!”"],[89,"बाबा"],[90,"अंघोळ"],[91,"करून"],[92,"येतो."]]},{"n":3,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/1586/size6/78567a2ac07672d7dc6bcf088f2151c8.jpg","text":"अनू छोटुशा कंगव्यानं त्याच्या मिश्या नीट विंचरते.\nमग त्यांची दोन्ही टोकं बोटांच्या चिमटीत पकडून वळवते.\nबाबाच्या मिश्या मस्त आकडेबाज होतात.\n“हं, झालं. आता विस्कटायच्या नाहीत हं त्या, सांगून ठेवतेय,” अनू बाबाला बजावते.","words":[[93,"अनू"],[94,"छोटुशा"],[95,"कंगव्यानं"],[96,"त्याच्या"],[97,"मिश्या"],[98,"नीट"],[99,"विंचरते."],[100,"मग"],[101,"त्यांची"],[102,"दोन्ही"],[103,"टोकं"],[104,"बोटांच्या"],[105,"चिमटीत"],[106,"पकडून"],[107,"वळवते."],[108,"बाबाच्या"],[109,"मिश्या"],[110,"मस्त"],[111,"आकडेबाज"],[112,"होतात."],[113,"“हं,"],[114,"झालं."],[115,"आता"],[116,"विस्कटायच्या"],[117,"नाहीत"],[118,"हं"],[119,"त्या,"],[120,"सांगून"],[121,"ठेवतेय,”"],[122,"अनू"],[123,"बाबाला"],[124,"बजावते."]]},{"n":4,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/1587/size6/74a1922738adf1db669f954039aa7ba2.jpg","text":"अनूला नेहमी वाटतं, की बाबानं झकास अंगरखा घातला,\nडोक्यावर लालचुटुक पगडी घातली आणि तो घोड्यावर बसला, तर कसला दिसेल!\nकमरेला तलवारबिलवार...\nएकदम मावळाच!\nचष्मिस मावळा!","words":[[125,"अनूला"],[126,"नेहमी"],[127,"वाटतं,"],[128,"की"],[129,"बाबानं"],[130,"झकास"],[131,"अंगरखा"],[132,"घातला,"],[133,"डोक्यावर"],[134,"लालचुटुक"],[135,"पगडी"],[136,"घातली"],[137,"आणि"],[138,"तो"],[139,"घोड्यावर"],[140,"बसला,"],[141,"तर"],[142,"कसला"],[143,"दिसेल!"],[144,"कमरेला"],[145,"तलवारबिलवार..."],[146,"एकदम"],[147,"मावळाच!"],[148,"चष्मिस"],[149,"मावळा!"]]},{"n":5,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/1588/size6/d3d41826942be3df086fb7b1114fe51a.jpg","text":"अनूला खरं म्हणजे मिश्यावाली सगळीच माणसं आवडतात.\nवर्गातल्या तुतीच्या, म्हणजे स्मृतीच्या बाबाच्या मिश्या केवढ्या जाड आहेत!\nत्या विंचरायला भलामोठ्ठा कंगवा लागत असेल.\nतुतीचा बाबा टेनिस मस्त खेळतो.\nखरं म्हणजे त्यानं कुस्ती खेळायला पाहिजे.\nअसा तुरेदार फेटा डोक्याला बांधला आणि खांद्यावर गदा घेतली, तर तो कसला भारी दिसेल!","words":[[150,"अनूला"],[151,"खरं"],[152,"म्हणजे"],[153,"मिश्यावाली"],[154,"सगळीच"],[155,"माणसं"],[156,"आवडतात."],[157,"वर्गातल्या"],[158,"तुतीच्या,"],[159,"म्हणजे"],[160,"स्मृतीच्या"],[161,"बाबाच्या"],[162,"मिश्या"],[163,"केवढ्या"],[164,"जाड"],[165,"आहेत!"],[166,"त्या"],[167,"विंचरायला"],[168,"भलामोठ्ठा"],[169,"कंगवा"],[170,"लागत"],[171,"असेल."],[172,"तुतीचा"],[173,"बाबा"],[174,"टेनिस"],[175,"मस्त"],[176,"खेळतो."],[177,"खरं"],[178,"म्हणजे"],[179,"त्यानं"],[180,"कुस्ती"],[181,"खेळायला"],[182,"पाहिजे."],[183,"असा"],[184,"तुरेदार"],[185,"फेटा"],[186,"डोक्याला"],[187,"बांधला"],[188,"आणि"],[189,"खांद्यावर"],[190,"गदा"],[191,"घेतली,"],[192,"तर"],[193,"तो"],[194,"कसला"],[195,"भारी"],[196,"दिसेल!"]]},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/1589/size6/6fdd9d27f3deb4f92eac847ed53dcb84.jpg","text":"साहिलच्या बाबाच्या मिश्या अगदी बारीक आहेत.\nत्या इतक्या छान कातरणं कसं काय जमतं त्याला, कोण जाणे.\nत्यानं मोठ्ठी काळी हॅट घातली, मोठ्ठा काळा कोट चढवला आणि काळा चष्मा घातला, तर तो टीव्हीवरच्या मालिकेतला गुप्तपोलिस असतो नं, वाईट चोराला पकडून देणारा, त्याच्यासारखा दिसेल.","words":[[197,"साहिलच्या"],[198,"बाबाच्या"],[199,"मिश्या"],[200,"अगदी"],[201,"बारीक"],[202,"आहेत."],[203,"त्या"],[204,"इतक्या"],[205,"छान"],[206,"कातरणं"],[207,"कसं"],[208,"काय"],[209,"जमतं"],[210,"त्याला,"],[211,"कोण"],[212,"जाणे."],[213,"त्यानं"],[214,"मोठ्ठी"],[215,"काळी"],[216,"हॅट"],[217,"घातली,"],[218,"मोठ्ठा"],[219,"काळा"],[220,"कोट"],[221,"चढवला"],[222,"आणि"],[223,"काळा"],[224,"चष्मा"],[225,"घातला,"],[226,"तर"],[227,"तो"],[228,"टीव्हीवरच्या"],[229,"मालिकेतला"],[230,"गुप्तपोलिस"],[231,"असतो"],[232,"नं,"],[233,"वाईट"],[234,"चोराला"],[235,"पकडून"],[236,"देणारा,"],[237,"त्याच्यासारखा"],[238,"दिसेल."]]},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/1590/size6/ed97a4a81eb7ca9ede63a8b3f0fbf72f.jpg","text":"शेजारच्या घरात राहणार्या आजोबांची मिशी सगळ्यांत बेश्ट आहे.\nआकाशातला चिमुकला काळापांढरा ढग त्यांच्या नाकाखाली राहायला आलाय असं वाटतं.\nत्या ढगामागे त्यांचं तोंड लपून जातं.\nत्यांना खाता कसं येत असेल?\nअनूला आजोबांची काळजीच वाटते.","words":[[239,"शेजारच्या"],[240,"घरात"],[241,"राहणार्या"],[242,"आजोबांची"],[243,"मिशी"],[244,"सगळ्यांत"],[245,"बेश्ट"],[246,"आहे."],[247,"आकाशातला"],[248,"चिमुकला"],[249,"काळापांढरा"],[250,"ढग"],[251,"त्यांच्या"],[252,"नाकाखाली"],[253,"राहायला"],[254,"आलाय"],[255,"असं"],[256,"वाटतं."],[257,"त्या"],[258,"ढगामागे"],[259,"त्यांचं"],[260,"तोंड"],[261,"लपून"],[262,"जातं."],[263,"त्यांना"],[264,"खाता"],[265,"कसं"],[266,"येत"],[267,"असेल?"],[268,"अनूला"],[269,"आजोबांची"],[270,"काळजीच"],[271,"वाटते."]]},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/1591/size6/077dd29c2517c86155485f0412002c1a.jpg","text":"अनूला प्रश्न पडतो, माझ्या नाकाखाली का मिश्या उगवत नाहीत?\nमग ती रोज अंघोळीआधी हातावर साबणाचा चिक्कार फेस करते आणि नाकाखाली तर्हेतर्हेच्या मिश्या चिकटवते.\n“माझी मिशी सगळ्यांपेक्षा मस्त आहे. पांढरीशुभ्र, मऊ मऊ....\nआहे की नाही छान?” ती खूष होऊन म्हणते.","words":[[272,"अनूला"],[273,"प्रश्न"],[274,"पडतो,"],[275,"माझ्या"],[276,"नाकाखाली"],[277,"का"],[278,"मिश्या"],[279,"उगवत"],[280,"नाहीत?"],[281,"मग"],[282,"ती"],[283,"रोज"],[284,"अंघोळीआधी"],[285,"हातावर"],[286,"साबणाचा"],[287,"चिक्कार"],[288,"फेस"],[289,"करते"],[290,"आणि"],[291,"नाकाखाली"],[292,"तर्हेतर्हेच्या"],[293,"मिश्या"],[294,"चिकटवते."],[295,"“माझी"],[296,"मिशी"],[297,"सगळ्यांपेक्षा"],[298,"मस्त"],[299,"आहे."],[300,"पांढरीशुभ्र,"],[301,"मऊ"],[302,"मऊ...."],[303,"आहे"],[304,"की"],[305,"नाही"],[306,"छान?”"],[307,"ती"],[308,"खूष"],[309,"होऊन"],[310,"म्हणते."]]}],"stats":{"pages":8,"words":310}}