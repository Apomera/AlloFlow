    {
      "n": 8,
      "img": "https://s3.amazonaws.com/BloomLibraryBooks/bborrayo%40gmail.com%2f4df5b7ef-e3e6-4030-9ba1-3490fda59870%2fLas+frutas1%2ffrutero.jpg",
      "text": "Las frutas son nutritivas. Por eso su consumo es saludable."
