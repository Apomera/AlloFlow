</button>
<button aria-label="Cell 15, row 3, column 3, unopened rock. Press to dig." aria-disabled="false" style="aspect-ratio:1 / 1;border-radius:8px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:#7c5e3b;color:var(--allo-stem-text, #f1f5f9);font-size:20px;display:flex;align-items:center;justify-content:center">
