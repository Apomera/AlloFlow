age.googleapis.com/static.storyweaver.org.in/illustration_crops/19/size6/14b4db70d06071c4e9c843e2bac3c296.jpg","text":"There was a large boulder on the grassy plain. He stumbled and fell down.","words":[[32,"There"],[33,"was"],[34,"a"],[35,"large"],[36,"boulder"],[37,"on"],[38,"the"],[39,"grassy"],[40,"plain."],[41,"He"],[42,"stumbled"],[43,"and"],[44,"fell"],[45,"down."]]},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/20/size6/37361c6a3d23feb30eaf9dd9e66e4fa0.jpg","text":"He burst into tears.","words":[[46,"He"],[47,"burst"],[48,"into"],[49,"tears."]]},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/21/size6/c6dd7e9100c59475dfff669aea42043c.jpg","text":"The monkey massaged his leg. Tears flowed from the fawn's eyes.","words":[[50,"The"],[51,"monkey"],[52,"massaged"],[53,"his"],[54,"leg."],[55,"Tears"],[56,"flowed"],[57,"from"],[58,"the"],[59,"fawn's"],[60,"eyes."]]},{"n":9,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/22/size6/b7c5a2321034eefd58064417dbed109c.jpg","text":"Brother Bear picked him up. The fawn didn't stop crying.","words":[[61,"Brother"],[62,"Bear"],[63,"picked"],[64,"him"],[65,"up."],[66,"The"],[67,"fawn"],[68,"didn't"],[69,"stop"],[70,"crying."]]},{"n":10,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/23/size6/4b9d3c5ef3ff7f193bbc57ee9873948a.jpg","text":"His mother came. She said, “Look, we’ll beat up this bad boulder!”","words":[[71,"His"],[72,"mother"],[73,"came."],[74,"She"],[75,"said,"],[76,"“Look,"],[77,"we’ll"],[78,"beat"],[79,"up"],[80,"this"],[81,"bad"],[82,"boulder!”"]]},{"n":11,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/24/size6/fa745053851dd15865fd30a47599ad37.jpg","text":"The fawn said, “Oh, don’t do that or he will also start crying.” His mother laughed. So did the fawn.","words":[[83,"The"],[84,"fawn"],[85,"said,"],[86,"“Oh,"],[87,"don’t"],[88,"do"],[89,"that"],[90,"or"],[91,"he"],[92,"will"],[93,"also"],[94,"start"],[95,"crying.”"],[96,"His"],[97,"mother"],[98,"laughed."],[99,"So"],[100,"did"],[101,"the"],[102,"fawn."]]},{"n":12,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/12/size6/fa745053851dd15865fd30a47599ad37.jpg","text":"13/13","words":null}],"stats":{"pages":12,"words":103}}