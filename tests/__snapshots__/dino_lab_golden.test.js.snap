exports[`Dino Lab — render per tab (golden master) > renders the anatomy tab (snapshot) 1`] = `
"<div style="min-height:100%;background:var(--allo-stem-canvas, #0f172a);color:var(--allo-stem-text, #f1f5f9)">
<div role="tablist" aria-label="Dino Lab sections" style="display:flex;flex-wrap:wrap;gap:4px;padding:10px 12px;border-bottom:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220)">
<button id="dinotab-explore" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🔍 Explore</button>
<button id="dinotab-timeline" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">⏳ Timeline</button>
<button id="dinotab-deeptime" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🕰️ Deep Time</button>
<button id="dinotab-sites" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🗺️ Sites</button>
<button id="dinotab-ecosystem" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🌍 Ecosystems</button>
<button id="dinotab-compare" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">⚖️ Compare</button>
<button id="dinotab-dig" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">⛏️ Dig Site</button>
<button id="dinotab-classify" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🌳 Classify</button>
<button id="dinotab-birds" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🐦 Bird Link</button>
<button id="dinotab-extinction" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">☄️ Extinction</button>
<button id="dinotab-anatomy" role="tab" aria-selected="true" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:700;background:#15803d;color:#fff;white-space:nowrap">🦴 Anatomy</button>
<button id="dinotab-records" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🏆 Records</button>
<button id="dinotab-quiz" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🧠 Quiz</button>
<button id="dinotab-notes" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">📓 Field Notes</button>
<button id="dinotab-glossary" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">📖 Glossary</button>
</div>
<div id="dinopanel" role="tabpanel" aria-labelledby="dinotab-anatomy" style="padding:16px">
<div>
<div style="margin-bottom:12px">
<div style="font-size:18px;font-weight:800">🦴 How we know what we know</div>
<div style="font-size:12.5px;color:var(--allo-stem-text-soft, #94a3b8);margin-top:2px">Paleontologists are detectives. Every fossil is a clue, and different clues answer different questions.</div>
</div>
<div style="background:var(--allo-stem-panel, #1e293b);border:1px solid var(--allo-stem-border, #334155);border-radius:14px;padding:14px;color:var(--allo-stem-text, #f1f5f9);margin-bottom:14px">
<div style="font-weight:800;font-size:14px;margin-bottom:8px">🪨 How a fossil forms</div>
<div style="display:grid;grid-template-columns:repeat(auto-fit, minmax(150px, 1fr));gap:8px">
<div style="padding:10px;border-radius:8px;background:var(--allo-stem-deeper, #0b1220);border:1px solid var(--allo-stem-border, #334155)">
<div style="font-size:12px;font-weight:800;color:var(--allo-stem-text, #f1f5f9);margin-bottom:3px">Step 1: Death and burial</div>
<div style="font-size:12px;color:var(--allo-stem-text-soft, #94a3b8);line-height:1.5">An animal dies and is quickly buried by mud or sand, before scavengers or weather destroy it.</div>
</div>
<div style="padding:10px;border-radius:8px;background:var(--allo-stem-deeper, #0b1220);border:1px solid var(--allo-stem-border, #334155)">
<div style="font-size:12px;font-weight:800;color:var(--allo-stem-text, #f1f5f9);margin-bottom:3px">Step 2: Mineral replacement</div>
<div style="font-size:12px;color:var(--allo-stem-text-soft, #94a3b8);line-height:1.5">Over ages, groundwater minerals seep in and replace the bone, turning it to stone.</div>
</div>
<div style="padding:10px;border-radius:8px;background:var(--allo-stem-deeper, #0b1220);border:1px solid var(--allo-stem-border, #334155)">
<div style="font-size:12px;font-weight:800;color:var(--allo-stem-text, #f1f5f9);margin-bottom:3px">Step 3: Rock and uplift</div>
<div style="font-size:12px;color:var(--allo-stem-text-soft, #94a3b8);line-height:1.5">Layers pile up and harden into rock. Earth movements lift them toward the surface.</div>
</div>
<div style="padding:10px;border-radius:8px;background:var(--allo-stem-deeper, #0b1220);border:1px solid var(--allo-stem-border, #334155)">
<div style="font-size:12px;font-weight:800;color:var(--allo-stem-text, #f1f5f9);margin-bottom:3px">Step 4: Erosion and discovery</div>
<div style="font-size:12px;color:var(--allo-stem-text-soft, #94a3b8);line-height:1.5">Wind and water wear the rock away and expose the fossil, where someone might spot it.</div>
</div>
</div>
<div style="font-size:11.5px;color:var(--allo-stem-text-soft, #94a3b8);font-style:italic;margin-top:8px">Most living things never fossilize at all. The fossil record is a tiny, lucky sample of past life.</div>
</div>
<div style="display:grid;grid-template-columns:repeat(auto-fit, minmax(220px, 1fr));gap:12px">
<div style="background:var(--allo-stem-panel, #1e293b);border:1px solid var(--allo-stem-border, #334155);border-radius:14px;padding:14px;color:var(--allo-stem-text, #f1f5f9)">
<div style="font-size:22px;margin-bottom:4px">🦴 <span style="font-size:15px;font-weight:800;vertical-align:middle">Bones</span>
</div>
<div style="font-size:12.5px;color:var(--allo-stem-text, #f1f5f9);margin-bottom:6px;line-height:1.5">Fossilized bone, where minerals replaced the original over time.</div>
<div style="font-size:12px;color:var(--allo-stem-text, #f1f5f9);font-weight:700;margin-bottom:2px">What it tells us</div>
<div style="font-size:12.5px;color:var(--allo-stem-text-soft, #94a3b8);line-height:1.5">Size, posture, age, injuries, and how an animal moved. Growth rings inside bones reveal how fast it grew and how old it was.</div>
</div>
<div style="background:var(--allo-stem-panel, #1e293b);border:1px solid var(--allo-stem-border, #334155);border-radius:14px;padding:14px;color:var(--allo-stem-text, #f1f5f9)">
<div style="font-size:22px;margin-bottom:4px">🦷 <span style="font-size:15px;font-weight:800;vertical-align:middle">Teeth</span>
</div>
<div style="font-size:12.5px;color:var(--allo-stem-text, #f1f5f9);margin-bottom:6px;line-height:1.5">The hardest, most common fossils, often found even when bones are not.</div>
<div style="font-size:12px;color:var(--allo-stem-text, #f1f5f9);font-weight:700;margin-bottom:2px">What it tells us</div>
<div style="font-size:12.5px;color:var(--allo-stem-text-soft, #94a3b8);line-height:1.5">Diet. Bladed serrated teeth slice meat; flat teeth grind plants; cone teeth grab fish.</div>
</div>
<div style="background:var(--allo-stem-panel, #1e293b);border:1px solid var(--allo-stem-border, #334155);border-radius:14px;padding:14px;color:var(--allo-stem-text, #f1f5f9)">
<div style="font-size:22px;margin-bottom:4px">👣 <span style="font-size:15px;font-weight:800;vertical-align:middle">Trackways</span>
</div>
<div style="font-size:12.5px;color:var(--allo-stem-text, #f1f5f9);margin-bottom:6px;line-height:1.5">Fossil footprints pressed into mud that later hardened.</div>
<div style="font-size:12px;color:var(--allo-stem-text, #f1f5f9);font-weight:700;margin-bottom:2px">What it tells us</div>
<div style="font-size:12.5px;color:var(--allo-stem-text-soft, #94a3b8);line-height:1.5">Behavior frozen in time: speed from stride length, group movement, and posture. Tracks record what the animal did.</div>
</div>
<div style="background:var(--allo-stem-panel, #1e293b);border:1px solid var(--allo-stem-border, #334155);border-radius:14px;padding:14px;color:var(--allo-stem-text, #f1f5f9)">
<div style="font-size:22px;margin-bottom:4px">🥚 <span style="font-size:15px;font-weight:800;vertical-align:middle">Eggs and nests</span>
</div>
<div style="font-size:12.5px;color:var(--allo-stem-text, #f1f5f9);margin-bottom:6px;line-height:1.5">Fossil eggs, sometimes with embryos, and the nests they were laid in.</div>
<div style="font-size:12px;color:var(--allo-stem-text, #f1f5f9);font-weight:700;margin-bottom:2px">What it tells us</div>
<div style="font-size:12.5px;color:var(--allo-stem-text-soft, #94a3b8);line-height:1.5">How dinosaurs reproduced and cared for young. Nesting colonies show parental care.</div>
</div>
<div style="background:var(--allo-stem-panel, #1e293b);border:1px solid var(--allo-stem-border, #334155);border-radius:14px;padding:14px;color:var(--allo-stem-text, #f1f5f9)">
<div style="font-size:22px;margin-bottom:4px">🪶 <span style="font-size:15px;font-weight:800;vertical-align:middle">Skin and feathers</span>
</div>
<div style="font-size:12.5px;color:var(--allo-stem-text, #f1f5f9);margin-bottom:6px;line-height:1.5">Rare impressions of scales, skin, or feathers in fine-grained rock.</div>
<div style="font-size:12px;color:var(--allo-stem-text, #f1f5f9);font-weight:700;margin-bottom:2px">What it tells us</div>
<div style="font-size:12.5px;color:var(--allo-stem-text-soft, #94a3b8);line-height:1.5">Body covering and even color, when fossil pigment structures (melanosomes) survive.</div>
</div>
<div style="background:var(--allo-stem-panel, #1e293b);border:1px solid var(--allo-stem-border, #334155);border-radius:14px;padding:14px;color:var(--allo-stem-text, #f1f5f9)">
<div style="font-size:22px;margin-bottom:4px">💩 <span style="font-size:15px;font-weight:800;vertical-align:middle">Coprolites</span>
</div>
<div style="font-size:12.5px;color:var(--allo-stem-text, #f1f5f9);margin-bottom:6px;line-height:1.5">Fossilized dung.</div>
<div style="font-size:12px;color:var(--allo-stem-text, #f1f5f9);font-weight:700;margin-bottom:2px">What it tells us</div>
<div style="font-size:12.5px;color:var(--allo-stem-text-soft, #94a3b8);line-height:1.5">What an animal actually ate. Crushed bone, plant fibers, or fish scales inside reveal real meals.</div>
</div>
<div style="background:var(--allo-stem-panel, #1e293b);border:1px solid var(--allo-stem-border, #334155);border-radius:14px;padding:14px;color:var(--allo-stem-text, #f1f5f9)">
<div style="font-size:22px;margin-bottom:4px">🪨 <span style="font-size:15px;font-weight:800;vertical-align:middle">Gastroliths</span>
</div>
<div style="font-size:12.5px;color:var(--allo-stem-text, #f1f5f9);margin-bottom:6px;line-height:1.5">Smooth stones swallowed to help grind food in the gut.</div>
<div style="font-size:12px;color:var(--allo-stem-text, #f1f5f9);font-weight:700;margin-bottom:2px">What it tells us</div>
<div style="font-size:12.5px;color:var(--allo-stem-text-soft, #94a3b8);line-height:1.5">Digestion strategy. Found with some plant-eaters and birds.</div>
</div>
<div style="background:var(--allo-stem-panel, #1e293b);border:1px solid var(--allo-stem-border, #334155);border-radius:14px;padding:14px;color:var(--allo-stem-text, #f1f5f9)">
<div style="font-size:22px;margin-bottom:4px">🔬 <span style="font-size:15px;font-weight:800;vertical-align:middle">Soft tissue and chemistry</span>
</div>
<div style="font-size:12.5px;color:var(--allo-stem-text, #f1f5f9);margin-bottom:6px;line-height:1.5">Very rare traces of original proteins, blood-vessel shapes, or pigments.</div>
<div style="font-size:12px;color:var(--allo-stem-text, #f1f5f9);font-weight:700;margin-bottom:2px">What it tells us</div>
<div style="font-size:12.5px;color:var(--allo-stem-text-soft, #94a3b8);line-height:1.5">Fine biological detail and links to living animals. These finds are carefully checked because contamination is easy.</div>
</div>
</div>
</div>
</div>
</div>"
`;

exports[`Dino Lab — render per tab (golden master) > renders the birds tab (snapshot) 1`] = `
"<div style="min-height:100%;background:var(--allo-stem-canvas, #0f172a);color:var(--allo-stem-text, #f1f5f9)">
<div role="tablist" aria-label="Dino Lab sections" style="display:flex;flex-wrap:wrap;gap:4px;padding:10px 12px;border-bottom:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220)">
<button id="dinotab-explore" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🔍 Explore</button>
<button id="dinotab-timeline" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">⏳ Timeline</button>
<button id="dinotab-deeptime" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🕰️ Deep Time</button>
<button id="dinotab-sites" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🗺️ Sites</button>
<button id="dinotab-ecosystem" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🌍 Ecosystems</button>
<button id="dinotab-compare" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">⚖️ Compare</button>
<button id="dinotab-dig" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">⛏️ Dig Site</button>
<button id="dinotab-classify" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🌳 Classify</button>
<button id="dinotab-birds" role="tab" aria-selected="true" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:700;background:#15803d;color:#fff;white-space:nowrap">🐦 Bird Link</button>
<button id="dinotab-extinction" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">☄️ Extinction</button>
<button id="dinotab-anatomy" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🦴 Anatomy</button>
<button id="dinotab-records" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🏆 Records</button>
<button id="dinotab-quiz" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🧠 Quiz</button>
<button id="dinotab-notes" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">📓 Field Notes</button>
<button id="dinotab-glossary" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">📖 Glossary</button>
</div>
<div id="dinopanel" role="tabpanel" aria-labelledby="dinotab-birds" style="padding:16px">
<div>
<div style="margin-bottom:12px">
<div style="font-size:18px;font-weight:800">🐦 The bird connection</div>
<div style="font-size:12.5px;color:var(--allo-stem-text-soft, #94a3b8);margin-top:2px">The single most important idea in this lab: birds are living dinosaurs.</div>
</div>
<div style="background:rgba(34,197,94,0.10);border:1px solid rgba(34,197,94,0.35);border-radius:14px;padding:14px;color:var(--allo-stem-text, #f1f5f9);margin-bottom:14px">
<div style="font-size:16px;font-weight:800;color:var(--allo-stem-text, #f1f5f9);margin-bottom:6px">Birds ARE dinosaurs.</div>
<div style="font-size:13px;line-height:1.55">One branch of small, feathered, meat-eating dinosaurs survived the asteroid 66 million years ago. We call its living members birds. There are more than 10,000 species of them today, so by that count dinosaurs are still among the most successful land animals on Earth.</div>
</div>
<div style="font-size:13.5px;font-weight:800;margin:0 0 8px">Seven clues that link them</div>
<div style="display:grid;grid-template-columns:repeat(auto-fit, minmax(220px, 1fr));gap:12px">
<div style="background:var(--allo-stem-panel, #1e293b);border:1px solid var(--allo-stem-border, #334155);border-radius:14px;padding:14px;color:var(--allo-stem-text, #f1f5f9)">
<div style="font-size:15px;font-weight:800;margin-bottom:4px">🪶 Feathers</div>
<div style="font-size:12.5px;color:var(--allo-stem-text-soft, #94a3b8);line-height:1.5">Dozens of dinosaurs are preserved with feathers, from simple fuzz to true flight feathers. Many were feathered long before any of them could fly.</div>
</div>
<div style="background:var(--allo-stem-panel, #1e293b);border:1px solid var(--allo-stem-border, #334155);border-radius:14px;padding:14px;color:var(--allo-stem-text, #f1f5f9)">
<div style="font-size:15px;font-weight:800;margin-bottom:4px">🦴 The wishbone</div>
<div style="font-size:12.5px;color:var(--allo-stem-text-soft, #94a3b8);line-height:1.5">Birds have a furcula, or wishbone. So did theropod dinosaurs like T. rex and Velociraptor. It is the very same bone.</div>
</div>
<div style="background:var(--allo-stem-panel, #1e293b);border:1px solid var(--allo-stem-border, #334155);border-radius:14px;padding:14px;color:var(--allo-stem-text, #f1f5f9)">
<div style="font-size:15px;font-weight:800;margin-bottom:4px">🎈 Hollow, air-filled bones</div>
<div style="font-size:12.5px;color:var(--allo-stem-text-soft, #94a3b8);line-height:1.5">Bird bones are light and filled with air sacs. The same air-filled bones appear in many dinosaurs, part of a bird-like breathing system.</div>
</div>
<div style="background:var(--allo-stem-panel, #1e293b);border:1px solid var(--allo-stem-border, #334155);border-radius:14px;padding:14px;color:var(--allo-stem-text, #f1f5f9)">
<div style="font-size:15px;font-weight:800;margin-bottom:4px">👣 Three-toed feet</div>
<div style="font-size:12.5px;color:var(--allo-stem-text-soft, #94a3b8);line-height:1.5">The classic bird footprint, three toes forward, matches theropod feet. Fossil dinosaur tracks look like giant bird tracks.</div>
</div>
<div style="background:var(--allo-stem-panel, #1e293b);border:1px solid var(--allo-stem-border, #334155);border-radius:14px;padding:14px;color:var(--allo-stem-text, #f1f5f9)">
<div style="font-size:15px;font-weight:800;margin-bottom:4px">🥚 Eggs and brooding</div>
<div style="font-size:12.5px;color:var(--allo-stem-text-soft, #94a3b8);line-height:1.5">Dinosaurs laid eggs in nests, and some, like Citipati and Oviraptor, sat on them to brood their young, exactly as birds do.</div>
</div>
<div style="background:var(--allo-stem-panel, #1e293b);border:1px solid var(--allo-stem-border, #334155);border-radius:14px;padding:14px;color:var(--allo-stem-text, #f1f5f9)">
<div style="font-size:15px;font-weight:800;margin-bottom:4px">🤚 A wrist that folds</div>
<div style="font-size:12.5px;color:var(--allo-stem-text-soft, #94a3b8);line-height:1.5">Birds fold their wings using a special half-moon wrist bone. The same bone let some dinosaurs tuck their arms against the body.</div>
</div>
<div style="background:var(--allo-stem-panel, #1e293b);border:1px solid var(--allo-stem-border, #334155);border-radius:14px;padding:14px;color:var(--allo-stem-text, #f1f5f9)">
<div style="font-size:15px;font-weight:800;margin-bottom:4px">📈 Fast growth, warm bodies</div>
<div style="font-size:12.5px;color:var(--allo-stem-text-soft, #94a3b8);line-height:1.5">Growth rings in dinosaur bones show many grew quickly and ran warm, more like birds and mammals than like modern reptiles.</div>
</div>
</div>
<div style="background:rgba(56,189,248,0.08);border:1px solid rgba(56,189,248,0.30);border-radius:14px;padding:14px;color:var(--allo-stem-text, #f1f5f9);margin-top:14px;margin-bottom:14px">
<div style="font-size:14px;font-weight:800;margin-bottom:4px">🪶 Archaeopteryx: caught in between</div>
<div style="font-size:12.5px;color:var(--allo-stem-text-soft, #94a3b8);line-height:1.55">Archaeopteryx, from about 150 million years ago, had wings and feathers like a bird but teeth, clawed fingers, and a long bony tail like a dinosaur. It is one of the clearest transitional fossils ever found, sitting right on the line between the two.</div>
</div>
<div style="background:var(--allo-stem-panel, #1e293b);border:1px solid var(--allo-stem-border, #334155);border-radius:14px;padding:14px;color:var(--allo-stem-text, #f1f5f9)">
<div style="font-size:14px;font-weight:800;margin-bottom:6px">🦖 Meet the feathered dinosaurs (45)</div>
<div style="font-size:12px;color:var(--allo-stem-text-soft, #94a3b8);margin-bottom:8px">Each of these is preserved with feathers, fuzz, quill knobs, or wings, or sits on the branch that leads to birds. Tap one to open its file.</div>
<div style="display:flex;flex-wrap:wrap;gap:5px">
<button aria-label="Open Anchiornis" style="font-size:11px;padding:3px 9px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Anchiornis</button>
<button aria-label="Open Anzu" style="font-size:11px;padding:3px 9px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Anzu</button>
<button aria-label="Open Archaeopteryx" style="font-size:11px;padding:3px 9px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Archaeopteryx</button>
<button aria-label="Open Avimimus" style="font-size:11px;padding:3px 9px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Avimimus</button>
<button aria-label="Open Balaur" style="font-size:11px;padding:3px 9px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Balaur</button>
<button aria-label="Open Beipiaosaurus" style="font-size:11px;padding:3px 9px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Beipiaosaurus</button>
<button aria-label="Open Beishanlong" style="font-size:11px;padding:3px 9px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Beishanlong</button>
<button aria-label="Open Caudipteryx" style="font-size:11px;padding:3px 9px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Caudipteryx</button>
<button aria-label="Open Changyuraptor" style="font-size:11px;padding:3px 9px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Changyuraptor</button>
<button aria-label="Open Concavenator" style="font-size:11px;padding:3px 9px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Concavenator</button>
<button aria-label="Open Conchoraptor" style="font-size:11px;padding:3px 9px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Conchoraptor</button>
<button aria-label="Open Dakotaraptor" style="font-size:11px;padding:3px 9px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Dakotaraptor</button>
<button aria-label="Open Dilong" style="font-size:11px;padding:3px 9px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Dilong</button>
<button aria-label="Open Dreadnoughtus" style="font-size:11px;padding:3px 9px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Dreadnoughtus</button>
<button aria-label="Open Eoabelisaurus" style="font-size:11px;padding:3px 9px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Eoabelisaurus</button>
<button aria-label="Open Eolambia" style="font-size:11px;padding:3px 9px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Eolambia</button>
<button aria-label="Open Epidexipteryx" style="font-size:11px;padding:3px 9px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Epidexipteryx</button>
<button aria-label="Open Gigantoraptor" style="font-size:11px;padding:3px 9px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Gigantoraptor</button>
<button aria-label="Open Incisivosaurus" style="font-size:11px;padding:3px 9px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Incisivosaurus</button>
<button aria-label="Open Kulindadromeus" style="font-size:11px;padding:3px 9px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Kulindadromeus</button>
<button aria-label="Open Liaoceratops" style="font-size:11px;padding:3px 9px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Liaoceratops</button>
<button aria-label="Open Mercuriceratops" style="font-size:11px;padding:3px 9px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Mercuriceratops</button>
<button aria-label="Open Microraptor" style="font-size:11px;padding:3px 9px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Microraptor</button>
<button aria-label="Open Ornithomimus" style="font-size:11px;padding:3px 9px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Ornithomimus</button>
<button aria-label="Open Oviraptor" style="font-size:11px;padding:3px 9px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Oviraptor</button>
<button aria-label="Open Pegomastax" style="font-size:11px;padding:3px 9px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Pegomastax</button>
<button aria-label="Open Pteranodon" style="font-size:11px;padding:3px 9px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Pteranodon</button>
<button aria-label="Open Rahonavis" style="font-size:11px;padding:3px 9px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Rahonavis</button>
<button aria-label="Open Riojasaurus" style="font-size:11px;padding:3px 9px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Riojasaurus</button>
<button aria-label="Open Scansoriopteryx" style="font-size:11px;padding:3px 9px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Scansoriopteryx</button>
<button aria-label="Open Secernosaurus" style="font-size:11px;padding:3px 9px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Secernosaurus</button>
<button aria-label="Open Shaochilong" style="font-size:11px;padding:3px 9px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Shaochilong</button>
<button aria-label="Open Sinornithosaurus" style="font-size:11px;padding:3px 9px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Sinornithosaurus</button>
<button aria-label="Open Sinosauropteryx" style="font-size:11px;padding:3px 9px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Sinosauropteryx</button>
<button aria-label="Open Sinovenator" style="font-size:11px;padding:3px 9px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Sinovenator</button>
<button aria-label="Open Tethyshadros" style="font-size:11px;padding:3px 9px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Tethyshadros</button>
<button aria-label="Open Tianyulong" style="font-size:11px;padding:3px 9px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Tianyulong</button>
<button aria-label="Open Tornieria" style="font-size:11px;padding:3px 9px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Tornieria</button>
<button aria-label="Open Unenlagia" style="font-size:11px;padding:3px 9px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Unenlagia</button>
<button aria-label="Open Utahraptor" style="font-size:11px;padding:3px 9px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Utahraptor</button>
<button aria-label="Open Velociraptor" style="font-size:11px;padding:3px 9px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Velociraptor</button>
<button aria-label="Open Willinakaqe" style="font-size:11px;padding:3px 9px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Willinakaqe</button>
<button aria-label="Open Yi" style="font-size:11px;padding:3px 9px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Yi</button>
<button aria-label="Open Yutyrannus" style="font-size:11px;padding:3px 9px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Yutyrannus</button>
<button aria-label="Open Zhenyuanlong" style="font-size:11px;padding:3px 9px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Zhenyuanlong</button>
</div>
</div>
</div>
</div>
</div>"
`;

exports[`Dino Lab — render per tab (golden master) > renders the classify tab (snapshot) 1`] = `
"<div style="min-height:100%;background:var(--allo-stem-canvas, #0f172a);color:var(--allo-stem-text, #f1f5f9)">
<div role="tablist" aria-label="Dino Lab sections" style="display:flex;flex-wrap:wrap;gap:4px;padding:10px 12px;border-bottom:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220)">
<button id="dinotab-explore" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🔍 Explore</button>
<button id="dinotab-timeline" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">⏳ Timeline</button>
<button id="dinotab-deeptime" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🕰️ Deep Time</button>
<button id="dinotab-sites" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🗺️ Sites</button>
<button id="dinotab-ecosystem" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🌍 Ecosystems</button>
<button id="dinotab-compare" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">⚖️ Compare</button>
<button id="dinotab-dig" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">⛏️ Dig Site</button>
<button id="dinotab-classify" role="tab" aria-selected="true" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:700;background:#15803d;color:#fff;white-space:nowrap">🌳 Classify</button>
<button id="dinotab-birds" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🐦 Bird Link</button>
<button id="dinotab-extinction" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">☄️ Extinction</button>
<button id="dinotab-anatomy" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🦴 Anatomy</button>
<button id="dinotab-records" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🏆 Records</button>
<button id="dinotab-quiz" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🧠 Quiz</button>
<button id="dinotab-notes" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">📓 Field Notes</button>
<button id="dinotab-glossary" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">📖 Glossary</button>
</div>
<div id="dinopanel" role="tabpanel" aria-labelledby="dinotab-classify" style="padding:16px">
<div>
<div style="margin-bottom:12px">
<div style="font-size:18px;font-weight:800">🌳 The dinosaur family tree</div>
<div style="font-size:12.5px;color:var(--allo-stem-text-soft, #94a3b8);margin-top:2px">Two great branches split early: the &quot;lizard-hipped&quot; Saurischia and the &quot;bird-hipped&quot; Ornithischia.</div>
</div>
<div style="background:var(--allo-stem-panel, #1e293b);border:1px solid var(--allo-stem-border, #334155);border-radius:14px;padding:14px;color:var(--allo-stem-text, #f1f5f9);margin-bottom:14px">
<div style="display:flex;justify-content:space-between;align-items:baseline">
<div style="font-weight:700">🧩 Sort the dinosaur</div>
<div style="font-size:12px;color:var(--allo-stem-text-soft, #94a3b8)">Score: 3/4</div>
</div>
<div style="font-size:14px;margin:8px 0">Which group does <strong>Brachiosaurus</strong> belong to?</div>
<div style="display:flex;flex-direction:column;gap:6px">
<button disabled="" style="text-align:left;padding:8px 12px;border-radius:8px;cursor:default;border:1px solid #ef4444;background:rgba(239,68,68,0.15);color:var(--allo-stem-text, #f1f5f9);font-size:12.5px">Theropod (mostly meat-eaters, two legs)</button>
<button disabled="" style="text-align:left;padding:8px 12px;border-radius:8px;cursor:default;border:1px solid #22c55e;background:rgba(34,197,94,0.18);color:var(--allo-stem-text, #f1f5f9);font-size:12.5px">Sauropodomorph (long-necked plant-eaters)</button>
<button disabled="" style="text-align:left;padding:8px 12px;border-radius:8px;cursor:default;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9);font-size:12.5px">Ornithischian (bird-hipped plant-eaters)</button>
</div>
<div style="margin-top:8px">
<div style="font-size:12.5px;color:var(--allo-stem-text-soft, #94a3b8);margin-bottom:6px">❌ Not quite. Brachiosaurus is a Sauropodomorph.</div>
<button style="font-size:12.5px;font-weight:700;padding:6px 14px;border-radius:8px;border:none;background:#15803d;color:#fff;cursor:pointer">Next →</button>
</div>
</div>
<div style="background:var(--allo-stem-panel, #1e293b);border:1px solid var(--allo-stem-border, #334155);border-radius:14px;padding:14px;color:var(--allo-stem-text, #f1f5f9)">
<div style="margin-left:0;margin-bottom:8px;padding-left:10px;border-left:2px solid #22c55e">
<div style="font-weight:800;font-size:14px">Dinosauria<span style="font-size:11px;font-style:italic;color:var(--allo-stem-text-soft, #94a3b8);font-weight:400;margin-left:6px">&quot;terrible lizards&quot;</span>
</div>
<div style="font-size:12.5px;color:var(--allo-stem-text, #f1f5f9);margin:2px 0 4px;line-height:1.5">All dinosaurs share an upright stance, with legs held under the body, and features inherited from one common ancestor.</div>
</div>
<div style="margin-left:18px;margin-bottom:8px;padding-left:10px;border-left:2px solid #38bdf8">
<div style="font-weight:800;font-size:14px">Saurischia<span style="font-size:11px;font-style:italic;color:var(--allo-stem-text-soft, #94a3b8);font-weight:400;margin-left:6px">&quot;lizard-hipped&quot;</span>
</div>
<div style="font-size:12.5px;color:var(--allo-stem-text, #f1f5f9);margin:2px 0 4px;line-height:1.5">One of the two great branches. Despite the name, it includes the meat-eaters, the long-necks, and birds.</div>
</div>
<div style="margin-left:36px;margin-bottom:8px;padding-left:10px;border-left:2px solid var(--allo-stem-border, #334155)">
<div style="font-weight:800;font-size:14px">Theropoda<span style="font-size:11px;font-style:italic;color:var(--allo-stem-text-soft, #94a3b8);font-weight:400;margin-left:6px">&quot;beast feet&quot;</span>
</div>
<div style="font-size:12.5px;color:var(--allo-stem-text, #f1f5f9);margin:2px 0 4px;line-height:1.5">Mostly meat-eaters that walked on two legs. Birds are living theropods. A few switched to plants.</div>
<div style="display:flex;flex-wrap:wrap;gap:5px">
<button style="font-size:11px;padding:2px 8px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">T. rex</button>
<button style="font-size:11px;padding:2px 8px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Velociraptor</button>
<button style="font-size:11px;padding:2px 8px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Allosaurus</button>
<button style="font-size:11px;padding:2px 8px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Spinosaurus</button>
<button style="font-size:11px;padding:2px 8px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Archaeopteryx</button>
</div>
</div>
<div style="margin-left:36px;margin-bottom:8px;padding-left:10px;border-left:2px solid var(--allo-stem-border, #334155)">
<div style="font-weight:800;font-size:14px">Sauropodomorpha<span style="font-size:11px;font-style:italic;color:var(--allo-stem-text-soft, #94a3b8);font-weight:400;margin-left:6px">&quot;lizard-foot forms&quot;</span>
</div>
<div style="font-size:12.5px;color:var(--allo-stem-text, #f1f5f9);margin:2px 0 4px;line-height:1.5">The long-necked plant-eaters, including the largest land animals ever, and their smaller early relatives.</div>
<div style="display:flex;flex-wrap:wrap;gap:5px">
<button style="font-size:11px;padding:2px 8px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Brachiosaurus</button>
<button style="font-size:11px;padding:2px 8px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Diplodocus</button>
<button style="font-size:11px;padding:2px 8px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Apatosaurus</button>
</div>
</div>
<div style="margin-left:18px;margin-bottom:8px;padding-left:10px;border-left:2px solid #38bdf8">
<div style="font-weight:800;font-size:14px">Ornithischia<span style="font-size:11px;font-style:italic;color:var(--allo-stem-text-soft, #94a3b8);font-weight:400;margin-left:6px">&quot;bird-hipped&quot;</span>
</div>
<div style="font-size:12.5px;color:var(--allo-stem-text, #f1f5f9);margin:2px 0 4px;line-height:1.5">The other great branch: plant-eaters with a backward-pointing hip bone. Includes armored, horned, and duck-billed dinosaurs.</div>
</div>
<div style="margin-left:36px;margin-bottom:8px;padding-left:10px;border-left:2px solid var(--allo-stem-border, #334155)">
<div style="font-weight:800;font-size:14px">Thyreophora<span style="font-size:11px;font-style:italic;color:var(--allo-stem-text-soft, #94a3b8);font-weight:400;margin-left:6px">&quot;shield bearers&quot;</span>
</div>
<div style="font-size:12.5px;color:var(--allo-stem-text, #f1f5f9);margin:2px 0 4px;line-height:1.5">The armored dinosaurs: the plated stegosaurs and the tank-like ankylosaurs.</div>
<div style="display:flex;flex-wrap:wrap;gap:5px">
<button style="font-size:11px;padding:2px 8px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Stegosaurus</button>
<button style="font-size:11px;padding:2px 8px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Ankylosaurus</button>
</div>
</div>
<div style="margin-left:36px;margin-bottom:8px;padding-left:10px;border-left:2px solid var(--allo-stem-border, #334155)">
<div style="font-weight:800;font-size:14px">Ornithopoda<span style="font-size:11px;font-style:italic;color:var(--allo-stem-text-soft, #94a3b8);font-weight:400;margin-left:6px">&quot;bird feet&quot;</span>
</div>
<div style="font-size:12.5px;color:var(--allo-stem-text, #f1f5f9);margin:2px 0 4px;line-height:1.5">Two- and four-legged plant-eaters, including the iguanodonts and the duck-billed hadrosaurs.</div>
<div style="display:flex;flex-wrap:wrap;gap:5px">
<button style="font-size:11px;padding:2px 8px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Iguanodon</button>
<button style="font-size:11px;padding:2px 8px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Parasaurolophus</button>
</div>
</div>
<div style="margin-left:36px;margin-bottom:8px;padding-left:10px;border-left:2px solid var(--allo-stem-border, #334155)">
<div style="font-weight:800;font-size:14px">Marginocephalia<span style="font-size:11px;font-style:italic;color:var(--allo-stem-text-soft, #94a3b8);font-weight:400;margin-left:6px">&quot;fringed heads&quot;</span>
</div>
<div style="font-size:12.5px;color:var(--allo-stem-text, #f1f5f9);margin:2px 0 4px;line-height:1.5">Dinosaurs with a bony shelf or dome at the back of the skull: horned ceratopsians and thick-headed pachycephalosaurs.</div>
<div style="display:flex;flex-wrap:wrap;gap:5px">
<button style="font-size:11px;padding:2px 8px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Triceratops</button>
</div>
</div>
</div>
</div>
</div>
</div>"
`;

exports[`Dino Lab — render per tab (golden master) > renders the compare tab (snapshot) 1`] = `
"<div style="min-height:100%;background:var(--allo-stem-canvas, #0f172a);color:var(--allo-stem-text, #f1f5f9)">
<div role="tablist" aria-label="Dino Lab sections" style="display:flex;flex-wrap:wrap;gap:4px;padding:10px 12px;border-bottom:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220)">
<button id="dinotab-explore" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🔍 Explore</button>
<button id="dinotab-timeline" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">⏳ Timeline</button>
<button id="dinotab-deeptime" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🕰️ Deep Time</button>
<button id="dinotab-sites" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🗺️ Sites</button>
<button id="dinotab-ecosystem" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🌍 Ecosystems</button>
<button id="dinotab-compare" role="tab" aria-selected="true" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:700;background:#15803d;color:#fff;white-space:nowrap">⚖️ Compare</button>
<button id="dinotab-dig" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">⛏️ Dig Site</button>
