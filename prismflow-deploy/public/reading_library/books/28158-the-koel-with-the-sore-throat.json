m"],[126,"in"],[127,"their"],[128,"search."],[129,"KU-OOOO"],[130,"KU-OOOO!"],[131,"Everybody"],[132,"wants"],[133,"to"],[134,"see"],[135,"the"],[136,"koel"],[137,"with"],[138,"the"],[139,"sore"],[140,"throat."]]},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/56952/size6/be68833bbebe31cb58fe88c49af6641b.jpg","text":"“There!” says Bhanu.\n“No, no, here!” says Zeba softly.\n“I can see one on that branch,” says Uma.\n“Parvez, look up . . . On that tree,” says Karan.\n“Oh no, how do we know which one has a sore throat?” asks Zeba.","words":[[141,"“There!”"],[142,"says"],[143,"Bhanu."],[144,"“No,"],[145,"no,"],[146,"here!”"],[147,"says"],[148,"Zeba"],[149,"softly."],[150,"“I"],[151,"can"],[152,"see"],[153,"one"],[154,"on"],[155,"that"],[156,"branch,”"],[157,"says"],[158,"Uma."],[159,"“Parvez,"],[160,"look"],[161,"up"],[162,"."],[163,"."],[164,"."],[165,"On"],[166,"that"],[167,"tree,”"],[168,"says"],[169,"Karan."],[170,"“Oh"],[171,"no,"],[172,"how"],[173,"do"],[174,"we"],[175,"know"],[176,"which"],[177,"one"],[178,"has"],[179,"a"],[180,"sore"],[181,"throat?”"],[182,"asks"],[183,"Zeba."]]},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/57058/size6/9696d049e040718b0bc41e560f99c045.jpg","text":"TUN TUNN TUNN TUN\n“Lunch time!” yells Bhanu.","words":[[184,"TUN"],[185,"TUNN"],[186,"TUNN"],[187,"TUN"],[188,"“Lunch"],[189,"time!”"],[190,"yells"],[191,"Bhanu."]]},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/56954/size6/8586641a4028adbc67cbc606d452d8c4.jpg","text":"Parvez can feel his stomach growling.\n“What is that sound,” jokes Stella.\nThey run inside and open their lunchboxes.\n“Idli, yay!” says Stella happily.\n“Mmmm . . . papaa . . . th . . .  thaa,” mumbles Parvez, munching a paratha.","words":[[192,"Parvez"],[193,"can"],[194,"feel"],[195,"his"],[196,"stomach"],[197,"growling."],[198,"“What"],[199,"is"],[200,"that"],[201,"sound,”"],[202,"jokes"],[203,"Stella."],[204,"They"],[205,"run"],[206,"inside"],[207,"and"],[208,"open"],[209,"their"],[210,"lunchboxes."],[211,"“Idli,"],[212,"yay!”"],[213,"says"],[214,"Stella"],[215,"happily."],[216,"“Mmmm"],[217,"."],[218,"."],[219,"."],[220,"papaa"],[221,"."],[222,"."],[223,"."],[224,"th"],[225,"."],[226,"."],[227,"."],[228,"thaa,”"],[229,"mumbles"],[230,"Parvez,"],[231,"munching"],[232,"a"],[233,"paratha."]]},{"n":9,"img":null,"text":"TUN-TUN-TUN-TUN TUNNN!\nLunch break is over. \nParvez picks up his bag and runs to Amina Dadi. She is waiting near the gate.","words":[[234,"TUN-TUN-TUN-TUN"],[235,"TUNNN!"],[236,"Lunch"],[237,"break"],[238,"is"],[239,"over."],[240,"Parvez"],[241,"picks"],[242,"up"],[243,"his"],[244,"bag"],[245,"and"],[246,"runs"],[247,"to"],[248,"Amina"],[249,"Dadi."],[250,"She"],[251,"is"],[252,"waiting"],[253,"near"],[254,"the"],[255,"gate."]]},{"n":10,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/57059/size6/bba695fa59ceaa399fc76a51cef6d81a.jpg","text":"“Parvez, you’re not wearing your hearing-aid! You know it will help you hear better, dear,” she says.\nShe pulls the small machine out of his shirt pocket.","words":[[256,"“Parvez,"],[257,"you’re"],[258,"not"],[259,"wearing"],[260,"your"],[261,"hearing-aid!"],[262,"You"],[263,"know"],[264,"it"],[265,"will"],[266,"help"],[267,"you"],[268,"hear"],[269,"better,"],[270,"dear,”"],[271,"she"],[272,"says."],[273,"She"],[274,"pulls"],[275,"the"],[276,"small"],[277,"machine"],[278,"out"],[279,"of"],[280,"his"],[281,"shirt"],[282,"pocket."]]},{"n":11,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/56956/size6/bf3b1024090a3d85778264c5aecd47b9.jpg","text":"“I dddon't lllike it,” he mutters.\n“And I don't like my glasses, but I wear them, don't I?” asks Dadi.\nJust then, he hears a koel faintly.\n“Ku-oooh-oooh!” imitates Parvez with a giggle. “Ku-oooooh-ooooooh!”\nParvez tells Dadi about the koel with a sore throat as they walk towards Sukarna School for the Deaf.","words":[[283,"“I"],[284,"dddon't"],[285,"lllike"],[286,"it,”"],[287,"he"],[288,"mutters."],[289,"“And"],[290,"I"],[291,"don't"],[292,"like"],[293,"my"],[294,"glasses,"],[295,"but"],[296,"I"],[297,"wear"],[298,"them,"],[299,"don't"],[300,"I?”"],[301,"asks"],[302,"Dadi."],[303,"Just"],[304,"then,"],[305,"he"],[306,"hears"],[307,"a"],[308,"koel"],[309,"faintly."],[310,"“Ku-oooh-oooh!”"],[311,"imitates"],[312,"Parvez"],[313,"with"],[314,"a"],[315,"giggle."],[316,"“Ku-oooooh-ooooooh!”"],[317,"Parvez"],[318,"tells"],[319,"Dadi"],[320,"about"],[321,"the"],[322,"koel"],[323,"with"],[324,"a"],[325,"sore"],[326,"throat"],[327,"as"],[328,"they"],[329,"walk"],[330,"towards"],[331,"Sukarna"],[332,"School"],[333,"for"],[334,"the"],[335,"Deaf."]]},{"n":12,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/56957/size6/b4ad05556d00cf94a40193cb899a32c7.jpg","text":"13/19","words":null},{"n":13,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/56958/size6/1bd09740ce6297be455a5b20d23fc63b.jpg","text":"In the evening, he meets Stella near his house.\n“Sstellaa, I h . . . h . . .  eard dhu koel!” he says, one word at a time.\nStella waves both her hands in the air. It means she is clapping. Parvez has taught her many words in Sign Language. Words that he has learnt from Sheela Miss at Sukarna School.","words":[[336,"In"],[337,"the"],[338,"evening,"],[339,"he"],[340,"meets"],[341,"Stella"],[342,"near"],[343,"his"],[344,"house."],[345,"“Sstellaa,"],[346,"I"],[347,"h"],[348,"."],[349,"."],[350,"."],[351,"h"],[352,"."],[353,"."],[354,"."],[355,"eard"],[356,"dhu"],[357,"koel!”"],[358,"he"],[359,"says,"],[360,"one"],[361,"word"],[362,"at"],[363,"a"],[364,"time."],[365,"Stella"],[366,"waves"],[367,"both"],[368,"her"],[369,"hands"],[370,"in"],[371,"the"],[372,"air."],[373,"It"],[374,"means"],[375,"she"],[376,"is"],[377,"clapping."],[378,"Parvez"],[379,"has"],[380,"taught"],[381,"her"],[382,"many"],[383,"words"],[384,"in"],[385,"Sign"],[386,"Language."],[387,"Words"],[388,"that"],[389,"he"],[390,"has"],[391,"learnt"],[392,"from"],[393,"Sheela"],[394,"Miss"],[395,"at"],[396,"Sukarna"],[397,"School."]]},{"n":14,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/56959/size6/a0a0569793975e19760d2b882630cc98.jpg","text":"“I ththink . . . itssss . . . ththroat . . . got be-tter,” he says.\n \nSheela Miss says his voice too will get better. It may just take a long time.\n \n“Catch?” calls Parvez, and off he runs. It is playtime now!","words":[[398,"“I"],[399,"ththink"],[400,"."],[401,"."],[402,"."],[403,"itssss"],[404,"."],[405,"."],[406,"."],[407,"ththroat"],[408,"."],[409,"."],[410,"."],[411,"got"],[412,"be-tter,”"],[413,"he"],[414,"says."],[415,"Sheela"],[416,"Miss"],[417,"says"],[418,"his"],[419,"voice"],[420,"too"],[421,"will"],[422,"get"],[423,"better."],[424,"It"],[425,"may"],[426,"just"],[427,"take"],[428,"a"],[429,"long"],[430,"time."],[431,"“Catch?”"],[432,"calls"],[433,"Parvez,"],[434,"and"],[435,"off"],[436,"he"],[437,"runs."],[438,"It"],[439,"is"],[440,"playtime"],[441,"now!"]]},{"n":15,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/56960/size6/227b9b55deb7daa687a4bb28bd8fee2a.jpg","text":"16/19","words":null},{"n":16,"img":null,"text":"SOME EARS ARE DIFFERENT\n - When Parvez was just five months old, his parents saw that he  didn’t react to loud noises at all. They took him to a doctor who said that Parvez may have hearing loss. The doctor explained how they could help Parvez learn everything just like children who can hear.\n - When you can hear well, you learn to speak easily too. Most deaf people do not speak very well because they cannot hear others talk.","words":[[442,"SOME"],[443,"EARS"],[444,"ARE"],[445,"DIFFERENT"],[446,"-"],[447,"When"],[448,"Parvez"],[449,"was"],[450,"just"],[451,"five"],[452,"months"],[453,"old,"],[454,"his"],[455,"parents"],[456,"saw"],[457,"that"],[458,"he"],[459,"didn’t"],[460,"react"],[461,"to"],[462,"loud"],[463,"noises"],[464,"at"],[465,"all."],[466,"They"],[467,"took"],[468,"him"],[469,"to"],[470,"a"],[471,"doctor"],[472,"who"],[473,"said"],[474,"that"],[475,"Parvez"],[476,"may"],[477,"have"],[478,"hearing"],[479,"loss."],[480,"The"],[481,"doctor"],[482,"explained"],[483,"how"],[484,"they"],[485,"could"],[486,"help"],[487,"Parvez"],[488,"learn"],[489,"everything"],[490,"just"],[491,"like"],[492,"children"],[493,"who"],[494,"can"],[495,"hear."],[496,"-"],[497,"When"],[498,"you"],[499,"can"],[500,"hear"],[501,"well,"],[502,"you"],[503,"learn"],[504,"to"],[505,"speak"],[506,"easily"],[507,"too."],[508,"Most"],[509,"deaf"],[510,"people"],[511,"do"],[512,"not"],[513,"speak"],[514,"very"],[515,"well"],[516,"because"],[517,"they"],[518,"cannot"],[519,"hear"],[520,"others"],[521,"talk."]]},{"n":17,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/56961/size6/5a04f7d7d23be5d090c464e9863939f0.jpg","text":"- People who have total hearing loss cannot hear anything. Parvez has partial hearing loss. So he needs a special teacher like Sheela Miss to help him learn Sign Language, lip-reading, and other ways of communicating.\n - Some people wear glasses so that they can see better. Parvez wears a hearing aid so that he can hear better. He has to be careful with this little machine.","words":[[522,"-"],[523,"People"],[524,"who"],[525,"have"],[526,"total"],[527,"hearing"],[528,"loss"],[529,"cannot"],[530,"hear"],[531,"anything."],[532,"Parvez"],[533,"has"],[534,"partial"],[535,"hearing"],[536,"loss."],[537,"So"],[538,"he"],[539,"needs"],[540,"a"],[541,"special"],[542,"teacher"],[543,"like"],[544,"Sheela"],[545,"Miss"],[546,"to"],[547,"help"],[548,"him"],[549,"learn"],[550,"Sign"],[551,"Language,"],[552,"lip-reading,"],[553,"and"],[554,"other"],[555,"ways"],[556,"of"],[557,"communicating."],[558,"-"],[559,"Some"],[560,"people"],[561,"wear"],[562,"glasses"],[563,"so"],[564,"that"],[565,"they"],[566,"can"],[567,"see"],[568,"better."],[569,"Parvez"],[570,"wears"],[571,"a"],[572,"hearing"],[573,"aid"],[574,"so"],[575,"that"],[576,"he"],[577,"can"],[578,"hear"],[579,"better."],[580,"He"],[581,"has"],[582,"to"],[583,"be"],[584,"careful"],[585,"with"],[586,"this"],[587,"little"],[588,"machine."]]},{"n":18,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/56962/size6/5129ac678219036e778b0f08c4d4d5ce.jpg","text":"- Parvez understands people better when they speak to him softly, and if they are facing him when they speak. Parvez cannot hear well. But he can see, feel, smell, understand and learn very well, and play catch!","words":[[589,"-"],[590,"Parvez"],[591,"understands"],[592,"people"],[593,"better"],[594,"when"],[595,"they"],[596,"speak"],[597,"to"],[598,"him"],[599,"softly,"],[600,"and"],[601,"if"],[602,"they"],[603,"are"],[604,"facing"],[605,"him"],[606,"when"],[607,"they"],[608,"speak."],[609,"Parvez"],[610,"cannot"],[611,"hear"],[612,"well."],[613,"But"],[614,"he"],[615,"can"],[616,"see,"],[617,"feel,"],[618,"smell,"],[619,"understand"],[620,"and"],[621,"learn"],[622,"very"],[623,"well,"],[624,"and"],[625,"play"],[626,"catch!"]]}],"stats":{"pages":18,"words":628}}