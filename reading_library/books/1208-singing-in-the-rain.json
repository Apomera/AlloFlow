tion"],[20,"was"],[21,"complete"],[22,"without"],[23,"Sukhiya"],[24,"Kaka's"],[25,"sweet"],[26,"songs."],[27,"Today"],[28,"he"],[29,"had"],[30,"been"],[31,"invited"],[32,"to"],[33,"village"],[34,"Jhalaura."]]},{"n":2,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/13877/size6/1c9ef1f14d559da2aa9be2f123ffe976.jpg","text":"Sukhiya Kaka twirled his big moustache and set off.\nHe was singing raag Malhar.\n...Come to me o rolling clouds...","words":[[35,"Sukhiya"],[36,"Kaka"],[37,"twirled"],[38,"his"],[39,"big"],[40,"moustache"],[41,"and"],[42,"set"],[43,"off."],[44,"He"],[45,"was"],[46,"singing"],[47,"raag"],[48,"Malhar."],[49,"...Come"],[50,"to"],[51,"me"],[52,"o"],[53,"rolling"],[54,"clouds..."]]},{"n":3,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/13878/size6/dd4b6553a1103af910637ee70e5ffeb4.jpg","text":"Suddenly, he heard, dhupp dhupp dhupp dhupp!\nWas someone giving a beat to his song?\nDinoo, the dinosuar came running towards him. Sukhiya Kaka was so happy to see him!","words":[[55,"Suddenly,"],[56,"he"],[57,"heard,"],[58,"dhupp"],[59,"dhupp"],[60,"dhupp"],[61,"dhupp!"],[62,"Was"],[63,"someone"],[64,"giving"],[65,"a"],[66,"beat"],[67,"to"],[68,"his"],[69,"song?"],[70,"Dinoo,"],[71,"the"],[72,"dinosuar"],[73,"came"],[74,"running"],[75,"towards"],[76,"him."],[77,"Sukhiya"],[78,"Kaka"],[79,"was"],[80,"so"],[81,"happy"],[82,"to"],[83,"see"],[84,"him!"]]},{"n":4,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/13879/size6/81a50d53a223639638194a24b8d29747.jpg","text":"You don't get such a BIG listener every day!\n... Come to me o rolling clouds, shower me with lovely rain!\nSukhiya Kaka and Dinoo sang a duet and did a little jig to keep time.","words":[[85,"You"],[86,"don't"],[87,"get"],[88,"such"],[89,"a"],[90,"BIG"],[91,"listener"],[92,"every"],[93,"day!"],[94,"..."],[95,"Come"],[96,"to"],[97,"me"],[98,"o"],[99,"rolling"],[100,"clouds,"],[101,"shower"],[102,"me"],[103,"with"],[104,"lovely"],[105,"rain!"],[106,"Sukhiya"],[107,"Kaka"],[108,"and"],[109,"Dinoo"],[110,"sang"],[111,"a"],[112,"duet"],[113,"and"],[114,"did"],[115,"a"],[116,"little"],[117,"jig"],[118,"to"],[119,"keep"],[120,"time."]]},{"n":5,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/13880/size6/caac6ab518e4cc51c919efb29b0cd1ed.jpg","text":"The clouds just had to listen to them!\nLightning flashed and the wind danced. Dark clouds came rolling in.\nSukhiya Kaka and Dinoo laughed with joy.","words":[[121,"The"],[122,"clouds"],[123,"just"],[124,"had"],[125,"to"],[126,"listen"],[127,"to"],[128,"them!"],[129,"Lightning"],[130,"flashed"],[131,"and"],[132,"the"],[133,"wind"],[134,"danced."],[135,"Dark"],[136,"clouds"],[137,"came"],[138,"rolling"],[139,"in."],[140,"Sukhiya"],[141,"Kaka"],[142,"and"],[143,"Dinoo"],[144,"laughed"],[145,"with"],[146,"joy."]]},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/13881/size6/ef9d3c2e6e2eb441f8744d3d53e8fee4.jpg","text":"As the rain came pouring down, Sukhiya Kaka and Dinoo shared a small umbrella. Then off they went to Jhalaura following the smell of yummy pakoras, singing\n...O thank you for the lovely rain...O..la la la.","words":[[147,"As"],[148,"the"],[149,"rain"],[150,"came"],[151,"pouring"],[152,"down,"],[153,"Sukhiya"],[154,"Kaka"],[155,"and"],[156,"Dinoo"],[157,"shared"],[158,"a"],[159,"small"],[160,"umbrella."],[161,"Then"],[162,"off"],[163,"they"],[164,"went"],[165,"to"],[166,"Jhalaura"],[167,"following"],[168,"the"],[169,"smell"],[170,"of"],[171,"yummy"],[172,"pakoras,"],[173,"singing"],[174,"...O"],[175,"thank"],[176,"you"],[177,"for"],[178,"the"],[179,"lovely"],[180,"rain...O..la"],[181,"la"],[182,"la."]]},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/13882/size6/baf97c5f1160fc93173c6ee9567e9927.jpg","text":"Dear Reader,\nHave you ever seen a dinosaur?\nDo you think they would have sung songs?\nWhat do you like to do in the rain?\nWhat do you like to eat when it rains?","words":[[183,"Dear"],[184,"Reader,"],[185,"Have"],[186,"you"],[187,"ever"],[188,"seen"],[189,"a"],[190,"dinosaur?"],[191,"Do"],[192,"you"],[193,"think"],[194,"they"],[195,"would"],[196,"have"],[197,"sung"],[198,"songs?"],[199,"What"],[200,"do"],[201,"you"],[202,"like"],[203,"to"],[204,"do"],[205,"in"],[206,"the"],[207,"rain?"],[208,"What"],[209,"do"],[210,"you"],[211,"like"],[212,"to"],[213,"eat"],[214,"when"],[215,"it"],[216,"rains?"]]},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/13883/size6/8827c24be6c337ec9f4fdf2974f96c90.jpg","text":"#6FrameStoryChallenge: A Carnival of Art\nThe illustrations in this book were created as part of the #6FrameStoryChallenge, an online campaign run by Pratham Books to build a rich bank of illustrations for StoryWeaver. The essence of the #6FrameStoryChallenge was to tell a good story using just 6 illustrations.\n \nThe campaign inspired nearly 70 illustrators to donate their time and skills to India’s first open-source story-publishing platform for children. What started out as an experimental campaign soon blossomed into a carnival of art, birthing nearly 500 new illustrations.\nThese wordless narratives cut across language barriers, opening up a world of possibilities, encouraging StoryWeaver’s growing community to dream up multiple stories around these images. The #6FrameStoryChallenge is a powerful reminder of the need for collaboration, to get closer to our mission: “A Book in Every Child’s Hand.”","words":[[217,"#6FrameStoryChallenge:"],[218,"A"],[219,"Carnival"],[220,"of"],[221,"Art"],[222,"The"],[223,"illustrations"],[224,"in"],[225,"this"],[226,"book"],[227,"were"],[228,"created"],[229,"as"],[230,"part"],[231,"of"],[232,"the"],[233,"#6FrameStoryChallenge,"],[234,"an"],[235,"online"],[236,"campaign"],[237,"run"],[238,"by"],[239,"Pratham"],[240,"Books"],[241,"to"],[242,"build"],[243,"a"],[244,"rich"],[245,