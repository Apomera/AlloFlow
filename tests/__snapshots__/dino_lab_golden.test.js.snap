<button aria-label="Open Saurophaganax" style="font-size:11.5px;padding:4px 10px;border-radius:999px;cursor:pointer;border:1px solid #ef444466;background:#ef444418;color:var(--allo-stem-text, #f1f5f9);margin-right:5px;margin-bottom:5px">🥩 Saurophaganax</button>
