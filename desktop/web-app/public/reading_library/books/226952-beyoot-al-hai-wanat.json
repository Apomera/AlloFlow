.org.in/illustration_crops/100621/size6/e49c9d2c07fcb2771e3ccef5374e6b22.jpg","text":"تَنْمُو بُيُوتُ الْقَوَاقِعِ الْحَلَزُونِيَّةِ وَالسَّلَاحِفِ عَلَى ظُهُورِهَا.","words":[[24,"تَنْمُو"],[25,"بُيُوتُ"],[26,"الْقَوَاقِعِ"],[27,"الْحَلَزُونِيَّةِ"],[28,"وَالسَّلَاحِفِ"],[29,"عَلَى"],[30,"ظُهُورِهَا."]]},{"n":5,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/100521/size6/9a3b3e7c66014f8a9d544fa56cf9d27a.jpg","text":"تَعِيشُ الْأَسْمَاكُ فِي الْمِيَاهِ.\nتَسْتَطِيعُ الضَّفَادِعُ الْعَيْشَ فِي الْمِيَاهِ أَوْ عَلَى سَطْحِ الْأَرْضِ.","words":[[31,"تَعِيشُ"],[32,"الْأَسْمَاكُ"],[33,"فِي"],[34,"الْمِيَاهِ."],[35,"تَسْتَطِيعُ"],[36,"الضَّفَادِعُ"],[37,"الْعَيْشَ"],[38,"فِي"],[39,"الْمِيَاهِ"],[40,"أَوْ"],[41,"عَلَى"],[42,"سَطْحِ"],[43,"الْأَرْضِ."]]},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/100623/size6/a1ff13f2e1c5dc9b557cd26f73bb48bc.jpg","text":"تَعِيشُ الْأَرَانِبُ وَالْفِئْرَانُ فِي جُحُورٍ تَحْتَ سَطْحِ الْأَرْضِ.","words":[[44,"تَعِيشُ"],[45,"الْأَرَانِبُ"],[46,"وَالْفِئْرَانُ"],[47,"فِي"],[48,"جُحُورٍ"],[49,"تَحْتَ"],[50,"سَطْحِ"],[51,"الْأَرْضِ."]]},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/100524/size6/8e8863980af82e7f8ac7a14f683bcb33.jpg","text":"تَتَّخِذُ الْقُرُودُ مِنَ الْأَشْجَارِ بَيْتًا لَهَا.","words":[[52,"تَتَّخِذُ"],[53,"الْقُرُودُ"],[54,"مِنَ"],[55,"الْأَشْجَارِ"],[56,"بَيْتًا"],[57,"لَهَا."]]},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/100525/size6/09d7e83c55b280514cea0fd0188fcfa1.jpg","text":"تَعِيشُ الدِّبَبَةُ وَالذِّئَابُ فِي الْأَوْكَارِ.","words":[[58,"تَعِيشُ"],[59,"الدِّبَبَةُ"],[60,"وَالذِّئَابُ"],[61,"فِي"],[62,"الْأَوْكَارِ."]]},{"n":9,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/100526/size6/298f12212f5d9bbd46c4c98842cec2f8.jpg","text":"تَعِيشُ التَّمَاسِيحُ فِي الْمُسْتَنْقَعَاتِ.","words":[[63,"تَعِيشُ"],[64,"التَّمَاسِيحُ"],[65,"فِي"],[66,"الْمُسْتَنْقَعَاتِ."]]},{"n":10,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/100527/size6/e4fc083c092f0798676f7e32257146c3.jpg","text":"تَعِيشُ الْغِزْلَانُ فِي الْغَابَاتِ.\nوَالنُّمُورُ أَيْضًا!","words":[[67,"تَعِيشُ"],[68,"الْغِزْلَانُ"],[69,"فِي"],[70,"الْغَابَاتِ."],[71,"وَالنُّمُورُ"],[72,"أَيْضًا!"]]},{"n":11,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/100528/size6/ad4be3f97ebb5e2e28dbd8601914c485.jpg","text":"بَيْتٌ وَاحِدٌ كَبِيرٌ.\nتَعِيشُ بَعْضُ الْحَيَوَانَاتِ بِالْقُرْبِ مِنَّا وَالْبَعْضُ الْآخَرُ بَعِيدًا عَنَّا.\nوَلَكِنْ هَلْ تَعْلَمُ فِيمَ نَتَشَابَهُ مَعَ جَمِيعِ الْحَيَوَانَاتِ فِي الْعَالَمِ؟\nجَمِيعُنَا نَبْنِي بُيُوتَنَا فِي بَيْتٍ وَاحِدٍ كَبِيرٍ، هُوَ كَوْكَبُ الْأَرْضِ!","words":[[73,"بَيْتٌ"],[74,"وَاحِدٌ"],[75,"كَبِيرٌ."],[76,"تَعِيشُ"],[77,"بَعْضُ"],[78,"الْحَيَوَانَاتِ"],[79,"بِالْقُرْبِ"],[80,"مِنَّا"],[81,"وَالْبَعْضُ"],[82,"الْآخَرُ"],[83,"بَعِيدًا"],[84,"عَنَّا."],[85,"وَلَكِنْ"],[86,"هَلْ"],[87,"تَعْلَمُ"],[88,"فِيمَ"],[89,"نَتَشَابَهُ"],[90,"مَعَ"],[91,"جَمِيعِ"],[92,"الْحَيَوَانَاتِ"],[93,"فِي"],[94,"الْعَالَمِ؟"],[95,"جَمِيعُنَا"],[96,"نَبْنِي"],[97,"بُيُوتَنَا"],[98,"فِي"],[99,"بَيْتٍ"],[100,"وَاحِدٍ"],[101,"كَبِيرٍ،"],[102,"هُوَ"],[103,"كَوْكَبُ"],[104,"الْأَرْضِ!"]]}],"stats":{"pages":11,"words":104}}