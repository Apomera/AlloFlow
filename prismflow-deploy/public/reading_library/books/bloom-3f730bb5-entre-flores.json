    {
      "n": 8,
      "img": "https://s3.amazonaws.com/BloomLibraryBooks/bborrayo%40gmail.com%2f3f730bb5-335d-4bce-a147-0aa558c47fe4%2fEntre+flores%2fAgricultor.png",
      "text": "Josué tiene pasión por la naturaleza. Desea ser ambientalista."
    },
    {
      "n": 9,
