exports[`Dino Lab — data contract > the Tyrannosaurus record is pinned (representative full entry, snapshot) 1`] = `
{
  "blurb": "One of the largest land predators ever, with a bite force estimated near 35,000 newtons, the strongest of any known land animal.",
  "clade": "Tyrannosauridae",
  "common": "T. rex",
  "diet": "carnivore",
  "epoch": "Late Cretaceous",
  "facts": [
    "The specimen "Sue" is about 90 percent complete.",
    "Juveniles were slender and probably fast; adults were bulkier.",
  ],
  "formation": "Hell Creek",
  "group": "theropod",
  "heightM": 3.7,
  "howKnow": "Dozens of partial skeletons, including "Sue" and "Stan", plus bite marks on other bones.",
  "id": "tyrannosaurus",
  "lengthM": 12.3,
  "meaning": "tyrant lizard king",
  "myaHi": 68,
  "myaLo": 66,
  "name": "Tyrannosaurus rex",
  "named": 1905,
  "namedBy": "Henry Fairfield Osborn",
  "period": "cretaceous",
  "region": "North America",
  "say": "tie-RAN-uh-SOR-us rex",
  "speedKmh": 20,
  "traits": [
    "Banana-sized teeth",
    "Tiny but strong arms",
    "Forward-facing eyes (good depth perception)",
  ],
  "uncertain": "Top speed is estimated from leg bones and muscle models, not measured. Feather extent is debated.",
  "weightKg": 8400,
}
`;

