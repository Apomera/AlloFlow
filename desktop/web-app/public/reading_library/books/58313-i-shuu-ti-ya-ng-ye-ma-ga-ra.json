{"schema":"allo-reading-book@1","slug":"58313-i-shuu-ti-ya-ng-ye-ma-ga-ra","title":"INSHUTI YANJYE MAGARA","description":"Wifuza kubona inshuti yawe magara? Reba muri iki gitabo urasanga usanzwe ufite inshuti idasanzwe!","language":"Kinyarwanda","langCode":"rw","isRtl":false,"level":"1","orientation":"landscape","authors":["Fred HIRWA"],"illustrators":["Suvidha Mistry"],"originalAuthors":[],"publisher":"Right To Play","license":"CC BY 4.0","licenseUrl":"https://creativecommons.org/licenses/by/4.0/","sourceId":"storyweaver","contentType":"story","source":{"id":"storyweaver","name":"StoryWeaver, Pratham Books","url":"https://storyweaver.org.in/en/stories/58313-i-shuu-ti-ya-ng-ye-ma-ga-ra"},"cover":{"card":"https://static.storyweaver.org.in/illustration_crops/704882/size3/b1586d957cd76fc5ad2d07442f85401c.jpg","large":"https://static.storyweaver.org.in/illustration_crops/704882/size6/b1586d957cd76fc5ad2d07442f85401c.jpg"},"audio":null,"pages":[{"n":1,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/12939/size6/26f3c562e8fcf285da64ace4885497a2.jpg","text":"Mfite inshuti. Tubana mu rugo","words":null},{"n":2,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/12940/size6/d07a196027366d86d218485a16115cef.jpg","text":"Iyo nishimye nayo irishima.","words":null},{"n":3,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/12941/size6/9968ed9b842685f573b114b9a2be8e6a.jpg","text":"Iyo ndimo kurira, nayo irarira","words":null},{"n":4,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/12942/size6/7f19ca3a7f4392ae1737ad6f7ba722e6.jpg","text":"Gusa simbasha kumva ijwi ryayo. Inshuti yajye iba mu ndorerwamo","words":null},{"n":5,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/12943/size6/f77bed787eca6e623588fd4492456666.jpg","text":"\"Ngwino\", mbwira inshuti yajye.\"Turaza gukina\". Ntabwo ishaka kuza","words":null},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/12944/size6/0ab978d66dc04fbd958537accfaf3474.jpg","text":"Ntabwo nishimye. Jya Kuryama","words":null},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/12945/size6/f2d91399e3710afc2ab72f1a4251ae1f.jpg","text":"Mu nzozi, inshuti yajye iraza! Turakina turishimana","words":null},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/12946/size6/99927082c4c7183837255183b81f106f.jpg","text":"Turakina, Turiruka, turasakuza, turaririmba hamwe","words":null},{"n":9,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/12947/size6/193694c2078e2b794802233069bfca43.jpg","text":"Iyo navugishaga inshuti yajye, nayo yamvugishaga","words":null},{"n":10,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/12948/size6/2fdc1d0c194d45e607462e4a77a7b9b4.jpg","text":"Mu gitondo, inshuti yajye irasubira mu ndorerwamo.","words":null},{"n":11,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/12949/size6/e6d48b6c13538e56e67d69f9f907c03e.jpg","text":"Gusa ntacyo bintwaye. Turongera gukina mu nzozi","words":null}],"stats":{"pages":11,"words":68}}