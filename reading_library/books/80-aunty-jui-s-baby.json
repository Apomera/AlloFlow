,[168,"“I"],[169,"want"],[170,"to"],[171,"hold"],[172,"the"],[173,"baby,”"],[174,"said"],[175,"Anu."],[176,"“Oh"],[177,"no,"],[178,"Anu."],[179,"You"],[180,"won’t"],[181,"be"],[182,"able"],[183,"to."],[184,"You’re"],[185,"much"],[186,"too"],[187,"small,”"],[188,"said"],[189,"Aai."],[190,"“But"],[191,"I’m"],[192,"her"],[193,"big"],[194,"sister,”"],[195,"said"],[196,"Anu."]]},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/1016/size6/02967c02c5e16f4fe1da4c72543f1b74.jpg","text":"Why should the baby sit on Aai’s lap? I want to sit on Aai’s lap too, thought Anu. But Aai said, “Anu, move away! You must not bother baby. See how tiny she is?”","words":[[197,"Why"],[198,"should"],[199,"the"],[200,"baby"],[201,"sit"],[202,"on"],[203,"Aai’s"],[204,"lap?"],[205,"I"],[206,"want"],[207,"to"],[208,"sit"],[209,"on"],[210,"Aai’s"],[211,"lap"],[212,"too,"],[213,"thought"],[214,"Anu."],[215,"But"],[216,"Aai"],[217,"said,"],[218,"“Anu,"],[219,"move"],[220,"away!"],[221,"You"],[222,"must"],[223,"not"],[224,"bother"],[225,"baby."],[226,"See"],[227,"how"],[228,"tiny"],[229,"she"],[230,"is?”"]]},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/1017/size6/c323a6611e6c3da64198d2fd84dd62df.jpg","text":"The baby was still wailing. “Waah...”\n“Oh dear!” said Aunty. “I think she’s soiled her nappy.”\nShe cleaned the baby and changed her nappy.\nThe baby gurgled happily.","words":[[231,"The"],[232,"baby"],[233,"was"],[234,"still"],[235,"wailing."],[236,"“Waah...”"],[237,"“Oh"],[238,"dear!”"],[239,"said"],[240,"Aunty."],[241,"“I"],[242,"think"],[243,"she’s"],[244,"soiled"],[245,"her"],[246,"nappy.”"],[247,"She"],[248,"cleaned"],[249,"the"],[250,"baby"],[251,"and"],[252,"changed"],[253,"her"],[254,"nappy."],[255,"The"],[256,"baby"],[257,"gurgled"],[258,"happily."]]},{"n":9,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/1018/size6/9a19507400b28d26303215db47a22218.jpg","text":"Anu was disgusted. What a silly baby. Potty in the nappy!\nAnd Aai and Aunty were mad! They didn't even scold the baby.","words":[[259,"Anu"],[260,"was"],[261,"disgusted."],[262,"What"],[263,"a"],[264,"silly"],[265,"baby."],[266,"Potty"],[267,"in"],[268,"the"],[269,"nappy!"],[270,"And"],[271,"Aai"],[272,"and"],[273,"Aunty"],[274,"were"],[275,"mad!"],[276,"They"],[277,"didn't"],[278,"even"],[279,"scold"],[280,"the"],[281,"baby."]]},{"n":10,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/1019/size6/3d14d6560e92b8c83f0764415c0595d4.jpg","text":"If I just pee in my underwear by mistake, Aai glares at me. But now look at her doing ‘kootchie-coo!’ to the baby! Wait till I get home. I’ll tell Baba how unfair Aai is.","words":[[282,"If"],[283,"I"],[284,"just"],[285,"pee"],[286,"in"],[287,"my"],[288,"underwear"],[289,"by"],[290,"mistake,"],[291,"Aai"],[292,"glares"],[293,"at"],[294,"me."],[295,"But"],[296,"now"],[297,"look"],[298,"at"],[299,"her"],[300,"doing"],[301,"‘kootchie-coo!’"],[302,"to"],[303,"the"],[304,"baby!"],[305,"Wait"],[306,"till"],[307,"I"],[308,"get"],[309,"home."],[310,"I’ll"],[311,"tell"],[312,"Baba"],[313,"how"],[314,"unfair"],[315,"Aai"],[316,"is."]]},{"n":11,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/1020/size6/9cc0ccc9883bdfa718b795340a904c44.jpg","text":"“Let’s go home, Aai!” Anu cried.\n“Why, Anu, don’t you like the baby?” asked Aunty. “Chee!” said Anu.\n“Silly baby, does potty in the nappy, doesn’t talk, doesn’t play. I don’t like your baby. Why did you get yourself such a silly baby?”","words":[[317,"“Let’s"],[318,"go"],[319,"home,"],[320,"Aai!”"],[321,"Anu"],[322,"cried."],[323,"“Why,"],[324,"Anu,"],[325,"don’t"],[326,"you"],[327,"like"],[328,"the"],[329,"baby?”"],[330,"asked"],[331,"Aunty."],[332,"“Chee!”"],[333,"said"],[334,"Anu."],[335,"“Silly"],[336,"baby,"],[337,"does"],[338,"potty"],[339,"in"],[340,"the"],[341,"nappy,"],[342,"doesn’t"],[343,"talk,"],[344,"doesn’t"],[345,"play."],[346,"I"],[347,"don’t"],[348,"like"],[349,"your"],[350,"baby."],[351,"Why"],[352,"did"],[353,"you"],[354,"get"],[355,"yourself"],[356,"such"],[357,"a"],[358,"silly"],[359,"baby?”"]]},{"n":12,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/1021/size6/67d4bfaad685cbb61256609492fedf21.jpg","text":"On the way back home, Anu asked her mother, “Aai, when will I become a baby?”\n \n“You won’t become a baby again, “ said Aai. “You’ll grow bigger now.”\n \n“I don’t want to be big! I want to be a baby and I want to sleep in your lap, and I want to drink milk with a spoon and I want to sit on Baba’s shoulders and go out and...”\n \nAnu muttered all the way home.","words":[[360,"On"],[361,"the"],[362,"way"],[363,"back"],[364,"home,"],[365,"Anu"],[366,"asked"],[367,"her"],[368,"mother,"],[369,"“Aai,"],[370,"when"],[371,"will"],[372,"I"],[373,"become"],[374,"a"],[375,"baby?”"],[376,"“You"],[377,"won’t"],[378,"become"],[379,"a"],[380,"baby"],[381,"again,"],[382,"“"],[383,"said"],[384,"Aai."],[385,"“You’ll"],[386,"grow"],[387,"bigger"],[388,"now.”"],[389,"“I"],[390,"don’t"],[391,"want"],[392,"to"],[393,"be"],[394,"big!"],[395,"I"],[396,"want"],[397,"to"],[398,"be"],[399,"a"],[400,"baby"],[401,"and"],[402,"I"],[403,"want"],[404,"to"],[405,"sleep"],[406,"in"],[407,"your"],[408,"lap,"],[409,"and"],[410,"I"],[411,"want"],[412,"to"],[413,"drink"],[414,"milk"],[415,"with"],[416,"a"],[417,"spoon"],[418,"and"],[419,"I"],[420,"want"],[421,"to"],[422,"sit"],[423,"on"],[424,"Baba’s"],[425,"shoulders"],[426,"and"],[427,"go"],[428,"out"],[429,"and...”"],[430,"Anu"],[431,"muttered"],[432,"all"],[433,"the"],[434,"way"],[435,"home."]]},{"n":13,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/1022/size6/dd4766e5a634907302a2abba9cd7c59d.jpg","text":"The next day Aai said, ”Anu, let’s give your small clothes, toys and cradle to Aunty Jui’s baby, shall we?”","words":[[436,"The"],[437,"next"],[438,"day"],[439,"Aai"],[440,"said,"],[441,"”Anu,"],[442,"let’s"],[443,"give"],[444,"your"],[445,"small"],[446,"clothes,"],[447,"toys"],[448,"and"],[449,"cradle"],[450,"to"],[451,"Aunty"],[452,"Jui’s"],[453,"baby,"],[454,"shall"],[455,"we?”"]]},{"n":14,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/1023/size6/d7cfd8d1b8231f64686a9bc374354cee.jpg","text":"“No!” yelled Anu. “That’s my ball and my cradle!”\n“Okay, what about giving away these clothes then? They’re so small,” said Aai.\n“No!” shouted Anu again. “I want to wear them, NOW!” So Aai put the small frock on Anu. She even put the little baby bonnet on her head.","words":[[456,"“No!”"],[457,"yelled"],[458,"Anu."],[459,"“That’s"],[460,"my"],[461,"ball"],[462,"and"],[463,"my"],[464,"cradle!”"],[465,"“Okay,"],[466,"what"],[467,"about"],[468,"giving"],[469,"away"],[470,"these"],[471,"clothes"],[472,"then?"],[473,"They’re"],[474,"so"],[475,"small,”"],[476,"said"],[477,"Aai."],[478,"“No!”"],[479,"shouted"],[480,"Anu"],[481,"again."],[482,"“I"],[483,"want"],[484,"to"],[485,"wear"],[486,"them,"],[487,"NOW!”"],[488,"So"],[489,"Aai"],[490,"put"],[491,"the"],[492,"small"],[493,"frock"],[494,"on"],[495,"Anu."],[496,"She"],[497,"even"],[498,"put"],[499,"the"],[500,"little"],[501,"baby"],[502,"bonnet"],[503,"on"],[504,"her"],[505,"head."]]},{"n":15,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/1024/size6/5fae597d08d7d8fd920b27eb4f0831ad.jpg","text":"Anu crawled all over the house.\nShe balanced the ball on her head and wandered around, calling, ‘Curd! Fresh curd!’ She played with the rattle: rat-a-tat-tat.","words":[[506,"Anu"],[507,"crawled"],[508,"all"],[509,"over"],[510,"the"],[511,"house."],[512,"She"],[513,"balanced"],[514,"the"],[515,"ball"],[516,"on"],[517,"her"],[518,"head"],[519,"and"],[520,"wandered"],[521,"around,"],[522,"calling,"],[523,"‘Curd!"],[524,"Fresh"],[525,"curd!’"],[526,"She"],[527,"played"],[528,"with"],[529,"the"],[530,"rattle:"],[531,"rat-a-tat-tat."]]},{"n":16,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/1025/size6/aa016dd2ce11ac29138fbb1159cf2a12.jpg","text":"Anu climbed into the cradle. She wanted to lie down and suck her thumb.\nBut she didn’t fit! Her feet stuck out at one end, and she couldn’t keep her arms straight. The tight little frock began to pinch. Anu was fed up. This was no fun at all!","words":[[532,"Anu"],[533,"climbed"],[534,"into"],[535,"the"],[536,"cradle."],[537,"She"],[538,"wanted"],[539,"to"],[540,"lie"],[541,"down"],[542,"and"],[543,"suck"],[544,"her"],[545,"thumb."],[546,"But"],[547,"she"],[548,"didn’t"],[549,"fit!"],[550,"Her"],[551,"feet"],[552,"stuck"],[553,"out"],[554,"at"],[555,"one"],[556,"end,"],[557,"and"],[558,"she"],[559,"couldn’t"],[560,"keep"],[561,"her"],[562,"arms"],[563,"straight."],[564,"The"],[565,"tight"],[566,"little"],[567,"frock"],[568,"began"],[569,"to"],[570,"pinch."],[571,"Anu"],[572,"was"],[573,"fed"],[574,"up."],[575,"This"],[576,"was"],[577,"no"],[578,"fun"],[579,"at"],[580,"all!"]]},{"n":17,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/1026/size6/6f744b743a2a6b3b1ac89beceea8be9b.jpg","text":"Anu said to her mother, “Aai, why don’t we give this frock and bonnet and cradle to Aunty Jui’s baby?”\n“Give it all away? But then what will you do?” asked Aai.\n \n“Aai, I’m a big sister now, aren’t I? Once you become a big sister you wear proper clothes, and sleep on the bed.”\n“Oh really? I had no idea!” said Aai, smiling.\n \nAnu wore her own clothes and said, “Aai, tell baby that her big sister has given her all this. You’ll tell her, won’t you?”\nAnu jumped on to her scooter and went off to play.","words":[[581,"Anu"],[582,"said"],[583,"to"],[584,"her"],[585,"mother,"],[586,"“Aai,"],[587,"why"],[588,"don’t"],[589,"we"],[590,"give"],[591,"this"],[592,"frock"],[593,"and"],[594,"bonnet"],[595,"and"],[596,"cradle"],[597,"to"],[598,"Aunty"],[599,"Jui’s"],[600,"baby?”"],[601,"“Give"],[602,"it"],[603,"all"],[60