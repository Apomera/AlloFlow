.in/illustration_crops/1051/size6/8bea2fa23515654fb7e41faf723e98d4.jpg","text":"\"مجے\nوہ کتاب چاہئے!\" عامر نے کہا۔\n\"نہیں، نہیں! وہ نہیں!\" دکاندار نے\nکہا۔ \"یہ کتاب لے لو۔\"","words":[[147,"\"مجے"],[148,"وہ"],[149,"کتاب"],[150,"چاہئے!\""],[151,"عامر"],[152,"نے"],[153,"کہا۔"],[154,"\"نہیں،"],[155,"نہیں!"],[156,"وہ"],[157,"نہیں!\""],[158,"دکاندار"],[159,"نے"],[160,"کہا۔"],[161,"\"یہ"],[162,"کتاب"],[163,"لے"],[164,"لو۔\""]]},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/1052/size6/9d8f3ae2bd45bf4c24dce2fb69f81d4a.jpg","text":"\"مجھے\nوہ والا چاہئے! سموسے کی ڈھیر سے ایک سموسہ نکالتے ہوئے عامر زور سے بولا۔\n\"نہیں،\nنہیں! وہ نہیں!\" دکاندار نے تنبیہ کی۔ \"میرے سارے سموسے زمین پر گرجائيں\nگے۔\"","words":[[165,"\"مجھے"],[166,"وہ"],[167,"والا"],[168,"چاہئے!"],[169,"سموسے"],[170,"کی"],[171,"ڈھیر"],[172,"سے"],[173,"ایک"],[174,"سموسہ"],[175,"نکالتے"],[176,"ہوئے"],[177,"عامر"],[178,"زور"],[179,"سے"],[180,"بولا۔"],[181,"\"نہیں،"],[182,"نہیں!"],[183,"وہ"],[184,"نہیں!\""],[185,"دکاندار"],[186,"نے"],[187,"تنبیہ"],[188,"کی۔"],[189,"\"میرے"],[190,"سارے"],[191,"سموسے"],[192,"زمین"],[193,"پر"],[194,"گرجائيں"],[195,"گے۔\""]]},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/1053/size6/1968861f411759712280c86f39419302.jpg","text":"\"مجھے\nوہ چاہئے!\" عامر نے زور سے کہا۔ اب اس کا مزاج بگڑ چکا تھا۔\n\"نہیں،\nنہیں! وہ نہیں!\" پھول بیچنے والے نے کہا۔ \"انہیں مت چھوؤ! وہ سبھی\nمرجھاجائيں گے۔","words":[[196,"\"مجھے"],[197,"وہ"],[198,"چاہئے!\""],[199,"عامر"],[200,"نے"],[201,"زور"],[202,"سے"],[203,"کہا۔"],[204,"اب"],[205,"اس"],[206,"کا"],[207,"مزاج"],[208,"بگڑ"],[209,"چکا"],[210,"تھا۔"],[211,"\"نہیں،"],[212,"نہیں!"],[213,"وہ"],[214,"نہیں!\""],[215,"پھول"],[216,"بیچنے"],[217,"والے"],[218,"نے"],[219,"کہا۔"],[220,"\"انہیں"],[221,"مت"],[222,"چھوؤ!"],[223,"وہ"],[224,"سبھی"],[225,"مرجھاجائيں"],[226,"گے۔"]]},{"n":9,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/1054/size6/0b9741