/storage.googleapis.com/static.storyweaver.org.in/illustration_crops/34375/size6/664ee71a6b8a2e26bceef8986a5e2ed6.jpg","text":"નિશાળેથી છૂટવાનો ઘંટ વાગ્યો ત્યારે, બધા જ બાળકો હસતાં હતાં અને\nઆનંદથી બૂમો પાડી રહ્યા હતાં.\nબધા જ,\nસિવાય કે અક્કુ. અક્કુ ખૂબ જ ગુસ્સામાં હતી!","words":[[1,"નિશાળેથી"],[2,"છૂટવાનો"],[3,"ઘંટ"],[4,"વાગ્યો"],[5,"ત્યારે,"],[6,"બધા"],[7,"જ"],[8,"બાળકો"],[9,"હસતાં"],[10,"હતાં"],[11,"અને"],[12,"આનંદથી"],[13,"બૂમો"],[14,"પાડી"],[15,"રહ્યા"],[16,"હતાં."],[17,"બધા"],[18,"જ,"],[19,"સિવાય"],[20,"કે"],[21,"અક્કુ."],[22,"અક્કુ"],[23,"ખૂબ"],[24,"જ"],[25,"ગુસ્સામાં"],[26,"હતી!"]]},{"n":2,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/34377/size6/5413c850c235276c82d2c830fb4b085b.jpg","text":"અક્કુ! અક્કુ! “જો પેલા સૂરજમુખીના સુંદર\nફૂલ!” તેઓ ખેતરમાંથી પસાર થઈ રહ્યાં હતાં ત્યારે તેના અપ્પાએ કહ્યું.\n“ગરર... એ તો એકદમ પીળાં છે! એને જોઈને મારી આંખો દુખે છે.” અક્કુએ કહ્યું.","words":[[27,"અક્કુ!"],[28,"અક્કુ!"],[29,"“જો"],[30,"પેલા"],[31,"સૂરજમુખીના"],[32,"સુંદર"],[33,"ફૂલ!”"],[34,"તેઓ"],[35,"ખેતરમાંથી"],[36,"પસાર"],[37,"થઈ"],[38,"રહ્યાં"],[39,"હતાં"],[40,"ત્યારે"],[41,"તેના"],[42,"અપ્પાએ"],[43,"કહ્યું."],[44,"“ગરર..."],[45,"એ"],[46,"તો"],[47,"એકદમ"],[48,"પીળાં"],[49,"છે!"],[50,"એને"],[51,"જોઈને"],[52,"મારી"],[53,"આંખો"],[54,"દુખે"],[55,"છે.”"],[56,"અક્કુએ"],[57,"કહ્યું."]]},{"n":3,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/34475/size6/c68d43c476fb00e6a0edc6012d080b2a.jpg","text":"“અક્કુ! અક્કુ! પેલા વાંદરાઓને તો જો!” તેમના ઘરના છાપરે આંગળી ચીંધતા\nઅપ્પાએ કહ્યું.\n“છી...” અક્કુએ કહ્યું. “શશશ....! ભાગી જાવ અહીંથી! શશશશ......!”","words":[[58,"“અક્કુ!"],[59,"અક્કુ!"],[60,"પેલા"],[61,"વાંદરાઓને"],[62,"તો"],[63,"જો!”"],[64,"તેમના"],[65,"ઘરના"],[66,"છાપરે"],[67,"આંગળી"],[68,"ચીંધતા"],[69,"અપ્પાએ"],[70,"કહ્યું."],[71,"“છી...”"],[72,"અક્કુએ"],[73,"કહ્યું."],[74,"“શશશ....!"],[75,"ભાગી"],[76,"જાવ"],[77,"અહીંથી!"],[78,"શશશશ......!”"]]},{"n":4,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/34456/size6/c907e536c48e520b27062b47fadbb313.jpg","text":"5/17","words":null},{"n":5,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/34660/size6/a92710186d254ddcde273e60fcc6278c.jpg","text":"“આ લે, થોડી છાશ પી લે” અપ્પાએ કહ્યું. “એ તારા ગુસ્સાને ઠંડો પાડી દેશે.”\n“હં...!” અક્કુએ કહ્યું. “મારે નથી પીવી!”\n“એકાદ ઘૂંટ પણ નહીં?”\n“ભલે! લાવો!” અક્કુએ કહ્યું, અને એક ઘૂંટડો પીધો.\nછાશ એટલી પણ ખરાબ નહોતી.\nતેણે બીજો ઘૂંટ પીધો.\nથોડીવારમાં તો ગ્લાસ ખાલી કરી નાખ્યો.","words":[[79,"“આ"],[80,"લે,"],[81,"થોડી"],[82,"છાશ"],[83,"પી"],[84,"લે”"],[85,"અપ્પાએ"],[86,"કહ્યું."],[87,"“એ"],[88,"તારા"],[89,"ગુસ્સાને"],[90,"ઠંડો"],[91,"પાડી"],[92,"દેશે.”"],[93,"“હં...!”"],[94,"અક્કુએ"],[95,"કહ્યું."],[96,"“મારે"],[97,"નથી"],[98,"પીવી!”"],[99,"“એકાદ"],[100,"ઘૂંટ"],[101,"પણ"],[102,"નહીં?”"],[103,"“ભલે!"],[104,"લાવો!”"],[105,"અક્કુએ"],[106,"કહ્યું,"],[107,"અને"],[108,"એક"],[109,"ઘૂંટડો"],[110,"પીધો."],[111,"છાશ"],[112,"એટલી"],[113,"પણ"],[114,"ખરાબ"],[115,"નહોતી."],[116,"તેણે"],[117,"બીજો"],[118,"ઘૂંટ"],[119,"પીધો."],[120,"થોડીવારમાં"],[121,"તો"],[122,"ગ્લાસ"],[123,"ખાલી"],[124,"કરી"],[125,"નાખ્યો."]]},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/34470/size6/1d54337ff32ae26d8575b97661065215.jpg","text":"“શું તું વડા ખાવાનું પસંદ કરીશ?” અપ્પાએ કહ્યું.\n“હુહ...”\nઅક્કુએ નિસાસો નાખ્યો.\n“એક\nટુકડો\nપણ નહીં ખાય?\n“ભલે, લાવો!” અક્કુએ કહ્યું , અને એક ટુકડો\nખાધો.\nતે એકદમ સ્વાદિષ્ટ હતો.\nતેણે બીજો ટુકડો\nખાધો.\nપછી ત્રીજો...\nથોડીવારમાં તો આખી થાળી સફાચટ કરી નાખી.","words":[[126,"“શું"],[127,"તું"],[128,"વડા"],[129,"ખાવાનું"],[130,"પસંદ"],[131,"કરીશ?”"],[132,"અપ્પાએ"],[133,"કહ્યું."],[134,"“હુહ...”"],[135,"અક્કુએ"],[136,"નિસાસો"],[137,"નાખ્યો."],[138,"“એક"],[139,"ટુકડો"],[140,"પણ"],[141,"નહીં"],[142,"ખાય?"],[143,"“ભલે,"],[144,"લાવો!”"],[145,"અક્કુએ"],[146,"કહ્યું"],[147,","],[148,"અને"],[149,"એક"],[150,"ટુકડો"],[151,"ખાધો."],[152,"તે"],[153,"એકદમ"],[154,"સ્વાદિષ્ટ"],[155,"હતો."],[156,"તેણે"],[157,"બીજો"],[158,"ટુકડો"],[159,"ખાધો."],[160,"પછી"],[161,"ત્રીજો..."],[162,"થોડીવારમાં"],[163,"તો"],[164,"આખી"],[165,"થાળી"],[166,"સફાચટ"],[167,"કરી"],[168,"નાખી."]]},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/34382/size6/cde7c1b8e6c779d029a871dbcbb7c42a.jpg","text":"“વાહ, ડાહી દિકરી” અપ્પાએ કહ્યું. “શું હવે તું મને કહીશ કે તું આટલા બધા ગુસ્સામાં કેમ છે?”\n“ના!” અક્કુએ કહ્યું.\n“મેં\nકઈ કર્યું?”\n“ના!”\n“તારી અમ્માએ કઈ\nકર્યું?”\n“ના!”\n“શું આજે શાળામાં કંઈ\nખરાબ બન્યું?”\n“કદાચ!”\n“ઓહ એમ!”","words":[[169,"“વાહ,"],[170,"ડાહી"],[171,"દિકરી”"],[172,"અપ્પાએ"],[173,"કહ્યું."],[174,"“શું"],[175,"હવે"],[176,"તું"],[177,"મને"],[178,"કહીશ"],[179,"કે"],[180,"તું"],[181,"આટલા"],[182,"બધા"],[183,"ગુસ્સામાં"],[184,"કેમ"],[185,"છે?”"],[186,"“ના!”"],[187,"અક્કુએ"],[188,"કહ્યું."],[189,"“મેં"],[190,"કઈ"],[191,"કર્યું?”"],[192,"“ના!”"],[193,"“તારી"],[194,"અમ્માએ"],[195,"કઈ"],[196,"કર્યું?”"],[197,"“ના!”"],[198,"“શું"],[199,"આજે"],[200,"શાળામાં"],[201,"કંઈ"],[202,"ખરાબ"],[203,"બન્યું?”"],[204,"“કદાચ!”"],[205,"“ઓહ"],[206,"એમ!”"]]},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/34383/size6/6861a9516d4d805174f67acf1d084337.jpg","text":"“તેનું ચિત્ર દોરીશ?” અપ્પાએ કહ્યું. “આ લે આ\nસરસ કાગળ અને મિણીયા રંગ.”\n“ભલે, સારું!” અક્કુએ કહ્યું.","words":[[207,"“તેનું"],[208,"ચિત્ર"],[209,"દોરીશ?”"],[210,"અપ્પાએ"],[211,"કહ્યું."],[212,"“આ"],[213,"લે"],[214,"આ"],[215,"સરસ"],[216,"કાગળ"],[217,"અને"],[218,"મિણીયા"],[219,"રંગ.”"],[220,"“ભલે,"],[221,"સારું!”"],[222,"અક્કુએ"],[223,"કહ્યું."]]},{"n":9,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/34471/size6/9982fb3fe8ba013417c023f2e5348995.jpg","text":"અક્કુએ એ એક ઈંટ દોરી...\n“આ એ જ નકામી ઈંટ છે જેના કારણે હું આજ સવારે ઠેસ ખાઈને પડી ગઈ હતી.” અક્કુએ કહ્યું.\n“તારી વાત સાચી છે. તે એકદમ નકામી ઈંટ છે!” અક્કુના અપ્પાએ કહ્યું.","words":[[224,"અક્કુએ"],[225,"એ"],[226,"એક"],[227,"ઈંટ"],[228,"દોરી..."],[229,"“આ"],[230,"એ"],[231,"જ"],[