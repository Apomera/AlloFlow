</line>
<text x="40" y="76.5" text-anchor="end" style="font-size:9px" fill="#64748b">61.2</text>
<line x1="44" y1="16" x2="464" y2="16" stroke="#eef2f7" stroke-width="1">
</line>
<text x="40" y="19" text-anchor="end" style="font-size:9px" fill="#64748b">68.4</text>
