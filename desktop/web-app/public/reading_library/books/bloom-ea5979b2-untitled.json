    {
      "n": 1,
      "img": "https://s3.amazonaws.com/BloomLibraryBooks/luja01552%40gmail.com%2fea5979b2-e37f-4849-ae9c-1e14df1d4752%2f%e1%80%85%e1%80%af%e1%80%99%e1%80%ba%e1%80%b8%e1%80%95%e1%80%b0%e1%80%b8%e1%80%80%e1%80%b2%e1%80%a1%e1%80%ae%e1%80%b8%e1%80%80%e1%80%9b%e1%80%b1%e1%80%ac%e1%80%ba%e1%80%99%e1%80%ba%e1%80%b8%e1%80%94%e1%80%b1%e1%80%ac%e1%82%88%2f1.jpg",
      "text": "ခည်အာည်ႇနီး မေဲႈလာ်စုမ်းပူးကဲကဲဒီးအူစုမ်း။ ဂေါႇမိုႈ အရာပ်ဒီဂေါ်ည်းကဲဒီး ပံင်ဟိုမ်းမှေဲမ်းချှီႇ၊ ဘတ်ညိူဝ်းချှီႇ ကဲစီမအေဲႈက္လဲန့်ချှီႇတော်န်းတို မှေဲမ်တိူဝ်ႈတော်န်းတို ဟာ့်။"
    },
    {
      "n": 2,
      "img": "https://s3.amazonaws.com/BloomLibraryBooks/luja01552%40gmail.com%2fea5979b2-e37f-4849-ae9c-1e14df1d4752%2f%e1%80%85%e1%80%af%e1%80%99%e1%80%ba%e1%80%b8%e1%80%95%e1%80%b0%e1%80%b8%e1%80%80%e1%80%b2%e1%80%a1%e1%80%ae%e1%80%b8%e1%80%80%e1%80%9b%e1%80%b1%e1%80%ac%e1%80%ba%e1%80%99%e1%80%ba%e1%80%b8%e1%80%94%e1%80%b1%e1%80%ac%e1%82%88%2f2.jpg",
      "text": "ကညျားပူးဒီး စီချှိုင်းလာ်မေဲႈဆံဝ်းအယ်တို စာနံင်တိူဝ်ႈ မေန်းကဲဟာ့်။ ဘည်ဘာည်းမာ် ဆံမ်ကာည်းဒီး အာဝ် တိူဝ်ႈမေန်းမ အီးမိုႈပူးကဲကဲဒီးကရီးကတီး၊ ကာည်းဂီ နာ်ႇလိူည် လည်ကနိုက်ခနားကာည်းဘာည်းဇေဲန်း။"
    },
    {
      "n": 3,
      "img": "https://s3.amazonaws.com/BloomLibraryBooks/luja01552%40gmail.com%2fea5979b2-e37f-4849-ae9c-1e14df1d4752%2f%e1%80%85%e1%80%af%e1%80%99%e1%80%ba%e1%80%b8%e1%80%95%e1%80%b0%e1%80%b8%e1%80%80%e1%80%b2%e1%80%a1%e1%80%ae%e1%80%b8%e1%80%80%e1%80%9b%e1%80%b1%e1%80%ac%e1%80%ba%e1%80%99%e1%80%ba%e1%80%b8%e1%80%94%e1%80%b1%e1%80%ac%e1%82%88%2f3.jpg",
      "text": "အီးမိုႈပါ့်တကျာက်ဒီကည်ဟိုမ်းကဲတာ် ဘဲတ်ဒီး၊ စီမေဲႈ လာ် ဆံဝ်းကတာည်း အီးဂေါ်ည်းပည်နှံက်အူန်း စာနံင် ယဲမ်တာ့်လာ်ဟိုမ်းပူး တံင်စုမ်းပူးက္လဲန့်ချှီႇကဲကဲဒီး။ ဆံဝ်း ကတာည်းကဲမာ် ဂီနာ်ႇလိူည်ယဲမ်ပူး ယာမ်းဘူဂေါ်ည်း ကညားပူး ကာည်း ယာမ်းဘူပည်တိူဝ်ႈ ဆံဝ်းကာည်းဒီး ကရီးကတီးဟာ့်။"
    },
    {
      "n": 4,
      "img": "https://s3.amazonaws.com/BloomLibraryBooks/luja01552%40gmail.com%2fea5979b2-e37f-4849-ae9c-1e14df1d4752%2f%e1%80%85%e1%80%af%e1%80%99%e1%80%ba%e1%80%b8%e1%80%95%e1%80%b0%e1%80%b8%e1%80%80%e1%80%b2%e1%80%a1%e1%80%ae%e1%80%b8%e1%80%80%e1%80%9b%e1%80%b1%e1%80%ac%e1%80%ba%e1%80%99%e1%80%ba%e1%80%b8%e1%80%94%e1%80%b1%e1%80%ac%e1%82%88%2f4.jpg",
      "text": "ဘိူဝ်လှာ်န်းဒေဲႈ အီးမိုႈစုမ်းပူးကဲကဲဒီးမာ် ဟည်ကတူႈ ကညားလာ်ဆံဝ်းကတာည်း တီုတ်ႏလာက်ႏဟာဝ်းကဲ အူတိုဟော်ည်ႇအူတိုဟာ့်။ ဘိူန်ဇေဲန်း အီးမိုႈပူးဒါင်းကဲ စီဒါ်ႈလာ် တာ့်ပူးဒဲ့ကဲ “အဲဟည်လိုကရော်မ်းနောႈအဲ နာ်ႏ။ ဂေါႇမိုႈဆံဝ်းအီးပည်တိူဝ်ႈမေန်းအဲဒီး အာဝ်တိူဝ်ႈ အဲကရီးကတီး၊ အဲအူပီအူႎါးကဲကဲနီး ဟည်ပေန်လာ် ပေါႇ ပံင်တီုတ်ႏဟာဝ်းဆံဝ်းကတာည်းကဲဟာ့်။”"
    },
    {
      "n": 5,
      "img": "https://s3.amazonaws.com/BloomLibraryBooks/luja01552%40gmail.com%2fea5979b2-e37f-4849-ae9c-1e14df1d4752%2f%e1%80%85%e1%80%af%e1%80%99%e1%80%ba%e1%80%b8%e1%80%95%e1%80%b0%e1%80%b8%e1%80%80%e1%80%b2%e1%80%a1%e1%80%ae%e1%80%b8%e1%80%80%e1%80%9b%e1%80%b1%e1%80%ac%e1%80%ba%e1%80%99%e1%80%ba%e1%80%b8%e1%80%94%e1%80%b1%e1%80%ac%e1%82%88%2f5.jpg",
      "text": "ဘည်ဘာည်းမာ် အီးမိုႈခေဲင်းနောႈပူးဒဲ့ကဲကဲဒီးအခည်း၊ ကဲစီဂီအူန်းမေဲႈလိူည် စာကဲနံင်ဘိူန်းဟိုမ်း ကာည်း စာ ကဲနံင်ဘိူန်းလည်ကနိုက် ခနားကဲဟာ့်။ ကဲအာဝ်တေဲႈ လေဲပ်မခေဲင်းနောႈကဲ ပံင်ဒါ်ႈပူးဒါင်း တာ့်ကဲဒီး၊ ကဲဂီ ဒါ်ႈလိူည် “အဲအာဝ်လိုမ အူန်းပေန်နောႈညျှာပ်မျိုးမှေဲ့။ ဆံဝ်းကဲအီးပည်တိူဝ်ႈအဲ၊ ကဲနံင်ရေဲန်းအူန်းပေါႇ အီးမိုႈ ဇီုင်းပံင်လိုကဲတာ့်လာ်ရေဲန်းဟာ့်။” ကဲဒါ်ႈဖာ်ႈဘာည်း ဇေဲန်း ကဲစီဆီုပ်ဂေါ်ည်းလူလီလူလာ် ဟာဝ်းဘိုးဟာ့်။"
    },
    {
      "n": 6,
      "img": "https://s3.amazonaws.com/BloomLibraryBooks/luja01552%40gmail.com%2fea5979b2-e37f-4849-ae9c-1e14df1d4752%2f%e1%80%85%e1%80%af%e1%80%99%e1%80%ba%e1%80%b8%e1%80%95%e1%80%b0%e1%80%b8%e1%80%80%e1%80%b2%e1%80%a1%e1%80%ae%e1%80%b8%e1%80%80%e1%80%9b%e1%80%b1%e1%80%ac%e1%80%ba%e1%80%99%e1%80%ba%e1%80%b8%e1%80%94%e1%80%b1%e1%80%ac%e1%82%88%2f6.jpg",
      "text": "စာအူဆငည်း ဇိုဂီဟိုမ်းပူးကဲတာ် ပံင်ဟိုမ်းကဲဘာည်း ဇေဲန်း၊ ဆံဝ်းအီးပည်တိူဝ်ႈမေန်းပူးကာည်းဒီးမာ် ဟည် ဂီနာ်ႇလိူည် လည်ကနိုက်ခနားကာည်း စီဘူတိူဝ်ႈမေန်းမ ပူးကဲကဲဒီးကရီးကတီး။ အီးမိုႈပူးဒါင်းကဲအခည်း၊ ကဲ ဘည်ဂေါ်ည်းချဲတ်စံမ့်မာ် ပူးဒဲ့ကဲဆံမ်ဂီနာ်ႇလိူည် ဂေါ်ည်းဘူဆော်န်မိုႈဆိဟာ့်။"
    },
    {
      "n": 7,
      "img": "https://s3.amazonaws.com/BloomLibraryBooks/luja01552%40gmail.com%2fea5979b2-e37f-4849-ae9c-1e14df1d4752%2f%e1%80%85%e1%80%af%e1%80%99%e1%80%ba%e1%80%b8%e1%80%95%e1%80%b0%e1%80%b8%e1%80%80%e1%80%b2%e1%80%a1%e1%80%ae%e1%80%b8%e1%80%80%e1%80%9b%e1%80%b1%e1%80%ac%e1%80%ba%e1%80%99%e1%80%ba%e1%80%b8%e1%80%94%e1%80%b1%e1%80%ac%e1%82%88%2f7.jpg",
      "text": "အီးမိုႈဆံဝ်းကတာည်းမာ် ဟည်ဂေါ်ည်းလာ်ဒါး ပါ့်ခနား ယုမ်ဘျည်း စီပည်ယဲမ်တိူဝ်ႈပေါႇ ဘည်ဘာည်းပူးကဲ ကဲဒီး၊ စာနံင်စင်ချင်တီုတ်ႏလာည်းဟာဝ်း ယာမ်းဘူ ထာင်ကဲဟာ့်။"
    },
    {
      "n": 8,
      "img": "https://s3.amazonaws.com/BloomLibraryBooks/luja01552%40gmail.com%2fea5979b2-e37f-4849-ae9c-1e14df1d4752%2f%e1%80%85%e1%80%af%e1%80%99%e1%80%ba%e1%80%b8%e1%80%95%e1%80%b0%e1%80%b8%e1%80%80%e1%80%b2%e1%80%a1%e1%80%ae%e1%80%b8%e1%80%80%e1%80%9b%e1%80%b1%e1%80%ac%e1%80%ba%e1%80%99%e1%80%ba%e1%80%b8%e1%80%94%e1%80%b1%e1%80%ac%e1%82%88%2f8.jpg",
      "text": "ဘိူဝ်ယေဲဝ်းဆံဝ်းကတာည်းကဲတာ် ဆံဝ်းအီးပည်ပူး အာဝ်ဂေါ်ည်းရီမ်းပူး၊ အီးမိုႈပူးကဲကဲဒီးမာ် ဂီနာ်ႇလိူည် ဟိုမ်း ပံင်ဟိုမ်းကဲဘာည်းဇေဲန်းဒီး၊ ကဲစီလည်လေႈဒေဲႈ ပေါႇ ဒခေဲင်းယုမ်ဘျည်း စီရီန်းဒါ်ႈလာ် နံင်တီုတ်ႏ လာက်ႏပူးကဲကဲဒီးဟာ့်။ ခည်ယာမ်းဇေဲန်း အီးမိုႈစုမ်းပူး ကဲကဲဒီးမာ် ဟည်ဂေါ်ည်းဘူနှီမ်းမဟာ့်။"
    },
    {
      "n": 9,
      "img": "https://s3.amazonaws.com/BloomLibraryBooks/luja01552%40gmail.com%2fea5979b2-e37f-4849-ae9c-1e14df1d4752%2f%e1%80%85%e1%80%af%e1%80%99%e1%80%ba%e1%80%b8%e1%80%95%e1%80%b0%e1%80%b8%e1%80%80%e1%80%b2%e1%80%a1%e1%80%ae%e1%80%b8%e1%80%80%e1%80%9b%e1%80%b1%e1%80%ac%e1%80%ba%e1%80%99%e1%80%ba%e1%80%b8%e1%80%94%e1%80%b1%e1%80%ac%e1%82%88%2f9.jpg",
      "text": "ဘိူဝ်ဂေါ်ည်းဘူနှီမ်းစုမ်းပူးကဲတာ် ဘာည်းဇေဲန်းဒီး၊ အီး မိုႈပူးဒါင်းကဲ စီဒဲႈကျောႈချဲတ် တာ့်ကဲ ဒါ်ႈ “ခူယံဝ်းနာ်ႏ။ ဂေါ်ည်းလည်ကရော်မ်းဒို့အူဒီ၊ ဂေါ်ည်းလည်ကစုဒို့အူ ဒီနာ်ႏ။”"
    },
    {
      "n": 10,
      "img": "https://s3.amazonaws.com/BloomLibraryBooks/luja01552%40gmail.com%2fea5979b2-e37f-4849-ae9c-1e14df1d4752%2f%e1%80%85%e1%80%af%e1%80%99%e1%80%ba%e1%80%b8%e1%80%95%e1%80%b0%e1%80%b8%e1%80%80%e1%80%b2%e1%80%a1%e1%80%ae%e1%80%b8%e1%80%80%e1%80%9b%e1%80%b1%e1%80%ac%e1%80%ba%e1%80%99%e1%80%ba%e1%80%b8%e1%80%94%e1%80%b1%e1%80%ac%e1%82%88%2f10.jpg",
      "text": "ဘိူဝ်ဘာည်းတာ့်ဇေဲန်း အီးမိုႈပူးဒဲ့ကဲကဲဒီး စီဂေါ်ည်း ပည်နှံက်ဆံဝ်း အန်းအီးပည်တိူဝ်ႈကဲဒိူဝ်း စာနံင်ဒေဲႈ ဂျဲတ်ကာင်းဒဲႈကဲ တာ့်ဒဖေးဆံဝ်းကတာည်းကဲကဲဒီး။ ဘည်ဘာည်းမာ် ဆံဝ်းကာည်းဒီးဆံမ်အာဝ်ဒေဲႈမ။"
    },
    {
      "n": 11,
      "img": "https://s3.amazonaws.com/BloomLibraryBooks/luja01552%40gmail.com%2fea5979b2-e37f-4849-ae9c-1e14df1d4752%2f%e1%80%85%e1%80%af%e1%80%99%e1%80%ba%e1%80%b8%e1%80%95%e1%80%b0%e1%80%b8%e1%80%80%e1%80%b2%e1%80%a1%e1%80%ae%e1%80%b8%e1%80%80%e1%80%9b%e1%80%b1%e1%80%ac%e1%80%ba%e1%80%99%e1%80%ba%e1%80%b8%e1%80%94%e1%80%b1%e1%80%ac%e1%82%88%2f11.jpg",
      "text": "ဇိုဂီရီန်းတီုတ်ႏလာည်းကဲတာ် ပူးဒဲ့ဒီးအူတို၊ ပူးဒါင်းကဲ စီဒါ်ႈလာ် “အဲဂေါ်ည်းလည်ကစုလာ်ဒါးအူဒီ စီႎီးက\nချဲင်ဒို့ တာ့်ဆံဝ်းကတာည်းကဲကဲနီး၊ နှာင်းကဲကံပ်ဘူ ဘိူန်း လာ်တီုတ်ႏဟာဝ်းအဲနာ်ႏ။”"
    },
