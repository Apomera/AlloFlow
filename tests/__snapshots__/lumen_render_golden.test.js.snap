<span class="text-[11px] text-slate-500 italic">honest data, made to share</span>
<span class="text-[11px] font-semibold text-amber-800 rounded-full px-2 py-0.5 ml-auto" style="background:#fffbeb;border:1px solid #fde68a">Measure · units</span>
</div>
<div class="mt-2 flex items-center gap-1 flex-wrap" role="group" aria-label="AI involvement ceiling">
<span class="text-xs text-slate-500 mr-1">AI ceiling:</span>
<button aria-pressed="true" class="bg-amber-600 text-white border-amber-600 px-2 py-1 text-xs rounded border">L1 · Data only</button>
<button aria-pressed="false" class="bg-white text-slate-700 border-slate-300 px-2 py-1 text-xs rounded border">L2 · Assisted</button>
<button aria-pressed="false" class="bg-white text-slate-700 border-slate-300 px-2 py-1 text-xs rounded border">L3 · Interpretive</button>
</div>
<button aria-expanded="true" aria-controls="lumen-view-options" class="mt-1.5 text-xs underline text-slate-600">▾ View options — Working · Box</button>
<div id="lumen-view-options">
<div class="mt-1 flex items-center gap-1 flex-wrap" role="group" aria-label="Audience">
<span class="text-xs text-slate-500 mr-1">Audience:</span>
<button aria-pressed="true" title="For your own analysis — the full technical wording." class="bg-slate-700 text-white border-slate-700 px-2 py-1 text-xs rounded border">Working</button>
<button aria-pressed="false" title="A defensible artifact for a formal decision — an IEP team, a review board, a grant reviewer. Sign-off + FERPA gates apply here." class="bg-white text-slate-700 border-slate-300 px-2 py-1 text-xs rounded border">Formal</button>
<button aria-pressed="false" title="For a lay audience — a parent, a student, the public. Keeps the uncertainty; never overstates." class="bg-white text-slate-700 border-slate-300 px-2 py-1 text-xs rounded border">Plain language</button>
</div>
<div class="mt-1 flex items-center gap-1 flex-wrap" role="group" aria-label="Chart type">
<span class="text-xs text-slate-500 mr-1">Chart:</span>
<button aria-pressed="false" class="bg-white text-slate-700 border-slate-300 px-2 py-1 text-xs rounded border">Trend</button>
<button aria-pressed="false" class="bg-white text-slate-700 border-slate-300 px-2 py-1 text-xs rounded border">Bar</button>
<button aria-pressed="false" class="bg-white text-slate-700 border-slate-300 px-2 py-1 text-xs rounded border">Dot</button>
<button aria-pressed="true" class="bg-slate-700 text-white border-slate-700 px-2 py-1 text-xs rounded border">Box</button>
<button aria-pressed="false" class="bg-white text-slate-700 border-slate-300 px-2 py-1 text-xs rounded border">Histogram</button>
<button aria-pressed="false" class="bg-white text-slate-700 border-slate-300 px-2 py-1 text-xs rounded border">Scatter</button>
<button aria-pressed="false" class="bg-white text-slate-700 border-slate-300 px-2 py-1 text-xs rounded border">Slope</button>
<button aria-pressed="false" class="bg-white text-slate-700 border-slate-300 px-2 py-1 text-xs rounded border">Multi-line</button>
<button aria-pressed="false" class="bg-white text-slate-700 border-slate-300 px-2 py-1 text-xs rounded border">Grouped bar</button>
</div>
</div>
<div class="mt-3 flex items-end gap-2 flex-wrap" role="group" aria-label="Measure setup">
<span class="text-xs text-slate-500 mr-1 self-center">Setup:</span>
<label class="text-xs text-slate-600 flex flex-col">Measure name<input type="text" placeholder="e.g. Plant height" aria-label="Measure name (y variable)" class="w-32 px-2 py-1 border rounded" value=""/>
</label>
<label class="text-xs text-slate-600 flex flex-col">Unit<input type="text" placeholder="e.g. cm" aria-label="Unit" class="w-28 px-2 py-1 border rounded" value=""/>
</label>
<label class="text-xs text-slate-600 flex flex-col">X-axis label<input type="text" placeholder="Week" aria-label="X-axis label (x variable)" class="w-24 px-2 py-1 border rounded" value=""/>
</label>
</div>
<div class="mt-3 flex items-end gap-2 flex-wrap">
<label class="text-xs text-slate-600 flex flex-col">Week (x)<input type="number" class="w-20 px-2 py-1 border rounded" value=""/>
</label>
<label class="text-xs text-slate-600 flex flex-col">Measure (y)<input type="number" class="w-24 px-2 py-1 border rounded" value=""/>
</label>
<label class="text-xs text-slate-600 flex flex-col" title="Optional condition tag (e.g. before / after). When the tag changes between points, a phase line is drawn there. Sticks until you change it.">Phase (optional)<input type="text" placeholder="e.g. before" class="w-24 px-2 py-1 border rounded" value=""/>
</label>
<button class="px-3 py-1 text-sm font-semibold rounded bg-amber-600 text-white hover:bg-amber-500">+ Add</button>
<button class="px-3 py-1 text-sm rounded border border-slate-300 hover:bg-slate-50" title="Remove the most recently added data point.">↩ Undo last</button>
<button class="px-3 py-1 text-sm rounded border border-slate-300 hover:bg-slate-50" title="Remove every data point and start fresh.">🗑 Clear all</button>
<button aria-expanded="false" aria-controls="lumen-practice-box" class="px-3 py-1 text-sm rounded border border-violet-400 text-violet-800 hover:bg-violet-50" title="Generate synthetic PRACTICE data to explore Lumen. Clearly marked — not real; cannot be exported as a defensible formal document.">⚗ Practice data…</button>
<button aria-expanded="false" aria-controls="lumen-paste-box" class="px-3 py-1 text-sm rounded border border-slate-300 hover:bg-slate-50" title="Paste a block of CSV / TSV / JSON text directly — no file needed.">⎘ Paste data…</button>
<label for="lumen-file-input" class="px-3 py-1 text-sm rounded border border-slate-300 hover:bg-slate-50 cursor-pointer" title="Import a CSV, TSV, JSON, or single-sheet spreadsheet (Excel/ODS) file. Headers are previewed; you map x/y/phase before binding.">⇪ Import file…</label>
<input id="lumen-file-input" type="file" accept=".csv,.tsv,.txt,.json,.xlsx,.ods,.xls,.xlsb,text/csv,text/tab-separated-values,text/plain,application/json,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.oasis.opendocument.spreadsheet,application/vnd.ms-excel" style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);border:0"/>
</div>
<div class="mt-2">
<button aria-expanded="false" aria-controls="lumen-bench-workspace" class="px-3 py-1 text-xs rounded border border-slate-300 hover:bg-slate-50">▣ Benchmark workspace (verify external norms)…</button>
