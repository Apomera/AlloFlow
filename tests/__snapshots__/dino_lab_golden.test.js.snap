<button aria-label="Open Brachiosaurus" style="font-size:11.5px;padding:4px 10px;border-radius:999px;cursor:pointer;border:1px solid #22c55e66;background:#22c55e18;color:var(--allo-stem-text, #f1f5f9);margin-right:5px;margin-bottom:5px">🌿 Brachiosaurus</button>
<button aria-label="Open Brontosaurus" style="font-size:11.5px;padding:4px 10px;border-radius:999px;cursor:pointer;border:1px solid #22c55e66;background:#22c55e18;color:var(--allo-stem-text, #f1f5f9);margin-right:5px;margin-bottom:5px">🌿 Brontosaurus</button>
<button aria-label="Open Camarasaurus" style="font-size:11.5px;padding:4px 10px;border-radius:999px;cursor:pointer;border:1px solid #22c55e66;background:#22c55e18;color:var(--allo-stem-text, #f1f5f9);margin-right:5px;margin-bottom:5px">🌿 Camarasaurus</button>
<button aria-label="Open Haplocanthosaurus" style="font-size:11.5px;padding:4px 10px;border-radius:999px;cursor:pointer;border:1px solid #22c55e66;background:#22c55e18;color:var(--allo-stem-text, #f1f5f9);margin-right:5px;margin-bottom:5px">🌿 Haplocanthosaurus</button>
<button aria-label="Open Stegosaurus" style="font-size:11.5px;padding:4px 10px;border-radius:999px;cursor:pointer;border:1px solid #22c55e66;background:#22c55e18;color:var(--allo-stem-text, #f1f5f9);margin-right:5px;margin-bottom:5px">🌿 Stegosaurus</button>
<button aria-label="Open Hesperosaurus" style="font-size:11.5px;padding:4px 10px;border-radius:999px;cursor:pointer;border:1px solid #22c55e66;background:#22c55e18;color:var(--allo-stem-text, #f1f5f9);margin-right:5px;margin-bottom:5px">🌿 Hesperosaurus</button>
<button aria-label="Open Camptosaurus" style="font-size:11.5px;padding:4px 10px;border-radius:999px;cursor:pointer;border:1px solid #22c55e66;background:#22c55e18;color:var(--allo-stem-text, #f1f5f9);margin-right:5px;margin-bottom:5px">🌿 Camptosaurus</button>
<button aria-label="Open Dryosaurus" style="font-size:11.5px;padding:4px 10px;border-radius:999px;cursor:pointer;border:1px solid #22c55e66;background:#22c55e18;color:var(--allo-stem-text, #f1f5f9);margin-right:5px;margin-bottom:5px">🌿 Dryosaurus</button>
<button aria-label="Open Gargoyleosaurus" style="font-size:11.5px;padding:4px 10px;border-radius:999px;cursor:pointer;border:1px solid #22c55e66;background:#22c55e18;color:var(--allo-stem-text, #f1f5f9);margin-right:5px;margin-bottom:5px">🌿 Gargoyleosaurus</button>
<button aria-label="Open Mymoorapelta" style="font-size:11.5px;padding:4px 10px;border-radius:999px;cursor:pointer;border:1px solid #22c55e66;background:#22c55e18;color:var(--allo-stem-text, #f1f5f9);margin-right:5px;margin-bottom:5px">🌿 Mymoorapelta</button>
<button aria-label="Open Nanosaurus" style="font-size:11.5px;padding:4px 10px;border-radius:999px;cursor:pointer;border:1px solid #22c55e66;background:#22c55e18;color:var(--allo-stem-text, #f1f5f9);margin-right:5px;margin-bottom:5px">🌿 Nanosaurus</button>
</div>
</div>
</div>
<div style="background:rgba(34,197,94,0.06);border:1px solid rgba(34,197,94,0.28);border-radius:14px;padding:14px;color:var(--allo-stem-text, #f1f5f9);margin-top:14px">
<div style="font-weight:800;font-size:14px;margin-bottom:2px">🔺 Energy pyramid</div>
<div style="font-size:12px;color:var(--allo-stem-text-soft, #94a3b8);margin-bottom:10px;line-height:1.5">Energy flows up from the sun. Some is lost at every step, so each level can feed fewer animals than the one below it. Bar width shows energy, not exact numbers.</div>
<div>
<div style="display:flex;flex-direction:column;align-items:center;margin-bottom:6px">
<div style="width:34%;min-width:140px;max-width:100%;box-sizing:border-box;background:#b91c1c;border-radius:8px;padding:8px 12px;text-align:center;color:#fff;font-weight:700;font-size:12.5px">🥩 Hunters · 7</div>
<div style="font-size:11px;color:var(--allo-stem-text-soft, #94a3b8);margin:1px 0">apex predator here: Saurophaganax</div>
</div>
<div style="display:flex;flex-direction:column;align-items:center;margin-bottom:6px">
<div style="width:64%;min-width:140px;max-width:100%;box-sizing:border-box;background:#b45309;border-radius:8px;padding:8px 12px;text-align:center;color:#fff;font-weight:700;font-size:12.5px">🦕 Plant-eaters + omnivores · 16</div>
<div style="font-size:11px;color:var(--allo-stem-text-soft, #94a3b8);margin:1px 0">the primary consumers</div>
</div>
<div style="display:flex;flex-direction:column;align-items:center;margin-bottom:6px">
<div style="width:100%;min-width:140px;max-width:100%;box-sizing:border-box;background:#15803d;border-radius:8px;padding:8px 12px;text-align:center;color:#fff;font-weight:700;font-size:12.5px">🌿 Plants (producers)</div>
<div style="font-size:11px;color:var(--allo-stem-text-soft, #94a3b8);margin:1px 0">ferns, cycads, and conifers — the green base that fed it all</div>
</div>
</div>
<div style="font-size:11.5px;color:var(--allo-stem-text-soft, #94a3b8);margin-top:8px;font-style:italic">16 kinds of plant-eater and omnivore shared this rock unit with 7 kinds of hunter. That few-predators-on-top shape is what an energy pyramid predicts.</div>
</div>
</div>
</div>
</div>"
`;

exports[`Dino Lab — render per tab (golden master) > renders the explore tab (snapshot) 1`] = `
"<div style="min-height:100%;background:var(--allo-stem-canvas, #0f172a);color:var(--allo-stem-text, #f1f5f9)">
<div role="tablist" aria-label="Dino Lab sections" style="display:flex;flex-wrap:wrap;gap:4px;padding:10px 12px;border-bottom:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220)">
<button id="dinotab-explore" role="tab" aria-selected="true" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:700;background:#15803d;color:#fff;white-space:nowrap">🔍 Explore</button>
<button id="dinotab-timeline" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">⏳ Timeline</button>
<button id="dinotab-deeptime" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🕰️ Deep Time</button>
<button id="dinotab-sites" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🗺️ Sites</button>
<button id="dinotab-ecosystem" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🌍 Ecosystems</button>
<button id="dinotab-compare" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">⚖️ Compare</button>
<button id="dinotab-dig" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">⛏️ Dig Site</button>
<button id="dinotab-classify" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🌳 Classify</button>
<button id="dinotab-birds" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🐦 Bird Link</button>
<button id="dinotab-extinction" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">☄️ Extinction</button>
<button id="dinotab-anatomy" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🦴 Anatomy</button>
<button id="dinotab-records" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🏆 Records</button>
<button id="dinotab-quiz" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🧠 Quiz</button>
<button id="dinotab-notes" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">📓 Field Notes</button>
<button id="dinotab-glossary" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">📖 Glossary</button>
</div>
<div id="dinopanel" role="tabpanel" aria-labelledby="dinotab-explore" style="padding:16px">
<div style="display:grid;grid-template-columns:minmax(0, 1.4fr) minmax(0, 1fr);gap:16px">
<div>
<div style="margin-bottom:12px">
<input type="text" placeholder="Search by name, meaning, clade, or place..." aria-label="Search dinosaurs" style="width:100%;box-sizing:border-box;padding:10px 12px;border-radius:10px;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9);font-size:14px;margin-bottom:10px" value="tyrannosaurus"/>
<div style="margin-bottom:6px">
<button aria-pressed="true" aria-label="All periods" style="padding:6px 12px;border-radius:999px;cursor:pointer;font-size:12px;font-weight:600;border:1px solid #15803d;background:#15803d;color:#fff;white-space:nowrap;margin-right:6px;margin-bottom:6px">All periods</button>
<button aria-pressed="false" aria-label="Triassic" style="padding:6px 12px;border-radius:999px;cursor:pointer;font-size:12px;font-weight:600;border:1px solid var(--allo-stem-border, #334155);background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap;margin-right:6px;margin-bottom:6px">Triassic</button>
<button aria-pressed="false" aria-label="Jurassic" style="padding:6px 12px;border-radius:999px;cursor:pointer;font-size:12px;font-weight:600;border:1px solid var(--allo-stem-border, #334155);background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap;margin-right:6px;margin-bottom:6px">Jurassic</button>
<button aria-pressed="false" aria-label="Cretaceous" style="padding:6px 12px;border-radius:999px;cursor:pointer;font-size:12px;font-weight:600;border:1px solid var(--allo-stem-border, #334155);background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap;margin-right:6px;margin-bottom:6px">Cretaceous</button>
</div>
<div style="margin-bottom:6px">
<button aria-pressed="true" aria-label="All diets" style="padding:6px 12px;border-radius:999px;cursor:pointer;font-size:12px;font-weight:600;border:1px solid #15803d;background:#15803d;color:#fff;white-space:nowrap;margin-right:6px;margin-bottom:6px">All diets</button>
<button aria-pressed="false" aria-label="🥩 Carnivore" style="padding:6px 12px;border-radius:999px;cursor:pointer;font-size:12px;font-weight:600;border:1px solid var(--allo-stem-border, #334155);background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap;margin-right:6px;margin-bottom:6px">🥩 Carnivore</button>
<button aria-pressed="false" aria-label="🌿 Herbivore" style="padding:6px 12px;border-radius:999px;cursor:pointer;font-size:12px;font-weight:600;border:1px solid var(--allo-stem-border, #334155);background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap;margin-right:6px;margin-bottom:6px">🌿 Herbivore</button>
<button aria-pressed="false" aria-label="🍴 Omnivore" style="padding:6px 12px;border-radius:999px;cursor:pointer;font-size:12px;font-weight:600;border:1px solid var(--allo-stem-border, #334155);background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap;margin-right:6px;margin-bottom:6px">🍴 Omnivore</button>
<button aria-pressed="false" aria-label="🐟 Piscivore" style="padding:6px 12px;border-radius:999px;cursor:pointer;font-size:12px;font-weight:600;border:1px solid var(--allo-stem-border, #334155);background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap;margin-right:6px;margin-bottom:6px">🐟 Piscivore</button>
</div>
<div style="margin-bottom:6px">
<button aria-pressed="true" aria-label="All places" style="padding:6px 12px;border-radius:999px;cursor:pointer;font-size:12px;font-weight:600;border:1px solid #15803d;background:#15803d;color:#fff;white-space:nowrap;margin-right:6px;margin-bottom:6px">All places</button>
<button aria-pressed="false" aria-label="Africa" style="padding:6px 12px;border-radius:999px;cursor:pointer;font-size:12px;font-weight:600;border:1px solid var(--allo-stem-border, #334155);background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap;margin-right:6px;margin-bottom:6px">Africa</button>
<button aria-pressed="false" aria-label="Antarctica" style="padding:6px 12px;border-radius:999px;cursor:pointer;font-size:12px;font-weight:600;border:1px solid var(--allo-stem-border, #334155);background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap;margin-right:6px;margin-bottom:6px">Antarctica</button>
<button aria-pressed="false" aria-label="Asia" style="padding:6px 12px;border-radius:999px;cursor:pointer;font-size:12px;font-weight:600;border:1px solid var(--allo-stem-border, #334155);background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap;margin-right:6px;margin-bottom:6px">Asia</button>
<button aria-pressed="false" aria-label="Australia" style="padding:6px 12px;border-radius:999px;cursor:pointer;font-size:12px;font-weight:600;border:1px solid var(--allo-stem-border, #334155);background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap;margin-right:6px;margin-bottom:6px">Australia</button>
<button aria-pressed="false" aria-label="Europe" style="padding:6px 12px;border-radius:999px;cursor:pointer;font-size:12px;font-weight:600;border:1px solid var(--allo-stem-border, #334155);background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap;margin-right:6px;margin-bottom:6px">Europe</button>
<button aria-pressed="false" aria-label="North America" style="padding:6px 12px;border-radius:999px;cursor:pointer;font-size:12px;font-weight:600;border:1px solid var(--allo-stem-border, #334155);background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap;margin-right:6px;margin-bottom:6px">North America</button>
<button aria-pressed="false" aria-label="South America" style="padding:6px 12px;border-radius:999px;cursor:pointer;font-size:12px;font-weight:600;border:1px solid var(--allo-stem-border, #334155);background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap;margin-right:6px;margin-bottom:6px">South America</button>
<button aria-pressed="false" aria-label="Worldwide oceans" style="padding:6px 12px;border-radius:999px;cursor:pointer;font-size:12px;font-weight:600;border:1px solid var(--allo-stem-border, #334155);background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap;margin-right:6px;margin-bottom:6px">Worldwide oceans</button>
</div>
<div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">
<span style="font-size:12px;color:var(--allo-stem-text-soft, #94a3b8)">Sort:</span>
<button aria-pressed="true" aria-label="A to Z" style="padding:6px 12px;border-radius:999px;cursor:pointer;font-size:12px;font-weight:600;border:1px solid #15803d;background:#15803d;color:#fff;white-space:nowrap;margin-right:6px;margin-bottom:6px">A to Z</button>
<button aria-pressed="false" aria-label="Oldest first" style="padding:6px 12px;border-radius:999px;cursor:pointer;font-size:12px;font-weight:600;border:1px solid var(--allo-stem-border, #334155);background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap;margin-right:6px;margin-bottom:6px">Oldest first</button>
<button aria-pressed="false" aria-label="Longest" style="padding:6px 12px;border-radius:999px;cursor:pointer;font-size:12px;font-weight:600;border:1px solid var(--allo-stem-border, #334155);background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap;margin-right:6px;margin-bottom:6px">Longest</button>
<button aria-pressed="false" aria-label="Heaviest" style="padding:6px 12px;border-radius:999px;cursor:pointer;font-size:12px;font-weight:600;border:1px solid var(--allo-stem-border, #334155);background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap;margin-right:6px;margin-bottom:6px">Heaviest</button>
<button style="font-size:12px;font-weight:700;padding:6px 12px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:transparent;color:var(--allo-stem-text, #f1f5f9)">🎲 Surprise me</button>
<span style="margin-left:auto;font-size:12px;color:var(--allo-stem-text-soft, #94a3b8)">1 of 362</span>
</div>
</div>
<div style="display:grid;grid-template-columns:repeat(auto-fill, minmax(150px, 1fr));gap:10px">
<button aria-label="Open T. rex" style="text-align:left;cursor:pointer;background:var(--allo-stem-panel, #1e293b);border:1px solid #22c55e;border-radius:12px;padding:12px;color:var(--allo-stem-text, #f1f5f9);position:relative">
<div style="font-size:26px;margin-bottom:4px">🦖</div>
<div style="font-weight:700;font-size:14px">T. rex</div>
<div style="font-size:11px;color:var(--allo-stem-text-soft, #94a3b8);font-style:italic;margin-bottom:6px">tyrant lizard king</div>
<div>
<span style="display:inline-block;font-size:10px;font-weight:700;padding:2px 7px;border-radius:999px;background:#22c55e22;color:var(--allo-stem-text, #f1f5f9);border:1px solid #22c55e55;margin-right:6px;margin-bottom:4px;white-space:nowrap">Cretaceous</span>
<span style="display:inline-block;font-size:10px;font-weight:700;padding:2px 7px;border-radius:999px;background:#ef444422;color:var(--allo-stem-text, #f1f5f9);border:1px solid #ef444455;margin-right:6px;margin-bottom:4px;white-space:nowrap">Carnivore</span>
</div>
</button>
</div>
</div>
<div>
<div style="background:var(--allo-stem-panel, #1e293b);border:1px solid var(--allo-stem-border, #334155);border-radius:14px;padding:14px;color:var(--allo-stem-text, #f1f5f9)">
<div style="display:flex;align-items:baseline;justify-content:space-between;gap:8px;flex-wrap:wrap">
<div style="font-size:20px;font-weight:800">T. rex</div>
<div style="display:flex;gap:6px">
<button style="font-size:11px;font-weight:700;padding:4px 10px;border-radius:8px;border:1px solid var(--allo-stem-border, #334155);background:transparent;color:var(--allo-stem-text-soft, #94a3b8);cursor:pointer">⚖️ Compare</button>
<button aria-label="Print a trading card for T. rex" style="font-size:11px;font-weight:700;padding:4px 10px;border-radius:8px;border:1px solid var(--allo-stem-border, #334155);background:transparent;color:var(--allo-stem-text-soft, #94a3b8);cursor:pointer">🖨️ Card</button>
</div>
</div>
<div style="font-size:12px;font-style:italic;color:var(--allo-stem-text-soft, #94a3b8)">Tyrannosaurus rex</div>
<div style="font-size:12px;color:var(--allo-stem-text-soft, #94a3b8);margin-bottom:8px">Say it: tie-RAN-uh-SOR-us rex  ·  Means: &quot;tyrant lizard king&quot;</div>
<div style="margin-bottom:8px">
<span style="display:inline-block;font-size:10px;font-weight:700;padding:2px 7px;border-radius:999px;background:#22c55e22;color:var(--allo-stem-text, #f1f5f9);border:1px solid #22c55e55;margin-right:6px;margin-bottom:4px;white-space:nowrap">Cretaceous · 68–66 mya</span>
<span style="display:inline-block;font-size:10px;font-weight:700;padding:2px 7px;border-radius:999px;background:#ef444422;color:var(--allo-stem-text, #f1f5f9);border:1px solid #ef444455;margin-right:6px;margin-bottom:4px;white-space:nowrap">🥩 Carnivore</span>
<span style="display:inline-block;font-size:10px;font-weight:700;padding:2px 7px;border-radius:999px;background:#38bdf822;color:var(--allo-stem-text, #f1f5f9);border:1px solid #38bdf855;margin-right:6px;margin-bottom:4px;white-space:nowrap">Theropod</span>
</div>
<p style="font-size:13.5px;line-height:1.55;margin:0 0 10px">One of the largest land predators ever, with a bite force estimated near 35,000 newtons, the strongest of any known land animal.</p>
<div>
<div style="display:flex;justify-content:space-between;gap:10px;padding:4px 0;border-bottom:1px solid var(--allo-stem-border, #334155);font-size:13px">
<span style="color:var(--allo-stem-text-soft, #94a3b8)">Length</span>
<span style="font-weight:600;text-align:right">12.3 m</span>
</div>
<div style="display:flex;justify-content:space-between;gap:10px;padding:4px 0;border-bottom:1px solid var(--allo-stem-border, #334155);font-size:13px">
<span style="color:var(--allo-stem-text-soft, #94a3b8)">Height</span>
<span style="font-weight:600;text-align:right">3.7 m</span>
</div>
<div style="display:flex;justify-content:space-between;gap:10px;padding:4px 0;border-bottom:1px solid var(--allo-stem-border, #334155);font-size:13px">
<span style="color:var(--allo-stem-text-soft, #94a3b8)">Weight</span>
<span style="font-weight:600;text-align:right">8.4 t</span>
</div>
<div style="display:flex;justify-content:space-between;gap:10px;padding:4px 0;border-bottom:1px solid var(--allo-stem-border, #334155);font-size:13px">
<span style="color:var(--allo-stem-text-soft, #94a3b8)">When</span>
<span style="font-weight:600;text-align:right">Late Cretaceous (68–66 mya)</span>
</div>
<div style="display:flex;justify-content:space-between;gap:10px;padding:4px 0;border-bottom:1px solid var(--allo-stem-border, #334155);font-size:13px">
<span style="color:var(--allo-stem-text-soft, #94a3b8)">Where</span>
<span style="font-weight:600;text-align:right">North America</span>
</div>
<div style="display:flex;justify-content:space-between;gap:10px;padding:4px 0;border-bottom:1px solid var(--allo-stem-border, #334155);font-size:13px">
<span style="color:var(--allo-stem-text-soft, #94a3b8)">Rock unit</span>
<span style="font-weight:600;text-align:right">Hell Creek Formation</span>
</div>
<div style="display:flex;justify-content:space-between;gap:10px;padding:4px 0;border-bottom:1px solid var(--allo-stem-border, #334155);font-size:13px">
<span style="color:var(--allo-stem-text-soft, #94a3b8)">Named</span>
<span style="font-weight:600;text-align:right">1905 by Henry Fairfield Osborn</span>
</div>
</div>
<div style="margin-top:10px">
<div style="font-size:12px;font-weight:700;color:var(--allo-stem-text-soft, #94a3b8);margin-bottom:6px">Size next to a person</div>
<div aria-label="T. rex is about 12.3 m long, an adult human is about 1.7 meters">
<div style="display:flex;align-items:center;gap:8px;margin-bottom:5px">
<span aria-hidden="true" style="width:18px;text-align:center;font-size:14px">🦖</span>
<div style="flex:1;height:14px;border-radius:6px;background:var(--allo-stem-deeper, #0b1220);overflow:hidden">
<div style="height:100%;width:100%;background:#ef4444;border-radius:6px">
</div>
</div>
<span style="font-size:11px;color:var(--allo-stem-text-soft, #94a3b8);min-width:96px;text-align:right">12.3 m long</span>
</div>
<div style="display:flex;align-items:center;gap:8px;margin-bottom:5px">
<span aria-hidden="true" style="width:18px;text-align:center;font-size:14px">🧍</span>
<div style="flex:1;height:14px;border-radius:6px;background:var(--allo-stem-deeper, #0b1220);overflow:hidden">
<div style="height:100%;width:14%;background:#94a3b8;border-radius:6px">
</div>
</div>
<span style="font-size:11px;color:var(--allo-stem-text-soft, #94a3b8);min-width:96px;text-align:right">human 1.7 m</span>
</div>
</div>
</div>
<div style="margin-top:10px">
<div style="font-size:12px;font-weight:700;color:var(--allo-stem-text-soft, #94a3b8);margin-bottom:4px">Standout traits</div>
<ul style="margin:0;padding-left:18px;font-size:13px;line-height:1.5">
<li>Banana-sized teeth</li>
<li>Tiny but strong arms</li>
<li>Forward-facing eyes (good depth perception)</li>
</ul>
</div>
<div style="margin-top:10px">
<div style="font-size:12px;font-weight:700;color:var(--allo-stem-text-soft, #94a3b8);margin-bottom:4px">Did you know</div>
<ul style="margin:0;padding-left:18px;font-size:13px;line-height:1.5">
<li>The specimen &quot;Sue&quot; is about 90 percent complete.</li>
<li>Juveniles were slender and probably fast; adults were bulkier.</li>
</ul>
</div>
<div style="margin-top:10px;padding:10px;border-radius:8px;background:rgba(56,189,248,0.10);border:1px solid rgba(56,189,248,0.35)">
<div style="font-size:12px;font-weight:700;color:var(--allo-stem-text, #f1f5f9);margin-bottom:3px">🔎 How we know</div>
<div style="font-size:12.5px;line-height:1.5">Dozens of partial skeletons, including &quot;Sue&quot; and &quot;Stan&quot;, plus bite marks on other bones.</div>
</div>
<div style="margin-top:8px;padding:10px;border-radius:8px;background:rgba(245,158,11,0.10);border:1px solid rgba(245,158,11,0.35)">
<div style="font-size:12px;font-weight:700;color:var(--allo-stem-text, #f1f5f9);margin-bottom:3px">⚖️ What we are not sure about</div>
<div style="font-size:12.5px;line-height:1.5">Top speed is estimated from leg bones and muscle models, not measured. Feather extent is debated.</div>
</div>
</div>
</div>
</div>
</div>
</div>"
`;

exports[`Dino Lab — render per tab (golden master) > renders the extinction tab (snapshot) 1`] = `
"<div style="min-height:100%;background:var(--allo-stem-canvas, #0f172a);color:var(--allo-stem-text, #f1f5f9)">
<div role="tablist" aria-label="Dino Lab sections" style="display:flex;flex-wrap:wrap;gap:4px;padding:10px 12px;border-bottom:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220)">
<button id="dinotab-explore" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🔍 Explore</button>
<button id="dinotab-timeline" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">⏳ Timeline</button>
<button id="dinotab-deeptime" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🕰️ Deep Time</button>
<button id="dinotab-sites" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🗺️ Sites</button>
<button id="dinotab-ecosystem" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🌍 Ecosystems</button>
<button id="dinotab-compare" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">⚖️ Compare</button>
<button id="dinotab-dig" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">⛏️ Dig Site</button>
<button id="dinotab-classify" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🌳 Classify</button>
<button id="dinotab-birds" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🐦 Bird Link</button>
<button id="dinotab-extinction" role="tab" aria-selected="true" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:700;background:#15803d;color:#fff;white-space:nowrap">☄️ Extinction</button>
<button id="dinotab-anatomy" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🦴 Anatomy</button>
<button id="dinotab-records" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🏆 Records</button>
<button id="dinotab-quiz" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🧠 Quiz</button>
<button id="dinotab-notes" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">📓 Field Notes</button>
<button id="dinotab-glossary" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">📖 Glossary</button>
</div>
<div id="dinopanel" role="tabpanel" aria-labelledby="dinotab-extinction" style="padding:16px">
<div>
<div style="margin-bottom:12px">
<div style="font-size:18px;font-weight:800">☄️ The five great extinctions</div>
<div style="font-size:12.5px;color:var(--allo-stem-text-soft, #94a3b8);margin-top:2px">One of them cleared the way for dinosaurs; another ended their reign.</div>
</div>
<div style="background:var(--allo-stem-panel, #1e293b);border:1px solid var(--allo-stem-border, #334155);border-radius:14px;padding:14px;color:var(--allo-stem-text, #f1f5f9)">
<div style="margin-bottom:10px">
<button aria-expanded="false" style="width:100%;text-align:left;cursor:pointer;border-radius:10px;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-panel, #1e293b);color:var(--allo-stem-text, #f1f5f9);padding:12px">
<div style="display:flex;justify-content:space-between;align-items:baseline;gap:8px;flex-wrap:wrap">
<span style="font-weight:800;font-size:14px">End-Ordovician</span>
<span style="font-size:12px;color:var(--allo-stem-text-soft, #94a3b8)">444 million years ago</span>
</div>
<div style="display:flex;align-items:center;gap:8px;margin-top:6px">
<div style="flex:1;height:10px;border-radius:6px;background:var(--allo-stem-deeper, #0b1220);overflow:hidden">
<div style="height:100%;width:85%;background:#ef4444">
</div>
</div>
<span style="font-size:11.5px;color:var(--allo-stem-text, #f1f5f9);font-weight:700;min-width:92px;text-align:right">~85% species lost</span>
</div>
</button>
</div>
<div style="margin-bottom:10px">
<button aria-expanded="false" style="width:100%;text-align:left;cursor:pointer;border-radius:10px;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-panel, #1e293b);color:var(--allo-stem-text, #f1f5f9);padding:12px">
<div style="display:flex;justify-content:space-between;align-items:baseline;gap:8px;flex-wrap:wrap">
<span style="font-weight:800;font-size:14px">Late Devonian</span>
<span style="font-size:12px;color:var(--allo-stem-text-soft, #94a3b8)">372 million years ago</span>
</div>
<div style="display:flex;align-items:center;gap:8px;margin-top:6px">
<div style="flex:1;height:10px;border-radius:6px;background:var(--allo-stem-deeper, #0b1220);overflow:hidden">
<div style="height:100%;width:75%;background:#ef4444">
</div>
</div>
<span style="font-size:11.5px;color:var(--allo-stem-text, #f1f5f9);font-weight:700;min-width:92px;text-align:right">~75% species lost</span>
</div>
</button>
</div>
<div style="margin-bottom:10px">
<button aria-expanded="false" style="width:100%;text-align:left;cursor:pointer;border-radius:10px;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-panel, #1e293b);color:var(--allo-stem-text, #f1f5f9);padding:12px">
<div style="display:flex;justify-content:space-between;align-items:baseline;gap:8px;flex-wrap:wrap">
<span style="font-weight:800;font-size:14px">End-Permian (&quot;the Great Dying&quot;)</span>
<span style="font-size:12px;color:var(--allo-stem-text-soft, #94a3b8)">252 million years ago</span>
</div>
<div style="display:flex;align-items:center;gap:8px;margin-top:6px">
<div style="flex:1;height:10px;border-radius:6px;background:var(--allo-stem-deeper, #0b1220);overflow:hidden">
<div style="height:100%;width:96%;background:#ef4444">
</div>
</div>
<span style="font-size:11.5px;color:var(--allo-stem-text, #f1f5f9);font-weight:700;min-width:92px;text-align:right">~96% species lost</span>
</div>
</button>
</div>
<div style="margin-bottom:10px">
<button aria-expanded="false" style="width:100%;text-align:left;cursor:pointer;border-radius:10px;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-panel, #1e293b);color:var(--allo-stem-text, #f1f5f9);padding:12px">
<div style="display:flex;justify-content:space-between;align-items:baseline;gap:8px;flex-wrap:wrap">
<span style="font-weight:800;font-size:14px">End-Triassic</span>
<span style="font-size:12px;color:var(--allo-stem-text-soft, #94a3b8)">201 million years ago</span>
</div>
<div style="display:flex;align-items:center;gap:8px;margin-top:6px">
<div style="flex:1;height:10px;border-radius:6px;background:var(--allo-stem-deeper, #0b1220);overflow:hidden">
<div style="height:100%;width:80%;background:#ef4444">
</div>
</div>
<span style="font-size:11.5px;color:var(--allo-stem-text, #f1f5f9);font-weight:700;min-width:92px;text-align:right">~80% species lost</span>
</div>
</button>
</div>
<div style="margin-bottom:10px">
<button aria-expanded="true" style="width:100%;text-align:left;cursor:pointer;border-radius:10px;border:1px solid rgba(239,68,68,0.45);background:var(--allo-stem-panel, #1e293b);color:var(--allo-stem-text, #f1f5f9);padding:12px">
<div style="display:flex;justify-content:space-between;align-items:baseline;gap:8px;flex-wrap:wrap">
<span style="font-weight:800;font-size:14px">☄️ End-Cretaceous (K-Pg)</span>
<span style="font-size:12px;color:var(--allo-stem-text-soft, #94a3b8)">66 million years ago</span>
</div>
<div style="display:flex;align-items:center;gap:8px;margin-top:6px">
<div style="flex:1;height:10px;border-radius:6px;background:var(--allo-stem-deeper, #0b1220);overflow:hidden">
<div style="height:100%;width:76%;background:#ef4444">
</div>
</div>
<span style="font-size:11.5px;color:var(--allo-stem-text, #f1f5f9);font-weight:700;min-width:92px;text-align:right">~76% species lost</span>
</div>
</button>
<div style="background:var(--allo-stem-panel, #1e293b);border:1px solid var(--allo-stem-border, #334155);border-radius:14px;padding:14px;color:var(--allo-stem-text, #f1f5f9);margin-top:6px">
<div style="font-size:12.5px;line-height:1.55;margin-bottom:6px">
<strong style="color:var(--allo-stem-text, #f1f5f9)">Cause: </strong>A roughly 10-kilometer asteroid struck near Chicxulub, Mexico; huge Deccan volcanism was also underway.</div>
<div style="font-size:12.5px;line-height:1.55;margin-bottom:6px">
<strong style="color:var(--allo-stem-text, #f1f5f9)">Effect: </strong>Ended all non-bird dinosaurs, the pterosaurs, and the great marine reptiles. Birds and mammals survived.</div>
<div style="font-size:12px;color:var(--allo-stem-text-soft, #94a3b8);font-style:italic">The only mass extinction firmly tied to an asteroid impact. Birds carry the dinosaur line forward.</div>
</div>
</div>
</div>
<div style="background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.30);border-radius:14px;padding:14px;color:var(--allo-stem-text, #f1f5f9);margin-top:14px">
<div style="font-weight:800;font-size:14px;margin-bottom:6px">☄️ The K-Pg case, up close</div>
<div style="font-size:12.5px;color:var(--allo-stem-text-soft, #94a3b8);margin-bottom:8px;line-height:1.5">Several independent lines of evidence point to the same moment.</div>
<div>
<div style="padding:10px;border-radius:8px;background:var(--allo-stem-deeper, #0b1220);border:1px solid var(--allo-stem-border, #334155);margin-bottom:6px">
<div style="font-weight:700;font-size:12.5px;margin-bottom:2px">The iridium layer</div>
<div style="font-size:12px;color:var(--allo-stem-text-soft, #94a3b8);line-height:1.5">A worldwide thin clay layer is rich in iridium, a metal rare in Earth’s crust but common in asteroids. Found by the Alvarez team in 1980.</div>
</div>
<div style="padding:10px;border-radius:8px;background:var(--allo-stem-deeper, #0b1220);border:1px solid var(--allo-stem-border, #334155);margin-bottom:6px">
<div style="font-weight:700;font-size:12.5px;margin-bottom:2px">The Chicxulub crater</div>
<div style="font-size:12px;color:var(--allo-stem-text-soft, #94a3b8);line-height:1.5">A buried ~180 km crater off Mexico’s Yucatán dates to exactly 66 million years ago, matching the layer.</div>
</div>
<div style="padding:10px;border-radius:8px;background:var(--allo-stem-deeper, #0b1220);border:1px solid var(--allo-stem-border, #334155);margin-bottom:6px">
<div style="font-weight:700;font-size:12.5px;margin-bottom:2px">Glass spherules and shocked quartz</div>
<div style="font-size:12px;color:var(--allo-stem-text-soft, #94a3b8);line-height:1.5">Tiny melted-rock beads and quartz with shock fractures, made by an enormous impact, appear in the same layer.</div>
</div>
<div style="padding:10px;border-radius:8px;background:var(--allo-stem-deeper, #0b1220);border:1px solid var(--allo-stem-border, #334155);margin-bottom:6px">
<div style="font-weight:700;font-size:12.5px;margin-bottom:2px">Soot and a dark &quot;impact winter&quot;</div>
<div style="font-size:12px;color:var(--allo-stem-text-soft, #94a3b8);line-height:1.5">Soot and dust would have blocked sunlight for months to years, cooling the planet and collapsing food chains.</div>
</div>
<div style="padding:10px;border-radius:8px;background:var(--allo-stem-deeper, #0b1220);border:1px solid var(--allo-stem-border, #334155);margin-bottom:6px">
<div style="font-weight:700;font-size:12.5px;margin-bottom:2px">The Deccan Traps debate</div>
<div style="font-size:12px;color:var(--allo-stem-text-soft, #94a3b8);line-height:1.5">Vast volcanic eruptions in India overlapped the impact. Most researchers see the asteroid as the main trigger, with volcanism as added stress.</div>
</div>
</div>
</div>
<div style="background:var(--allo-stem-panel, #1e293b);border:1px solid var(--allo-stem-border, #334155);border-radius:14px;padding:14px;color:var(--allo-stem-text, #f1f5f9);margin-top:14px">
<div style="font-weight:700;margin-bottom:4px">🐦 What survived</div>
<div style="font-size:12.5px;color:var(--allo-stem-text-soft, #94a3b8);line-height:1.55">Birds, mammals, crocodiles, turtles, amphibians, and many insects and plants made it through. The dinosaur story did not end; it narrowed to the birds.</div>
</div>
</div>
</div>
</div>"
`;

exports[`Dino Lab — render per tab (golden master) > renders the glossary tab (snapshot) 1`] = `
"<div style="min-height:100%;background:var(--allo-stem-canvas, #0f172a);color:var(--allo-stem-text, #f1f5f9)">
<div role="tablist" aria-label="Dino Lab sections" style="display:flex;flex-wrap:wrap;gap:4px;padding:10px 12px;border-bottom:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220)">
<button id="dinotab-explore" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🔍 Explore</button>
<button id="dinotab-timeline" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">⏳ Timeline</button>
<button id="dinotab-deeptime" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🕰️ Deep Time</button>
<button id="dinotab-sites" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🗺️ Sites</button>
<button id="dinotab-ecosystem" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🌍 Ecosystems</button>
<button id="dinotab-compare" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">⚖️ Compare</button>
<button id="dinotab-dig" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">⛏️ Dig Site</button>
<button id="dinotab-classify" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🌳 Classify</button>
<button id="dinotab-birds" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🐦 Bird Link</button>
<button id="dinotab-extinction" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">☄️ Extinction</button>
<button id="dinotab-anatomy" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🦴 Anatomy</button>
<button id="dinotab-records" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🏆 Records</button>
<button id="dinotab-quiz" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🧠 Quiz</button>
<button id="dinotab-notes" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">📓 Field Notes</button>
<button id="dinotab-glossary" role="tab" aria-selected="true" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:700;background:#15803d;color:#fff;white-space:nowrap">📖 Glossary</button>
</div>
<div id="dinopanel" role="tabpanel" aria-labelledby="dinotab-glossary" style="padding:16px">
<div>
<div style="margin-bottom:12px">
<div style="font-size:18px;font-weight:800">📖 Glossary</div>
<div style="font-size:12.5px;color:var(--allo-stem-text-soft, #94a3b8);margin-top:2px">The words paleontologists use, in plain language.</div>
</div>
<input type="text" placeholder="Search terms..." aria-label="Search glossary" style="width:100%;box-sizing:border-box;padding:10px 12px;border-radius:10px;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9);font-size:14px;margin-bottom:10px" value="fossil"/>
<div style="background:var(--allo-stem-panel, #1e293b);border:1px solid var(--allo-stem-border, #334155);border-radius:14px;padding:14px;color:var(--allo-stem-text, #f1f5f9)">
<div style="padding:8px 0;border-bottom:1px solid var(--allo-stem-border, #334155)">
<div style="font-weight:700;font-size:13.5px;color:var(--allo-stem-text, #f1f5f9)">Coprolite</div>
<div style="font-size:12.5px;color:var(--allo-stem-text, #f1f5f9);line-height:1.5;margin-top:2px">Fossilized dung, which can reveal what an animal actually ate.</div>
</div>
<div style="padding:8px 0;border-bottom:1px solid var(--allo-stem-border, #334155)">
<div style="font-weight:700;font-size:13.5px;color:var(--allo-stem-text, #f1f5f9)">Fossil</div>
<div style="font-size:12.5px;color:var(--allo-stem-text, #f1f5f9);line-height:1.5;margin-top:2px">Any preserved trace of ancient life: bones, teeth, footprints, eggs, dung, or impressions.</div>
</div>
<div style="padding:8px 0;border-bottom:1px solid var(--allo-stem-border, #334155)">
<div style="font-weight:700;font-size:13.5px;color:var(--allo-stem-text, #f1f5f9)">Index fossil</div>
<div style="font-size:12.5px;color:var(--allo-stem-text, #f1f5f9);line-height:1.5;margin-top:2px">A common, short-lived, widespread fossil used to date the rock layer it sits in.</div>
</div>
<div style="padding:8px 0;border-bottom:1px solid var(--allo-stem-border, #334155)">
<div style="font-weight:700;font-size:13.5px;color:var(--allo-stem-text, #f1f5f9)">Melanosome</div>
<div style="font-size:12.5px;color:var(--allo-stem-text, #f1f5f9);line-height:1.5;margin-top:2px">A tiny structure that holds pigment. Fossil melanosomes can reveal a dinosaur’s color.</div>
</div>
<div style="padding:8px 0;border-bottom:1px solid var(--allo-stem-border, #334155)">
<div style="font-weight:700;font-size:13.5px;color:var(--allo-stem-text, #f1f5f9)">Paleontology</div>
<div style="font-size:12.5px;color:var(--allo-stem-text, #f1f5f9);line-height:1.5;margin-top:2px">The science that studies ancient life through fossils.</div>
</div>
<div style="padding:8px 0;border-bottom:1px solid var(--allo-stem-border, #334155)">
<div style="font-weight:700;font-size:13.5px;color:var(--allo-stem-text, #f1f5f9)">Taphonomy</div>
<div style="font-size:12.5px;color:var(--allo-stem-text, #f1f5f9);line-height:1.5;margin-top:2px">The study of how organisms decay and become fossils, the story between death and discovery.</div>
</div>
<div style="padding:8px 0;border-bottom:1px solid var(--allo-stem-border, #334155)">
<div style="font-weight:700;font-size:13.5px;color:var(--allo-stem-text, #f1f5f9)">Trackway</div>
<div style="font-size:12.5px;color:var(--allo-stem-text, #f1f5f9);line-height:1.5;margin-top:2px">A series of fossil footprints that records how an animal moved.</div>
</div>
</div>
</div>
</div>
</div>"
`;

exports[`Dino Lab — render per tab (golden master) > renders the notes tab (snapshot) 1`] = `
"<div style="min-height:100%;background:var(--allo-stem-canvas, #0f172a);color:var(--allo-stem-text, #f1f5f9)">
<div role="tablist" aria-label="Dino Lab sections" style="display:flex;flex-wrap:wrap;gap:4px;padding:10px 12px;border-bottom:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220)">
<button id="dinotab-explore" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🔍 Explore</button>
<button id="dinotab-timeline" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">⏳ Timeline</button>
<button id="dinotab-deeptime" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🕰️ Deep Time</button>
<button id="dinotab-sites" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🗺️ Sites</button>
<button id="dinotab-ecosystem" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🌍 Ecosystems</button>
<button id="dinotab-compare" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">⚖️ Compare</button>
<button id="dinotab-dig" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">⛏️ Dig Site</button>
<button id="dinotab-classify" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🌳 Classify</button>
<button id="dinotab-birds" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🐦 Bird Link</button>
<button id="dinotab-extinction" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">☄️ Extinction</button>
<button id="dinotab-anatomy" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🦴 Anatomy</button>
<button id="dinotab-records" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🏆 Records</button>
<button id="dinotab-quiz" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🧠 Quiz</button>
<button id="dinotab-notes" role="tab" aria-selected="true" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:700;background:#15803d;color:#fff;white-space:nowrap">📓 Field Notes</button>
<button id="dinotab-glossary" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">📖 Glossary</button>
</div>
<div id="dinopanel" role="tabpanel" aria-labelledby="dinotab-notes" style="padding:16px">
<div>
<div style="margin-bottom:12px">
<div style="font-size:18px;font-weight:800">📓 Field notes: myths, corrected</div>
<div style="font-size:12.5px;color:var(--allo-stem-text-soft, #94a3b8);margin-top:2px">Science updates as new fossils turn up. Here are popular ideas the evidence has changed.</div>
</div>
<div style="background:rgba(34,197,94,0.08);border:1px solid rgba(34,197,94,0.30);border-radius:14px;padding:14px;color:var(--allo-stem-text, #f1f5f9);margin-bottom:14px">
<div style="font-weight:700;margin-bottom:4px">🔬 Why these change</div>
<div style="font-size:12.5px;color:var(--allo-stem-text-soft, #94a3b8);line-height:1.55">Each correction came from new fossils or new methods. Changing your mind when the evidence changes is how science is supposed to work.</div>
</div>
<div style="display:grid;grid-template-columns:repeat(auto-fit, minmax(260px, 1fr));gap:12px">
<div style="background:var(--allo-stem-panel, #1e293b);border:1px solid var(--allo-stem-border, #334155);border-radius:14px;padding:14px;color:var(--allo-stem-text, #f1f5f9)">
<div style="font-size:13.5px;font-weight:800;color:var(--allo-stem-text, #f1f5f9);margin-bottom:6px">❌ Myth: All the dinosaurs died out.</div>
<div style="font-size:13px;margin-bottom:6px;line-height:1.5">
<strong style="color:var(--allo-stem-text, #f1f5f9)">✅ Reality: </strong>Birds are dinosaurs. One branch of small feathered theropods survived the K-Pg extinction.</div>
<div style="font-size:12.5px;color:var(--allo-stem-text-soft, #94a3b8);line-height:1.5">There are more than 10,000 living bird species. The group lives on every time a sparrow lands on your windowsill.</div>
</div>
<div style="background:var(--allo-stem-panel, #1e293b);border:1px solid var(--allo-stem-border, #334155);border-radius:14px;padding:14px;color:var(--allo-stem-text, #f1f5f9)">
<div style="font-size:13.5px;font-weight:800;color:var(--allo-stem-text, #f1f5f9);margin-bottom:6px">❌ Myth: Dinosaurs dragged their tails on the ground.</div>
<div style="font-size:13px;margin-bottom:6px;line-height:1.5">
<strong style="color:var(--allo-stem-text, #f1f5f9)">✅ Reality: </strong>Most held their tails off the ground, stiff and level, as a counterbalance.</div>
<div style="font-size:12.5px;color:var(--allo-stem-text-soft, #94a3b8);line-height:1.5">Trackways almost never show tail drag marks, and tail bones often had stiffening rods.</div>
</div>
<div style="background:var(--allo-stem-panel, #1e293b);border:1px solid var(--allo-stem-border, #334155);border-radius:14px;padding:14px;color:var(--allo-stem-text, #f1f5f9)">
<div style="font-size:13.5px;font-weight:800;color:var(--allo-stem-text, #f1f5f9);margin-bottom:6px">❌ Myth: Brontosaurus was never real, just a mistake.</div>
<div style="font-size:13px;margin-bottom:6px;line-height:1.5">
<strong style="color:var(--allo-stem-text, #f1f5f9)">✅ Reality: </strong>The name has a tangled history, but a 2015 study argued Brontosaurus is a valid genus again.</div>
<div style="font-size:12.5px;color:var(--allo-stem-text-soft, #94a3b8);line-height:1.5">It was folded into Apatosaurus in 1903 and revived in 2015. Science can change its mind with new evidence.</div>
</div>
<div style="background:var(--allo-stem-panel, #1e293b);border:1px solid var(--allo-stem-border, #334155);border-radius:14px;padding:14px;color:var(--allo-stem-text, #f1f5f9)">
<div style="font-size:13.5px;font-weight:800;color:var(--allo-stem-text, #f1f5f9);margin-bottom:6px">❌ Myth: Pterosaurs, plesiosaurs, and mosasaurs were dinosaurs.</div>
<div style="font-size:13px;margin-bottom:6px;line-height:1.5">
<strong style="color:var(--allo-stem-text, #f1f5f9)">✅ Reality: </strong>None of them were dinosaurs. They were other reptile groups living at the same time.</div>
<div style="font-size:12.5px;color:var(--allo-stem-text-soft, #94a3b8);line-height:1.5">&quot;Lived with dinosaurs&quot; is not the same as &quot;was a dinosaur&quot;.</div>
</div>
<div style="background:var(--allo-stem-panel, #1e293b);border:1px solid var(--allo-stem-border, #334155);border-radius:14px;padding:14px;color:var(--allo-stem-text, #f1f5f9)">
<div style="font-size:13.5px;font-weight:800;color:var(--allo-stem-text, #f1f5f9);margin-bottom:6px">❌ Myth: Dinosaurs were slow, cold-blooded, and dim.</div>
<div style="font-size:13px;margin-bottom:6px;line-height:1.5">
<strong style="color:var(--allo-stem-text, #f1f5f9)">✅ Reality: </strong>Many were active and fast, and their metabolisms varied. Several had large brains for their size.</div>
<div style="font-size:12.5px;color:var(--allo-stem-text-soft, #94a3b8);line-height:1.5">Bone structure, growth rates, and posture suggest many dinosaurs ran warm and lived fast.</div>
</div>
<div style="background:var(--allo-stem-panel, #1e293b);border:1px solid var(--allo-stem-border, #334155);border-radius:14px;padding:14px;color:var(--allo-stem-text, #f1f5f9)">
<div style="font-size:13.5px;font-weight:800;color:var(--allo-stem-text, #f1f5f9);margin-bottom:6px">❌ Myth: T. rex could not see you if you stood still.</div>
<div style="font-size:13px;margin-bottom:6px;line-height:1.5">
<strong style="color:var(--allo-stem-text, #f1f5f9)">✅ Reality: </strong>T. rex likely had excellent vision, including good depth perception.</div>
<div style="font-size:12.5px;color:var(--allo-stem-text-soft, #94a3b8);line-height:1.5">Its forward-facing eyes gave overlapping fields of view. The &quot;stand still&quot; idea is a movie plot device.</div>
</div>
<div style="background:var(--allo-stem-panel, #1e293b);border:1px solid var(--allo-stem-border, #334155);border-radius:14px;padding:14px;color:var(--allo-stem-text, #f1f5f9)">
<div style="font-size:13.5px;font-weight:800;color:var(--allo-stem-text, #f1f5f9);margin-bottom:6px">❌ Myth: Dilophosaurus had a neck frill and spat venom.</div>
<div style="font-size:13px;margin-bottom:6px;line-height:1.5">
<strong style="color:var(--allo-stem-text, #f1f5f9)">✅ Reality: </strong>There is no fossil evidence for either. Both were invented for Jurassic Park.</div>
<div style="font-size:12.5px;color:var(--allo-stem-text-soft, #94a3b8);line-height:1.5">The real Dilophosaurus was also much larger than the film’s small &quot;spitter&quot;.</div>
</div>
<div style="background:var(--allo-stem-panel, #1e293b);border:1px solid var(--allo-stem-border, #334155);border-radius:14px;padding:14px;color:var(--allo-stem-text, #f1f5f9)">
<div style="font-size:13.5px;font-weight:800;color:var(--allo-stem-text, #f1f5f9);margin-bottom:6px">❌ Myth: Early humans lived alongside (non-bird) dinosaurs.</div>
<div style="font-size:13px;margin-bottom:6px;line-height:1.5">
<strong style="color:var(--allo-stem-text, #f1f5f9)">✅ Reality: </strong>The non-bird dinosaurs died out about 66 million years before humans appeared.</div>
<div style="font-size:12.5px;color:var(--allo-stem-text-soft, #94a3b8);line-height:1.5">Our species is only a few hundred thousand years old. Cave-people-versus-dinosaurs is pure cartoon.</div>
</div>
<div style="background:var(--allo-stem-panel, #1e293b);border:1px solid var(--allo-stem-border, #334155);border-radius:14px;padding:14px;color:var(--allo-stem-text, #f1f5f9)">
<div style="font-size:13.5px;font-weight:800;color:var(--allo-stem-text, #f1f5f9);margin-bottom:6px">❌ Myth: Velociraptor was a big, scaly, man-sized hunter.</div>
<div style="font-size:13px;margin-bottom:6px;line-height:1.5">
<strong style="color:var(--allo-stem-text, #f1f5f9)">✅ Reality: </strong>The real Velociraptor was about the size of a turkey and covered in feathers.</div>
<div style="font-size:12.5px;color:var(--allo-stem-text-soft, #94a3b8);line-height:1.5">The movie &quot;raptors&quot; were really sized after Deinonychus, and still left off the feathers.</div>
</div>
<div style="background:var(--allo-stem-panel, #1e293b);border:1px solid var(--allo-stem-border, #334155);border-radius:14px;padding:14px;color:var(--allo-stem-text, #f1f5f9)">
<div style="font-size:13.5px;font-weight:800;color:var(--allo-stem-text, #f1f5f9);margin-bottom:6px">❌ Myth: T. rex was the biggest dinosaur.</div>
<div style="font-size:13px;margin-bottom:6px;line-height:1.5">
<strong style="color:var(--allo-stem-text, #f1f5f9)">✅ Reality: </strong>T. rex was a giant predator, but the largest dinosaurs were long-necked sauropods many times heavier.</div>
<div style="font-size:12.5px;color:var(--allo-stem-text-soft, #94a3b8);line-height:1.5">Titanosaurs like Argentinosaurus may have weighed ten times as much as T. rex.</div>
</div>
<div style="background:var(--allo-stem-panel, #1e293b);border:1px solid var(--allo-stem-border, #334155);border-radius:14px;padding:14px;color:var(--allo-stem-text, #f1f5f9)">
<div style="font-size:13.5px;font-weight:800;color:var(--allo-stem-text, #f1f5f9);margin-bottom:6px">❌ Myth: All the famous dinosaurs lived at the same time.</div>
<div style="font-size:13px;margin-bottom:6px;line-height:1.5">
<strong style="color:var(--allo-stem-text, #f1f5f9)">✅ Reality: </strong>They are spread across more than 150 million years. Many never met.</div>
<div style="font-size:12.5px;color:var(--allo-stem-text-soft, #94a3b8);line-height:1.5">Stegosaurus is closer in time to us than to T. rex.</div>
</div>
<div style="background:var(--allo-stem-panel, #1e293b);border:1px solid var(--allo-stem-border, #334155);border-radius:14px;padding:14px;color:var(--allo-stem-text, #f1f5f9)">
<div style="font-size:13.5px;font-weight:800;color:var(--allo-stem-text, #f1f5f9);margin-bottom:6px">❌ Myth: All dinosaurs were huge.</div>
<div style="font-size:13px;margin-bottom:6px;line-height:1.5">
<strong style="color:var(--allo-stem-text, #f1f5f9)">✅ Reality: </strong>Dinosaurs came in every size, from chicken-sized hunters to the largest land animals ever.</div>
<div style="font-size:12.5px;color:var(--allo-stem-text-soft, #94a3b8);line-height:1.5">Microraptor was crow-sized. Giants get the spotlight, but small dinosaurs were everywhere.</div>
</div>
</div>
</div>
</div>
</div>"
`;

exports[`Dino Lab — render per tab (golden master) > renders the quiz tab (snapshot) 1`] = `
"<div style="min-height:100%;background:var(--allo-stem-canvas, #0f172a);color:var(--allo-stem-text, #f1f5f9)">
<div role="tablist" aria-label="Dino Lab sections" style="display:flex;flex-wrap:wrap;gap:4px;padding:10px 12px;border-bottom:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220)">
<button id="dinotab-explore" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🔍 Explore</button>
<button id="dinotab-timeline" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">⏳ Timeline</button>
<button id="dinotab-deeptime" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🕰️ Deep Time</button>
<button id="dinotab-sites" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🗺️ Sites</button>
<button id="dinotab-ecosystem" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🌍 Ecosystems</button>
<button id="dinotab-compare" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">⚖️ Compare</button>
<button id="dinotab-dig" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">⛏️ Dig Site</button>
<button id="dinotab-classify" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🌳 Classify</button>
<button id="dinotab-birds" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🐦 Bird Link</button>
<button id="dinotab-extinction" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">☄️ Extinction</button>
<button id="dinotab-anatomy" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🦴 Anatomy</button>
<button id="dinotab-records" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🏆 Records</button>
<button id="dinotab-quiz" role="tab" aria-selected="true" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:700;background:#15803d;color:#fff;white-space:nowrap">🧠 Quiz</button>
<button id="dinotab-notes" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">📓 Field Notes</button>
<button id="dinotab-glossary" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">📖 Glossary</button>
</div>
<div id="dinopanel" role="tabpanel" aria-labelledby="dinotab-quiz" style="padding:16px">
<div>
<div style="margin-bottom:12px">
<div style="font-size:18px;font-weight:800">🧠 Dino quiz</div>
<div style="font-size:12.5px;color:var(--allo-stem-text-soft, #94a3b8);margin-top:2px">One question at a time. Read the explanation after each, that is where the learning is.</div>
</div>
<div style="background:var(--allo-stem-panel, #1e293b);border:1px solid var(--allo-stem-border, #334155);border-radius:14px;padding:14px;color:var(--allo-stem-text, #f1f5f9)">
<div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:10px">
<span style="font-size:12px;color:var(--allo-stem-text-soft, #94a3b8)">Question 3 of 34</span>
<span style="font-size:12px;font-weight:700;color:var(--allo-stem-text, #f1f5f9)">Score: 3/5 (60%)</span>
</div>
<div style="font-size:15.5px;font-weight:700;margin-bottom:12px;line-height:1.45">Which &quot;dinosaur&quot; was NOT actually a dinosaur?</div>
<div>
<button disabled="" style="display:block;width:100%;text-align:left;margin-bottom:8px;padding:10px 14px;border-radius:10px;cursor:default;font-size:13.5px;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Triceratops</button>
<button disabled="" style="display:block;width:100%;text-align:left;margin-bottom:8px;padding:10px 14px;border-radius:10px;cursor:default;font-size:13.5px;border:1px solid #ef4444;background:rgba(239,68,68,0.15);color:var(--allo-stem-text, #f1f5f9)">❌ Stegosaurus</button>
<button disabled="" style="display:block;width:100%;text-align:left;margin-bottom:8px;padding:10px 14px;border-radius:10px;cursor:default;font-size:13.5px;border:1px solid #22c55e;background:rgba(34,197,94,0.18);color:var(--allo-stem-text, #f1f5f9)">✅ Pteranodon</button>
<button disabled="" style="display:block;width:100%;text-align:left;margin-bottom:8px;padding:10px 14px;border-radius:10px;cursor:default;font-size:13.5px;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Velociraptor</button>
</div>
<div style="background:rgba(56,189,248,0.08);border:1px solid rgba(56,189,248,0.30);border-radius:14px;padding:14px;color:var(--allo-stem-text, #f1f5f9);margin-top:4px;margin-bottom:10px">
<div style="font-size:12.5px;line-height:1.55">
<strong style="color:var(--allo-stem-text, #f1f5f9)">➡️ Good try. </strong>Pteranodon was a flying pterosaur, a close cousin but not a dinosaur.</div>
</div>
<div style="display:flex;gap:8px">
<button style="flex:1;font-size:13.5px;font-weight:700;padding:10px;border-radius:10px;border:none;background:#15803d;color:#fff;cursor:pointer">Next question →</button>
<button style="font-size:12.5px;font-weight:600;padding:10px 14px;border-radius:10px;border:1px solid var(--allo-stem-border, #334155);background:transparent;color:var(--allo-stem-text-soft, #94a3b8);cursor:pointer">Restart</button>
</div>
</div>
</div>
</div>
</div>"
`;

