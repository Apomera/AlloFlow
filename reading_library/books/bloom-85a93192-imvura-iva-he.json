      "text": "Mama, imvura iva he?"
    },
    {
      "n": 18,
      "img": null,
      "text": "Ngwino nge kukwereka."
    },
    {
      "n": 19,
      "img": null,
      "text": "Mama, ikiyaga kiri gucumba umwotsi!"
    },
    {
      "n": 20,
      "img": null,
      "text": "Cibiri, uriya si umwotsi nk’uwo mu ziko."
    },
    {
      "n": 21,
      "img": null,
      "text": "Izuba rirava, rigatanga ubushyuhe."
    },
    {
      "n": 22,
      "img": null,
      "text": "Iyo amazi ashyushye rero ahinduka umwuka."
    },
    {
      "n": 23,
      "img": null,
      "text": "Uwo mwuka ugera mu kirere ukaba ibicu."
    },
    {
      "n": 24,
      "img": null,
      "text": "Umuyaga mama!"
    },
    {
      "n": 25,
      "img": null,
      "text": "Uriya muyaga ukonje urahura n’ibicu."
    },
    {
      "n": 26,
      "img": null,
      "text": "Maze na byo bikonje."
    },
    {
      "n": 27,
      "img": null,
      "text": "Byongere bihinduke imvura."
    },
    {
      "n": 28,
      "img": null,
      "text": "None se ayo mazi afatwa n’iki mu kirere mama?"
    },
    {
      "n": 29,
      "img": null,
      "text": "Nta cyo. Arongera agahanuka."
