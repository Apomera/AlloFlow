<button aria-label="Open Marshosaurus" style="font-size:11.5px;padding:4px 10px;border-radius:999px;cursor:pointer;border:1px solid #ef444466;background:#ef444418;color:var(--allo-stem-text, #f1f5f9);margin-right:5px;margin-bottom:5px">🥩 Marshosaurus</button>
<button aria-label="Open Stokesosaurus" style="font-size:11.5px;padding:4px 10px;border-radius:999px;cursor:pointer;border:1px solid #ef444466;background:#ef444418;color:var(--allo-stem-text, #f1f5f9);margin-right:5px;margin-bottom:5px">🥩 Stokesosaurus</button>
<button aria-label="Open Ornitholestes" style="font-size:11.5px;padding:4px 10px;border-radius:999px;cursor:pointer;border:1px solid #ef444466;background:#ef444418;color:var(--allo-stem-text, #f1f5f9);margin-right:5px;margin-bottom:5px">🥩 Ornitholestes</button>
</div>
</div>
<div style="margin-bottom:10px">
<div style="font-size:12px;font-weight:700;color:var(--allo-stem-text, #f1f5f9);margin-bottom:4px">🍴 Omnivores (1)</div>
<div style="display:flex;flex-wrap:wrap">
