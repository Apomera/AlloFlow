 \nतो नीमा क्या खाती है?","words":[[160,"सर्दी"],[161,"के"],[162,"मौसम"],[163,"में,"],[164,"दिन"],[165,"होते"],[166,"हैं"],[167,"छोटे,"],[168,"और"],[169,"सताती"],[170,"है"],[171,"सर्दी…"],[172,"तो"],[173,"नीमा"],[174,"क्या"],[175,"खाती"],[176,"है?"]]},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/29828/size6/d043761e1213e14d540b38d33cf36d65.jpg","text":"सर्दी के मौसम में मिलते हैं लाल और हरे पत्तेदार साग।\nलाल-सुर्ख़ चुकंदर,\nमोटे-ताज़े, गूदेदार शरीफ़े,\nदेखो-देखो! नीमा पेड़ पर चढ़ गई,\nओहो! उसने सारी भूरी भूरी, खट्टी इमलियाँ तोड़ लीं!","words":[[177,"सर्दी"],[178,"के"],[179,"मौसम"],[180,"में"],[181,"मिलते"],[182,"हैं"],[183,"लाल"],[184,"और"],[185,"हरे"],[186,"पत्तेदार"],[187,"साग।"],[188,"लाल-सुर्ख़"],[189,"चुकंदर,"],[190,"मोटे-ताज़े,"],[191,"गूदेदार"],[192,"शरीफ़े,"],[193,"देखो-देखो!"],[194,"नीमा"],[195,"पेड़"],[196,"पर"],[197,"चढ़"],[198,"गई,"],[199,"ओहो!"],[200,"उसने"],[201,"सारी"],[202,"भूरी"],[203,"भूरी,"],[204,"खट्टी"],[205,"इमलियाँ"],[206,"तोड़"],[207,"लीं!"]]},{"n":9,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/29829/size6/83bd3d69e3ada13f3424c29c05d219e0.jpg","text":"नीमा को खाना बहुत पसंद है। लेकिन वो मौसम के हिसाब से खाती है।\nमम्म्म! मम्म्म!\nचबा... चबा!\nकचकच!\nकचा... कच!","words":[[208,"नीमा"],[209,"को"],[210,"खाना"],[211,"बहुत"],[212,"पसंद"],[213,"है।"],[214,"लेकिन"],[215,"वो"],[216,"मौसम"],[217,"के"],[218,"हिसाब"],[219,"से"],[220,"खाती"],[221,"है।"],[222,"मम्म्म!"],[223,"मम्म्म!"],[224,"चबा..."],[225,"चबा!"],[226,"कचकच!"],[227,"कचा..."],[228,"कच!"]]},{"n":10,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/29830/size6/ee29feec1fb017e8dcf844053c945cbd.jpg","text":"दुनिया में पाँच मौसम होते हैं - वसंत, गर्मी, बरसात, शरद और जाड़े। लेकिन कुछ जगहों पर, जैसे भारत में जहाँ नीमा रेहती है, गर्मी, बरसात और जाड़े, बस तीन ही मौसम होते हैं।","words":[[229,"दुनिया"],[230,"में"],[231,"पाँच"],[232,"मौसम"],[233,"होते"],[234,"हैं"],[235,"-"],[236,"वसंत,"],[237,"गर्मी,"],[238,"बरसात,"],[239,"शरद"],[240,"और"],[241,"जाड़े।"],[242,"लेकिन"],[243,"कुछ"],[244,"जगहों"],[245,"पर,"],[246,"जैसे"],[247,"भारत"],[248,"में"],[249,"जहाँ"],[250,"नीमा"],[251,"रेहती"],[252,"है,"],[253,"गर्मी,"],[254,"बरसात"],[255,"और"],[256,"जाड़े,"],[257,"बस"],[258,"तीन"],[259,"ही"],[260,"मौसम"],[261,"होते"],[262,"हैं।"]]},{"n":11,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/31936/size6/4a1dc02e2a62931d2748a64bb4a28104.jpg","text":"मौसम के हिसाब से खाना:\nनीमा की तरह, आप भी पूरे साल रंग-बिरँगी सब्ज़ियाँ और फल खा सकते हैं। आइये बनाएँ एक कैलेंडर मौसम के हिसाब से जिससे यह पता चले कि पूरे साल कब और कौनसी सब्जियाँ और फल हमें खाने चाहियें!\n                     इमली: जनवरी से फ़रवरी \n \n                     चीकू: जनवरी\nसे फ़रवरी और\nमई से जुलाई \n                     शहतूत:  अक्टूबर से नवम्बर और मार्च से मई","words":[[263,"मौसम"],[264,"के"],[265,"हिसाब"],[266,"से"],[267,"खाना"],[268,":"],[269,"नीमा"],[270,"की"],[271,"तरह,"],[272,"आप"],[273,"भी"],[274,"पूरे"],[275,"साल"],[276,"रंग-बिरँगी"],[277,"सब्ज़ियाँ"],[278,"और"],[279,"फल"],[280,"खा"],[281,"सकते"],[282,"हैं।"],[283,"आइये"],[284,"बनाएँ"],[285,"एक"],[286,"कैलेंडर"],[287,"मौसम"],[288,"के"],[289,"हिसाब"],[290,"से"],[291,"जिससे"],[292,"यह"],[293,"पता"],[294,"चले"],[295,"कि"],[296,"पूरे"],[297,"साल"],[298,"कब"],[299,"और"],[300,"कौनसी"],[301,"सब्जियाँ"],[302,"और"],[303,"फल"],[304,"हमें"],[305,"खाने"],[306,"चाहियें!"],[307,"इमली"],[308,":"],[309,"जनवरी"],[310,"से"],[311,"फ़रवरी"],[312,"चीकू"],[313,":"],[314,"जनवरी"],[315,"से"],[316,"फ़रवरी"],[317,"और"],[318,"मई"],[319,"से"],[320,"जुलाई"],[321,"शहतूत"],[322,":"],[323,"अक्टूबर"],[324,"से"],[325,"नवम्बर"],[326,"और"],[327,"मार्च"],[328,"से"],[329,"मई"]]},{"n":12,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/29832/size6/9f23c8314f01903043b29b6679c31989.jpg","text":"पालक: अक्टूबर, मार्च से मई \nआम: मार्च से अगस्त   \nतरबूज़: अप्रैल से जून","words":[[330,"पालक"],[331,":"],[332,"अक्टूबर,"],[333,"मार