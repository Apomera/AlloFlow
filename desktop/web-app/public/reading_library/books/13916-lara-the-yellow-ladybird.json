tps://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/38577/size6/2b625a1efee370640d8d23d7bbafadbd.jpg","text":"Even Sesa, the\nsulky spider, \nwas happy to see her.","words":[[33,"Even"],[34,"Sesa,"],[35,"the"],[36,"sulky"],[37,"spider,"],[38,"was"],[39,"happy"],[40,"to"],[41,"see"],[42,"her."]]},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/38578/size6/ae1302457cab7e210da6fecbd8e6d422.jpg","text":"At school, she\nplayed with lots of friends.","words":[[43,"At"],[44,"school,"],[45,"she"],[46,"played"],[47,"with"],[48,"lots"],[49,"of"],[50,"friends."]]},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/38579/size6/15524710615545a75daefba1e9029be2.jpg","text":"But Lara wanted \nto be like the \nother ladybirds. \n“I wish I had \nred wings like you,\nMama,” she\ncried.","words":[[51,"But"],[52,"Lara"],[53,"wanted"],[54,"to"],[55,"be"],[56,"like"],[57,"the"],[58,"other"],[59,"ladybirds."],[60,"“I"],[61,"wish"],[62,"I"],[63,"had"],[64,"red"],[65,"wings"],[66,"like"],[67,"you,"],[68,"Mama,”"],[69,"she"],[70,"cried."]]},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/38580/size6/0ef70273abfc4efe86c07555056dad74.jpg","text":"So one day, to\ncheer her up, Lara’s mother painted her wings bright red.","words":[[71,"So"],[72,"one"],[73,"day,"],[74,"to"],[75,"cheer"],[76,"her"],[77,"up,"],[78,"Lara’s"],[79,"mother"],[80,"painted"],[81,"her"],[82,"wings"],[83,"bright"],[84,"red."]]},{"n":9,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/38581/size6/92f5d6ad1ca8bfb0c68f7497c13b4a4b.jpg","text":"The next morning, nobody greeted Lara on her way to school.","words":[[85,"The"],[86,"next"],[87,"morning,"],[88,"nobody"],[89,"greeted"],[90,"Lara"],[91,"on"],[92,"her"],[93,"way"],[94,"to"],[95,"school."]]},{"n":10,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/38582/size6/0c41cac99bfcc38a75eeca985a8cdf47.jpg","text":"And when she got\nthere, none of her\nfriends said hello.","words":[[96,"And"],[97,"when"],[98,"she"],[99,"got"],[100,"there,"],[101,"none"],[102,"of"],[103,"her"],[104,"friends"],[105,"said"],[106,"hello."]]},{"n":11,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/38583/size6/1427eb78d2378f9192d497abd5a3a153.jpg","text":"Lara sat all\nalone. \nNo one noticed \nher new red wings.","words":[[107,"Lara"],[108,"sat"],[109,"all"],[110,"alone."],[111,"No"],[112,"one"],[113,"noticed"],[114,"her"],[115,"new"],[116,"red"],[117,"wings."]]},{"n":12,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/38584/size6/058ae1839d66a264a48fef4c83a01392.jpg","text":"Until Miss Miya\nspotted her and said: “You’ve painted\nyour lovely yellow wings!”","words":[[118,"Until"],[119,"Miss"],[120,"Miya"],[121,"spotted"],[122,"her"],[123,"and"],[124,"said:"],[125,"“You’ve"],[126,"painted"],[127,"your"],[128,"lovely"],[129,"yellow"],[130,"wings!”"]]},{"n":13,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/38585/size6/e05dea00c5a1cf26682b4abb54aa3136.jpg","text":"Lara’s classmates\nwere shocked. \n“Your wings are special!”\n“So unique!”\n“So rare!”","words":[[131,"Lara’s"],[132,"classmates"],[133,"were"],[134,"shocked."],[135,"“Your"],[136,"wings"],[137,"are"],[138,"special!”"],[139,"“So"],[140,"unique!”"],[141,"“So"],[142,"rare!”"]]},{"n":14,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/38587/size6/24e42a24dc32c17d0a7b3de7fd23be5d.jpg","text":"“Lara,” Miss Miya\nsaid, “your yellow wings are what make you you.\nLike Sipho’s spot… and Sally’s legs.”","words":[[143,"“Lara,”"],[144,"Miss"],[145,"Miya"],[146,"said,"],[147,"“your"],[148,"yellow"],[149,"wings"],[150,"are"],[151,"what"],[152,"make"],[153,"you"],[154,"you."],[155,"Like"],[156,"Sipho’s"],[157,"spot…"],[158,"and"],[159,"Sally’s"],[160,"legs.”"]]},{"n":15,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/38588/size6/af5ede35bfdbf04134c33b6c418fb36c.jpg","text":"Back home, Lara\ntook a long bath and scrubbed until her golden wings gleamed.","words":[[161,"Back"],[162,"home,"],[163,"Lara"],[164,"took"],[165,"a"],[166,"long"],[167,"bath"],[168,"and"],[169,"scrubbed"],[170,"until"],[171,"her"],[172,"golden"],[173,"wings"],[174,"gleamed."]]},{"n":16,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/38589/size6/29e91a77593362e7082fb75ee6693268.jpg","text":"“I’ll never paint\nmy wings again!”\nshe thought.\nExcept, maybe once or twice …","words":[[175,"“I’ll"],[176,"never"],[177,"paint"],[178,"my"],[179,"wings"],[180,"again!”"],[181,"she"],[182,"thought."],[183,"Except,"],[184,"maybe"],[185,"once"],[186,"or"],[187,"twice"],[188,"…"]]},{"n":17,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/38590/size6/322cb8464d2985fbd7302d98b964a49f.jpg","text":"To try a bit of\npurple …\nor something nice.\nBut not for ever\nand just for fun.","words":[[189,"To"],[190,"try"],[191,"a"],[192,"bit"],[193,"of"],[194,"purple"],[195,"…"],[196,"or"],[197,"something"],[198,"nice."],[199,"But"],[200,"not"],[201,"for"],[202,"ever"],[203,"and"],[204,"just"],[205,"for"],[206,"fun."]]},{"n":18,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/38591/size6/126f163f82309bce2f99abde33b1d9f9.jpg","text":"19/20","words":null},{"n":19,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/38592/size6/f35f454986ef999ed5a8cff6680d55e9.jpg","text":"20/20","words":null}],"stats":{"pages":19,"words":208}}