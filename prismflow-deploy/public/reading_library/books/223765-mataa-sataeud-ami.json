bea87940808e207321c10f87ffc69a.jpg","text":"حَكَى وَالِدُ رُوجَا قِصَّةً لَهَا:\n\"وَهَكَذَا، عِنْدَمَا أَلْقَى الْبَائِعُ قُبَّعَتَهُ، أَلْقَتِ الْقُرُودُ قُبَّعَاتِهَا أَيْضًا...\".","words":[[186,"حَكَى"],[187,"وَالِدُ"],[188,"رُوجَا"],[189,"قِصَّةً"],[190,"لَهَا:"],[191,"\"وَهَكَذَا،"],[192,"عِنْدَمَا"],[193,"أَلْقَى"],[194,"الْبَائِعُ"],[195,"قُبَّعَتَهُ،"],[196,"أَلْقَتِ"],[197,"الْقُرُودُ"],[198,"قُبَّعَاتِهَا"],[199,"أَيْضًا...\"."]]},{"n":10,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/56077/size6/3ec68f5ee7bbc5383f70238329f1cc0e.jpg","text":"صَاحَتْ رُوجَا: \"أُمِّي\"!\nسَأَلَتْهَا أُمُّهَا: \"مَاذَا فَعَلْتِ طَوَالَ الْيَوْمِ يَا رُوجَا\"؟\nتِيكْ تُوكْ! تِيكْ تُوكْ! \nإِنَّهَا السَّاعَةُ 9 مَسَاءً تَقْرِيبًا.","words":[[200,"صَاحَتْ"],[201,"رُوجَا:"],[202,"\"أُمِّي\"!"],[203,"سَأَلَتْهَا"],[204,"أُمُّهَا:"],[205,"\"مَاذَا"],[206,"فَعَلْتِ"],[207,"طَوَالَ"],[208,"الْيَوْمِ"],[209,"يَا"],[210,"رُوجَا\"؟"],[211,"تِيكْ"],[212,"تُوكْ!"],[213,"تِيكْ"],[214,"تُوكْ!"],[215,"إِنَّهَا"],[216,"السَّاعَةُ"],[217,"9"],[218,"مَسَاءً"],[219,"تَقْرِيبًا."]]},{"n":11,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/56013/size6/e45bb5fe6ae98c72f9aea1fd8562bc08.jpg","text":"قَالَتْ رُوجَا بِابْتِسَامَةٍ عَرِيضَةٍ: \"لَقَدِ اسْتَمْتَعْتُ كَثِيرًا الْيَوْمَ يَا أُمِّي! جَهَّزَ أَبِي وَجْبَةَ الْإِفْطَارِ لِي.\nوَاشْتَرَيْتُ الْبَاذِنْجَانَ مَعَ جَدِّي.\nوَجَهَّزَ جَدِّي الْخُبْزَ لِلْغَدَاءِ.","words":[[220,"قَالَتْ"],[221,"رُوجَا"],[222,"بِابْتِسَامَةٍ"],[223,"عَرِيضَةٍ:"],[224,"\"لَقَدِ"],[225,"اسْتَمْتَعْتُ"],[226,"كَثِيرًا"],[227,"الْيَوْمَ"],[228,"يَا"],[229,"أُمِّي!"],[230,"جَهَّزَ"],[231,"أَبِي"],[232,"وَجْبَةَ"],[233,"الْإِفْطَارِ"],[234,"لِي."],[235,"وَاشْتَرَيْتُ"],[236,"الْبَاذِنْجَانَ"],[237,"مَعَ"],[238,"جَدِّي."],[239,"وَجَهَّزَ"],[240,"جَدِّي"],[241,"الْخُبْزَ"],[242,"لِلْغَدَاءِ."]]},{"n":12,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/56014/size6/6d64f6a3096860df1dd1db1986bfbb14.jpg","text":"وَاسْتَقْبَلْتُ أُخْتِي عِنْدَمَا عَادَتْ مِنَ الْمَدْرَسَةِ. \nوَلَعِبْتُ فِي الْحَدِيقَةِ. \nوَأَطْعَمْتُ سِيلْفِي طَعَامَ الْعَشَاءِ.\nوَحَكَى لِي أَبِي قِصَّةً، وَهَا أَنْتِ قَدْ عُدْتِ الْآنَ\"!","words":[[243,"وَاسْتَقْبَلْتُ"],[244,"أُخْتِي"],[245,"عِنْدَمَا"],[246,"عَادَتْ"],[247,"مِنَ"],[248,"الْمَدْرَسَةِ."],[249,"وَلَعِبْتُ"],[250,"فِي"],[251,"الْحَدِيقَةِ."],[252,"وَأَطْعَمْتُ"],[253,"سِيلْفِي"],[254,"طَعَامَ"],[255,"الْعَشَاءِ."],[256,"وَحَكَى"],[257,"لِي"],[258,"أَبِي"],[259,"قِصَّةً،"],[260,"وَهَا"],[261,"أَنْتِ"],[262,"قَدْ"],[263,"عُدْتِ"],[264,"الْآنَ\"!"]]},{"n":13,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/56021/size6/a0cabb5ffa2aa5923af6eb6a8c188872.jpg","text":"تِيكْ تُوكْ! تِيكْ تُوكْ! \nإِنَّهَا السَّاعَةُ 9 مَسَاءً!","words":[[265,"تِيكْ"],[266,"تُوكْ!"],[267,"تِيكْ"],[268,"تُوكْ!"],[269,"إِنَّهَا"],[270,"السَّاعَةُ"],[271,"9"],[272,"مَسَاءً!"]]},{"n":14,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/56025/size6/b9700f55225056b64b24dedf4db2d02b.jpg","text":"يَوْمِي\nهَذِهِ بَعْضُ الْأَشْيَاءِ الَّتِي تَقُومُ بِهَا رُوجَا فِي أَوْقَاتٍ مُخْتَلِفَةٍ مِنَ الْيَوْمِ.\nمَاذَا فَعَلْتِ أَنْتِ فِي الْوَقْتِ نَفْسِهِ الْبَارِحَةَ؟\nارْسُمِي صُوَرًا لِنَفْسِكِ عَلَى وَرَقَةٍ وَأَنْتِ تَقُومِينَ بِأَشْيَاءَ مُخْتَلِفَةٍ.\n1. تَتَنَاوَلُ رُوجَا وَجْبَةَ الْإِفْطَارِ السَّاعَةَ 8 صَبَاحًا. مَاذَا فَعَلْتِ أَنْتِ السَّاعَةَ 8 صَبَاحًا الْبَارِحَةَ؟\n2. تَذْهَبُ رُوجَا لِلتَّسَوُّقِ السَّاعَةَ 10 صَبَاحًا. مَاذَا فَعَلْتِ أَنْتِ السَّاعَةَ 10صَبَاحًا الْبَارِحَةَ؟\n3. تَتَنَاوَلُ رُوجَا طَعَامَ الْغَدَاءِ السَّاعَةَ 1 بَعْدَ الظُّهْرِ. مَاذَا فَعَلْتِ أَنْتِ السَّاعَةَ 1 بَعْدَ الظُّهْرِ الْبَارِحَةَ؟","words":[[273,"يَوْمِي"],[274,"هَذِهِ"],[275,"بَعْضُ"],[276,"الْأَشْيَاءِ"],[277,"الَّتِي"],[278,"تَقُومُ"],[279,"بِهَا"],[280,"رُوجَا"],[281,"فِي"],[282,"أَوْقَاتٍ"],[283,"مُخْتَلِفَةٍ"],[284,"مِنَ"],[285,"الْيَوْمِ."],[286,"مَاذَا"],[287,"