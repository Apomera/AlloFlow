ग"],[11,"की"],[12,"बरसाती"],[13,"ख़रीद"],[14,"कर"],[15,"दी।"],[16,"“माँ,"],[17,"क्या"],[18,"मैं"],[19,"इसे"],[20,"अभी"],[21,"पहन"],[22,"सकता"],[23,"हूँ?”"],[24,"“नहीं,"],[25,"बेटे!"],[26,"केवल"],[27,"तभी,"],[28,"जब"],[29,"बारिश"],[30,"होगी।"],[31,"और"],[32,"अभी"],[33,"तो"],[34,"आसमान"],[35,"साफ़"],[36,"है।”"]]},{"n":2,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/4577/size6/7e2a12330ed1592b38671c8e828f2da2.jpg","text":"सोमवार धूप से भरा चमकीला दिन था।\n“माँ, क्या आज बारिश होगी?” मनु ने पूछा।\n“नहीं मनु, आज नहीं। आज बरसाती मत पहनना नहीं तो तुम अजीब लगोगे,” माँ बोलीं।","words":[[37,"सोमवार"],[38,"धूप"],[39,"से"],[40,"भरा"],[41,"चमकीला"],[42,"दिन"],[43,"था।"],[44,"“माँ,"],[45,"क्या"],[46,"आज"],[47,"बारिश"],[48,"होगी?”"],[49,"मनु"],[50,"ने"],[51,"पूछा।"],[52,"“नहीं"],[53,"मनु,"],[54,"आज"],[55,"नहीं।"],[56,"आज"],[57,"बरसाती"],[58,"मत"],[59,"पहनना"],[60,"नहीं"],[61,"तो"],[62,"तुम"],[63,"अजीब"],[64,"लगोगे,”"],[65,"माँ"],[66,"बोलीं।"]]},{"n":3,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/4578/size6/6307adabee20b8399316a92eefbc18bf.jpg","text":"मंगलवार को आसमान नीला था।\n“माँ, कब होगी पूरी मेरे मन की बात?” मनु ने पूछा।\n“आज नहीं बेटा! आज तो आसमान मे स़िर्फ एक नन्हा स़फेद बादल है,” माँ बोलीं।","words":[[67,"मंगलवार"],[68,"को"],[69,"आसमान"],[70,"नीला"],[71,"था।"],[72,"“माँ,"],[73,"कब"],[74,"होगी"],[75,"पूरी"],[76,"मेरे"],[77,"मन"],[78,"की"],[79,"बात?”"],[80,"मनु"],[81,"ने"],[82,"पूछा।"],[83,"“आज"],[84,"नहीं"],[85,"बेटा!"],[86,"आज"],[87,"तो"],[88,"आसमान"],[89,"मे"],[90,"स़िर्फ"],[91,"एक"],[92,"नन्हा"],[93,"स़फेद"],[94,"बादल"],[95,"है,”"],[96,"माँ"],[97,"बोलीं।"]]},{"n":4,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/4579/size6/f01f672df1b86412b3fe579a438275f1.jpg","text":"बुधवार को बहुत गर्मी थी।\n“माँ, बारिश क्यों नहीं हो रही?” मनु ने पूछा।\n“बेटे, मुझे लगता है बारिश जल्दी होगी। शायद आज दोपहर तक हो जाये।” माँ बोलीं।","words":[[98,"बुधवार"],[99,"को"],[100,"बहुत"],[101,"