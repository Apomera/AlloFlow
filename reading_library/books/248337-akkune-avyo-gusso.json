ું ચિત્ર દોર્યું...\n“આ લુચ્ચો કાગડો મારી ઈડલી ઉપાડીને ઉડી ગયો.”\nઅક્કુએ કહ્યું.\n“બિચારાને બહુ ભૂખ લાગી હશે.”, અપ્પાએ કહ્યું.","words":[[320,"અને"],[321,"પછી"],[322,"અક્કુએ"],[323,"કાગડાનું"],[324,"ચિત્ર"],[325,"દોર્યું..."],[326,"“આ"],[327,"લુચ્ચો"],[328,"કાગડો"],[329,"મારી"],[330,"ઈડલી"],[331,"ઉપાડીને"],[332,"ઉડી"],[333,"ગયો.”"],[334,"અક્કુએ"],[335,"કહ્યું."],[336,"“બિચારાને"],[337,"બહુ"],[338,"ભૂખ"],[339,"લાગી"],[340,"હશે.”,"],[341,"અપ્પાએ"],[342,"કહ્યું."]]},{"n":13,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/34390/size6/f202ff87629c125194c3c0638cb9fe1a.jpg","text":"અને પછી અક્કુએ તેના શિક્ષિકાનું ચિત્ર દોર્યું...\n“આ મારા શિક્ષક છે, અમલાબેન.”\nઅક્કુએ કહ્યું.\n“હું પડી ગઈ ત્યારે તેમણે મારી મદદ કરી અને મને ગળે લગાવી.”\n“વાહ! તો\nતે કેટલા સારા કહેવાય!” અપ્પાએ કહ્યું.\n“અને પછી તેણે મારા ગાલોને ચીટલી ભરી. મને તે જરાય પસંદ નથી કે કોઈ મારા ગાલોને ચૂટલી ખણે.”\n“ઓહ..! ચૂટલી દુખતી હશે, નહી?”\n“થોડી વાર દુખી પણ હવે નહી.”\n“વાહ એ તો સારું કહેવાય.”","words":[[343,"અને"],[344,"પછી"],[345,"અક્કુએ"],[346,"તેના"],[347,"શિક્ષિકાનું"],[348,"ચિત્ર"],[349,"દોર્યું..."],[350,"“આ"],[351,"મારા"],[352,"શિક્ષક"],[353,"છે,"],[354,"અમલાબેન.”"],[355,"અક્કુએ"],[356,"કહ્યું."],[357,"“હું"],[358,"પડી"],[359,"ગઈ"],[360,"ત્યારે"],[361,"તેમણે"],[362,"મારી"],[363,"મદદ"],[364,"કરી"],[365,"અને"],[366,"મને"],[367,"ગળે"],[368,"લગાવી.”"],[369,"“વાહ!"],[370,"તો"],[371,"તે"],[372,"કેટલા"],[373,"સારા"],[374,"કહેવાય!”"],[375,"અપ્પાએ"],[376,"કહ્યું."],[377,"“અને"],[378,"પછી"],[379,"તેણે"],[380,"મારા"],[381,"ગાલોને"],[382,"ચીટલી"],[383,"ભરી."],[384,"મને"],[385,"તે"],[386,"જરાય"],[387,"પસંદ"],[388,"નથી"],[389,"કે"],[390,"કોઈ"],[391,"મારા"],[392,"ગાલોને"],[393,"ચૂટલી"],[394,"ખણે.”"],[395,"“ઓહ..!"],[396,"ચૂટલી"],[397,"દુખતી"],[398,"હશે,"],[399,"નહી?”"],[400,"“થોડી"],[401,"વાર"],[402,"દુખી"],[403,"પણ"],[404,"હવે"],[405,"નહી.”"],[406,"“વાહ"],[407,"એ"],[408,"તો"],[409,"સારું"],[410,"કહેવાય.”"]]},{"n":14,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/34656/size6/e16c8be2609807e76fd0d98755b83262.jpg","text":"“જો,તું કેટલું સરસ ચિત્ર દોરે છે \nઅક્કુ?” અપ્પાએ કહ્યું.\n“તું સાચે જ એક ચિત્રકાર છો હો! શું હવે તું તારી અમ્મા માટે પણ કંઈક દોરીશ?”\n“હમ્મ...ભલે!”\nઅક્કુએ કહ્યું. અને પછી ચિત્રો દોરવાનું ચાલું કર્યું.\n“આ (સફેદ)\nઉંદર છે...અને આ હોડી છે...અને આ નારિયેળ ઝાડ છે...”","words":[[411,"“જો,તું"],[412,"કેટલું"],[413,"સરસ"],[414,"ચિત્ર"],[415,"દોરે"],[416,"છે"],[417,"અક્કુ?”"],[418,"અપ્પાએ"],[419,"કહ્યું."],[420,"“તું"],[421,"સાચે"],[422,"જ"],[423,"એક"],[424,"ચિત્રકાર"],[425,"છો"],[426,"હો!"],[427,"શું"],[428,"હવે"],[429,"તું"],[430,"તારી"],[431,"અમ્મા"],[432,"માટે"],[433,"પણ"],[434,"કંઈક"],[435,"દોરીશ?”"],[436,"“હમ્મ...ભલે!”"],[437,"અક્કુએ"],[438,"કહ્યું."],[439,"અને"],[440,"પછી"],[441,"ચિત્રો"],[442,"દોરવાનું"],[443,"ચાલું"],[444,"કર્યું."],[445,"“આ"],[446,"(સફેદ)"],[447,"ઉંદર"],[448,"છે...અને"],[449,"આ"],[450,"હોડી"],[451,"છે...અને"],[452,"આ"],[453,"નારિયેળ"],[454,"ઝાડ"],[455,"છે...”"]]},{"n":15,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/34659/size6/85b11bf3e2ea9821eecfa8325880e120.jpg","text":"“અને આ સૂરજમુખીનું ફૂલ છે...અને આ તમારી સાઈકલ છે,\nઅપ્પા...અને આ એક કૂતરો છે...અને આ એક દેડકો છે...”\nથોડીવારમાં તો અક્કુ તે પેલી ઈંટના કારણે પડવાનું, બિક્કુનું તેના પર હસવું\nઅને તેની ઈડલીને કાગડા દ્વારાઉપાડી જવું તે બધું જ ભૂલી ગઈ.\nઅને તેનો ગુસ્સો પણ જાણે છૂમંતર થઈ ગયો!","words":[[456,"“અને"],[457,"આ"],[458,"સૂરજમુખીનું"],[459,"ફૂલ"],[460,"છે...અને"],[461,"આ"],[462,"તમારી"],[463,"સાઈકલ"],[464,"છે,"],[465,"અપ્પા...અને"],[466,"આ"],[467,"એક"],[468,"કૂતરો"],[469,"છે...અને"],[470,"આ"],[471,"એક"],[472,"દેડકો"],[473,"છે...”"],[474,"થોડીવારમાં"],[475,"તો"],[476,"અક્કુ"],[477,"તે"],[478,"પેલી"],[479,"ઈંટના"],[480,"કારણે"],[481,"પડવાનું,"],[482,"બિક્કુનું"],[483,"તેના"],[484,"પર"],[485,"હસવું"],[486,"અને"],[487,"તેની"],[488,"ઈડલીને"],[489,"કાગડા"],[490,"દ્વારાઉપાડી"],[491,"જવું"],[492,"તે"],[493,"બધું"],[494,"જ"],[495,"ભૂલી"],[496,"ગઈ."],[497,"અને"],[498,"તેનો"],[499,"ગુસ્સો"],[500,"પણ"],[501,"જાણે"],[502,"છૂમંતર"],[503,"થઈ"],[504,"ગયો!"]]},{"n":16,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/34655/size6/81cf61cec8c514b77c4321e8678c5112.jpg","text":"જો તમને પણ અક્કુની જેમ ગુસ્સો આવે તો આ ૧૦ વસ્તુઓ કરો.\n૧. જોરથી હસો અને તમારા\nહાથ ઉપર-નીચે કરતાં કરતાં કૂદકા મારો!\n૨. એકદમ ધીમેધીમે શ્વાસ લો અને શ્વાસ છોડો!\n૩. પાણી અથવા છાશ પીઓ.\n૪. ફળનો એક ટુકડો ખાઓ! અથવા એક વડું ખાવ.\n૫. તમે જે અનુભવી રહ્યા તે તમારાથી મોટા વડીલને કહો.\n૬. તમે જે અનુભવી રહ્યા તે\nલખો.\n૭. તમારા ગુસ્સાના કારણનું ચિત્ર દોરો.\n૮. માટીના\nઢગલા સાથે રમો.\n૯. તમારા ગુસ્સાનું ગીત બનાવો અને જોરથી ગાઓ.\n૧૦. વાંદરાની\nજેમ નાચો!","words":[[505,"જો"],[506,"તમને"],[507,"પણ"],[508,"અક્કુની"],[509,"જેમ"],[510,"ગુસ્સો"],[511,"આવે"],[512,"તો"],[513,"આ"],[514,"૧૦"],[515,"વસ્તુઓ"],[516,"કરો."],[517,"૧."],[518,"જોરથી"],[519,"હસો"],[520,"અને"],[521,"તમારા"],[522,"હાથ"],[523,"ઉપર-નીચે"],[524,"કરતાં"],[525,"કરતાં"],[526,"કૂદકા"],[527,"મારો!"],[528,"૨."],[529,"એકદમ"],[530,"ધીમેધીમે"],[531,"શ્વાસ"],[532,"લો"],[533,"અને"],[534,"શ્વાસ"],[535,"છોડો!"],[536,"૩."],[537,"પાણી"],[538,"અથવા"],[539,"છાશ"],[540,"પીઓ."],[541,"૪."],[542,"ફળનો"],[543,"એક"],[544,"ટુકડો"],[545,"ખાઓ!"],[546,"અથવા"],[547,"એક"],[548,"વડું"],[549,"ખાવ."],[550,"૫."],[551,"તમે"],[552,"જે"],[553,"અનુભવી"],[554,"રહ્યા"],[555,"તે"],[556,"તમારાથી"],[557,"મોટા"],[558,"વડીલને"],[559,"કહો."],[560,"૬."],[561,"તમે"],[562,"જે"],[563,"અનુભવી"],[564,"રહ્યા"],[565,"તે"],[566,"લખો."],[567,"૭."],[568,"તમારા"],[569,"ગુસ્સાના"],[570,"કારણનું"],[571,"ચિત્ર"],[572,"દોરો."],[573,"૮."],[574,"માટીના"],[575,"ઢગલા"],[576,"સાથે"],[577,"રમો."],[578,"૯."],[579,"તમારા"],[580,"ગુસ્સાનું"],[581,"ગીત"],[582,"બનાવો"],[583,"અને"],[584,"જોરથી"],[585,"ગાઓ."],[586,"૧૦."],[587,"વાંદરાની"],[588,"જેમ"],[589,"નાચો!"]]}],"stats":{"pages":16,"words":589}}