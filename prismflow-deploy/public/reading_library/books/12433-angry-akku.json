d with\njoy.\nAll,\nexcept Akku. Akku was ANGRY!","words":[[1,"When"],[2,"the"],[3,"last"],[4,"school"],[5,"bell"],[6,"rang,"],[7,"all"],[8,"the"],[9,"children"],[10,"laughed"],[11,"and"],[12,"screamed"],[13,"with"],[14,"joy."],[15,"All,"],[16,"except"],[17,"Akku."],[18,"Akku"],[19,"was"],[20,"ANGRY"],[21,"!"]]},{"n":2,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/34377/size6/5413c850c235276c82d2c830fb4b085b.jpg","text":"\"Akku!\nAkku! Look at the pretty sunflowers!\" said Appa, as they rode\nthrough a field.\n\"GRRMPH!\nThey’re TOO YELLOW! They’re making my eyes hurt!\" said Akku.","words":[[22,"\"Akku!"],[23,"Akku!"],[24,"Look"],[25,"at"],[26,"the"],[27,"pretty"],[28,"sunflowers!\""],[29,"said"],[30,"Appa,"],[31,"as"],[32,"they"],[33,"rode"],[34,"through"],[35,"a"],[36,"field."],[37,"\"GRRMPH!"],[38,"They’re"],[39,"TOO"],[40,"YELLOW!"],[41,"They’re"],[42,"making"],[43,"my"],[44,"eyes"],[45,"hurt!\""],[46,"said"],[47,"Akku."]]},{"n":3,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/34475/size6/c68d43c476fb00e6a0edc6012d080b2a.jpg","text":"\"Akku!\nAkku! Look! Look at all the monkeys!\" said Appa, \npointing at the\nroof of their house.\n\"CHEEE!\"\nsaid Akku. \"SHOOO! Go AWAY! SHOOO!\"","words":[[48,"\"Akku!"],[49,"Akku!"],[50,"Look!"],[51,"Look"],[52,"at"],[53,"all"],[54,"the"],[55,"monkeys!\""],[56,"said"],[57,"Appa,"],[58,"pointing"],[59,"at"],[60,"the"],[61,"roof"],[62,"of"],[63,"their"],[64,"house."],[65,"\"CHEEE!\""],[66,"said"],[67,"Akku."],[68,"\"SHOOO!"],[69,"Go"],[70,"AWAY!"],[71,"SHOOO!\""]]},{"n":4,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/34456/size6/c907e536c48e520b27062b47fadbb313.jpg","text":"5/17","words":null},{"n":5,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/34660/size6/a92710186d254ddcde273e60fcc6278c.jpg","text":"\"Here,\ndrink some buttermilk,\" said Appa. \"It’ll cool you down.\"\n\"HRRRM!\"\