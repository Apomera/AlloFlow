{"schema":"allo-reading-book@1","slug":"250570-khata-alqut","title":"خَطَأُ الْقِطَّةِ","description":"لَمْ يَسْتَطِعِ الصَّبِيُّ فِي هَذِهِ الْقِصَّةِ إِكْمَالَ وَاجِبَاتِهِ الْمَدْرَسِيَّةِ بِسَبَبِ قِطَّةٍ مُشَاغِبَةٍ. رُبَّمَا يَبْدُو كَأَنَّهُ عُذْرٌ سَخِيفٌ، أَلَيْسَ كَذَلِكَ؟ حَسَنًا، اقْرَأِ الْقِصَّةَ لِتَعْرِفَ مَاذَا حَدَثَ لِهَذَا الصَّبِيِّ، وَسَتَرَى كَيْفَ يُمْكِنُ أَنْ يُؤَدِّيَ شَيْءٌ مَا إِلَى شَيْءٍ آخَرَ، ثُمَّ شَيْءٍ آخَرَ، وَهَكَذَا...","language":"Arabic","langCode":"ar","isRtl":true,"level":"2","orientation":"landscape","authors":["Halima Al-Shukaili"],"illustrators":["Priya Kuriyan"],"originalAuthors":[],"publisher":"Education Above All (EAA)","license":"CC BY 4.0","licenseUrl":"https://creativecommons.org/licenses/by/4.0/","sourceId":"storyweaver","contentType":"story","source":{"id":"storyweaver","name":"StoryWeaver, Pratham Books","url":"https://storyweaver.org.in/en/stories/250570-khata-alqut"},"cover":{"card":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/696669/size3/8717a72070ac52bd090aeebc8e6b36e6.jpg","large":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/696669/size6/8717a72070ac52bd090aeebc8e6b36e6.jpg"},"audio":{"src":"https://storage.googleapis.com/story-weaver-e2e-production/stories/250570/audios/story/250570-khata-alqut.mp3","cues":[[1,0,2],[2,2,2.32],[3,2.32,2.76],[4,2.76,4.36],[5,4.36,4.8],[6,4.8,4.96],[7,4.96,5.24],[8,5.24,5.92],[9,5.92,7.04],[10,7.04,8.74],[11,8.74,8.96],[12,8.96,9.48],[13,9.48,9.75],[14,9.75,9.98],[15,9.98,11.42],[16,11.42,11.76],[17,11.76,11.92],[18,11.92,12.32],[19,12.32,12.84],[20,12.84,13.56],[21,13.56,16.3],[22,16.3,16.64],[23,16.64,16.9],[24,16.9,17.3],[25,17.3,18],[26,18,18.3],[27,18.3,19.5],[28,19.5,19.8],[29,19.8,20.32],[30,20.32,20.86],[31,20.86,22.65],[32,22.65,22.88],[33,22.88,23.22],[34,23.22,23.66],[35,23.66,24],[36,24,24.66],[37,24.66,25.64],[38,25.64,26],[39,26,26.8],[40,26.8,30.96],[41,30.96,31.4],[42,31.4,31.62],[43,31.62,32.06]