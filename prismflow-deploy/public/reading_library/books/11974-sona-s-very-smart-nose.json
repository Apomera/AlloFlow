,[65,"Why"],[66,"don’t"],[67,"you"],[68,"just"],[69,"sit"],[70,"and"],[71,"watch"],[72,"me"],[73,"working?”"],[74,"Uncle"],[75,"added"],[76,"a"],[77,"colour"],[78,"and"],[79,"essence"],[80,"to"],[81,"one"],[82,"vessel."],[83,"“Ah-hh-h,"],[84,"that"],[85,"smell"],[86,"goes"],[87,"straight"],[88,"to"],[89,"my"],[90,"throat!"],[91,"That"],[92,"is"],[93,"kala-khatta,"],[94,"right?”"]]},{"n":4,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/33339/size6/8bbb260f97db48fc62996534cb1b245d.jpg","text":"“You\nare right, Sona. That gives the chuskis a tangy taste,” said Uncle. \n“But I can\nsmell something else too. Not a good smell!” said Sona.","words":[[95,"“You"],[96,"are"],[97,"right,"],[98,"Sona."],[99,"That"],[100,"gives"],[101,"the"],[102,"chuskis"],[103,"a"],[104,"tangy"],[105,"taste,”"],[106,"said"],[107,"Uncle."],[108,"“But"],[109,"I"],[110,"can"],[111,"smell"],[112,"something"],[113,"else"],[114,"too."],[115,"Not"],[116,"a"],[117,"good"],[118,"smell!”"],[119,"said"],[120,"Sona."]]},{"n":5,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/33340/size6/7d9f1b10e0aa5bbabc8e6c57311fd17e.jpg","text":"Uncle\nadded a flavour to another vessel. \nSona took a deep breath. “Ah, this is an\nearthy-sweet smell! Pomegranate chuski!”","words":[[121,"Uncle"],[122,"added"],[123,"a"],[124,"flavour"],[125,"to"],[126,"another"],[127,"vessel."],[128,"Sona"],[129,"took"],[130,"a"],[131,"deep"],[132,"breath."],[133,"“Ah,"],[134,"this"],[135,"is"],[136,"an"],[137,"earthy-sweet"],[138,"smell!"],[139,"Pomegranate"],[140,"chuski!”"]]},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/33341/size6/8f9e85e47e579433466dc0684b6c8704.jpg","text":"“Wow,\nSona, you are right again!” said Uncle and went to another vessel. “But I can\nstill smell something that is not nice!” said Sona, holding her nose.","words":[[141,"“Wow,"],[142,"Sona,"],[143,"you"],[144,"are"],[145,"right"],[146,"again!”"],[1