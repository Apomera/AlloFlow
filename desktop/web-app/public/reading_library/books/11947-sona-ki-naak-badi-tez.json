rage.googleapis.com/static.storyweaver.org.in/illustration_crops/33337/size6/d8a11fb32e52ce90b82be8a2f964a985.jpg","text":"चाचा तरह-तरह के स्वाद और ख़ुशबू वाले रस तैयार कर रहे थे। चार-चार पतीलों में आग पर इकट्ठे रस पक रहे थे।\nसोना ने कहा, \"चाचा मैं भी रस पकाऊँगी।\"","words":[[19,"चाचा"],[20,"तरह-तरह"],[21,"के"],[22,"स्वाद"],[23,"और"],[24,"ख़ुशबू"],[25,"वाले"],[26,"रस"],[27,"तैयार"],[28,"कर"],[29,"रहे"],[30,"थे।"],[31,"चार-चार"],[32,"पतीलों"],[33,"में"],[34,"आग"],[35,"पर"],[36,"इकट्ठे"],[37,"रस"],[38,"पक"],[39,"रहे"],[40,"थे।"],[41,"सोना"],[42,"ने"],[43,"कहा,"],[44,"\"चाचा"],[45,"मैं"],[46,"भी"],[47,"रस"],[48,"पकाऊँगी।\""]]},{"n":3,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/33338/size6/bb34dfecb445ff0fdddcd3ecd1d3ecf1.jpg","text":"चाचा बोले, \"नहीं, सोना, तुम बस ध्यान से देखो।\" चाचा ने एक पतीले में रंग और खुशबू डाली। \nसोना ने सूँघ कर कहा, \"गले में खट से लगने वाली गंध। चाचा यह ‘काली खट्टी’ चुस्की का रसा है।\"","words":[[49,"चाचा"],[50,"बोले,"],[51,"\"नहीं,"],[52,"सोना,"],[53,"तुम"],[54,"बस"],[55,"ध्यान"],[56,"से"],[57,"देखो।\""],[58,"चाचा"],[59,"ने"],[60,"एक"],[61,"पतीले"],[62,"में"],[63,"रंग"],[64,"और"],[65,"खुशबू"],[66,"डाली।"],[67,"सोना"],[68,"ने"],[69,"सूँघ"],[70,"कर"],[71,"कहा,"],[72,"\"गले"],[73,"में"],[74,"खट"],[75,"से"],[76,"लगने"],[77,"वाली"],[78,"गंध।"],[79,"चाचा"],[80,"यह"],[81,"‘काली"],[82,"खट्टी’"],[83,"चुस्की"],[84,"का"],[85,"रसा"],[86,"है।\""]]},{"n":4,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/33339/size6/8bbb260f97db48fc62996534cb1b245d.jpg","text":"\"ठीक सोना!\" चाचा ने पतीला हटाया।\n\"मगर कुछ और गंध भी है।\" सोना ने नाक सिकोड़ी, \"अच्छी गंध नहीं चाचा।\"","words":[[87,"\"ठीक"],[88,"सोना!\""],[89,"चाचा"],[90,"ने"],[91,"पतीला"],[92,"हटाया।"],[93,"\"मगर"],[94,"कुछ"],[95,"और"],[96,"गंध"],[97,"भी"],[98,"है।\""],[99,"सोना"],[100,"ने"],[101,"नाक"],[102,"सिकोड़ी,"],[103,"\"अच्छी"],[104,"गंध"],[105,"नहीं"],[106,"चाचा।\""]]},{"n":5,"img":"https://storage.googleapis.com/static.stor