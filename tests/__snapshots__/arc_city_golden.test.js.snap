exports[`Arc City — module contract > board readouts for screen readers (snapshot) 1`] = `
{
  "L1": "Arc City, level: First Light. Author a straight-line beam. The dark node to light is at x 8, y 4. Aim the beam through any gates, over any walls, to reach the node.",
  "L2": "Arc City, level: Cross-Street. Author a straight-line beam. The dark node to light is at x 9, y 2. A gate with an opening from y 3 to 5 is at x 4. Aim the beam through any gates, over any walls, to reach the node.",
  "L3": "Arc City, level: Clear the Wall. Author a parabola beam. The dark node to light is at x 8, y 0.5. A wall 4 units tall stands at x 5. A gate with an opening from y 3.4 to 4.3 is at x 6.5. Aim the beam through any gates, over any walls, to reach the node.",
  "L4": "Arc City, level: Switchback. Author a V-shaped, absolute-value beam. The dark node to light is at x 5, y 1. A gate with an opening from y 4 to 6 is at x 2. A gate with an opening from y 4 to 6 is at x 8. Aim the beam through any gates, over any walls, to reach the node.",
  "L5": "Arc City, level: Sine Boulevard. Author a sine-wave beam. The dark node to light is at x 9.4, y 4. A gate with an opening from y 6 to 6.9 is at x 1.5. A gate with an opening from y 1.1 to 2 is at x 4.7. A gate with an opening from y 6 to 6.9 is at x 7.85. Aim the beam through any gates, over any walls, to reach the node.",
  "L6": "Arc City, level: Tilt Gates. Author a parabola beam. The dark node to light is at x 8.5, y 0.5. A gate with an opening from y 2.5 to 4.5 is at x 3, which the beam must pass while climbing at a slope near 1.5 (give or take 0.5). A gate with an opening from y 2.5 to 4.5 is at x 7, which the beam must pass while descending at a slope near -1.5 (give or take 0.5). Aim the beam through any gates, over any walls, to reach the node.",
  "L7": "Arc City, level: Exponent Reach. Author an exponential beam that curves toward a floor it never touches. The dark node to light is at x 9.5, y 1.1. A gate with an opening from y 4.2 to 4.5 is at x 1. A gate with an opening from y 2.36 to 2.66 is at x 3. A gate with an opening from y 1.53 to 1.83 is at x 5. A gate with an opening from y 1.15 to 1.45 is at x 7. A gate with an opening from y 1 to 1.3 is at x 9. Aim the beam through any gates, over any walls, to reach the node.",
  "L8": "Arc City, level: Logarithm Heights. Author a logarithmic beam — a concave climb that rises fast then slows. The dark node to light is at x 9.5, y 5.7. A gate with an opening from y 1.68 to 1.94 is at x 0.5. A gate with an opening from y 2.26 to 2.52 is at x 1. A gate with an opening from y 3.64 to 3.9 is at x 3. A gate with an opening from y 4.45 to 4.71 is at x 5. A gate with an opening from y 5.03 to 5.29 is at x 7. A gate with an opening from y 5.47 to 5.73 is at x 9. Aim the beam through any gates, over any walls, to reach the node.",
  "L9": "Arc City, The Gauntlet: an adaptive capstone — one challenge from every function family, weakest first.",
}
`;

