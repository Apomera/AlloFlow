# AlloFlow "School Box" Local Deployment Configuration
# Copy this file to .env and adjust values for your district's hardware.

# --- Web Frontend Settings ---
# The port the React frontend will be exposed on your intranet.
WEB_PORT=3000

# --- Local AI Inference (Ollama) Settings ---
# By default, Ollama binds to 11434. 
# You can change this if your IT department has port conflicts.
OLLAMA_PORT=11434

# Which open-source LLM should the system pull on startup? 
# Recommended for hardware with dedicated GPUs: llama3.1 (8B)
# Recommended for standard hardware: phi3.5 (3B)
OLLAMA_MODEL=phi3.5

# --- Local TTS Proxy Settings ---
# The port the Kokoro/Piper audio caching engine runs on.
TTS_PORT=5002

# --- Google Gemini Fallback (Optional) ---
# If you want to allow cloud-fallback for massive generation tasks,
# uncomment and provide your district's API key. 
# (WARNING: Doing so will route prompts outside the local network).
# GOOGLE_API_KEY=your_key_here
