,514.92,515.4],[791,515.4,515.88],[792,515.88,516.12],[793,516.12,516.52],[794,516.52,516.82],[795,516.82,518.22],[796,518.22,520.32],[797,520.32,520.72],[798,520.72,521.2],[799,521.2,522.44],[800,522.44,522.84],[801,522.84,523.32],[802,523.32,523.8],[803,523.8,524.76],[804,524.76,525.12],[805,525.12,525.4],[806,525.4,526.18],[807,526.18,526.56],[808,526.56,526.8],[809,526.8,527.16],[810,527.16,527.4],[811,527.4,527.8],[812,527.8,528.4],[813,528.4,528.88],[814,528.88,529.36],[815,529.36,529.64],[816,529.64,530.28],[817,530.28,530.88],[818,530.88,531.32],[819,531.32,531.62],[820,531.62,532.04],[821,532.04,532.36],[822,532.36,533.08],[823,533.08,533.92],[824,533.92,533.92],[825,533.92,535.6],[826,535.6,536.16],[827,536.16,536.48],[828,536.48,537.36],[829,537.36,537.84],[830,537.84,538.2],[831,538.2,538.92],[832,538.92,539.76],[833,539.76,540.2],[834,540.2,541.32],[835,541.32,541.32],[836,541.32,541.32],[837,541.32,601.32]]},"pages":[{"n":1,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/56727/size6/b4479f10da94c3904d9a138fb6e0d5af.jpg","text":"Tulsa wishes she could visit a forest. Her teacher reads stories about tigers to the class. \nShe loves to hear about forests and animals.","words":[[1,"Tulsa"],[2,"wishes"],[3,"she"],[4,"could"],[5,"visit"],[6,"a"],[7,"forest."],[8,"Her"],[9,"teacher"],[10,"reads"],[11,"stories"],[12,"about"],[13,"tigers"],[14,"to"],[15,"the"],[16,"class."],[17,"S"],[18,"he"],[19,"loves"],[20,"to"],[21,"hear"],[22,"about"],[23,"forests"],[24,"and"],[25,"animals."]]},{"n":2,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/56728/size6/4e66911f0b0d0b7fff30525096767d56.jpg","text":"One day, her wish comes true! Khare Chacha, a senior forest official, invites Tulsa and her friends to visit a forest called Kanha Tiger Reserve. Tulsa and her friends can’t stop grinning. They will go to the forest for a whole day and a whole night!","words":[[26,"One"],[27,"day,"],[28,"her"],[29,"wish"],[30,"comes"],[31,"true!"],[32,"Khare"],[33,"Chacha,"],[34,"a"],[35,"senior"],[36,"forest"],[37,"official,"],[38,"invites"],[39,"Tulsa"],[40,"and"],[41,"her"],[42,"friends"],[43,"to"],[44,"visit"],[45,"a"],[46,"forest"],[47,"called"],[48,"Kanha"],[49,"Tiger"],[50,"Reserve."],[51,"Tulsa"],[52,"and"],[53,"her"],[54,"friends"],[55,"can’t"],[56,"stop"],[57,"grinning."],[58,"They"],[59,"will"],[60,"go"],[61,"to"],[62,"the"],[63,"forest"],[64,"for"],[65,"a"],[66,"whole"],[67,"day"],[68,"and"],[69,"a"],[70,"whole"],[71,"night!"]]},{"n":3,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/56729/size6/4cd757ccbc4e435e2826bb8900c7489a.jpg","text":"It takes four hours by bus from the school to the forest. As soon as Tulsa gets down from the bus, a strong hand shakes her hand and then ruffles her hair. “Welcome to Kanha!” \nIt is Khare Chacha.","words":[[72,"It"],[73,"takes"],[74,"four"],[75,"hours"],[76,"by"],[77,"bus"],[78,"from"],[79,"the"],[80,"school"],[81,"to"],[82,"the"],[83,"forest."],[84,"As"],[85,"soon"],[86,"as"],[87,"Tulsa"],[88,"gets"],[89,"down"],[90,"from"],[91,"the"],[92,"bus,"],[93,"a"],[94,"strong"],[95,"hand"],[96,"shakes"],[97,"her"],[98,"hand"],[99,"and"],[100,"then"],[101,"ruffles"],[102,"her"],[103,"hair."],[104,"“Welcome"],[105,"to"],[106,"Kanha!”"],[107,"It"],[108,"is"],[109,"Khare"],[110,"Chacha."]]},{"n":4,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/56740/size6/c0a931171d17a37011c4b80fadd7c5d3.jpg","text":"Tulsa and her friends Rani, Mithu, and Dipti stay close to one another. “Sniff the air. It smells of trees and leaves!” says Mithu.\n“The air is clean like it has been washed with soap!” adds Rani.","words":[[111,"Tulsa"],[112,"and"],[113,"her"],[114,"friends"],[115,"Rani,"],[116,"Mithu,"],[117,"and"],[118,"Dipti"],[119,"stay"],[120,"close"],[121,"to"],[122,"one"],[123,"another."],[124,"“Sniff"],[125,"the"],[126,"air."],[127,"It"],[128,"smells"],[129,"of"],[130,"trees"],[131,"and"],[132,"leaves!”"],[133,"says"],[134,"Mithu."],[135,"“The"],[136,"air"],[137,"is"],[138,"clean"],[139,"like"],[140,"it"],[141,"has"],[142,"been"],[143,"washed"],[144,"with"],[145,"soap!”"],[146,"adds"],[147,"Rani."]]},{"n":5,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/56731/size6/7398aaf1dc2e6c530e9863ee216e02aa.jpg","text":"It's almost sunset now. Khare Chacha and other forest officials tell them about the forest they will visit tomorrow. They play the sounds of animals and birds for the girls to hear and recognise.","words":[[148,"It's"],[149,"almost"],[150,"sunset"],[151,"now."],[152,"Khare"],[153,"Chacha"],[154,"and"],[155,"other"],[156,"forest"],[157,"officials"],[158,"tell"],[159,"them"],[160,"about"],[161,"the"],[162,"forest"],[163,"they"],[164,"will"],[165,"visit"],[166,"tomorrow."],[167,"They"],[168,"play"],[169,"the"],[170,"sounds"],[171,"of"],[172,"animals"],[173,"and"],[174,"birds"],[175,"for"],[176,"the"],[177,"girls"],[178,"to"],[179,"hear"],[180,"and"],[181,"recognise."]]},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/56732/size6/e9bfe8f72ecf91f22f6317897d260e49.jpg","text":"PIAON! PIAON! \n“It’s a peacock!”\nOOW! OOW!\n“I know! It’s a barking deer.”\nKEEE! KEE!\n“That is the sound of crickets!”\nNext day, Tulsa wakes up at five in the morning. Brrr! It’s cold! Everyone bundles up in warm clothes. One by one, they get into the bus. “All around us there is tall grass covered in a thick blanket of fog,” Ranveer Uncle, the forest guide, tells them. \nTulsa can feel the cold and pure air in her mouth. It tastes like mint leaves.","words":[[182,"PIAON!"],[183,"PIAON!"],[184,"“It’s"],[185,"a"],[186,"peacock!”"],[187,"OOW!"],[188,"OOW!"],[189,"“I"],[190,"know!"],[191,"It’s"],[192,"a"],[193,"barking"],[194,"deer.”"],[195,"KEEE!"],[196,"KEE!"],[197,"“That"],[198,"is"],[199,"the"],[200,"sound"],[201,"of"],[202,"crickets!”"],[203,"Next"],[204,"day,"],[205,"Tulsa"],[206,"wakes"],[207,"up"],[208,"at"],[209,"five"],[210,"in"],[211,"the"],[212,"morning."],[213,"Brrr!"],[214,"It’s"],[215,"cold!"],[216,"Everyone"],[217,"bundles"],[218,"up"],[219,"in"],[220,"warm"],[221,"clothes."],[222,"One"],[223,"by"],[224,"one,"],[225,"they"],[226,"get"],[227,"into"],[228,"the"],[229,"bus."],[230,"“All"],[231,"around"],[232,"us"],[233,"there"],[234,"is"],[235,"tall"],[236,"grass"],[237,"covered"],[238,"in"],[239,"a"],[240,"thick"],[241,"blanket"],[242,"of"],[243,"fog,”"],[244,"Ranveer"],[245,"Uncle,"],[246,"the"],[247,"forest"],[248,"guide,"],[249,"tells"],[250,"them."],[251,"Tulsa"],[252,"can"],[253,"feel"],[254,"the"],[255,"cold"],[256,"and"],[257,"pure"],[258,"air"],[259,"in"],[260,"her"],[261,"mouth."],[262,"It"],[263,"tastes"],[264,"like"],[265,"mint"],[266,"leaves."]]},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/56733/size6/fcc982812f23653f27749a4675d7e412.jpg","text":"“Shhh!” Ranveer Uncle whispers. “There are two jackals right next to our bus.” Everyone listens carefully. They hear the rustling sound of the tall grass. Dried leaves crush under their feet, as the jackals run lightly into the dense forest.","words":[[267,"“Shhh!”"],[268,"Ranveer"],[269,"Uncle"],[270,"whispers."],[271,"“There"],[272,"are"],[273,"two"],[274,"jackals"],[275,"right"],[276,"next"],[277,"to"],[278,"our"],[279,"bus.”"],[280,"Everyone"],[281,"listens"],[282,"carefully."],[283,"They"],[284,"hear"],[285,"the"],[286,"rustling"],[287,"sound"],[288,"of"],[289,"the"],[290,"tall"],[291,"grass."],[292,"Dried"],[293,"leaves"],[294,"crush"],[295,"under"],[296,"their"],[297,"feet,"],[298,"as"],[299,"the"],[300,"jackals"],[301,"run"],[302,"lightly"],[303,"into"],[304,"the"],[305,"dense"],[306,"forest."]]},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/56734/size6/0a0c52e91be291adf9c6553933075c79.jpg","text":"Ranveer Uncle whispers again. “A big deer called sambar is standing on the left side of the road. The deer is brown and has big stem-like horns called antlers on its head.” Everyone focuses to their left.\nHAUNNNNK! HAUNNNK!  The sambar runs off. \"Sounds like a very big horn!” says Tulsa. All the girls laugh.","words":[[307,"Ranveer"],[308,"Uncle"],[309,"whispers"],[310,"again."],[311,"“A"],[312,"big"],[313,"deer"],[314,"called"],[315,"sambar"],[316,"is"],[317,"standing"],[318,"on"],[319,"the"],[320,"left"],[321,"side"],[322,"of"],[323,"the"],[324,"road."],[325,"The"],[326,"deer"],[327,"is"],[328,"brown"],[329,"and"],[330,"has"],[331,"big"],[332,"stem-like"],[333,"horns"],[334,"called"],[335,"antlers"],[336,"on"],[337,"its"],[338,"head.”"],[339,"Everyone"],[340,"focuses"],[341,"to"],[342,"their"],[343,"left."],[344,"HAUNNNNK!"],[345,"HAUNNNK!"],[346,"The"],[347,"sambar"],[348,"runs"],[349,"off."],[350,"\""],[351,"Sounds"],[352,"like"],[353,"a"],[354,"very"],[355,"big"],[356,"horn!”"],[357,"says"],[358,"Tulsa."],[359,"All"],[360,"the"],[361,"girls"],[362,"laugh."]]},{"n":9,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/56735/size6/44f837765d97b51e461b94da1129e173.jpg","text":"Soon, the air becomes even cooler. “We are near a river now,” Ranveer Uncle says. Tulsa can hear the gurgling of the water. So many birds are calling from the trees.","words":[[363,"Soon,"],[364,"the"],[365,"air"],[366,"becomes"],[367,"even"],[368,"cooler."],[369,"“We"],[370,"are"],[371,"near"],[372,"a"],[373,"river"],[374,"now,”"],[375,"Ranveer"],[376,"Uncle"],[377,"says."],[378,"Tulsa"],[379,"can"],[380,"hear"],[381,"the"],[382,"gurgling"],[383,"of"],[384,"the"],[385,"water."],[386,"So"],[387,"many"],[388,"birds"],[389,"are"],[390,"calling"],[391,"from"],[392,"the"],[393,"trees."]]},{"n":10,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/56736/size6/90ce1fb31b7e8f8d43fe6728cf95ab15.jpg","text":"FHWEEE! FHWEEE!\n“That one is whistling!” says Rashmi.\n“Yes Rashmi, that is the call of a thrush,” says Ranveer Uncle.\nKEEECH! KEECH!\n“And that screeching you hear is the call of the jungle babbler.”","words":[[394,"FHWEEE!"],[395,"FHWEEE!"],[396,"“That"],[397,"one"],[398,"is"],[399,"whistling!”"],[400,"says"],[401,"Rashmi."],[402,"“Yes"],[403,"Rashmi,"],[404,"that"],[405,"is"],[406,"the"],[407,"call"],[408,"of"],[409,"a"],[410,"thrush,”"],[411,"says"],[412,"Ranveer"],[413,"Uncle."],[414,"KEEECH!"],[415,"KEECH!"],[416,"“And"],[417,"that"],[418,"screeching"],[419,"you"],[420,"hear"],[421,"is"],[422,"the"],[423,"call"],[424,"of"],[425,"the"],[426,"jungle"],[427,"babbler.”"]]},{"n":11,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/56737/size6/9cf96f50f4a05e26ed653088d2810fc2.jpg","text":"Soft leaves fall from above. Baby monkeys are showering them with leaves! Tulsa picks up a leaf that falls on her. It smells fresh and pure, just like the forest.","words":[[428,"Soft"],[429,"leaves"],[430,"fall"],[431,"from"],[432,"above."],[433,"Baby"],[434,"monkeys"],[435,"are"],[436,"showering"],[437,"them"],[438,"with"],[439,"leaves!"],[440,"Tulsa"],[441,"picks"],[442,"up"],[443,"a"],[444,"leaf"],[445,"that"],[446,"falls"],[447,"on"],[448,"her."],[449,"It"],[450,"smells"],[451,"fresh"],[452,"and"],[453,"pure,"],[454,"just"],[455,"like"],[456,"the"],[457,"forest."]]},{"n":12,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/56738/size6/055417c5277197704457698f62d624c1.jpg","text":"The bus starts moving uphill. \n“Hold this creeper. See how it feels like a strong rope? The leaves are like cotton!” Everyone takes turns to hold the creeper. \n“This is the mahul,” says Ranveer Uncle. “The leaves are used to make small bowls.”","words":[[458,"The"],[459,"bus"],[460,"starts"],[461,"moving"],[462,"uphill."],[463,"“Hold"],[464,"this"],[465,"creeper."],[466,"See"],[467,"how"],[468,"it"],[469,"feels"],[470,"like"],[471,"a"],[472,"strong"],[473,"rope?"],[474,"T"],[475,"he"],[476,"leaves"],[477,"are"],[478,"like"],[479,"cotton!”"],[480,"Every