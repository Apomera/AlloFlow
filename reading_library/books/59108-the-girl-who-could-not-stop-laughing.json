!” Anna told her.\nThe thought of her pet dog Muthu laughing set T. Sundari off again.","words":[[519,"“Today,"],[520,"we"],[521,"laugh"],[522,"to"],[523,"show"],[524,"others"],[525,"that"],[526,"we"],[527,"like"],[528,"them"],[529,"or"],[530,"to"],[531,"express"],[532,"our"],[533,"happiness."],[534,"Other"],[535,"animal"],[536,"species"],[537,"can"],[538,"laugh"],[539,"too,"],[540,"T."],[541,"Sundari."],[542,"“Like"],[543,"chimpanzees,"],[544,"bonobos,"],[545,"rats,"],[546,"dolphins"],[547,"and"],[548,"even"],[549,"dogs!”"],[550,"Anna"],[551,"told"],[552,"her."],[553,"The"],[554,"thought"],[555,"of"],[556,"her"],[557,"pet"],[558,"dog"],[559,"Muthu"],[560,"laughing"],[561,"set"],[562,"T."],[563,"Sundari"],[564,"off"],[565,"again."]]},{"n":17,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/105918/size6/ffdf48c04a74063bec6d57987d8bf0c8.jpg","text":"When the laughter finally subsided, Anna said, “Do you know you just exercised, T. Sundari?”\n“How, Anna? We were talking the whole time.”\n“Whenever you smile even a little, the muscles of your face get to work. So each time you giggle or laugh, it’s a complete workout for your face,” Anna told her.\n“Ooh,” said T. Sundari, “will my cheeks have biceps then?”","words":[[566,"When"],[567,"the"],[568,"laughter"],[569,"finally"],[570,"subsided,"],[571,"Anna"],[572,"said,"],[573,"“Do"],[574,"you"],[575,"know"],[576,"you"],[577,"just"],[578,"exercised,"],[579,"T."],[580,"Sundari?”"],[581,"“How,"],[582,"Anna?"],[583,"We"],[584,"were"],[585,"talking"],[586,"the"],[587,"whole"],[588,"time.”"],[589,"“Whenever"],[590,"you"],[591,"smile"],[592,"even"],[593,"a"],[594,"little,"],[595,"the"],[596,"muscles"],[597,"of"],[598,"your"],[599,"face"],[600,"get"],[601,"to"],[602,"work."],[603,"So"],[604,"each"],[605,"time"],[606,"you"],[607,"giggle"],[608,"or"],[609,"laugh,"],[610,"it’s"],[611,"a"],[612,"complete"],[613,"workout"],[614,"for"],[615,"your"],[616,"face,”"],[617,"Anna"],[618,"told"],[619,"her."],[6