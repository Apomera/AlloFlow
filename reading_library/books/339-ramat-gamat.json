","words":[[23,"તેઓ"],[24,"ભેગા"],[25,"રમતા"],[26,"હતા."],[27,"એક"],[28,"દિવસ"],[29,"ગોલુએ"],[30,"કહ્યું,"],[31,"“ચાલ,આજે"],[32,"આપણે"],[33,"નવી"],[34,"રમત"],[35,"રમીએ.”"]]},{"n":3,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/4164/size6/7cf442bcab4b8b77a04b8952acf05833.jpg","text":"“તું બેસી જા. હું એક જ કૂદકો મારીને તારી પીઠ પર\nચઢી જઈશ.”\nછોટુએ સૂચન કર્યું.  \nગોલુ બેસી ગયો. છોટુએ એક મોટી છલાંગ મારી.","words":[[36,"“તું"],[37,"બેસી"],[38,"જા."],[39,"હું"],[40,"એક"],[41,"જ"],[42,"કૂદકો"],[43,"મારીને"],[44,"તારી"],[45,"પીઠ"],[46,"પર"],[47,"ચઢી"],[48,"જઈશ.”"],[49,"છોટુએ"],[50,"સૂચન"],[51,"કર્યું."],[52,"ગોલુ"],[53,"બેસી"],[54,"ગયો."],[55,"છોટુએ"],[56,"એક"],[57,"મોટી"],[58,"છલાંગ"],[59,"મારી."]]},{"n":4,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/4165/size6/47c421dba71f4326098256871213ae8d.jpg","text":"ધમ...મ...મ! એ ગોલુની પીઠ પર\nચઢી\nગયો.\n“વાઉ!” ગોલુ હસ્યો અને બોલ્યો, “હવે મારો વારો. તું બેસી જા અને હું કૂદકો લગાવી તારી પીઠ પર ગોઠવાઈ જાઉં.”","words":[[60,"ધમ...મ...મ!"],[61,"એ"],[62,"ગોલુની"],[63,"પીઠ"],[64,"પર"],[65,"ચઢી"],[66,"ગયો."],[67,"“વાઉ!”"],[68,"ગોલુ"],[69,"હસ્યો"],[70,"અને"],[71,"બોલ્યો,"],[72,"“હવે"],[73,"મારો"],[74,"વારો."],[75,"તું"],[76,"બેસી"],[77,"જા"],[78,"અને"],[79,"હું"],[80,"કૂદકો"],[81,"લગાવી"],[82,"તારી"],[83,"પીઠ"],[84,"પર"],[85,"ગોઠવાઈ"],[86,"જાઉં.”"]]},{"n":5,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/4166/size6/2a1ed1000db583e991e99cdd5b6d1e08.jpg","text":"“તું!”\n“હા, હું.”\n“તું એવું કેવી રીતે કરી શકે?” છોટુ ચિંતામાં બોલ્યો.","words":[[87,"“તું!”"],[88,"“હા,"],[89,"હું.”"],[90,"“તું"],[91,"એવું"],[92,"કેવી"],[93,"રીતે"],[94,"કરી"],[95,"શકે?”"],[96,"છોટુ"],[97,"ચિંતામાં"],[98,"બોલ્યો."]]},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/4167/size6/58232a7004c248f5ea5ce5d2fdb4ab28.jpg","text":"“આવી રીતે!” ગોલુએ એને બતાડ્યું.","words":[[99,"“આવી"],[100,"રીતે!”"],[101,"ગોલુએ"],[102,"એને"