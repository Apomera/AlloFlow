{
  "name": "alloflow-admin",
  "version": "0.11.3",
  "description": "AlloFlow Admin - Setup Wizard & Management",
  "main": "public/main.js",
  "author": "AlloFlow Team",
  "license": "MIT",
  "homepage": "./",
  "dependencies": {
    "lucide-react": "^1.7.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "electron": "^27.3.11",
    "electron-builder": "^24.13.3",
    "electron-log": "^5.0.1",
    "electron-updater": "^6.1.7",
    "rimraf": "^5.0.5",
    "wait-on": "^7.0.1"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "clean": "rimraf dist",
    "ensure-python": "node scripts/ensure-python.js",
    "dist": "npm run clean && npm run ensure-python && npm run build && electron-builder --publish never",
    "dist:win": "npm run clean && npm run ensure-python && npm run build && electron-builder -w --publish never",
    "dist:mac": "npm run clean && npm run ensure-python && npm run build && electron-builder --mac --publish never",
    "build:local": "node ../local_build.js",
    "dist:mac:remediation": "node scripts/build-remediation.js mac",
    "dist:win:remediation": "node scripts/build-remediation.js win"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "build": {
    "appId": "com.alloflow.admin",
    "productName": "AlloFlow Admin",
    "afterPack": "./afterPack.js",
    "files": [
      "build/**/*",
      "public/**/*",
      "node_modules/**/*"
    ],
    "extraMetadata": {
      "main": "public/main.js"
    },
    "extraResources": [
      {
        "from": "../python-runtime",
        "to": "python-runtime",
        "filter": ["**/*"]
      },
      {
        "from": "../tts-server",
        "to": "tts-server",
        "filter": ["**/*", "!*.bat"]
      },
      {
        "from": "../local-app/build",
        "to": "local-app",
        "filter": ["**/*"]
      },
      {
        "from": "../local-app/backend",
        "to": "local-app/backend",
        "filter": ["**/*"]
      }
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64"]
        }
      ],
      "category": "public.app-category.education",
      "icon": "public/icons/icon.icns"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AlloFlow Admin",
      "include": "uninstaller.nsh",
      "warningsAsErrors": false
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "public/icons/icon.ico"
    }
  }
}
