ht"],[11,"Chintu"],[12,"fancy"],[13,"glasses."],[14,"Mother"],[15,"bought"],[16,"me"],[17,"a"],[18,"bright"],[19,"blue"],[20,"cap."],[21,"The"],[22,"baby"],[23,"got"],[24,"sugar"],[25,"candy."]]},{"n":3,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/2791/size6/71d6d252238a3ceb3948291ba2865fad.jpg","text":"On the way home, a very strong wind came.\nIt blew my cap away.","words":[[26,"On"],[27,"the"],[28,"way"],[29,"home,"],[30,"a"],[31,"very"],[32,"strong"],[33,"wind"],[34,"came."],[35,"It"],[36,"blew"],[37,"my"],[38,"cap"],[39,"away."]]},{"n":4,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/2792/size6/08a18c29e1aff75deb9416131409b928.jpg","text":"My cap got stuck on a branch of the old Pipal tree.","words":[[40,"My"],[41,"cap"],[42,"got"],[43,"stuck"],[44,"on"],[45,"a"],[46,"branch"],[47,"of"],[48,"the"],[49,"old"],[50,"Pipal"],[51,"tree."]]},{"n":5,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/2793/size6/cbb7590914f9a56a1e420873d491a8cf.jpg","text":"I cried a lot. \nAnd I did not eat my dinner.","words":[[52,"I"],[53,"cried"],[54,"a"],[55,"lot."],[56,"And"],[57,"I"],[58,"did"],[59,"not"],[60,"eat"],[61,"my"],[62,"dinner."]]},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/2794/size6/30c5a5325f67da008f08afe0d26b3d15.jpg","text":"Later that night, the moon came up.\nIt looked at my cap on the old Pipal tree.","words":[[63,"Later"],[64,"that"],[65,"night,"],[66,"the"],[67,"moon"],[68,"came"],[69,"up."],[70,"It"],[71,"looked"],[72,"at"],[73,"my"],[74,"cap"],[75,"on"],[76,"the"],[77,"old"],[78,"Pipal"],[79,"tree."]]},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/2795/size6/698b1c39dee9c67c31d1eb2bbc86a603.jpg","text":"It tried on my cap. \nThe moon smiled happily. \nI had to smile too.","words":[[80,"It"],[81,"tried"],[82,"on"],[83,"my"],[84,"cap."],[85,"The"],[86,"moon"],[87,"smiled"],[88,"happily."],[89,"I"],[90,"had"],[91,"to"],[92,"smile"],[93,"too."]]},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/2796/size6/a923f4c88afca7f7f21bd661a5f57f63.jpg","text":"After school the next day, my mother gave me a shiny new red cap. “The moon sent it,” she said.","words":[[94,"After"],[95,"school"],[96,"the"],[97,"next"],[98,"day,"],[99,"my"],[100,"mother"],[101,"gave"],[102,"me"],[103,"a"],[104,"shiny"],[105,"new"],[106,"red"],[107,"cap."],[108,"“The"],[109,"moon"],[110,"sent"],[111,"it,”"],[112,"she"],[113,"said."]]},{"n":9,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/2797/size6/70673625fc413701734cc82521eb0ce9.jpg","text":"That night, both the moon and I wore our caps and smiled.\nWe were happy.","words":[[114,"That"],[115,"night,"],[116,"both"],[117,"the"],[118,"moon"],[119,"and"],[120,"I"],[121,"wore"],[122,"our"],[123,"caps"],[124,"and"],[125,"smiled."],[126,"We"],[127,"were"],[128,"happy."]]},{"n":10,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/2798/size6/43a09a01293fed4b7626ce466ed01489.jpg","text":"Do you think the sun needs a hat?","words":[[129,"Do"],[130,"you"],[131,"think"],[132,"the"],[133,"sun"],[134,"needs"],[135,"a"],[136,"hat?"]]},{"n":11,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/2799/size6/7db264d4d80d4c90b80894f15d14e1da.jpg","text":"Guess which cap I am wearing today!","words":[[137,"Guess"],[138,"which"],[139,"cap"],[140,"I"],[141,"am"],[142,"wearing"],[143,"today!"]]}],"stats":{"pages":11,"words":143}}