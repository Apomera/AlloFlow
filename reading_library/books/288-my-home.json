{"schema":"allo-reading-book@1","slug":"288-my-home","title":"My Home","description":"Welcome to my Home!\r\n","language":"English","langCode":"en","isRtl":false,"level":"1","orientation":"landscape","authors":["Manisha Chaudhry"],"illustrators":["Rajeev Verma 'Banjara'"],"originalAuthors":[],"publisher":"Pratham Books","license":"CC BY 4.0","licenseUrl":"https://creativecommons.org/licenses/by/4.0/","sourceId":"storyweaver","contentType":"story","source":{"id":"storyweaver","name":"StoryWeaver, Pratham Books","url":"https://storyweaver.org.in/en/stories/288-my-home"},"cover":{"card":"https://static.storyweaver.org.in/illustration_crops/721927/size3/1ca18189954b1b018db5336dc0be3018.jpg","large":"https://static.storyweaver.org.in/illustration_crops/721927/size6/1ca18189954b1b018db5336dc0be3018.jpg"},"audio":null,"pages":[{"n":1,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/3421/size6/9d51c92986b799cbad6e1c07cab57657.jpg","text":"This is my home.","words":null},{"n":2,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/3422/size6/eb1c334b003770e3f73225521b80bb45.jpg","text":"I live here with my whole family.","words":null},{"n":3,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/3423/size6/5417e0cc7b90683d9ddecaf7841db8c0.jpg","text":"We take off our shoes and chappals here.","words":null},{"n":4,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/3424/size6/eab1d428986274f9dd0dc927cd23b912.jpg","text":"This is where we wash our face and hands.","words":null},{"n":5,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/3425/size6/17c19449d1644f455412a6e4315ba477.jpg","text":"I hang my clothes on the hook.","words":null},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/3426/size6/0214dba475974e3436cacbf05a1f6754.jpg","text":"My grandfather keeps his stick in the corner.","words":null},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/3427/size6/f66d03d620f264af6ec2141f6b31902b.jpg","text":"We also keep our mats there.","words":null},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/3428/size6/22bdbecbe4918017b27bfa694bfce978.jpg","text":"My father keeps his motorcycle outside.","words":null},{"n":9,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/3429/size6/eeb516589979091868238c716b7fae93.jpg","text":"But his helmet is on the cupboard.","words":null},{"n":10,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/3430/size6/62d6a0d306c3d621efdb39a74207d568.jpg","text":"My mother and grandmother keep their saris in the trunk.","words":null},{"n":11,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/3431/size6/a17bc7bcbb4d2ddadf48bc0927c51217.jpg","text":"Tasty food is cooked in the kitchen.","words":null},{"n":12,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/3432/size6/2c8e224b3786e4dbadacaa428efe3896.jpg","text":"When it is cold, we bring out quilts.","words":null},{"n":13,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/3433/size6/2da06c0dd545bbcd4a24c52bc5545af5.jpg","text":"When it is hot, we use a fan.","words":null},{"n":14,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/3434/size6/9089e0d4cb6a71859e351a1dea89e551.jpg","text":"When we have important guests, we bring out the chairs.","words":null},{"n":15,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/3435/size6/8498f00e4d7aae1d9d5614fc1649905c.jpg","text":"You must come and visit my home. Come soon.","words":null}],"stats":{"pages":15,"words":114}}