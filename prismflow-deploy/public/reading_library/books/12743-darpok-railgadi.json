\nचलने से भूमि काँपने लगी और\nआस-पास\nके सभी कुत्ते भागने लगे!\nयह\nतो कमाल हो गया!","words":[[327,"\"ऊ........,\""],[328,"नया"],[329,"इंजन"],[330,"डर"],[331,"के"],[332,"मारे"],[333,"चीखा।"],[334,"पर"],[335,"जानते"],[336,"हैं"],[337,"क्या"],[338,"हुआ?"],[339,"एक"],[340,"ज़ोर"],[341,"की"],[342,"सीटी"],[343,"इंजन"],[344,"से"],[345,"निकली!"],[346,"दाना"],[347,"चुगती"],[348,"हुई"],[349,"कुछ"],[350,"मैनाएँ"],[351,"शोर"],[352,"मचाते"],[353,"हुए"],[354,"उड़"],[355,"गयीं।"],[356,"जैसे"],[357,"ही"],[358,"इंजन"],[359,"आगे"],[360,"बढ़ा,"],[361,"बिजली"],[362,"के"],[363,"तारों"],[364,"पर"],[365,"बैठे"],[366,"कौवे,"],[367,"गौरैया"],[368,"और"],[369,"दूसरी"],[370,"चिड़ियाँ"],[371,"डर"],[372,"के"],[373,"मारे"],[374,"उड़"],[375,"निकलीं।"],[376,"इंजन"],[377,"हँसा"],[378,"कि"],[379,"ये"],[380,"सब"],[381,"उसे"],[382,"देख"],[383,"कर"],[384,"डर"],[385,"रही"],[386,"थीं।"],[387,"उसके"],[388,"चलने"],[389,"से"],[390,"भूमि"],[391,"काँपने"],[392,"लगी"],[393,"और"],[394,"आस-पास"],[395,"के"],[396,"सभी"],[397,"कुत्ते"],[398,"भागने"],[399,"लगे!"],[400,"यह"],[401,"तो"],[402,"कमाल"],[403,"हो"],[404,"गया!"]]},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/2499/size6/5f35f7619a663a85fd43f0338d2814d7.jpg","text":"थोड़ी\nही देर में इंजन अपने घर से\nदूर आ चुका था।\nतभी उसकी नज़र सामने पटरी पर बैठे एक बड़े\nबैल पर पड़ी जो जुगाली कर रहा था।\nइंजन घबराया और डर के मारे उसके मुँह से एक\nज़ोर की चीख निकली, \"ऊ.....।\" और बैल ने\nअपनी दुम उठा जान बचाने के लिए दौड़ लगायी।","words":[[405,"थोड़ी"],[406,"ही"],[407,"देर"],[408,"में"],[409,"इंजन"],[410,"अपने"],[411,"घर"],[412,"से"],[413,"दूर"],[414,"आ"],[415,"चुका"],[416,"था।"],[417,"तभी"],[418,"उसकी"],[419,"नज़र"],[420,"सामने"],[421,"पटरी"],[422,"पर"],[423,"बैठे"],[424,"एक"],[425,"बड़े"],[426,"बैल"],[427,"पर"],[428,"पड़ी"],[429,"जो"],[430,"जुगाली"],[431,"कर"],[432,"रहा"],[433,"था।"],[434,"इंजन"],[435,"घबराया"],[436,"और"],[437,"डर"],[438,"के"],[439,"मारे"],[440,"उसके"],[441,"मुँह"],[442,"से"],[443,"एक"],[444,"ज़ोर"],[445,"की"],[446,"चीख"],[44