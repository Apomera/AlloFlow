 leg do you \nplace before which, when you go for a walk.\"","words":[[185,"“Is"],[186,"that"],[187,"so?”"],[188,"says"],[189,"Elder"],[190,"Ant"],[191,"with"],[192,"a"],[193,"sigh."],[194,"\"Tell"],[195,"me,"],[196,"Mr"],[197,"Centipede,"],[198,"which"],[199,"leg"],[200,"do"],[201,"you"],[202,"place"],[203,"before"],[204,"which,"],[205,"when"],[206,"you"],[207,"go"],[208,"for"],[209,"a"],[210,"walk.\""]]},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/55309/size6/1f1b35924283993d492b771b17a4cace.jpg","text":"“I start simply with this one…” says Mr Centipede, lifting leg number 4.\n“Oh nooo! I mean… that one.” He lifts leg number 8.\n“Oh noooo! None of them. I mean, one of them.\nOh nooo! I have forgotten what I mean!”","words":[[211,"“I"],[212,"start"],[213,"simply"],[214,"with"],[215,"this"],[216,"one…”"],[217,"says"],[218,"Mr"],[219,"Centipede,"],[220,"lifting"],[221,"leg"],[222,"number"],[223,"4."],[224,"“Oh"],[225,"nooo!"],[226,"I"],[227,"mean…"],[228,"that"],[229,"one.”"],[230,"He"],[231,"lifts"],[232,"leg"],[233,"number"],[234,"8."],[235,"“Oh"],[236,"noooo!"],[237,"None"],[238,"of"],[239,"them."],[240,"I"],[241,"mean,"],[242,"one"],[243,"of"],[244,"them."],[245,"Oh"],[246,"nooo!"],[247,"I"],[248,"have"],[249,"forgotten"],[250,"what"],[251,"I"],[252,"mean!”"]]},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/55332/size6/2bf0108acdbec7d29dff847af9083df4.jpg","text":"“Run, run quickly!” they hear a voice.\n“Who is that?” cries Big Beetle.\n“I am Stick Insect. You, with all those boots, had better run.”","words":[[253,"“Run,"],[254,"run"],[255,"quickly!”"],[256,"they"],[257,"hear"],[258,"a"],[259,"voice."],[260,"“Who"],[261,"is"],[262,"that?”"],[263,"cries"],[264,"Big"],[265,"Beetle."],[266,"“I"],[267,"am"],[268,"Stick"],[269,"Insect."],[270,"You,"],[271,"with"],[272,"all"],[273,"those"],[274,"boots,"],[275,"had"],[276,"better"],[277,"run.”"]]},{"n":9,"img":"https://storage.googl