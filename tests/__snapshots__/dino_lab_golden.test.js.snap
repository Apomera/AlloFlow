<button aria-label="Open Camarasaurus" style="font-size:11px;padding:3px 9px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Camarasaurus</button>
<button aria-label="Open Cryolophosaurus" style="font-size:11px;padding:3px 9px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Cryolophosaurus</button>
<button aria-label="Open Kentrosaurus" style="font-size:11px;padding:3px 9px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Kentrosaurus</button>
<button aria-label="Open Anchiornis" style="font-size:11px;padding:3px 9px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Anchiornis</button>
