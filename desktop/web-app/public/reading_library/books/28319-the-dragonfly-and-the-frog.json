{"schema":"allo-reading-book@1","slug":"28319-the-dragonfly-and-the-frog","title":"La libellula e la rana","description":"A dragonfly meets an animal that sings wonderfully after the rain. A friendship is born between enemy animals.","language":"Italian","langCode":"it","isRtl":false,"level":"2","orientation":"landscape","authors":["lidia pantaleo"],"illustrators":["Malvika Tewari"],"originalAuthors":[],"publisher":"StoryWeaver Community","license":"CC BY 4.0","licenseUrl":"https://creativecommons.org/licenses/by/4.0/","sourceId":"storyweaver","contentType":"story","source":{"id":"storyweaver","name":"StoryWeaver, Pratham Books","url":"https://storyweaver.org.in/en/stories/28319-the-dragonfly-and-the-frog"},"cover":{"card":"https://static.storyweaver.org.in/illustration_crops/57005/size3/9e6f82f2d409f70a8dc3680465381286.jpg","large":"https://static.storyweaver.org.in/illustration_crops/57005/size6/9e6f82f2d409f70a8dc3680465381286.jpg"},"audio":null,"pages":[{"n":1,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/57006/size6/a079223dd73595256e31ca067ce2d9b4.jpg","text":"UNA LIBELLULA VOLAVA SUI FIORI.","words":null},{"n":2,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/57007/size6/a2f7ded65de0aba4827bfedde0b79254.jpg","text":"LA SORPRESE LA PIOGGIA.","words":null},{"n":3,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/57008/size6/b2e7a5988a58180c6787f4cd7a6b9c75.jpg","text":"LE SUE ALI DIVENTARONO PESANTI PESANTI.","words":null},{"n":4,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/57009/size6/707e04e70a1eba199c56d1481ddc3265.jpg","text":"NON SAPENDO CHE FARE, SI FERMO'. SCELSE UNA BELLA FOGLIA E SI APPOGGIO' AD ESSA.","words":null},{"n":5,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/57010/size6/d82629aa69db3eb40627ad939fb5fa0b.jpg","text":"PRESTO SMISE DI PIOVERE. IL SOLE VENNE FUORI LUMINOSO.","words":null},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/57011/size6/7823801ee7b27ca1bcaec2d0ecf6267c.jpg","text":"VOLANDO SI TROVO' DINANZI UN ALBERO BELLISSIMO. VICINO ALL'ALBERO UNO STAGNO DA CUI ARRIVAVA UN CANTO DELIZIOSO.","words":null},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/57012/size6/8a1f3cadfbe52936fc6bb17c979a0f6b.jpg","text":"LA LIBELLULA SI DIRESSE VERSO LO STAGNO. LI', CON GRANDE MERAVIGLIA, SCOPRI' CHE A CANTARE ERA UNA GROSSA RANA.","words":null},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/57013/size6/73818300cb3de77139e80292dfec3452.jpg","text":"IL CANTO DELLA RANA ATTIRAVA ALTRE LIBELLULE.","words":null},{"n":9,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/57014/size6/259f63f31429e96a978a2e053886b822.jpg","text":"LA LIBELLULA ERA CONFUSA. COME MAI LA RANA, UN SUO NEMICO, CANTAVA PER LE LIBELLULE?","words":null},{"n":10,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/57015/size6/fbdd5ebbf9b48015319808ade9ab9ef9.jpg","text":"FU COSI' CHE LA RANA RACCONTO' LA SUA STORIA ALLA LIBELLULA.\nDA GIRINO LE ALTRE RANE LA PRENDEVANO IN GIRO PER LA SUA VOCE, SOLO UNA LIBELLULA DIVENNE SUA AMICA. E DA ALLORA CANTA SOLO PER LORO.","words":null},{"n":11,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/57016/size6/e7eddb481ca080ac1e4662b11b18fc7e.jpg","text":"A QUEL PUNTO, LA LIBELLULA DECISE DI RESTARE PER UN PO' DI TEMPO VICINO ALLO STAGNO E DI ASCOLTARE IL BEL CANTO DELLA RANA.","words":null}],"stats":{"pages":11,"words":158}}