क"],[643,"शब्द"],[644,"और"],[645,"फिर"],[646,"दूसरा।"],[647,"एक"],[648,"वाक्य"],[649,"और"],[650,"दूसरा"],[651,"वाक्य।"],[652,"लो!"],[653,"अब"],[654,"एक"],[655,"नयी"],[656,"कहानी।"]]},{"n":21,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/53363/size6/0f3c6a7fe6a98e653058990c85a7a24b.jpg","text":"क्योंकि पुचकू के हाथ लग गई है एक नयी किताब।","words":[[657,"क्योंकि"],[658,"पुचकू"],[659,"के"],[660,"हाथ"],[661,"लग"],[662,"गई"],[663,"है"],[664,"एक"],[665,"नयी"],[666,"किताब।"]]}],"stats":{"pages":21,"words":653}}