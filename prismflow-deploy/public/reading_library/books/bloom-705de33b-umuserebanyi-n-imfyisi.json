  "pages": [
    {
      "n": 1,
      "img": "https://s3.amazonaws.com/BloomLibraryBooks/vianneymanirambona2%40gmail.com%2f705de33b-4747-4d4c-9ce0-a09fd82d9170%2fThe+Lizard+and+the+Hyena%2fPic1.jpg",
      "text": "Harabaye umuserebanyi, ukaba wari umuhigi. Umusi umwe, urahiga umusi wose ariko ntihagira ico ufata."
    },
    {
      "n": 2,
      "img": "https://s3.amazonaws.com/BloomLibraryBooks/vianneymanirambona2%40gmail.com%2f705de33b-4747-4d4c-9ce0-a09fd82d9170%2fThe+Lizard+and+the+Hyena%2fPic2.jpg",
      "text": "Ntibitevye, wa muserebanyi ufata ubunyegeri uca utangura kuburya. Uraburya gushika naho uhaga"
    },
    {
      "n": 3,
      "img": "https://s3.amazonaws.com/BloomLibraryBooks/vianneymanirambona2%40gmail.com%2f705de33b-4747-4d4c-9ce0-a09fd82d9170%2fThe+Lizard+and+the+Hyena%2fpic3.jpg",
      "text": "Uhejeje kurya bwa bunyegeri bwose,wa muserebanyi uranyoterwa niko guca uja ku mugezi guhiga icunywa."
    },
    {
      "n": 4,
      "img": "https://s3.amazonaws.com/BloomLibraryBooks/vianneymanirambona2%40gmail.com%2f705de33b-4747-4d4c-9ce0-a09fd82d9170%2fThe+Lizard+and+the+Hyena%2fPic4.jpg",
      "text": "Ubwo nyene wumva ijwi. Wa muserebanyi ngo uhindukire ubona imfyisi ije iwugana. Utangura kwibaza ico wokora ngo iyo mfyisi ntiwurye"
    },
    {
      "n": 5,
      "img": "https://s3.amazonaws.com/BloomLibraryBooks/vianneymanirambona2%40gmail.com%2f705de33b-4747-4d4c-9ce0-a09fd82d9170%2fThe+Lizard+and+the+Hyena%2fPic5.jpg",
      "text": "Wa muserebanyi wumva iciyumviro kiraje. Uca ufata ningoga inkoni ndende utangura kwijiginyura."
    },
    {
      "n": 6,
      "img": "https://s3.amazonaws.com/BloomLibraryBooks/vianneymanirambona2%40gmail.com%2f705de33b-4747-4d4c-9ce0-a09fd82d9170%2fThe+Lizard+and+the+Hyena%2fPic7.jpg",
      "text": "Ya mfyisi ibonye wa mu serebanyi iwubaza iti: \"Mushinganta, wariye iki kugira urinde wihaganyuza ikintu kingana uko kwose?"
    },
    {
      "n": 7,
      "img": "https://s3.amazonaws.com/BloomLibraryBooks/vianneymanirambona2%40gmail.com%2f705de33b-4747-4d4c-9ce0-a09fd82d9170%2fThe+Lizard+and+the+Hyena%2fPic8.jpg",
      "text": "Wa muserebanyi urayishura uti: \"Nariko ndarya inyama z'imfyisi zokeje, none rero mbonye uje, niko kwihaganyura kugira ndye iziwawe zo zikiri nshasha§"
    },
    {
      "n": 8,
      "img": "https://s3.amazonaws.com/BloomLibraryBooks/vianneymanirambona2%40gmail.com%2f705de33b-4747-4d4c-9ce0-a09fd82d9170%2fThe+Lizard+and+the+Hyena%2fPic9.jpg",
      "text": "Imaze kuvyumva, ya mfyisi iratangara cane ica itungwa nayo yameze"
    },
    {
      "n": 9,
      "img": "https://s3.amazonaws.com/BloomLibraryBooks/vianneymanirambona2%40gmail.com%2f705de33b-4747-4d4c-9ce0-a09fd82d9170%2fThe+Lizard+and+the+Hyena%2fPic10.jpg",
      "text": "Ico uwu mugani utwigisha: Uruyeri ni uburyo bwiza bwo kwirwanira"
    }
  ],
