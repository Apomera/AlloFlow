,"different"],[20,"from"],[21,"each"],[22,"other!"]]},{"n":2,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/55131/size6/079698d9f76cc51f19a57458c1b067da.jpg","text":"Goby was a fish with seven fins and no legs. He had very powerful eyes.\nSnap was a pistol shrimp with many legs. She had big, noisy claws. But she could not see very well.","words":[[23,"Goby"],[24,"was"],[25,"a"],[26,"fish"],[27,"with"],[28,"seven"],[29,"fins"],[30,"and"],[31,"no"],[32,"legs."],[33,"He"],[34,"had"],[35,"very"],[36,"powerful"],[37,"eyes."],[38,"Snap"],[39,"was"],[40,"a"],[41,"pistol"],[42,"shrimp"],[43,"with"],[44,"many"],[45,"legs."],[46,"She"],[47,"had"],[48,"big,"],[49,"noisy"],[50,"claws."],[51,"But"],[52,"she"],[53,"could"],[54,"not"],[55,"see"],[56,"very"],[57,"well."]]},{"n":3,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/55132/size6/534775cfa56e11e704cd219a61617c43.jpg","text":"CLICK, CLICK, CLICKETY CLACKET! \nOh oh, what a racket!\nThe noise from Snap’s claws scared away many animals in the ocean.","words":[[58,"CLICK,"],[59,"CLICK,"],[60,"CLICKETY"],[61,"CLACKET!"],[62,"Oh"],[63,"oh,"],[64,"what"],[65,"a"],[66,"racket!"],[67,"The"],[68,"noise"],[69,"from"],[70,"Snap’s"],[71,"claws"],[72,"scared"],[73,"away"],[74,"many"],[75,"animals"],[76,"in"],[77,"the"],[78,"ocean."]]},{"n":4,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/55184/size6/e7e00fc35489ac8350219afcc5fdc14f.jpg","text":"Snap’s eyes were weak, so she often got lost in the dark ocean.\nCLICK, CLICK, CLICKETY CLACKET! \nOh oh, what a racket!\nDon’t worry. Her best friend Goby was always nearby to take her home.","words":[[79,"Snap’s"],[80,"eyes"],[81,"were"],[82,"weak,"],[83,"so"],[84,"she"],[85,"often"],[86,"got"],[87,"lost"],[88,"in"],[89,"the"],[90,"dark"],[91,"ocean."],[92,"CLICK,"],[93,"CLICK,"],[94,"CLICKETY"],[95,"CLACKET!"],[96,"Oh"],[97,"oh,"],[98,"what"],[99,"a"],[100,"racket!"],[101,"Don’t"],[102,"worry."],[103,"Her"],[104,"best"],[105,"friend"],[106,"Goby"],[107,"was"],[108,"always"],[109,"nearby"],[110,"to"],[111,"take"],[112,"her"],[113,"home."]]},{"n":5,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/55185/size6/9662154ad12817b570d8551cba3a494d.jpg","text":"Snap shared her cosy burrow home with Goby. She clawed away any sand that fell into the burrow. \nCLICK, CLICK, CLICKETY CLACKET! Oh oh, what a racket!\nTheir home was always clean and tidy.","words":[[114,"Snap"],[115,"shared"],[116,"her"],[117,"cosy"],[118,"burrow"],[119,"home"],[120,"with"],[121,"Goby."],[122,"She"],[123,"clawed"],[124,"away"],[125,"any"],[126,"sand"],[127,"that"],[128,"fell"],[129,"into"],[130,"the"],[131,"burrow."],[132,"CLICK,"],[133,"CLICK,"],[134,"CLICKETY"],[135,"CLACKET!"],[136,"Oh"],[137,"oh,"],[138,"what"],[139,"a"],[140,"racket!"],[141,"Their"],[142,"home"],[143,"was"],[144,"always"],[145,"clean"],[146,"and"],[147,"tidy."]]},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/55186/size6/190e03afbea0016e2b60c8043a9b64db.jpg","text":"One day, Goby went for a swim on his own.\n“Ah, no more loud clickety-clacks,” he said. “Do I really need such a noisy best friend?” he wondered.","words":[[148,"One"],[149,"day,"],[150,"Goby"],[151,"went"],[152,"for"],[153,"a"],[154,"swim"],[155,"on"],[156,"his"],[157,"own."],[158,"“Ah,"],[159,"no"],[160,"more"],[161,"loud"],[162,"clickety-clacks,”"],[163,"he"],[164,"said."],[165,"“Do"],[166,"I"],[167,"really"],[168,"need"],[169,"such"],[170,"a"],[171,"noisy"],[172,"best"],[173,"friend?”"],[174,"he"],[175,"wondered."]]},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/55183/size6/18e678975ecc39299f82186497bef453.jpg","text":"Suddenly, Goby spotted two bright eyes in front of him. It was a big, hungry, sea bass fish!\n“Time for a goby fish sandwich,” said the sea bass. It swam closer.","words":[[176,"Suddenly,"],[177,"Goby"],[178,"spotted"],[179,"two"],[180,"bright"],[181,"eyes"],[182,"in"],[183,"front"],[184,"of"],[185,"him."],[186,"It"],[187,"was"],[188,"a"],[189,"big,"],[190,"hungry,"],[191,"sea"],[192,"bass"],[193,"fish!"],[194,"“Time"],[195,"for"],[196,"a"],[197,"goby"],[198,"fish"],[199,"sandwich,”"],[200,"said"],[201,"the"],[202,"sea"],[203,"bass."],[204,"It"],[205,"swam"],[206,"closer."]]},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/55195/size6/b2a9e4f79f7b374e1d0abb43e9030210.jpg","text":"Goby closed his eyes, shivering with fright.\nCLICK, CLICK, \nCLICKETY CLACKET! \nOh oh, what a racket!\n“What is that terrible noise?” asked the sea bass.","words":[[207,"Goby"],[208,"closed"],[209,"his"],[210,"eyes,"],[211,"shivering"],[212,"with"],[213,"fright."],[214,"CLICK,"],[215,"CLICK,"],[216,"CLICKETY"],[217,"CLACKET!"],[218,"Oh"],[219,"oh,"],[220,"what"],[221,"a"],[222,"racket!"],[223,"“What"],[224,"is"],[225,"that"],[226,"terrible"],[227,"noise?”"],[228,"asked"],[229,"the"],[230,"sea"],[231,"bass."]]},{"n":9,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/55200/size6/5f8f2e08c122502e92be1901d151e975.jpg","text":"It was Snap!\nCLICK, CLICK, CLICKETY CLACKET! \nOh oh, what a racket!\nIt was too loud for the sea bass. \nIt swam far, far away.","words":[[232,"It"],[233,"was"],[234,"Snap!"],[235,"CLICK,"],[236,"CLICK,"],[237,"CLICKETY"],[238,"CLACKET!"],[239,"Oh"],[240,"oh,"],[241,"what"],[242,"a"],[243,"racket!"],[244,"It"],[245,"was"],[246,"too"],[247,"loud"],[248,"for"],[249,"the"],[250,"sea"],[251,"bass."],[252,"It"],[253,"swam"],[254,"far,"],[255,"far"],[256,"away."]]},{"n":10,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/55189/size6/7b76f764815baa9854855a5e4467f17a.jpg","text":"PHEW! Goby hugged Snap. \nWhat would he do without his noisy best friend!","words":[[257,"PHEW!"],[258,"Goby"],[259,"hugged"],[260,"Snap."],[261,"What"],[262,"would"],[263,"he"],[264,"do"],[265,"with