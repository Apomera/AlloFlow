<button aria-pressed="false" style="font-size:12px;font-weight:500;padding:6px 11px;border-radius:9px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text-soft, #94a3b8)">Kem Kem (4)</button>
<button aria-pressed="false" style="font-size:12px;font-weight:500;padding:6px 11px;border-radius:9px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text-soft, #94a3b8)">Cloverly (4)</button>
<button aria-pressed="false" style="font-size:12px;font-weight:500;padding:6px 11px;border-radius:9px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text-soft, #94a3b8)">Two Medicine (4)</button>
<button aria-pressed="false" style="font-size:12px;font-weight:500;padding:6px 11px;border-radius:9px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text-soft, #94a3b8)">Ischigualasto (4)</button>
