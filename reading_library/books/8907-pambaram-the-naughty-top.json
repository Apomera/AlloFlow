[118,"Paati’s"],[119,"store-room."],[120,"Mani"],[121,"Chitappa"],[122,"wound"],[123,"the"],[124,"string"],[125,"around"],[126,"the"],[127,"top"],[128,"many"],[129,"times"],[130,"and"],[131,"with"],[132,"a"],[133,"flick"],[134,"of"],[135,"his"],[136,"wrist,"],[137,"he"],[138,"let"],[139,"it"],[140,"go."],[141,"Pambaram"],[142,"couldn’t"],[143,"believe"],[144,"it"],[145,"was"],[146,"spinning!"],[147,"Bala"],[148,"and"],[149,"Priya"],[150,"jumped"],[151,"up"],[152,"and"],[153,"down,"],[154,"clapping"],[155,"their"],[156,"hands"],[157,"with"],[158,"glee."]]},{"n":4,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/27857/size6/635dc10cff90f45f74f2f2d99ff6c57b.jpg","text":"Mani\nChitappa scooped Pambaram onto his palm.\n“Show\nme your palm,” said Mani Chitappa and gently placed the spinning\nPambaram in the middle of Priya’s palm. \n“Tee! Hee! Hee!”\ngiggled Priya. “It tickles!”\nPambaram’s\njoy knew no bounds. It decided, today,\nit was going to have fun. Loads and loads of fun! And it wasn’t going to stop spinning ever!","words":[[159,"Mani"],[160,"Chitappa"],[161,"scooped"],[162,"Pambaram"],[163,"onto"],[164,"his"],[165,"palm."],[166,"“Show"],[167,"me"],[168,"your"],[169,"palm,”"],[170,"said"],[171,"Mani"],[172,"Chitappa"],[173,"and"],[174,"gently"],[175,"placed"],[176,"the"],[177,"spinning"],[178,"Pambaram"],[179,"in"],[180,"the"],[181,"middle"],[182,"of"],[183,"Priya’s"],[184,"palm."],[185,"“Tee!"],[186,"Hee!"],[187,"Hee!”"],[188,"giggled"],[189,"Priya."],[190,"“It"],[191,"tickles!”"],[192,"Pambaram’s"],[193,"joy"],[194,"knew"],[195,"no"],[196,"bounds."],[197,"It"],[198,"decided,"],[199,"today,"],[200,"it"],[201,"was"],[202,"going"],[203,"to"],[204,"have"],[205,"fun."],[206,"Loads"],[207,"and"],[208,"loads"],[209,"of"],[210,"fun!"],[211,"And"],[212,"it"],[213,"wasn’t"],[214,"going"],[215,"to"],[216,"stop"],[217,"spinning"],[218,"ever!"]]},{"n":5,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/27858/size6/b33d288a9805d7423e86db52db81b09e.jpg","text":"Pambaram\njumped from Priya’s palm onto Bala’s. “Ha! Ha! Ha!” laughed\nBala. “It does tickle!” Pambaram climbed slowly up his arm and\nperched on his shoulder, spinning gaily all the while. What was\nPambaram going to do now?\nOne\nbig jump and it was back on the ground!","words":[[219,"Pambaram"],[220,"jumped"],[221,"from"],[222,"Priya’s"],[223,"palm"],[224,"onto"],[225,"Bala’s."],[226,"“Ha!"],[227,"Ha!"],[228,"Ha!”"],[229,"laughed"],[230,"Bala."],[231,"“It"],[232,"does"],[233,"tickle!”"],[234,"Pambaram"],[235,"climbed"],[236,"slowly"],[237,"up"],[238,"his"],[239,"arm"],[240,"and"],[241,"perched"],[242,"on"],[243,"his"],[244,"shoulder,"],[245,"spinning"],[246,"gaily"],[247,"all"],[248,"the"],[249,"while."],[250,"What"],[251,"was"],[252,"Pambaram"],[253,"going"],[254,"to"],[255,"do"],[256,"now?"],[257,"One"],[258,"big"],[259,"jump"],[260,"and"],[261,"it"],[262,"was"],[263,"back"],[264,"on"],[265,"the"],[266,"ground!"]]},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/27859/size6/509e16a2286a8f8254e5131a6913d018.jpg","text":"Priya pretended to be Pambaram. With outstretched arms, flailing pigtails and billowing frock, she went round and round and round till she was dizzy!","words":[[267,"Priya"],[268,"pretended"],[269,"to"],[270,"be"],[271,"Pambaram."],[272,"With"],[273,"outstretched"],[274,"arms,"],[275,"flailing"],[276,"pigtails"],[277,"and"],[278,"billowing"],[279,"frock,"],[280,"she"],[281,"went"],[282,"round"],[283,"and"],[284,"round"],[285,"and"],[286,"round"],[287,"till"],[288,"she"],[289,"was"],[290,"dizzy!"]]},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/27861/size6/5aa37da8133c60be5194a0a1f7cc23d2.jpg","text":"“Where is it going?” shouted Bala.\nPambaram was in a mood to play catch-me-if-you-can! \nSpinning wildly, it disappeared into the house. Where was Pambaram now? Under the table!","words":[[291,"“Where"],[292,"is"],[293,"it"],[294,"going?”"],[295,"shouted"],[296,"Bala."],[297,"Pambaram"],[298,"was"],[299,"in"],[300,"a"],[301,"mood"],[302,"to"],[303,"play"],[304,"catch-me-if-you-can!"],[305,"Spinning"],[306,"wildly,"],[307,"it"],[308,"disappeared"],[309,"into"],[310,"the"],[311,"house."],[312,"Where"],[313,"was"],[314,"Pambaram"],[315,"now?"],[316,"Under"],[317,"the"],[318,"table!"]]},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/27862/size6/55a966e58edbc8fcbdce105ccf2c3d01.jpg","text":"Bala crawled under the table but Pambaram vanished like a shot! Where was Pambaram now?\nOn top of the big clock!  \nPriya climbed onto a chair and tried to reach it but Pambaram was off with a flying leap!","words":[[319,"Bala"],[320,"crawled"],[321,"under"],[322,"the"],[323,"table"],[324,"but"],[325,"Pambaram"],[326,"vanished"],[327,"like"],[328,"a"],[329,"shot!"],[330,"Where"],[331,"was"],[332,"Pambaram"],[333,"now?"],[334,"On"],[335,"top"],[336,"of"],[337,"the"],[338,"big"],[339,"clock!"],[340,"Priya"],[341,"climbed"],[342,"onto"],[343,"a"],[344,"chair"],[345,"and"],[346,"tried"],[347,"to"],[348,"reach"],[349,"it"],[350,"but"],[351,"Pambaram"],[352,"was"],[353,"off"],[354,"with"],[355,"a"],[356,"flying"],[357,"leap!"]]},{"n":9,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/27863/size6/f45f3c158f988993e4390eba4b1ae0bc.jpg","text":"Zip! Zap! Zoom! Pambaram streaked into the kitchen. Where was Pambaram now?\nTiptoeing\non the grinder’s rim! Chitra Paati made a grab for it but Pambaram\nwas quicker!\nWhere\nwas Pambaram now? On top of the cupboard!","words":[[358,"Zip!"],[359,"Zap!"],[360,"Zoom!"],[361,"Pambaram"],[362,"streaked"],[363,"into"],[364,"the"],[365,"kitchen."],[366,"Where"],[367,"was"],[368,"Pambaram"],[369,"now?"],[370,"Tiptoeing"],[371,"on"],[372,"the"],[373,"grinder’s"],[374,"rim!"],[375,"Chitra"],[376,"Paati"],[377,"made"],[378,"a"],[379,"grab"],[380,"for"],[381,"it"],[382,"but"],[383,"Pambaram"],[384,"was"],[385,"quicker!"],[386,"Where"],[387,"was"],[388,"Pambaram"],[389,"now?"],[390,"On"],[391,"top"],[392,"of"],[393,"the"],[394,"cupboard!"]]},{"n":10,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/27864/size6/b59ea06b77a74022f26c1a1f9499f6f5.jpg","text":"Girija\nswiped at it with the broom but instead of Pambaram, \nshe brought down\na tin of flour! Pambaram rushed out \nthrough the kitchen door into the\nbackyard.\n \nWhat was Pambaram doing now?\nSpinning madly in a puddle of water!","words":[[395,"Girija"],[396,"swiped"],[397,"at"],[398,"it"],[399,"with"],[400,"the"],[401,"broom"],[402,"but"],[403,"instead"],[404,"of"],[405,"Pambaram,"],[406,"she"],[407,"brought"],[408,"down"],[409,"a"],[410,"tin"],[411,"of"],[412,"flour!"],[413,"Pambaram"],[414,"rushed"],[415,"out"],[416,"through"],[417,"the"],[418,"kitchen"],[419,"door"],[420,"into"],[421,"the"],[422,"backyard."],[423,"What"],[424,"was"],[425,"Pambaram"],[426,"doing"],[427,"now?"],[428,"Spinning"],[429,"madly"],[430,"in"],[431,"a"],[432,"puddle"],[433,"of"],[434,"water!"]]},{"n":11,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/27865/size6/8f4ee7a7af138706e387515ae8bac080.jpg","text":"Bala and Priya tried their best to catch Pambaram but they were only splashed with muddy water!\nWhat was Pambaram doing now? Zigzagging around the feet of Chitra Paati’s hens! “CLUCK! CLUCK! CLUCK!” cried the astonished hens, for they had never set eyes on Pambaram before!","words":[[435,"Bala"],[436,"and"],[437,"Priya"],[438,"tried"],[439,"their"],[440,"best"],[441,"to"],[442,"catch"],[443,"Pambaram"],[444,"but"],[445,"they"],[446,"were"],[447,"only"],[448,"splashed"],[449,"with"],[450,"muddy"],[451,"water!"],[452,"What"],[453,"was"],[454,"Pambaram"],[455,"doing"],[456,"now?"],[457,"Zigzagging"],[458,"around"],[459,"the"],[460,"feet"],[461,"of"],[462,"Chitra"],[463,"Paati’s"],[464,"hens!"],[465,"“CLUCK!"],[466,"CLUCK!"],[467,"CLUCK!”"],[468,"cried"],[4