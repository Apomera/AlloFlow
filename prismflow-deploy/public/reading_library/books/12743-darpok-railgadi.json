,[29,"तुम"],[30,"तो"],[31,"नयी-नयी"],[32,"जगह"],[33,"घूमोगे।"],[34,"खूब"],[35,"यात्राएँ"],[36,"और"],[37,"कारनामे"],[38,"करोगे!\""],[39,"परन्तु"],[40,"इंजन"],[41,"को"],[42,"नयी"],[43,"जगह"],[44,"घूमने"],[45,"की"],[46,"इच्छा"],[47,"नहीं"],[48,"थी,"],[49,"वह"],[50,"तो"],[51,"घबराया"],[52,"हुआ"],[53,"था,"],[54,"सहमा"],[55,"हुआ"],[56,"सा,"],[57,"मानो"],[58,"डर"],[59,"से"],[60,"छोटा"],[61,"हो"],[62,"गया"],[63,"हो!"]]},{"n":2,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/2494/size6/3d3dc0c23be8bddc77b9ed7382e7c272.jpg","text":"उसका\nरेलवे शेड छोड़ कर जाने का\nबिल्कुल मन \nभी नहीं था।\nजब\nमैदानों में गाएँ रँभाती थीं\nवह सहम जाता था।\nदूसरे\nइंजनों के साथ रहने में ही उसे\nमज़ा आता था।\nजब\nकुत्ते भौंकते हुए उसकी ओर\nभागते तो वह\nडरता और उसका मन\nकहीं छुप जाने का होता था!\nपर\nवह छुपता कहाँ और भला शेड में\nकब तक रहा\nजा सकता था?","words":[[64,"उसका"],[65,"रेलवे"],[66,"शेड"],[67,"छोड़"],[68,"कर"],[69,"जाने"],[70,"का"],[71,"बिल्कुल"],[72,"मन"],[73,"भी"],[74,"नहीं"],[75,"था।"],[76,"जब"],[77,"मैदानों"],[78,"में"],[79,"गाएँ"],[80,"रँभाती"],[81,"थीं"],[82,"वह"],[83,"सहम"],[84,"जाता"],[85,"था।"],[86,"दूसरे"],[87,"इंजनों"],[88,"के"],[89,"साथ"],[90,"रहने"],[91,"में"],[92,"ही"],[93,"उसे"],[94,"मज़ा"],[95,"आता"],[96,"था।"],[97,"जब"],[98,"कुत्ते"],[99,"भौंकते"],[100,"हुए"],[101,"उसकी"],[102,"ओर"],[103,"भागते"],[104,"तो"],[105,"वह"],[106,"डरता"],[107,"और"],[108,"उसका"],[109,"मन"],[110,"कहीं"],[111,"छुप"],[112,"जाने"],[113,"का"],[114,"होता"],[115,"था!"],[116,"पर"],[117,"वह"],[118,"छुपता"],[119,"कहाँ"],[120,"और"],[121,"भला"],[122,"शेड"],[123,"में"],[124,"कब"],[125,"तक"],[126,"रहा"],[127,"जा"],[128,"सकता"],[129,"था?"]]},{"n":3,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/2495/size6/032533f81790e260d4922cc834878fe3.jpg","text":"एक\nबूढ़े इंजन ने जो देश भर में\nघूम चुका था,\nदेखा कि यह नया इंजन कैसे डरा हुआ सा था?\nउसने समझाया कि नया इंजन उन गायों और\nकुत्तों से कितना बड़ा है।  \nपर\nनए इंजन को विश्वास न हुआ।\nवह\nबोला,\n\"पर वे सभी कितने बलवान और खूँखार लगते हैं।\nमैं अकेले कहीं नहीं जाऊँगा।\" \"तुम अकेले\nकहाँ हो, इंजन चालक तो तुम्हारे साथ ही है,\"\nबूढ़े इंजन ने समझाया।","words":[[130,"एक"],[131,"बूढ़े"],[132,"इंजन"],[133,"ने"],[134,"जो"],[135,"देश"],[136,"भर"],[137,"में"],[138,"घूम"],[139,"चुका"],[140,"था,"],[141,"देखा"],[142,"कि"],[143,"यह"],[144,"नया"],[145,"इंजन"],[146,"कैसे"],[147,"डरा"],[148,"हुआ"],[149,"सा"],[150,"था?"],[151,"उसने"],[152,"समझाया"],[153,"कि"],[154,"नया"],[155,"इंजन"],[156,"उन"],[157,"गायों"],[158,"और"],[159,"कुत्तों"],[160,"से"],[161,"कितना"],[162,"बड़ा"],[163,"है।"],[164,"पर"],[165,"नए"],[166,"इंजन"],[167,"को"],[168,"विश्वास"],[169,"न"],[170,"हुआ।"],[171,"वह"],[172,"बोला,"],[173,"\"पर"],[174,"वे"],[175,"सभी"],[176,"कितने"],[177,"बलवान"],[178,"और"],[179,"खूँखार"],[180,"लगते"],[181,"हैं।"],[182,"मैं"],[183,"अकेले"],[184,"कहीं"],[185,"नहीं"],[186,"जाऊँगा।\""],[187,"\"तुम"],[188,"अकेले"],[189,"कहाँ"],[190,"हो,"],[191,"इंजन"],[192,"चालक"],[193,"तो"],[194,"तुम्हारे"],[195,"साथ"],[196,"ही"],[197,"है,\""],[198,"बूढ़े"],[199,"इंजन"],[200,"ने"],[201,"समझाया।"]]},{"n":4,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/2496/size6/802198495f62d75d4811a2418652756f.jpg","text":"इंजन\nगाड़ी के गार्ड को भी पहचानता\nथा।\nवह\nदेखने\nमें भला आदमी लगता था और गाड़ी के चलने के\nसमय हरी झंडी दिखाया करता था। इंजन को लगा\nकि भला \nयह छोटा सा आदमी मेरी क्या सहायता करेगा। वह  \nचालक को भी पहचानता था और उसका दयालु चेहरा \nभी उसे अच्छा लगता था।","words":[[202,"इंजन"],[203,"गाड़ी"],[204,"के"],[205,"गार्ड"],[206,"को"],[207,"भी"],[208,"पहचानता"],[209,"था।"],[210,"वह"],[211,"देखने"],[212,"में"],[213,"भला"],[214,"आदमी"],[215,"लगता"],[216,"था"],[217,"और"],[218,"गाड़ी"],[219,"के"],[220,"चलने"],[221,"के"],[222,"समय"],[223,"हरी"],[224,"झंडी"],[225,"दिखाया"],[226,"करता"],[227,"था।"],[228,"इंजन"],[229,"को"],[230,"लगा"],[231,"कि"],[232,"भला"],[233,"यह"],[234,"छोटा"],[235,"सा"],[236,"आदमी"],[237,"मेरी"],[238,"क्या"],[239,"सहायता"],[240,"करेगा।"],[241,"वह"],[242,"चालक"],[243,"