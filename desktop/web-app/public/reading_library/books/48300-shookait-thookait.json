कुछ"],[40,"भी"],[41,"साबुत"],[42,"नहीं"],[43,"बचा"],[44,"था।"]]},{"n":3,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/85274/size6/9a2bc339f821caba30777bd9a99102d5.gif","text":"कमला ने जूते को उठाया। जूते में से नाख़ून फैलाये एक पंजा निकला और फुफकार सी मारते\nहुए कमला को झपट्टा मार कर नोच लिया। खरोंच पर जलन मचने से वह कराह उठी।\nएक चीख के साथ कमला के मुँह से निकला- “शू कैट!”\nफिर शू कैट ने एक जम्हाई ली।","words":[[45,"कमला"],[46,"ने"],[47,"जूते"],[48,"को"],[49,"उठाया।"],[50,"जूते"],[51,"में"],[52,"से"],[53,"नाख़ून"],[54,"फैलाये"],[55,"एक"],[56,"पंजा"],[57,"निकला"],[58,"और"],[59,"फुफकार"],[60,"सी"],[61,"मारते"],[62,"हुए"],[63,"कमला"],[64,"को"],[65,"झपट्टा"],[66,"मार"],[67,"कर"],[68,"नोच"],[69,"लिया।"],[70,"खरोंच"],[71,"पर"],[72,"जलन"],[73,"मचने"],[74,"से"],[75,"वह"],[76,"कराह"],[77,"उठी।"],[78,"एक"],[79,"चीख"],[80,"के"],[81,"साथ"],[82,"कमला"],[83,"के"],[84,"मुँह"],[85,"से"],[86,"निकला-"],[87,"“शू"],[88,"कैट!”"],[89,"फिर"],[90,"शू"],[91,"कैट"],[92,"ने"],[93,"एक"],[94,"जम्हाई"],[95,"ली।"]]},{"n":4,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/85276/size6/4299a846bc9b1df50086247439f751d4.gif","text":"कमला ने शू कैट को उठाया और उसे बकरियों के बाड़े में ले गयी। उसे एक कटोरे में\nदूध पीने के लिए दिया।\nशू कैट ने उसे सूँघा और\nनाक-भौं सिकोड़ते हुए कटोरे में ही थूक दिया।\nउसके बाद शू कैट ने बकरियों के लिए\nसारी घास खा ली। तब से, कमला जहाँ जाती, शू कैट भी उसके पीछे-पीछे वहीं चली जाती।","words":[[96,"कमला"],[97,"ने"],[98,"शू"],[99,"कैट"],[100,"को"],[101,"उठाया"],[102,"और"],[103,"उसे"],[104,"बकरियों"],[105,"के"],[106,"बाड़े"],[107,"में"],[108,"ले"],[109,"गयी।"],[110,"उसे"],[111,"एक"],[112,"कटोरे"],[113,"में"],[114,"दूध"],[115,"पीने"],[116,"के"],[117,"लिए"],[118,"दिया।"],[119,"शू"],[120,"कैट"],[121,"ने"],[122,"उसे"],[123,"सूँघा"],[124,"और"],[125,"नाक-भौं"],[126,"सिकोड़ते"],[127,"हुए"],[128,"कटोरे"],[129,"में"],[130,"ही"],[131,"थूक"],[132,"दिया।"],[133,"उसके"],[134,"बाद"],[135,"शू"],[136,"कैट"],[137,"ने"],[138,"बकरियों"],[139,"के"],[140,"लिए"],[141,"सारी"],[142,"घास"],[143,"खा"],[144,"ली।"],[145,"तब"],[146,"से,"],[147,"कमला"],[148,"जहाँ"],[149,"जाती,"],[150,"शू"],[151,"कैट"],[152,"भी"],[153,"उसके"],[154,"पीछे-पीछे"],[155,"वहीं"],[156,"चली"],[157,"जाती।"]]},{"n":5,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/85277/size6/d37c191140a03cb05059255ac68db4b7.gif","text":"स्कूल में उसने शमीम मिस को पंजा मार दिया। “शू! कैट! वह उस पर बुरी तरह\nचिल्लायीं। शू कैट ने उन पर भी थूक दिया।\nउसने कमला की क्लास के सब बच्चों को खरोंचे मारे। जहाँ शू कैट के पंजों की\nखरोंच लगती, वहाँ हरे रंग का चमकता हुआ घाव हो जाता।","words":[[158,"स्कूल"],[159,"में"],[160,"उसने"],[161,"शमीम"],[162,"मिस"],[163,"को"],[164,"पंजा"],[165,"मार"],[166,"दिया।"],[167,"“शू!"],[168,"कैट!"],[169,"वह"],[170,"उस"],[171,"पर"],[172,"बुरी"],[173,"तरह"],[174,"चिल्लायीं।"],[175,"शू"],[176,"कैट"],[177,"ने"],[178,"उन"],[179,"पर"],[180,"भी"],[181,"थूक"],[182,"दिया।"],[183,"उसने"],[184,"कमला"],[185,"की"],[186,"क्लास"],[187,"के"],[188,"सब"],[189,"बच्चों"],[190,"को"],[191,"खरोंचे"],[192,"मारे।"],[193,"जहाँ"],[194,"शू"],[195,"कैट"],[196,"के"],[197,"पंजों"],[198,"की"],[199,"खरोंच"],[200,"लगती,"],[201,"वहाँ"],[202,"हरे"],[203,"रंग"],[204,"का"],[205,"चमकता"],[206,"हुआ"],[207,"घाव"],[208,"हो"],[209,"जाता।"]]},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/85278/size6/84fe9fa7a0299dc5bcb40a15a80a10d9.gif","text":"शू कैट ने अख़बार वाले को खरोचे मारे। उसने सत्रह बकरियों, तेरह मुर्गियों, तीन\nकुत्तों और एक दादा जी को भी खरोंच डाला।\n“ओए। शू कैट!” उसे देखते ही हर किसी के मुँह से निकल जाता. . . कन्नड़,\nअंग्रेज़ी, तमिल, उर्दू, तेलुगू, मिमियाली, भौकांली, कुड़कुड़ू. . . .यानी\nअपनी-अपनी बोली में! जवाब में बिल्ली सिर्फ़ एक ही बात कहती- “थू!”","words":[[210,"शू"],[211,"कैट"],[212,"ने"],[213,"अख़बार"],[214,"वाले"],[215,"को"],[216,"खरोचे"],[217,"मारे।"],[218,"उसने"],[219,"सत्रह"],[220,"बकरियों,"],[221,"तेरह"],[222,"मुर्गियों,"],[223,"तीन"],[224,"कुत्तों"],[225,"और"],[226,"एक"],