<input type="text" placeholder="e.g. hygiene routine" aria-label="Symbol context" style="width:100%;border:1px solid #d1d5db;border-radius:6px;padding:7px 9px;font-size:13px;box-sizing:border-box;font-family:inherit;background:#fff;color:inherit" value=""/>
</div>
<div>
<label style="font-size:11px;font-weight:600;color:#374151;display:block;margin-bottom:3px">Category</label>
<select aria-label="Symbol category" style="width:100%;border:1px solid #d1d5db;border-radius:6px;padding:7px 9px;font-size:13px;box-sizing:border-box;font-family:inherit;background:#fff;color:inherit">
<option value="" selected="">other</option>
<option value="emotions">emotions</option>
<option value="classroom">classroom</option>
<option value="daily living">daily living</option>
<option value="food">food</option>
<option value="social">social</option>
<option value="actions">actions</option>
<option value="places">places</option>
<option value="objects">objects</option>
</select>
</div>
</div>
<button disabled="" aria-label="Generate symbol" style="padding:8px 14px;background:#d1d5db;color:#6b7280;border:none;border-radius:7px;font-weight:600;font-size:12px;cursor:not-allowed;white-space:nowrap">✨ Generate</button>
<button disabled="" aria-label="Find a validated Mulberry symbol" title="Search the Mulberry symbol set — hand-designed, validated AAC symbols (CC BY-SA)" style="padding:8px 14px;background:#d1d5db;color:#6b7280;border:none;border-radius:7px;font-weight:600;font-size:12px;cursor:not-allowed;white-space:nowrap">🔎 Find validated symbol</button>
<p style="font-size:10px;color:#6b7280;margin:6px 0 0;line-height:1.4">AI-generated symbols are not a validated set (e.g. PCS / SymbolStix) — review each before classroom or clinical use, or use <b style="color:#0e7490">Find validated symbol</b> for hand-designed Mulberry symbols.</p>
</div>
<div style="flex:1;display:flex;flex-direction:column;overflow:hidden;gap:10px">
<div style="flex:1;overflow-y:auto">
<div style="display:flex;flex-direction:column;gap:6px;margin-bottom:8px">
<div style="display:flex;align-items:center;gap:6px">
<span style="font-weight:600;font-size:12px;color:#374151">Gallery (0)</span>
<input type="text" placeholder="🔍 Search symbols…" aria-label="Search symbols in gallery" style="border:1px solid #e5e7eb;border-radius:6px;padding:3px 10px;font-size:11px;flex:1" value=""/>
<button aria-label="Show favorite symbols only" style="padding:3px 8px;border:1px solid #e5e7eb;border-radius:12px;background:#fff;color:#6b7280;font-size:11px;cursor:pointer;font-weight:400;flex-shrink:0">⭐</button>
</div>
<div style="display:flex;gap:4px;flex-wrap:wrap">
<button aria-label="Filter by All" style="padding:2px 8px;border:1px solid #7c3aed;border-radius:10px;background:#ede9fe;color:#7c3aed;font-size:10px;cursor:pointer;font-weight:700">All</button>
<button aria-label="Filter by Nouns" style="padding:2px 8px;border:1px solid #e5e7eb;border-radius:10px;background:#f9fafb;color:#6b7280;font-size:10px;cursor:pointer;font-weight:400">Nouns</button>
<button aria-label="Filter by Verbs" style="padding:2px 8px;border:1px solid #e5e7eb;border-radius:10px;background:#f9fafb;color:#6b7280;font-size:10px;cursor:pointer;font-weight:400">Verbs</button>
<button aria-label="Filter by Adjectives" style="padding:2px 8px;border:1px solid #e5e7eb;border-radius:10px;background:#f9fafb;color:#6b7280;font-size:10px;cursor:pointer;font-weight:400">Adjectives</button>
<button aria-label="Filter by Other" style="padding:2px 8px;border:1px solid #e5e7eb;border-radius:10px;background:#f9fafb;color:#6b7280;font-size:10px;cursor:pointer;font-weight:400">Other</button>
</div>
</div>
<div style="text-align:center;color:#6b7280;padding:30px 0;font-size:13px">Generate your first symbol using the panel on the left.</div>
</div>
</div>
</div>
</div>
</div>
</div>
</div>"
`;

