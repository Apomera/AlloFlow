<div id="dinopanel" role="tabpanel" aria-labelledby="dinotab-dig" style="padding:16px">
<div>
<div style="margin-bottom:12px">
<div style="font-size:18px;font-weight:800">⛏️ Excavate a fossil</div>
<div style="font-size:12.5px;color:var(--allo-stem-text-soft, #94a3b8);margin-top:2px">Dig cells to uncover bones. Clues appear as you go. Then identify what you found.</div>
</div>
<div style="display:grid;grid-template-columns:minmax(0, 1.1fr) minmax(0, 1fr);gap:16px">
<div>
<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px">
<span role="status" aria-live="polite" aria-atomic="true" style="font-size:12.5px;color:var(--allo-stem-text-soft, #94a3b8)">Site #3 | bones found: 3/10 | cells dug: 7/24</span>
<button style="font-size:12px;font-weight:700;padding:5px 12px;border-radius:8px;border:1px solid var(--allo-stem-border, #334155);background:transparent;color:var(--allo-stem-text, #f1f5f9);cursor:pointer">🔄 New dig</button>
</div>
<div role="group" aria-label="Dig grid with 4 rows and 6 columns. Revealed cells stay focusable so bone and rock results can be reviewed." style="display:grid;grid-template-columns:repeat(6, 1fr);gap:6px">
<button aria-label="Cell 1, row 1, column 1, bone fragment uncovered." aria-disabled="true" style="aspect-ratio:1 / 1;border-radius:8px;cursor:default;border:1px solid var(--allo-stem-border, #334155);background:rgba(245,158,11,0.25);color:var(--allo-stem-text, #f1f5f9);font-size:20px;display:flex;align-items:center;justify-content:center">🦴</button>
<button aria-label="Cell 2, row 1, column 2, empty rock uncovered." aria-disabled="true" style="aspect-ratio:1 / 1;border-radius:8px;cursor:default;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9);font-size:20px;display:flex;align-items:center;justify-content:center">·</button>
<button aria-label="Cell 3, row 1, column 3, empty rock uncovered." aria-disabled="true" style="aspect-ratio:1 / 1;border-radius:8px;cursor:default;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9);font-size:20px;display:flex;align-items:center;justify-content:center">·</button>
<button aria-label="Cell 4, row 1, column 4, unopened rock. Press to dig." aria-disabled="false" style="aspect-ratio:1 / 1;border-radius:8px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:#7c5e3b;color:var(--allo-stem-text, #f1f5f9);font-size:20px;display:flex;align-items:center;justify-content:center">
</button>
<button aria-label="Cell 5, row 1, column 5, unopened rock. Press to dig." aria-disabled="false" style="aspect-ratio:1 / 1;border-radius:8px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:#7c5e3b;color:var(--allo-stem-text, #f1f5f9);font-size:20px;display:flex;align-items:center;justify-content:center">
</button>
<button aria-label="Cell 6, row 1, column 6, empty rock uncovered." aria-disabled="true" style="aspect-ratio:1 / 1;border-radius:8px;cursor:default;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9);font-size:20px;display:flex;align-items:center;justify-content:center">·</button>
<button aria-label="Cell 7, row 2, column 1, unopened rock. Press to dig." aria-disabled="false" style="aspect-ratio:1 / 1;border-radius:8px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:#7c5e3b;color:var(--allo-stem-text, #f1f5f9);font-size:20px;display:flex;align-items:center;justify-content:center">
