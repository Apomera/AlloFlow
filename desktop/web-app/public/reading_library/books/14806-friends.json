ords":[[30,"My"],[31,"friend"],[32,"Sisa"],[33,"likes"],[34,"to"],[35,"play"],[36,"hide-and-seek."]]},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/40722/size6/322ba2c13fd8bd2030c50cf3ac720aaf.jpg","text":"My friend Ayanda likes to read.","words":[[37,"My"],[38,"friend"],[39,"Ayanda"],[40,"likes"],[41,"to"],[42,"read."]]},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/40723/size6/a798c60db839ca1235cc1f7bf37c8a32.jpg","text":"Me? I like to do the things they like to do.","words":[[43,"Me?"],[44,"I"],[45,"like"],[46,"to"],[47,"do"],[48,"the"],[49,"things"],[50,"they"],[51,"like"],[52,"to"],[53,"do."]]},{"n":9,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/40724/size6/6d11a8950c7a9b1837446845de13dc69.jpg","text":"I play soccer with Zizo.","words":[[54,"I"],[55,"play"],[56,"soccer"],[57,"with"],[58,"Zizo."]]},{"n":10,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/40725/size6/f78d60c6f215e14685ff75860b1599d9.jpg","text":"I swim with Lele.","words":[[59,"I"],[60,"swim"],[61,"with"],[62,"Lele."]]},{"n":11,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/40726/size6/c3fda1cd3c99535146e166d49dc59828.jpg","text":"I play hide-and-seek with Sisa.","words":[[63,"I"],[64,"play"],[65,"hide-and-seek"],[66,"with"],[67,"Sisa."]]},{"n":12,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/40727/size6/a66e5df13da9654bb50813a2e53cdddd.jpg","text":"Come, friend, what do you like?","words":[[68,"Come,"],[69,"friend,"],[70,"what"],[71,"do"],[72,"you"],[73,"like?"]]},{"n":13,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/40728/size6/81ffb755ee84db0b7cf91778498a854f.jpg","text":"Come, play soccer with us.","words":[[74,"Come,"],[75,"play"],[76,"soccer"],[77,"with"],[78,"us."]]},{"n":14,"img":"https://storage.googleapis.com/static.story