n− ૧  ⁄ ૨ કિગ્રા. તાજાં લાલ ટમેટાં\n− ૧  ⁄ ૨ કિગ્રા. કાંદા\n− ૧  ⁄ ૨ કિગ્રા. બટેટાં\n− ૧ નાળિયેર\n− ૬ લીંબુ\n* અરધું આમ લખાય : ૧  ⁄ ૨.\nએટલે કે કોઇ વસ્તુના બે સરખા ભાગ.\n* કિલોગ્રામ ટૂંકમાં કિગ્રા. લખાય.","words":[[32,"શાકવાળા"],[33,"મોનપ્પાભાઇ"],[34,"એક"],[35,"પછી"],[36,"એક"],[37,"વસ્તુ"],[38,"જોખીને"],[39,"થેલીમાં"],[40,"મૂકતા"],[41,"ગયા"],[42,":"],[43,"−"],[44,"૧ ⁄ ૨"],[45,"કિગ્રા."],[46,"તાજાં"],[47,"લાલ"],[48,"ટમેટાં"],[49,"−"],[50,"૧ ⁄ ૨"],[51,"કિગ્રા."],[52,"કાંદા"],[53,"−"],[54,"૧ ⁄ ૨"],[55,"કિગ્રા."],[56,"બટેટાં"],[57,"−"],[58,"૧"],[59,"નાળિયેર"],[60,"−"],[61,"૬"],[62,"લીંબુ"],[63,"*"],[64,"અરધું"],[65,"આમ"],[66,"લખાય"],[67,":"],[68,"૧ ⁄ ૨."],[69,"એટલે"],[70,"કે"],[71,"કોઇ"],[72,"વસ્તુના"],[73,"બે"],[74,"સરખા"],[75,"ભાગ."],[76,"*"],[77,"કિલોગ્રામ"],[78,"ટૂંકમાં"],[79,"કિગ્રા."],[80,"લખાય."]]},{"n":3,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/64802/size6/c6edff58d34f231acfb316b02347b891.jpg","text":"તારા અને રવિ તો ગાતાં-રમતાં ઘર તરફ ચાલ્યાં :\n“અમારે જોઇએ...\nટમેટાંની ચટણી, ટમેટાંની ચટણી.\nઅમ્માના \nહાથની ભાવતી ટમેટાં-ચટણી!”","words":[[81,"તારા"],[82,"અને"],[83,"રવિ"],[84,"તો"],[85,"ગાતાં-રમતાં"],[86,"ઘર"],[87,"તરફ"],[88,"ચાલ્યાં"],[89,":"],[90,"“અમારે"],[91,"જોઇએ..."],[92,"ટમેટાંની"],[93,"ચટણી,"],[94,"ટમેટાંની"],[95,"ચટણી."],[96,"અમ્માના"],[97,"હાથની"],[98,"ભાવતી"],[99,"ટમેટાં-ચટણી!”"]]},{"n":4,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/64803/size6/10d85afd43f95b6b437e850121f8c491.jpg","text":"અચાનક રવિએ તારાને પૂછ્યું, “જો તો, તારા પગ \nપર કાંઇ ટપકતું હોય એવું લાગે છે?”\nઅરે, આ થેલી તો ભીનીભીની ગઇ છે! સાવ નીચે મૂકેલાં \nટમેટાં ચેપાઇ ગયાં છે.\nતારાએ રવિની ધીરેથી કહ્યું, \n“ભાઇ, આપણી ટમેટા-ચટણી તો ભારે! \nના હો, આ ચટણી અમ્માના હાથની \nહોય એવી નથી!”","words":[[100,"અચાનક"],[101,"રવિએ"],[102,"તારાને"],[103,"પૂછ્યું,"],[104,"“જો"],[105,"તો,"],[106,"તારા"],[107,"પગ"],[108,"પર"],[109,"કાંઇ"],[110,"ટપકતું"],[111,"હોય"],[112,"એવું"],[113,"લાગે"],[114,"છે?”"],[115,"અરે,"],[116,"આ"],[117,"થેલી"],[118,"તો"],[119,"ભીનીભીની"],[120,"ગઇ"],[121,"છે!"],[122,"સાવ"],[123,"નીચે"],[124,"મૂકેલાં"],[125,"ટમેટાં"],[126,"ચેપાઇ"],[127,"ગયાં"],[128,"છે."],[129,"તારાએ"],[130,"રવિની"],[131,"ધીરેથી"],[132,"કહ્યું,"],[133,"“ભાઇ,"],[134,"આપણી"],[135,"ટમેટા-ચટણી"],[136,"તો"],[137,"ભારે!"],[138,"ના"],[139,"હો,"],[140,"આ"],[141,"ચટણી"],[142,"અમ્માના"],[143,"હાથની"],[144,"હોય"],[145,"એવી"],[146,"નથી!”"]]},{"n":5,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/67922/size6/a89ad53683c851c6294a1b74d416da1e.jpg","text":"પછીના અઠવાડિયે તારા અને રવિ વધુ સાવચેત બન્યાં.\n“ભારે ને કઠણ શાકભાજી થેલીને તળિયે અને હળવાં-પોચાં ઉપર રાખવાનાં,” રવિ આવું રટણ લેતો રહ્યો.\nહવે થેલીમાં શાક આમ એક પછી એક ભર્યાં :\n− ૧ તરબૂચ\n− ૧  ⁄ ૨ કિગ્રા. બટેટાં\n− ૧ નાળિયેર\n− ૧  ⁄ ૨ કિગ્રા. દ્રાક્ષ\n− ૬ કાચાં કેળાં \n− ૧  ⁄ ૨ કિગ્રા. ટમેટાં, સહુથી ઉપર.","words":[[147,"પછીના"],[148,"અઠવાડિયે"],[149,"તારા"],[150,"અને"],[151,"રવિ"],[152,"વધુ"],[153,"સાવચેત"],[154,"બન્યાં."],[155,"“ભારે"],[156,"ને"],[157,"કઠણ"],[158,"શાકભાજી"],[159,"થેલીને"],[160,"તળિયે"],[161,"અને"],[162,"હળવાં-પોચાં"],[163,"ઉપર"],[164,"રાખવાનાં,”"],[165,"રવિ"],[166,"આવું"],[167,"રટણ"],[168,"લેતો"],[169,"રહ્યો."],[170,"હવે"],[171,"થેલીમાં"],[172,"શાક"],[173,"આમ"],[174,"એક"],[175,"પછી"],[176,"એક"],[177,"ભર્યાં"],[178,":"],[179,"−"],[180,"૧"],[181,"તરબૂચ"],[182,"−"],[183,"૧ ⁄ ૨"],[184,"કિગ્રા."],[185,"બટેટાં"],[186,"−"],[187,"૧"],[188,"નાળિયેર"],[189,"−"],[190,"૧ ⁄ ૨"],[191,"કિગ્રા."],[192,"દ્રાક્ષ"],[193,"−"],[194,"૬"],[195,"કાચાં"],[196,"કેળાં"],[197,"−"],[198,"૧ ⁄ ૨"],[199,"કિગ્રા."],[200,"ટમેટાં,"],[201,"સહુથી"],[202,"ઉપર."]]},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/67923/size6/31c2c0520c1ded2ff0bf3a647a8d7601.jpg","text":"ઘેર જઈને શું જોયું? કાચાં કેળાં નીચે મૂકેલી દ્રાક્ષનો રસ નીકળી ગયેલો!\nતારા વીલે મોઢે બોલી : “ગયે વખતે આપણે ટમેટાંની ચટણી કરી નાખેલી, આ વખતે દ્રાક્ષનો રસ કાઢ્યો. કોણ જાણે, આવતે વખતે શી ગરબડ થવાની!”","words":[[203,"ઘેર"],[204,"જઈને"],[205,"શું"],[206,"જોયું?"],[207,"કાચાં"],[208,"કેળાં"],[209,"નીચે"],[210,"મૂકેલી"],[211,"દ્રાક્ષનો"],[212,"રસ"],[213,"નીકળી"],[214,"ગયેલો!"],[215,"તારા"],[216,"વીલે"],[217,"મોઢે"],[218,"બોલી"],[219,":"],[220,"“ગયે"],[221,"વખતે"],[222,"આપણે"],[223,"ટમેટાંની"],[224,"ચટણી"],[225,"કરી"],[226,"નાખેલી,"],[227,"આ"],[228,"વખતે"],[229,"દ્રાક્ષનો"],[230,"રસ"],[231,"કાઢ્યો."],[232,"કોણ"],[233,"જાણે,"],[234,"આવતે"],[235,"વખતે"],[236,"શી"],[237,"ગરબડ"],[238,"થવાની!”"]]},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/68024/size6/904c7c2fd179e9a98c5a8ef4b1e44303.jpg","text":"ફરી એક વાર અમ્માએ યાદી આપી તેમાં નારંગી પણ હતી. \nએ પોચી અને હળવી હોય. એટલે એ પણ ટમેટાંની સાથે સહુથી ઉપર.","words":[[239,"ફરી"],[240,"એક"],[241,"વાર"],[242,"અમ્માએ"],[243,"યાદી"],[244,"આપી"],[245,"તેમાં"],[246,"નારંગી"],[247,"પણ"],[248,"હતી."],[249,"એ"],[250,"પોચી"],[251,"અને"],[252,"હળવી"],[253,"હોય."],[254,"એટલે"],[255,"એ"],[256,"પણ"],[257,"ટમેટાંની"],[258,"સાથે"],[259,"સહુથી"],[260,"ઉપર."]]},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/67925/size6/5050466b7e1b7a4b938c9723b2cfbd58.jpg","text":"તારા અને રવિ એમનું ચટણી-ગીત ગણગણતાં ઘેર જતાં હતાં ત્યારે એમના દોસ્તારોએ એમને જોયાં. \nએ બધાં ખૂબ તરસ્યાં હતાં એટલે બધી નારંગી ઓહિયાં કરી ગયાં!","words":[[261,"તારા"],[262,"અને"],[263,"રવિ"],[264,"એમનું"],[265,"ચટણી-ગીત"],[266,"ગણગણતાં"],[267,"ઘેર"],[268,"જતાં"],[269,"હતાં"],[270,"ત્યારે"],[271,"એમના"],[272,"દોસ્તારોએ"],[273,"એમને"],[274,"જોયાં."],[275,"એ"],[276,"બધાં"],[277,"ખૂબ"],[278,"તરસ્યાં"],[279,"હતાં"],[280,"એટલે"],[281,"બધી"],[282,"નારંગી"],[283,"ઓહિયાં"],[284,"કરી"],[285,"ગયાં!"]]},{"n":9,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/67926/size6/7a1874c21edeff6949ac5e4cb49d414a.jpg","text":"ઘરે આવ્યાં ત્યારે નારંગી ખવાઇ ગયાની વાત સાંભળીને અમ્મા તો એમની પર વહાલથી વરસી પડ્યાં. \nઅમ્મા કહે, એમાં ઉદાસ શા માટે થવું?","words":[[286,"ઘરે"],[287,"આવ્યાં"],[288,"ત્યારે"],[289,"નારંગી"],[290,"ખવાઇ"],[291,"ગયાની"],[292,"વાત"],[293,"સાંભળીને"],[294,"અમ્મા"],[295,"તો"],[296,"એમની"],[297,"પર"],[298,"વહાલથી"],[299,"વરસી"],[300,"પડ્યાં."],[301,"અમ્મા"],[302,"કહે,"],[303,"એમાં"],[304,"ઉદાસ"],[305,"શા"],[306,"માટે"],[307,"થવું?"]]},{"n":10,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/64811/size6/f1ea10ec065bc89191b052c7a2b20e99.jpg","text":"પછીના અઠવાડિયે તારા અને રવિ જરા ચતુર રહ્યાં : \nનારંગી બધી ફુદીનાની ઝૂડી નીચે સંતાડી દીધી. હવે તરસ્યાં \nમિત્રોને નારંગીનાં દર્શન નહીં થાય!","words":[[308,"પછીના"],[309,"અઠવાડિયે"],[310,"તારા"],[311,"અને"],[312,"રવિ"],[313,"જરા"],[314,"ચતુર"],[315,"રહ્યાં"],[316,":"],[317,"નારંગી"],[318,"બધી"],[319,"ફુદીનાની"],[320,"ઝૂડી"],[321,"નીચે"],[322,"સંતાડી"],[323,"દીધી."],[324,"હવે"],[325,"તરસ્યાં"],[326,"મિત્રોને"],[327,"નારંગીનાં"],[328,"દર્શન"],[329,"નહીં"],[330,"થાય!"]]},{"n":11,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/67927/size6/eb444f036933c78a1e1bb511107d56c4.jpg","text":"એ રાતે અમ્માએ એમની સ્વાદિષ્ટ ટમેટા-ચટણી સાથે લીંબું-ભાત બનાવ્યાં, અને તારા અને રવિ ભરપેટ જમ્યાં. \nએ પછી એમને શું મળ્યું? હા વળી, મીઠી-મધુરી રસદાર નારંગી!","words":[[331,"એ"],[332,"રાતે"],[333,"અમ્માએ"],[334,"એમની"],[335,"સ્વાદિષ્ટ"],[336,"ટમેટા-ચટણી"],[337,"સાથે"],[338,"લીંબું-ભાત"],[339,"બનાવ્યાં,"],[340,"અને"],[341,"તારા"],[342,"અને"],[343,"રવિ"],[344,"ભરપેટ"],[345,"જમ્યાં."],[346,"એ"],[347,"પછી"],[348,"એમને"],[349,"શું"],[350,"મળ્યું?"],[351,"હા"],[352,"વળી,"],[353,"મીઠી-મધુરી"],[354,"રસદાર"],[355,"નારંગી!"]]},{"n":12,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/64813/size6/15359003d33e4d771a77efa89aa190d4.jpg","text":"તો ચાલો ભરીએ શાકભાજીની થેલી! \n૧. તમારાં બા (મમ્મી) તમને સફરજન, તરબૂચ, અને કેળાં ખરીદવા મોકલે તો થેલીમાં કયું ફળ સહુથી નીચે કદી ન મૂકો?","words":[[356,"તો"],[357,"ચાલો"],[358,"ભરીએ"],[359,"શાકભાજીની"],[360,"થેલી!"],[361,"૧."],[362,"તમારાં"],[363,"બા"],[364,"(મમ્મી)"],[365,"તમને"],[366,"સફરજન,"],[367,"તરબૂચ,"],[368,"અને"],[369,"કેળાં"],