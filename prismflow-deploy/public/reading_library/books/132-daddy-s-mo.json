245.5,246.6],[380,246.6,246.76],[381,246.76,247.2],[382,247.2,248.44],[383,248.44,249.24],[384,249.24,249.78],[385,249.78,250.48],[386,250.48,251.18],[387,251.18,252],[388,252,252.6],[389,252.6,253.1],[390,253.1,254.04],[391,254.04,255.2],[392,255.2,255.9],[393,255.9,256.5],[394,256.5,257.36],[395,257.36,257.52],[396,257.52,257.7],[397,257.7,258.82],[398,258.82,259.72],[399,259.72,260.26],[400,260.26,261.16],[401,261.16,261.48],[402,261.48,321.48]]},"pages":[{"n":1,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/1593/size6/8f2ad771eae7b81887aa8a7feeba18ed.jpg","text":"Anu likes many things about Daddy. She likes the bright paper lanterns he makes, the crisp onion pakodas he fries and the cute tortoise he makes out of paper. Besides, he climbs the stairs with a hop, and wrestles with Uncle for fun. When guests come over, he always makes them laugh.\nAnu likes all these things about Daddy.\nBut do you know what Anu likes most of all? Daddy's moustache!","words":[[1,"Anu"],[2,"likes"],[3,"many"],[4,"things"],[5,"about"],[6,"Daddy."],[7,"She"],[8,"likes"],[9,"the"],[10,"bright"],[11,"paper"],[12,"lanterns"],[13,"he"],[14,"makes,"],[15,"the"],[16,"crisp"],[17,"onion"],[18,"pakodas"],[19,"he"],[20,"fries"],[21,"and"],[22,"the"],[23,"cute"],[24,"tortoise"],[25,"he"],[26,"makes"],[27,"out"],[28,"of"],[29,"paper."],[30,"Besides,"],[31,"he"],[32,"climbs"],[33,"the"],[34,"stairs"],[35,"with"],[36,"a"],[37,"hop,"],[38,"and"],[39,"wrestles"],[40,"with"],[41,"Uncle"],[42,"for"],[43,"fun."],[44,"When"],[45,"guests"],[46,"come"],[47,"over,"],[48,"he"],[49,"always"],[50,"makes"],[51,"them"],[52,"laugh."],[53,"Anu"],[54,"likes"],[55,"all"],[56,"these"],[57,"things"],[58,"about"],[59,"Daddy."],[60,"But"],[61,"do"],[62,"you"],[63,"know"],[64,"what"],[65,"Anu"],[66,"likes"],[67,"most"],[68,"of"],[69,"all?"],[70,"Daddy's"],[71,"moustache!"]]},{"n":2,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/1594/size6/1f2069911dc3649839d81cb4f60fa20c.jpg","text":"Every morning as Daddy shaves, Anu sits by and watches him carefully.\nDaddy holds his tiny pair of scissors between his two fingers, and with a snip-snip-snip he trims his moustache. Anu says, “Now a little to the left…now a bit to the right…no no, Daddy! Don’t make your moustache small! I won’t talk to you if you do!”","words":[[72,"Every"],[73,"morning"],[74,"as"],[75,"Daddy"],[76,"shaves,"],[77,"Anu"],[78,"sits"],[79,"by"],[80,"and"],[81,"watches"],[82,"him"],[83,"carefully."],[84,"Daddy"],[85,"holds"],[86,"his"],[87,"tiny"],[88,"pair"],[89,"of"],[90,"scissors"],[91,"between"],[92,"his"],[93,"two"],[94,"fingers,"],[95,"and"],[96,"with"],[97,"a"],[98,"snip-snip-snip"],[99,"he"],[100,"trims"],[101,"his"],[102,"moustache."],[103,"Anu"],[104,"says,"],[105,"“Now"],[106,"a"],[107,"little"],[108,"to"],[109,"the"],[110,"left…now"],[111,"a"],[112,"bit"],[113,"to"],[114,"the"],[115,"right…no"],[116,"no,"],[117,"Daddy!"],[118,"Don’t"],[119,"make"],[120,"your"],[121,"moustache"],[122,"small!"],[123,"I"],[124,"won’t"],[125,"talk"],[126,"to"],[127,"you"],[128,"if"],[129,"you"],[130,"do!”"]]},{"n":3,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/1595/size6/78567a2ac07672d7dc6bcf088f2151c8.jpg","text":"When Daddy comes out of the shower, Anu takes a little comb and brushes his moustache neatly.\nShe then holds both ends between her fingertips and gives them a twirl!\nThen Daddy’s moustache looks stiff and proud.\n“Done, Daddy! Now don’t you mess it up, okay?” she says sternly.","words":[[131,"When"],[132,"Daddy"],[133,"comes"],[134,"out"],[135,"of"],[136,"the"],[137,"shower,"],[138,"Anu"],[139,"takes"],[140,"a"],[141,"little"],[142,"comb"],[143,"and"],[144,"brushes"],[145,"his"],[146,"moustache"],[147,"neatly."],[148,"She"],[149,"then"],[150,"holds"],[151,"both"],[152,"ends"],[153,"between"],[154,"her"],[155,"fingertips"],[156,"and"],[157,"gives"],[158,"them"],[159,"a"],[160,"twirl!"],[161,"Then"],[162,"Daddy’s"],[163,"moustache"],[164,"looks"],[165,"stiff"],[166,"and"],[167,"proud."],[168,"“Done,"],[169,"Daddy!"],[170,"Now"],[171,"don’t"],[172,"you"],[173,"mess"],[174,"it"],[175,"up,"],[176,"okay?”"],[177,"she"],[178,"says"],[179,"sternly."]]},{"n":4,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/1596/size6/74a1922738adf1db669f954039aa7ba2.jpg","text":"Anu always thinks, if Daddy wears a smart tunic and a turban and rides a tall horse, with a sword across his belt, how grand he'll look!\nJust like a soldier wearing glasses!","words":[[180,"Anu"],[181,"always"],[182,"thinks,"],[183,"if"],[184,"Daddy"],[185,"wears"],[186,"a"],[187,"smart"],[188,"tunic"],[189,"and"],[190,"a"],[191,"turban"],[192,"and"],[193,"rides"],[194,"a"],[195,"tall"],[196,"horse,"],[197,"with"],[198,"a"],[199,"sword"],[200,"across"],[201,"his"],[202,"belt,"],[203,"how"],[204,"grand"],[205,"he'll"],[206,"look!"],[207,"Just"],[208,"like"],[209,"a"],[210,"soldier"],[211,"wearing"],[212,"glasses!"]]},{"n":5,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/1597/size6/d3d41826942be3df086fb7b1114fe51a.jpg","text":"Actually, Anu likes anyone with a moustache. Like the dad of her friend Tuti, whose real name is Smruti. He has such a fat moustache! He must need a big fat comb to brush it.\nTuti’s dad plays very good tennis. But really, he should be a wrestler.\nIf he wears a pleated turban and carries a giant club on his shoulder, he’ll look just great!","words":[[213,"Actually,"],[214,"Anu"],[215,"likes"],[216,"anyone"],[217,"with"],[218,"a"],[219,"moustache."],[220,"Like"],[221,"the"],[222,"dad"],[223,"of"],[224,"her"],[225,"friend"],[226,"Tuti,"],[227,"whose"],[228,"real"],[229,"name"],[230,"is"],[231,"Smruti."],[232,"He"],[233,"has"],[234,"such"],[235,"a"],[236,"fat"],[237,"moustache!"],[238,"He"],[239,"must"],[240,"need"],[241,"a"],[242,"big"],[243,"fat"],[244,"comb"],[245,"to"],[246,"brush"],[247,"it."],[248,"Tuti’s"],[249,"dad"],[250,"plays"],[251,"very"],[252,"good"],[253,"tennis."],[254,"But"],[255,"really,"],[256,"he"],[257,"should"],[258,"be"],[259,"a"],[260,"wrestler."],[261,"If"],[262,"he"],[263,"wears"],[264,"a"],[265,"pleated"],[266,"turban"],[267,"and"],[268,"carries"],[269,"a"],[270,"giant"],[271,"club"],[272,"on"],[273,"his"],[274,"shoulder,"],[275,"he’ll"],[276,"look"],[277,"just"],[278,"great!"]]},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/1598/size6/6fdd9d27f3deb4f92eac847ed53dcb84.jpg","text":"Sahil’s dad has a pencil-thin moustache. Anu wonders how he manages to trim it so fine.\nIf he wears a tall black hat, a long black overcoat and dark glasses, he’ll look just like the detective on TV, who catches all the thieves!","words":[[279,"Sahil’s"],[280,"dad"],[281,"has"],[282,"a"],[283,"pencil-thin"],[284,"moustache."],[285,"Anu"],[286,"wonders"],[287,"how"],[288,"he"],[289,"manages"],[290,"to"],[291,"trim"],[292,"it"],[293,"so"],[294,"fine."],[295,"If"],[296,"he"],[297,"wears"],[298,"a"],[299,"tall"],[300,"black"],[301,"hat,"],[302,"a"],[303,"long"],[304,"black"],[305,"overcoat"],[306,"and"],[307,"dark"],[308,"glasses,"],[309,"he’ll"],[310,"look"],[311,"just"],[312,"like"],[313,"the"],[314,"detective"],[315,"on"],[316,"TV,"],[317,"who"],[318,"catches"],[319,"all"],[320,"the"],[321,"thieves!"]]},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/1599/size6/ed97a4a81eb7ca9ede63a8b3f0fbf72f.jpg","text":"But Grandpa who lives next door has the best moustache of all! It looks as if a big white cloud has come down from the sky to live under his nose! His mouth is hidden behind the cloud.\nAnu is anxious about Grandpa... how can he eat with that cloud in the way?","words":[[322,"But"],[323,"Grandpa"],[324,"who"],[325,"lives"],[326,"next"],[327,"door"],[328,"has"],[329,"the"],[330,"best"],[331,"moustache"],[332,"of"],[333,"all!"],[334,"It"],[335,"looks"],[336,"as"],[337,"if"],[338,"a"],[339,"big"],[340,"white"],[341,"cloud"],[342,"has"],[343,"come"],[344,"down"],[345,"from"],[346,"the"],[347,"sky"],[348,"to"],[349,"live"],[350,"under"],[351,"his"],[352,"nose!"],[353,"His"],[354,"mouth"],[355,"is"],[356,"hidden"],[357,"behind"],[358,"the"],[359,"cloud."],[360,"Anu"],[361,"is"],[362,"anxious"],[363,"about"],[364,"Grandpa..."],[365,"how"],[366,"can"],[367,"he"],[368,"eat"],[369,"with"],[370,"that"],[371,"cloud"],[372,"in"],[373,"the"],[374,"way?"]]},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/1600/size6/077dd29c2517c86155485f0412002c1a.jpg","text":"Anu wonders why a moustache doesn’t grow under her nose.\nEvery morning she wets her soap, makes a lot of lather and gives herself many different kinds of moustaches.\n“My moustache is the best,” she says. “It’s pure white, and so soft! Isn’t it nice?” she asks, happily.","words":[[375,"Anu"],[376,"wonders"],[377,"why"],[378,"a"],[379,"moustache"],[380,"doesn’t"],[381,"grow"],[382,"under"],[383,"her"],[384,"nose."],[385,"Every"],[386,"morning"],[387,"she"],[388,"wets"],[389,"her"],[390,"soap,"],[391,"makes"],[392,"a"],[393,"lot"],[394,"of"],[395,"lather"],[396,"and"],[397,"gives"],[398,"herself"],[399,"many"],[400,"different"],[401,"kinds"],[402,"of"],[403,"moustaches."],[404,"“My"],[405,"moustache"],[406,"is"],[407,"the"],[408,"best,”"],[409,"she"],[410,"says."],[411,"“It’s"],[412,"pure"],[413,"white,"],[414,"and"],[415,"so"],[416,"soft!"],[417,"Isn’t"],[418,"it"],[419,"nice?”"],[420,"she"],[421,"asks,"],[422,"happily."]]}],"stats":{"pages":8,"words":422}}