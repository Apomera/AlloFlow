<button aria-label="batch generation mode" style="flex:1;padding:5px;border-radius:6px;border:none;background:transparent;font-weight:400;font-size:11px;cursor:pointer;color:#6b7280;box-shadow:none">📋 Batch</button>
</div>
<div style="margin-bottom:4px">
