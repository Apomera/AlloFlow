storyweaver.org.in/illustration_crops/32258/size6/34976bed40d0b1af2c84aab3d32040a1.jpg","text":"Orange peels and biscuit\npackets,\nBroken toys and pencil\nshavings,\nTwisted plastic bottles and\ncolourful plastic bags,\nAll surrounded by a swarm of\nbuzzing flies.","words":[[54,"Orange"],[55,"peels"],[56,"and"],[57,"biscuit"],[58,"packets,"],[59,"Broken"],[60,"toys"],[61,"and"],[62,"pencil"],[63,"shavings,"],[64,"Twisted"],[65,"plastic"],[66,"bottles"],[67,"and"],[68,"colourful"],[69,"plastic"],[70,"bags,"],[71,"All"],[72,"surrounded"],[73,"by"],[74,"a"],[75,"swarm"],[76,"of"],[77,"buzzing"],[78,"flies."]]},{"n":4,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/32259/size6/01e229f8f6aa392eb72f75384d4b3cbe.jpg","text":"No one wanted to play with a\ngirl who had a cloud of trash hanging over her.\nWhat if a rotten banana peel\nfell on your head? YUCK!\nCheekoo couldn’t even play\nhide-and-seek anymore.\nThe cloud would always give\nher away.","words":[[79,"No"],[80,"one"],[81,"wanted"],[82,"to"],[83,"play"],[84,"with"],[85,"a"],[86,"girl"],[87,"who"],[88,"had"],[89,"a"],[90,"cloud"],[91,"of"],[92,"trash"],[93,"hanging"],[94,"over"],[95,"her."],[96,"What"],[97,"if"],[98,"a"],[99,"rotten"],[100,"banana"],[101,"peel"],[102,"fell"],[103,"on"],[104,"your"],[105,"head?"],[106,"YUCK!"],[107,"Cheekoo"],[108,"couldn’t"],[109,"even"],[110,"play"],[111,"hide-and-seek"],[112,"anymore."],[113,"The"],[114,"cloud"],[115,"would"],[116,"always"],[117,"give"],[118,"her"],[119,"away."]]},{"n":5,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/32260/size6/f637503c7239cb4ec7c24630e4f167c9.jpg","text":"\"Let’s walk to school\ntogether,\" she said to Sona.\nSona ran off in the opposite\ndirection.\n\"May I borrow your pencil\nsharpener?\" she asked Sweety. Sweety made a face and changed her seat to go sit with Asha.\nCheekoo even had to eat her\nlunch alone.\nCheekoo knew that she should have listened to her Amma. Amma always told her not to litter.","words":[[120,"\"Let’s"],[121,"walk"],[122,"to"],[123,"school"],[124,"together,\""],[125,"she"],[126,"said"],[127,"to"],[128,"Sona."],[129,"Sona"],[130,"ran"],[131,"off"],[132,"in"],[133,"the"],[134,"opposite"],[135,"direction."],[136,"\"May"],[137,"I"],[138,"borrow"],[139,"your"],[140,"pencil"],[141,"sharpener?\""],[142,"she"],[143,"asked"],[144,"Sweety."],[145,"Sweety"],[146,"made"],[147,"a"],[148,"face"],[149,"and"],[150,"changed"],[151,"her"],[152,"seat"],[153,"to"],[154,"go"],[155,"sit"],[156,"with"],[157,"Asha."],[158,"Cheekoo"],[159,"even"],[160,"had"],[161,"to"],[162,"eat"],[163,"her"],[164,"lunch"],[165,"alone."],[166,"Cheekoo"],[167,"knew"],[168,"that"],[169,"she"],[170,"should"],[171,"have"],[172,"listened"],[173,"to"],[174,"her"],[175,"Amma."],[176,"Amma"],[177,"always"],[178,"told"],[179,"her"],[180,"not"],[181,"to"],[182,"litter."]]},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/32261/size6/72050021a65f0440ccca962a26c6eaea.jpg","text":"\"Don’t throw the banana peel on the road!\"\n\"Throw the empty biscuit packet in the dustbin.\" \nBut Cheekoo never listened. She only laughed and kept littering.","words":[[183,"\"Don’t"],[184,"throw"],[185,"the"],[186,"banana"],[187,"peel"],[188,"on"],[189,"the"],[190,"road!\""],[191,"\"Throw"],[192,"the"],[193,"empty"],[194,"biscuit"],[195,"packet"],[196,"in"],[197,"the"],[198,"dustbin.\""],[199,"But"],[200,"Cheekoo"],[201,"never"],[202,"listened."],[203,"She"],[204,"only"],[205,"laughed"],[206,"and"],[207,"kept"],[208,"littering."]]},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/32273/size6/1587d1f3b58ea8f4c873d282c6a0703f.jpg","text":"Then one day, Amma became very angry. \"Soon, all this trash will start following you!\" she said.\nCheekoo just laughed.\nThe next morning, Cheekoo woke\nup to a foul smell and the sound of buzzing flies. The cloud of trash was hanging over her head.\nAmma’s words had come true!\nAnd then, Cheekoo was unable to laugh.","words":[[209,"Then"],[210,"one"],[211,"day,"],[212,"Amma"],[213,"became"],[214,"very"],[215,"angry."],[216,"\"Soon,"],[217,"all"],[218,"this"],[219,"trash"],[220,"will"],[221,"start"],[222,"following"],[223,"you!\""],[224,"she"],[225,"said."],[226,"Cheekoo"],[227,"just"],[228,"laughed."],[229,"The"],[230,"next"],[231,"morning,"],[232,"Cheekoo"],[233,"woke"],[234,"up"],[235,"to"],[236,"a"],[237,"foul"],[238,"smell"],[239,"and"],[240,"the"],[241,"sound"],[242,"of"],[243,"buzzing"],[244,"flies."],[245,"The"],[246,"cloud"],[247,"of"],[248,"trash"],[249,"was"],[250,"hanging"],[251,"over"],[252,"her"],[253,"head."],[254,"Amma’s"],[255,"words"],[256,"had"],[257,"come"],[258,"true!"],[259,"And"],[260,"then,"],[261,"Cheekoo"],[262,"was"],[263,"unable"],[264,"to"],[265,"laugh."]]},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/32262/size6/f533dde58857fa9c474820ab0428ee2c.jpg","text":"9/19","words":null},{"n":9,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/32263/size6/be2aa89bdbdddc0955f3d3e5053a6ccc.jpg","text":"Cheekoo tried to run away.  \nBut the trash cloud followed\nher everywhere.\nCheekoo took a broom to sweep\nthe cloud down.\nBut the trash could not be\nswept away.","words":[[266,"Cheekoo"],[267,"tried"],[268,"to"],[269,"run"],[270,"away."],[271,"But"],[272,"the"],[273,"trash"],[274,"cloud"],[275,"followed"],[276,"her"],[277,"everywhere."],[278,"Cheekoo"],[279,"took"],[280,"a"],[281,"broom"],[282,"to"],[283,"sweep"],[284,"the"],[285,"cloud"],[286,"down."],[287,"But"],[288,"the"],[289,"trash"],[290,"could"],[291,"not"],[292,"be"],[293,"swept"],[294,"away."]]},{"n":10,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/32673/size6/022ab30d81d5872800a3e5377fdc1c55.jpg","text":"Cheekoo tried EVERYTHING.\nShe screamed and asked the\ncloud to leave her alone. She even tried throwing the cloud into the dustbin.\nBut the cloud of trash just\nwouldn’t go. So\nCheekoo became very unhappy.","words":[[295,"Cheekoo"],[296,"tried"],[297,"EVERYTHING"],[298,"."],[299,"She"],[300,"screamed"],[301,"and"],[302,"asked"],[303,"the"],[304,"cloud"],[305,"to"],[306,"leave"],[307,"her"],[308,"alone."],[309,"She"],[310,"even"],[311,"tried"],[312,"throwing"],[313,"the"],[314,"cloud"],[315,"into"],[316,"the"],[317,"dustbin."],[318,"But"],[319,"the"],[320,"cloud"],[321,"of"],[322,"trash"],[323,"just"],[324,"wouldn’t"],[325,"go."],[326,"So"],[327,"Cheekoo"],[328,"became"],[329,"very"],[330,"unhappy."]]},{"n":11,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/32674/size6/014eeb89a8e2aa50f040e445fd4d6166.jpg","text":"Then something happened!\nCheekoo saw Bala throwing a\nbanana peel on the road.\nCheekoo was annoyed. Could he\nnot see the cloud over her head?\n\"Oye silly boy!\" she\nyelled. \"Don’t throw the peel on the road. Someone will slip!\"\nBala, scared of the trash\ncloud, threw the peel in the dustbin.","words":[[331,"Then"],[332,"something"],[333,"happened!"],[334,"Cheekoo"],[335,"saw"],[336,"Bala"],[337,"throwing"],[338,"a"],[339,"banana"],[340,"peel"],[341,"on"],[342,"the"],[343,"road."],[344,"Cheekoo"],[345,"was"],[346,"annoyed."],[347,"Could"],[348,"he"],[349,"not"],[350,"see"],[351,"the"],[352,"cloud"],[353,"over"],[354,"her"],[355,"head?"],[356,"\"Oye"],[357,"silly"],[358,"boy!\""],[359,"she"],[360,"yelled."],[361,"\"Don’t"],[362,"throw"],[363,"the"],[364,"peel"],[365,"on"],[366,"the"],[367,"road."],[368,"Someone"],[369,"will"],[370,"slip!\""],[371,"Bala,"],[372,"scared"],[373,"of"],[374,"the"],[375,"trash"],[376,"cloud,"],[377,"threw"],[378,"the"],[379,"peel"],[380,"in"],[381,"the"],[382,"dustbin."]]},{"n":12,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/32268/size6/e3d78c27a0b7096f521e42a1763de333.jpg","text":"The next day, the trash cloud\nhad become smaller!\n\"How did that happen?\"\nCheekoo wondered.\nThen, Cheekoo saw Reema\nAunty throwing away\nplastic bags.\n\"Aunty!\" Cheekoo said.\n\"Please pick up these bags and reuse them.\"\nReema Aunty picked up the bags\nand left.\nThe next day when Cheekoo woke\nup, the cloud was much smaller.\nCheekoo smiled. She knew what\nshe had to do.","words":[[383,"The"],[384,"next"],[385,"day,"],[386,"the"],[387,"trash"],[388,"cloud"],[389,"had"],[390,"become"],[391,"smaller!"],[392,"\"How"],[393,"did"],[394,"that"],[395,"happen?\""],[396,"Cheekoo"],[397,"wondered."],[398,"Then,"],[399,"Cheekoo"],[400,"saw"],[401,"Reema"],[402,"Aunty"],[403,"throwing"],[404,"away"],[405,"plastic"],[406,"bags."],[407,"\"Aunty!\""],[408,"Cheekoo"],[409,"said."],[410,"\"Please"],[411,"pick"],[412,"up"],[413,"these"],[414,"bags"],[415,"and"],[416,"reuse"],[417,"them.\""],[418,"Reema"],[419,"Aunty"],[420,"picked"],[421,"up"],[422,"the"],[423,"bags"],[424,"and"],[425,"left."],[426,"The"],[427,"next"],[428,"day"],[429,"when"],[430,"Cheekoo"],[431,"woke"],[432,"up,"],[433,"the"],[434,"cloud"],[435,"was"],[436,"much"],[437,"smaller."],[438,"Cheekoo"],[439,"smiled."],[440,"She"],[441,"knew"],[442,"what"],[443,"she"],[444,"had"],[445,"to"],[446,"do."]]},{"n":13,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/32269/size6/21510907cda099f55ffadb2af016c429.jpg","text":"When someone threw away\na biscuit packet or pencil shavings, Cheekoo stopped them.\nShe picked up every twisted\nplastic bottle and put it in the dustbin.\nThe village became cleaner and\ncleaner. And Cheekoo’s cloud became smaller and smaller.\nUntil one day, it was gone. \nCOMPLETELY gone.\nCheekoo\nwas now perhaps the happiest girl in the world.","words":[[447,"When"],[448,"someone"],[449,"threw"],[450,"away"],[451,"a"],[452,"biscuit"],[453,"packet"],[454,"or"],[455,"pencil"],[456,"shavings,"],[457,"Cheekoo"],[458,"stopped"],[459,"them."],[460,"She"],[461,"picked"],[462,"up"],[463,"every"],[464,"twisted"],[465,"plastic"],[466,"bottle"],[467,"and"],[468,"put"],[469,"it"],[470,"in"],[471,"the"],[472,"dustbin."],[473,"The"],[474,"village"],[475,"became"],[476,"cleaner"],[477,"and"],[478,"cleaner."],[479,"And"],[480,"Cheekoo’s"],[481,"cloud"],[482,"became"],[483,"smaller"],[484,"and"],[485,"smaller."],[486,"Until"],[487,"one"],[488,"day,"],[489,"it"],[490,"was"],[491,"gone."],[492,"COMPLETELY"],[493,"gone."],[494,"Cheekoo"],[495,"was"],[496,"now"],[497,"perhaps"],[498,"the"],[499,"happiest"],[500,"girl"],[501,"in"],[502,"the"],[503,"world."]]},{"n":14,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/32772/size6/e7d5fc7ec4d080fad561342bc15b4884.jpg","text":"Cheekoo never littered again.  \nSecretly, she liked living in a clean village.\nBut she was also scared that the trash cloud \nwould come back, some day.  \nWho knew!","words":[[504,"Cheekoo"],[505,"never"],[506,"littered"],[507,"again."],[508,"Secretly,"],[509,"she"],[510,"liked"],[511,"living"],[512,"in"],[513,"a"],[514,"clean"],[515,"village."],[516,"But"],[517,"she"],[518,"was"],[519,"also"],[520,"scared"],[521,"that"],[522,"the"],[523,"trash"],[524,"cloud"],[525,"would"],[526,"come"],[527,"back,"],[528,"some"],[529,"day."],[530,"Who"],[531,"knew!"]]},{"n":15,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/32736/size6/206582346fa517ea57035392f7d4f079.jpg","text":"16/19","words":null},{"n":16,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/32767/size6/6fd99e761accddc399b365b078572221.jpg","text":"Let’s Talk About Trash\nEver wondered what happens to\ntrash once you throw it away? No,\nit doesn’t become a cloud on your head. The trash ends up in a big garbage bin near your home.\nWhen you litter, the trash collects by the side of the road. Some of it goes into the drains that carry waste water from your house. This clogs the drains and attracts flies which spread nasty diseases! UGH! Nobody likes living in a dirty environment. Ask Cheekoo.","words":[[532,"Let’s"],[533,"Talk"],[534,"About"],[535,"Trash"],[536,"Ever"],[537,"wondered"],[538,"what"],[539,"happens"],[540,"to"],[541,"trash"],[542,"once"],[543,"you"],[544,"throw"],[545,"it"],[546,"away?"],[547,"No,"],[548,"it"],[549,"doesn’t"],[550,"become"],[551,"a"],[552,"cloud"],[553,"on"],[554,"your"],[555,"head."],[556,"The"],[557,"trash"],[558,"ends"],[559,"up"],[560,"in"],[561,"a"],[562,"big"],[563,"garbage"],[564,"bin"],[565,"near"],[566,"your"],[567,"home."],[568,"When"],[569,"you"],[570,"litter,"],[571,"the"],[572,"trash"],[573,"collects"],[574,"by"],[575,"the"],[576,"side"],[577,"of"],[578,"the"],[579,"road."],[580,"Some"],[581,"of"],[582,"it"],[583,"goes"],[584,"into"],[585,"the"],[586,"drains"],[587,"that"],[588,"carry"],[589,"waste"],[590,"water"],[591,"from"],[592,"your"],[593,"house."],[594,"This"],[595,"clogs"],[596,"the"],[597,"drains"],[598,"and"],[599,"attracts"],[600,"flies"],[601,"which"],[602,"spread"],[603,"nasty"],[604,"diseases!"],[605,"UGH!"],[606,"Nobody"],[607,"likes"],[608,"living"],[609,"in"],[610,"a"],[611,"dirty"],[612,"environment."],[613,"Ask"],[614,"Cheekoo."]]},{"n":17,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/32769/size6/72739e51585c8bc12283fcd628027978.jpg","text":"Here’s how NOT  \nto make a\ncloud of trash\n - We\ncan start by not littering our surroundings.\n - Always,\nalways throw waste\ninto a dustbin – look around for the nearest one.","words":[[615,"Here’s"],[616,"how"],[617,"NOT"],[618,"to"],[619,"make"],[620,"a"],[621,"cloud"],[622,"of"],[623,"trash"],[624,"-"],[625,"We"],[626,"can"],[627,"start"],[628,"by"],[629,"not"],[630,"littering"],[631,"our"],[632,"surroundings."],[633,"-"],[634,"Always,"],[635,"always"],[636,"throw"],[637,"waste"],[638,"into"],[639,"a"],[640,"dustbin"],[641,"–"],[642,"look"],[643,"around"],[644,"for"],[645,"the"],[646,"nearest"],[647,"one."]]},{"n":18,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/32768/size6/8bc7eef0caaa631976bed79aad65deab.jpg","text":"- After you eat a banana, don’t throw it on the road. Put the peel in a small bag until you find a dustbin.\n - There are many things that you may think are useless, like the paper bag into which you put the peel. But not everything is waste. So don’t throw the bag with the peel! Take it home and reuse it.\n - Cover dustbins so that flies can’t get inside.","words":[[648,"-"],[649,"After"],[650,"you"],[651,"eat"],[652,"a"],[653,"banana,"],[654,"don’t"],[655,"throw"],[656,"it"],[657,"on"],[658,"the"],[659,"road."],[660,"Put"],[661,"the"],[662,"peel"],[663,"in"],[664,"a"],[665,"small"],[666,"bag"],[667,"until"],[668,"you"],[669,"find"],[670,"a"],[671,"dustbin."],[672,"-"],[673,"There"],[674,"are"],[675,"many"],[676,"things"],[677,"that"],[678,"you"],[679,"may"],[680,"think"],[681,"are"],[682,"useless,"],[683,"like"],[684,"the"],[685,"paper"],[686,"bag"],[687,"into"],[688,"which"],[689,"you"],[690,"put"],[691,"the"],[692,"peel."],[693,"But"],[694,"not"],[695,"everything"],[696,"is"],[697,"waste."],[698,"So"],[699,"don’t"],[700,"throw"],[701,"the"],[702,"bag"],[703,"with"],[704,"the"],[705,"peel!"],[706,"Take"],[707,"it"],[708,"home"],[709,"and"],[710,"reuse"],[711,"it."],[712,"-"],[713,"Cover"],[714,"dustbins"],[715,"so"],[716,"that"],[717,"flies"],[718,"can’t"],[719,"get"],[720,"inside."]]}],"stats":{"pages":18,"words":721}}