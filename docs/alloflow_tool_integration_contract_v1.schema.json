{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alloflow.org/schema/tool-integration-contract-v1.json",
  "title": "AlloFlow Tool Integration Contract v1",
  "type": "object",
  "additionalProperties": true,
  "required": ["schemaVersion", "id", "name", "version", "reviewedAt", "reviewAfter", "license", "citation", "supportedMethodPacks", "capabilities", "privacy", "reproducibility"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_-]{1,79}$" },
    "name": { "type": "string", "minLength": 1, "maxLength": 120 },
    "version": { "type": "string", "minLength": 1, "maxLength": 80 },
    "reviewedAt": { "type": "string", "format": "date" },
    "reviewAfter": { "type": "string", "format": "date" },
    "license": {
      "type": "object",
      "anyOf": [{ "required": ["name"] }, { "required": ["spdx"] }],
      "properties": { "name": { "type": "string" }, "spdx": { "type": "string" }, "url": { "type": "string" }, "note": { "type": "string" } }
    },
    "citation": { "type": "object", "required": ["text"], "properties": { "text": { "type": "string", "minLength": 1 }, "url": { "type": "string" } } },
    "supportedMethodPacks": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": { "enum": ["scientific_investigation", "engineering_design", "humanistic_interpretation", "community_qualitative", "civic_policy", "creative_cultural"] }
    },
    "capabilities": { "type": "object", "required": ["captureArtifact"], "properties": { "captureArtifact": { "const": true }, "rawDataIncluded": { "type": "boolean" } } },
    "privacy": {
      "type": "object", "required": ["learnerApprovalRequired"],
      "properties": {
        "learnerApprovalRequired": { "const": true },
        "directIdentifiersAllowed": { "type": "boolean" },
        "sequenceLikeTextAllowed": { "type": "boolean" },
        "sanitizerId": { "type": "string" },
        "sanitizerRequired": { "type": "boolean" }
      }
    },
    "reproducibility": {
      "type": "object", "required": ["requiredFields"],
      "properties": {
        "requiredFields": {
          "type": "array", "minItems": 2, "uniqueItems": true,
          "allOf": [
            { "contains": { "const": "softwareVersion" } },
            { "contains": { "const": "limitations" } }
          ],
          "items": { "enum": ["softwareVersion", "sourceRecordId", "parameters", "randomSeed", "limitations", "datasetVersion", "transformations"] }
        }
      }
    }
  }
}