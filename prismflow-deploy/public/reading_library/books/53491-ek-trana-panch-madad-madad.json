[69,"બે,"],[70,"ત્રણ,"],[71,"ચાર!"],[72,"ચાર"],[73,"તો"],[74,"બેકી"],[75,"સંખ્યા"],[76,"કહેવાય!”"],[77,"ચારેય"],[78,"જંતુઓ"],[79,"તો"],[80,"જોર"],[81,"કરીને"],[82,"હાંફ્યાં,"],[83,"પણ"],[84,"તેઓ"],[85,"ભમરાને"],[86,"સવળો"],[87,"કરી"],[88,"ન"],[89,"શક્યાં."],[90,"1+3=4"]]},{"n":4,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/90929/size6/66e4327510ab10546efc5b8e4107c21f.jpg","text":"“અલ્યાં ફૂદાં!” લેડી બગે સાદ પાડ્યો.\nપાંચ ફૂદાં મદદે આવ્યાં. ભમરાએ મિત્રોની સંખ્યા ગણી. “અરે, તમે નવેય મદદે આવ્યા છો ને કાંઇ!” ભમરો બોલ્યો :\n“નવ તો એકી સંખ્યા થઈ!” નવ જંતુ ધક્કા દઈને હાંફી ગયાં. પણ ભમરાને સવળો ન કરી શક્યાં.\n4+5=9","words":[[91,"“અલ્યાં"],[92,"ફૂદાં!”"],[93,"લેડી"],[94,"બગે"],[95,"સાદ"],[96,"પાડ્યો."],[97,"પાંચ"],[98,"ફૂદાં"],[99,"મદદે"],[100,"આવ્યાં."],[101,"ભમરાએ"],[102,"મિત્રોની"],[103,"સંખ્યા"],[104,"ગણી."],[105,"“અરે,"],[106,"તમે"],[107,"નવેય"],[108,"મદદે"],[109,"આવ્યા"],[110,"છો"],[111,"ને"],[112,"કાંઇ!”"],[113,"ભમરો"],[114,"બોલ્યો"],[115,":"],[116,"“નવ"],[117,"તો"],[118,"એકી"],[119,"સંખ્યા"],[120,"થઈ!”"],[121,"નવ"],[122,"જંતુ"],[123,"ધક્કા"],[124,"દઈને"],[125,"હાંફી"],[126,"ગયાં."],[127,"પણ"],[128,"ભમરાને"],[129,"સવળો"],[130,"ન"],[131,"કરી"],[132,"શક્યાં."],[133,"4+5=9"]]},{"n":5,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/90930/size6/e196a552e76802f9efb5af14538e07dd.jpg","text":"એવામાં સાત કરોળિયા કૂદકા મારતા મદદમાં આવ્યા :\nટુપ ટુપ ટુપ.\nભમરાએ મિત્રોની સંખ્યા ગણી. ભમરો બોલ્યો : “મિત્રો થયા સોળ, બેકી સંખ્યા!”\nસોળેસોળ જીવાતોએ જોર કર્યું. પણ ભમરો કેમેય સવળો થાય તો ને!\n9+7=16","words":[[134,"એવામાં"],[135,"સાત"],[136,"કરોળિયા"],[137,"કૂદકા"],[138,"મારતા"],[139,"મદદમાં"],[140,"આવ્યા"],[141,":"],[142,"ટુપ"],[143,"ટુપ"],[144,"ટુપ."],[145,"ભમરાએ"],[146,"મિત્રોની"],[147,"સંખ્યા"],[148,"ગણી."],[149,"ભમરો"],[150,"બોલ્યો"],[151,":"],[152,"“મિત્રો"],[153,"થયા"],[154,"સોળ,"],[155,"બેકી"],[156,"સંખ્યા!”"],[157,"સોળેસોળ"],[158,"જીવાતોએ"],[159,"જોર"],[160,"કર્યું."],[161,"પણ"],[162,"ભમરો"],[163,"કેમેય"],[164,"સવળો"],[165,"થાય"],[166,"તો"],[167,"ને!"],[168,"9+7=16"]]},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/90933/size6/8dce9eed2141ced68577b1f6aad98b2f.jpg","text":"7/12","words":null},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/92567/size6/92c9e9f16f1f52cad48bbfa3d1b9eb31.jpg","text":"“એલા, લીલી માખને બોલાવો!” લેડી બગે બૂમ પાડી. નવ લીલી માખી મદદ કરવા ઊડી આવી.\n“અરે...વાહ ભઈ! હવે થયા પચ્ચીસ મિત્રો! પચ્ચીસ એટલે...” થાકેલો ભમરો બોલ્યો.\n“...એકી સંખ્યા!” પચ્ચીસે પચ્ચીસ જીવડાં એક સાથે બૂમ પાડી ઊઠ્યાં.\n16+9=25","words":[[169,"“એલા,"],[170,"લીલી"],[171,"માખને"],[172,"બોલાવો!”"],[173,"લેડી"],[174,"બગે"],[175,"બૂમ"],[176,"પાડી."],[177,"નવ"],[178,"લીલી"],[179,"માખી"],[180,"મદદ"],[181,"કરવા"],[182,"ઊડી"],[183,"આવી."],[184,"“અરે...વાહ"],[185,"ભઈ!"],[186,"હવે"],[187,"થયા"],[188,"પચ્ચીસ"],[189,"મિત્રો!"],[190,"પચ્ચીસ"],[191,"એટલે...”"],[192,"થાકેલો"],[193,"ભમરો"],[194,"બોલ્યો."],[195,"“...એકી"],[196,"સંખ્યા!”"],[197,"પચ્ચીસે"],[198,"પચ્ચીસ"],[199,"જીવડાં"],[200,"એક"],[201,"સાથે"],[202,"બૂમ"],[203,"પાડી"],[204,"ઊઠ્યાં."],[205,"16+9=25"]]},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/90935/size6/754ed482127c4128c43f84680f814e9f.jpg","text":"9/12","words":null},{"n":9,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/90936/size6/2b374cd4551e0303fb97b8cfccdde93f.jpg","text":"પચ્ચીસ જીવડાંએ ભેગાં થઈને ધક્કા દીધા!\nછેવટે ભમરાને\nચત્તો\nકર્યો!","words":[[206,"પચ્ચીસ"],[207,"જીવડાંએ"],[208,"ભેગાં"],[209,"થઈને"],[210,"ધક્કા"],[211,"દીધા!"],[212,"છેવટે"],[213,"ભમરાને"],[214,"ચત્તો"],[215,"કર્યો!"]]},{"n":10,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/92568/size6/b30c73aef4bf3ab7c149ade55d34c7f2.jpg","text":"બેકી સંખ્યાઓને\nઅંતે\n0, 2, 4, 6 કે 8 અંક હોય.\nએકી આંકડા બેકી અંકથી ભાગી ન શકાય. એકી સંખ્યાઓને\nઅંતે \n1, 3, 5, 7 કે 9 અંક આવે.","words":[[216,"બેકી"],[217,"સંખ્યાઓ"],[218,"