तर के\nनीचे दुबक गई!\nमिथुन\nचिल्लाया, \"चूहा!\" और\nवह बिल्ली के साथ भाग गया।","words":[[64,"मिथुन"],[65,"ने"],[66,"पालतू"],[67,"बिल्ली"],[68,"से"],[69,"कहा,"],[70,"\"पकड़ो"],[71,"उसे।\""],[72,"बिल्ली"],[73,"ने"],[74,"चूहे"],[75,"को"],[76,"देखा"],[77,"और"],[78,"बिस्तर"],[79,"के"],[80,"नीचे"],[81,"दुबक"],[82,"गई!"],[83,"मिथुन"],[84,"चिल्लाया,"],[85,"\"चूहा!\""],[86,"और"],[87,"वह"],[88,"बिल्ली"],[89,"के"],[90,"साथ"],[91,"भाग"],[92,"गया।"]]},{"n":4,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/10809/size6/66897ebcdde07f8034295bf5901dfc6c.jpg","text":"\"मैं\nभगाती हूँ इसे,\" माँ\nने बहादुरी दिखाते हुए कहा। \nउन्होंने\nझाड़ू निकाला और चूहे को इधर-उधर\nढूँढने लगी।\nतभी\nपापा चिल्लाए, \"चूहा! तुम्हारे\nपीछे!\"\nचूहा\nदिखते ही माँ बिस्तर के नीचे\nछुप गईं!","words":[[93,"\"मैं"],[94,"भगाती"],[95,"हूँ"],[96,"इसे,\""],[97,"माँ"],[98,"ने"],[99,"बहादुरी"],[100,"दिखाते"],[101,"हुए"],[102,"कहा।"],[103,"उन्होंने"],[104,"झाड़ू"],[105,"निकाला"],[106,"और"],[107,"चूहे"],[108,"को"],[109,"इधर-उधर"],[110,"ढूँढने"],[111,"लगी।"],[112,"तभी"],[113,"पापा"],[114,"चिल्लाए,"],[115,"\"चूहा!"],[116,"तुम्हारे"],[117,"पीछे!\""],[118,"चूहा"],[119,"दिखते"],[120,"ही"],[121,"माँ"],[122,"बिस्तर"],[123,"के"],[124,"नीचे"],[125,"छुप"],[126,"गईं!"]]},{"n":5,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/10810/size6/00bfccc7be51d2836c78016865b449f5.jpg","text":"दादी\nसोफ़े से नीचे उतरी और\nबोलीं, \"मैं\nजानती हूँ कि क्या करना है!\"\nफिर\nउन्होंने अख़बार को मोड़ा और\nउसे इधर उधर खोसने लगीं।","words":[[127,"दादी"],[128,"सोफ़े"],[129,"से"],[130,"नीचे"],[131,"उतरी"],[132,"और"],[133,"बोलीं,"],[134,"\"मैं"],[135,"जानती"],[136,"हूँ"],[137,"कि"],[138,"क्या"],[139,"करना"],[140,"है!\""],[141,"फिर"],[142,"उन्होंने"],[143,"अख़बार"],[144,"को"],[145,"मोड़ा"],[146,"और"],[147,"उसे"],[148,"इधर"],[149,"उधर"],[150,"खोसने"],[151,"लगीं।"]]},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/10811/size6/c6afff80eadf9d6884db33eabb51da22.jpg","text":"\"चूहा, वहाँ तुम्हारी बाईं तरफ!\" पापा\nख़िड़की पर और ऊँचे चढ़ते हुए\nचिल्लाये।\nदादी\nने चूहे को देखा और बिस्तर के\nनीचे जा छुपीं। पापा\nने धीमे से कहा, \"अब क्या\nकरूँ?\"","words":[[152,"\""],[153,"चूहा,"],[154,"वहाँ"],[155,"तुम्हारी"],[156,"बाईं"],[157,"तरफ!\""],[158,"पापा"],[159,"ख़िड़की"],[160,"पर"],[161,"और"],[162,"ऊँचे"],[163,"चढ़ते"],[164,"हुए"],[165,"चिल्लाये।"],[166,"दादी"],[167,"ने"],[168,"चूहे"],[169,"को"],[170,"देखा"],[171,"और"],[172,"बिस्तर"],[173,"के"],[174,"नीचे"],[175,"जा"],[176,"छुपीं।"],[177,"पापा"],[178,"ने"],[179,"धीमे"],[180,"से"],[181,"कहा,"],[182,"\"अब"],[183,"क्या"],[184,"करूँ?\""]]},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/10812/size6/4f0db01a6f8150eaad671e8f26ee6554.jpg","text":"वो\nखिड़की पर और ऊपर नहीं चढ़ सकते\nथे। वो ख़िड़की से नीचे उतरे और\nइससे पहले कि चूहा उनको देखता, वह बिस्तर के नीचे घुस गये।","words":[[185,"वो"],[186,"खिड़की"],[187,"पर"],[188,"और"],[189,"ऊपर"],[190,"नहीं"],[191,"चढ़"],[192,"सकते"],[193,"थे।"],[194,"वो"],[195,"ख़िड़की"],[196,"से"],[197,"नीचे"],[198,"उतरे"],[199,"और"],[200,"इससे"],[201,"पहले"],[202,"कि"],[203,"चूहा"],[204,"उनको"],[205,"देखता,"],[206,"वह"],[207,"बिस्तर"],[208,"के"],[209,"नीचे"],[210,"घुस"],[211,"गये।"]]},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/10813/size6/6b85ac54304e492b90eb9e002d317c46.jpg","text":"\"घर\nके अंदर चूहा!\" सब एक साथ चिल्ला उठे।\nशोर\nसे छोटी जग गई। आँखें मलते हुए वो अपनी दरी पर बैठ गई।\nअरे\nउसके तकिये पर वो क्या था?","words":[[212,"\"घर"],[213,"के"],[214,"अंदर"],[215,"चूहा!\""],[216,"सब"],[217,"एक"],[218,"साथ"],[219,"चिल्ला"],[220,"उठे।"],[221,"शोर"],[222,"से"],[223,"छोटी"],[224,"जग"],[225,"गई।"],[226,"आँखें"],[227,"मलते"],[228,"हुए"],[229,"वो"],[230,"अपनी"],[231,"दरी"],[232,"पर"],[233,"बैठ"],[234,"गई।"],[235,"अरे"],[236,"उसके"],[237,"तकिये"],[238,"पर"],[239,"वो"],[240,"क्या"],[241,"था?"]]},{"n":9,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/