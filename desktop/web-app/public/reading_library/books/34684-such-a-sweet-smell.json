":[[10,"Not"],[11,"from"],[12,"here!"],[13,"This"],[14,"is"],[15,"the"],[16,"lovely"],[17,"smell"],[18,"of"],[19,"flowers."]]},{"n":3,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/64733/size6/978f70d2acdc51dfe72efca6b4279e1b.jpg","text":"Not from here! This is the bad smell of cow\ndung.","words":[[20,"Not"],[21,"from"],[22,"here!"],[23,"This"],[24,"is"],[25,"the"],[26,"bad"],[27,"smell"],[28,"of"],[29,"cow"],[30,"dung."]]},{"n":4,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/61967/size6/b9d47697b965ec3315807b4e3b755975.jpg","text":"Eek! This is the\nyucky-mucky smell of my dirty socks.","words":[[31,"Eek!"],[32,"This"],[33,"is"],[34,"the"],[35,"yucky-mucky"],[36,"smell"],[37,"of"],[38,"my"],[39,"dirty"],[40,"socks."]]},{"n":5,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/61968/size6/b2df2077fc293516b8d9d795600774ea.jpg","text":"Mmmm... This is the yummy smell of hot luchi-aalu!","words":[[41,"Mmmm..."],[42,"This"],[43,"is"],[44,"the"],[45,"yummy"],[46,"smell"],[47,"of"],[48,"hot"],[49,"luchi-aalu!"]]},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/61977/size6/13134d341e449fbd85d0f9c2d54ace2e.jpg","text":"Aha! That sweet smell is from here! From this new sweet stall.\nThe sweet smell is coming from these fresh gulab jamoons!","words":[[50,"Aha!"],[51,"That"],[52,"sweet"],[53,"smell"],[54,"is"],[55,"from"],[56,"here!"],[57,"From"],[58,"this"],[59,"new"],[60,"sweet"],[61,"stall."],[62,"The"],[63,"sweet"],[64,"smell"],[65,"is"],[66,"coming"],[67,"from"],[68,"these"],[69,"fresh"],[70,"gulab"],[71,"jamoons!"]]},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/61970/size6/ec5906f7a2a1844b48958ff047c63086.jpg","text":"Dear friends, did you know that the inside of our noses are lined with millions of cells? These cells help us smell things.\nThey help us tell if they are good smells or bad smells. Smell helps us guess the taste of things.\nThe smell of something also tells us how far we are from it.","words":[[72,"Dear"],[73,"friends,"],[74,"did"],[75,"you"],[76,"know"],[77,"that"],[78,"the"],[79,"inside"],[80,"of"],[81,"our"],[82,"noses"],[83,"are"],[84,"lined"],[85,"with"],[86,"millions"],[87,"of"],[88,"cells?"],[89,"These"],[90,"cells"],[91,"help"],[92,"us"],[93,"smell"],[94,"things."],[95,"They"],[96,"help"],[97,"us"],[98,"tell"],[99,"if"],[100,"they"],[101,"are"],[102,"good"],[103,"smells"],[104,"or"],[105,"bad"],[106,"smells."],[107,"Smell"],[108,"helps"],[109,"us"],[110,"guess"],[111,"the"],[112,"taste"],[113,"of"],[114,"things."],[115,"The"],[116,"smell"],[117,"of"],[118,"something"],[119,"also"],[120,"tells"],[121,"us"],[122,"how"],[123,"far"],[124,"we"],[125,"are"],[126,"from"],[127,"it."]]},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/61978/size6/18b95657f8f680d776c3fcc546736221.jpg","text":"The\nsense of smell is much stronger in animals than it is in humans.\nHaven’t\nyou noticed that mosquitoes smell us out,\nno matter where we are?","words":[[128,"The"],[129,"sense"],[130,"of"],[131,"smell"],[132,"is"],[133,"much"],[134,"stronger"],[135,"in"],[136,"animals"],[137,"than"],[138,"it"],[139,"is"],[140,"in"],[141,"humans."],[142,"Haven’t"],[143,"you"],[144,"noticed"],[145,"that"],[146,"mosquitoes"],[147,"smell"],[148,"us"],[149,"out,"],[150,"no"],[151,"matter"],[152,"where"],[153,"we"],[154,"are?"]]},{"n":9,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/61972/size6/cdeff9eca2bc7b0fd62d39a205828b40.jpg","text":"And who tells the ants about the crumbs that we drop on the floor while eating? Simple. It’s their sense of smell!\nEveryone knows that dogs have very sharp noses. That’s how they help us find robbers and bombs.","words":[[155,"And"],[156,"who"],[157,"tells"],[158,"the"],[159,"ants"],[160,"about"],[161,"the"],[162,"crumbs"],[163,"that"],[164,"we"],[165,"drop"],[166,"on"],[167,"the"],[168,"floor"],[169,"while"],[170,"eating?"],[171,"Simple."],[172,"It’s"],[173,"their"],[174,"sense"],[175,"of"],[176,"smell!"],[177,"Everyone"],[178,"knows"],[179,"that"],[180,"dogs"],[181,"have"],[182,"very"],[183,"sharp"],[184,"noses."],[185,"That’s"],[186,"how"],[187,"they"],[188,"help"],[189,"us"],[190,"find"],[191,"robbers"],[192,"and"],[193,"bombs."]]},{"n":10,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/61973/size6/14f70ea6b6f0359cebe3acf527ad623a.jpg","text":"So do you know why we take a deep breath when we are passing by a beautiful garden? \nAnd why we cover our noses when we are near a garbage heap?","words":[[194,"So"],[195,"do"],[196,"you"],[197,"know"],[198,"why"],[199,"we"],[200,"take"],[201,"a"],[202,"deep"],[203,"breath"],[204,"when"],[205,"we"],[206,"are"],[207,"passing"],[208,"by"],[209,"a"],[210,"beautiful"],[211,"garden?"],[212,"And"],[213,"why"],[214,"we"],[215,"cover"],[216,"our"],[217,"noses"],[218,"when"],[219,"we"],[220,"are"],[221,"near"],[222,"a"],[223,"garbage"],[224,"heap?"]]},{"n":11,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/61974/size6/ff46a61ff69f344ab52413ec8b9c2b02.jpg","text":"Because something is telling us to do so. And that something is our fantastic sense of smell!","words":[[225,"Because"],[226,"something"],[227,"is"],[228,"telling"],[229,"us"],[230,"to"],[231,"do"],[232,"so."],[233,"And"],[234,"that"],[235,"something"],[236,"is"],[237,"our"],[238,"fantastic"],[239,"sense"],[240,"of"],[241,"smell!"]]}],"stats":{"pages":11,"words":241}}