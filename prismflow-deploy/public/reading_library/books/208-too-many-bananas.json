ry"],[130,"happy."],[131,"He"],[132,"went"],[133,"back"],[134,"to"],[135,"growing"],[136,"bananas"],[137,"on"],[138,"his"],[139,"farm."]]},{"n":9,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/2474/size6/6ae4160395fdc69728b954c9fe07dcd9.jpg","text":"But he did not offer the fruits to anyone anymore.","words":[[140,"But"],[141,"he"],[142,"did"],[143,"not"],[144,"offer"],[145,"the"],[146,"fruits"],[147,"to"],[148,"anyone"],[149,"anymore."]]},{"n":10,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/2475/size6/93756774ab9251674b217957f77a1b62.jpg","text":"Not to his family.\nNot to his neighbour.\nNot to his friends.","words":[[150,"Not"],[151,"to"],[152,"his"],[153,"family."],[154,"Not"],[155,"to"],[156,"his"],[157,"neighbour."],[158,"Not"],[159,"to"],[160,"his"],[161,"friends."]]},{"n":11,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/2476/size6/34ed675c20313800ce9a68c662319077.jpg","text":"Not to the traders who could sell the bananas in far away markets. And not even to his cows!","words":[[162,"Not"],[163,"to"],[164,"the"],[165,"traders"],[166,"who"],[167,"could"],[168,"sell"],[169,"the"],[170,"bananas"],[171,"in"],[172,"far"],[173,"away"],[174,"markets."],[175,"And"],[176,"not"],[177,"even"],[178,"to"],[179,"his"],[180,"cows!"]]},{"n":12,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/2477/size6/a3774c093b38a5ba8ee510e729f62d2d.jpg","text":"Everyone became very curious.\nWhere were all the bananas going?","words":[[181,"Everyone"],[182,"became"],[183,"very"],[184,"curious."],[185,"Where"],[186,"were"],[187,"all"],[188,"the"],[189,"bananas"],[190,"going?"]]},{"n":13,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/2478/size6/40d570c49013d7f03a754131496ad152.jpg","text":"One day, neighbour Shivanna arranged a very big pooja.","words":[[191,"One"],[192,"day,"],[193,"neighbour"],[194,"Shivanna"],