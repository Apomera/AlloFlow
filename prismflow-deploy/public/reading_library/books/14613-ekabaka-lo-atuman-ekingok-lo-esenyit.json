ata.\nEkeritos adaun aparasia nu ipu.","words":null},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/13835/size6/a95b6b33c564971fee5fd6ab6131012e.jpg","text":"Ikamuni do Ekabaka ekingok.","words":null},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/13836/size6/a39b3220e6cc4ed1332efe72ae2e35e0.jpg","text":"Kwana do esenyit ekabaka lo atumit.","words":null}],"stats":{"pages":7,"words":52}}