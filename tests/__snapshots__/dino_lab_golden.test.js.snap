<div id="dinopanel" role="tabpanel" aria-labelledby="dinotab-compare" style="padding:16px">
<div>
<div style="margin-bottom:12px">
<div style="font-size:18px;font-weight:800">⚖️ Compare two dinosaurs</div>
<div style="font-size:12.5px;color:var(--allo-stem-text-soft, #94a3b8);margin-top:2px">Shared axes reveal scale; time, place, and fossil coverage keep the conclusion honest.</div>
</div>
