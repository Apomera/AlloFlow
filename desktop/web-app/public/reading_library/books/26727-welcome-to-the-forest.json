ops/56745/size6/64f67a39bd9ab00df00f241b56a2b411.jpg","text":"This is a real story\nIn January 2017, the Last Wilderness Foundation in association with the Kanha Forest Department conducted a camp for 23 visually impaired students from the Ananya Manav Sai Samiti, Jabalpur. \nThe students were taken on a safari and nature trail using their fabulous sensory skills to enjoy the forest.","words":[[743,"This"],[744,"is"],[745,"a"],[746,"real"],[747,"story"],[748,"In"],[749,"January"],[750,"2017,"],[751,"the"],[752,"Last"],[753,"Wilderness"],[754,"Foundation"],[755,"in"],[756,"association"],[757,"with"],[758,"the"],[759,"Kanha"],[760,"Forest"],[761,"Department"],[762,"conducted"],[763,"a"],[764,"camp"],[765,"for"],[766,"23"],[767,"visually"],[768,"impaired"],[769,"students"],[770,"from"],[771,"the"],[772,"Ananya"],[773,"Manav"],[774,"Sai"],[775,"Samiti,"],[776,"Jabalpur."],[777,"The"],[778,"students"],[779,"were"],[780,"taken"],[781,"on"],[782,"a"],[783,"safari"],[784,"and"],[785,"nature"],[786,"trail"],[787,"using"],[788,"their"],[789,"fabulous"],[790,"sensory"],[791,"skills"],[792,"to"],[793,"enjoy"],[794,"the"],[795,"forest."]]},{"n":20,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/56746/size6/cc37bf1c99e1036dfc1fa3112136a555.jpg","text":"About Last Wilderness Foundation\nThe Last Wilderness Foundation is an NGO that works in urban and rural areas with children to spread awareness about wildlife and biodiversity, and sensitise them towards conservation and the environment. \nFor details, visit www.thelastwilderness.org.","words":[[796,"About"],[797,"Last"],[798,"Wilderness"],[799,"Foundation"],[800,"The"],[801,"Last"],[802,"Wilderness"],[803,"Foundation"],[804,"is"],[805,"an"],[806,"NGO"],[807,"that"],[808,"works"],[809,"in"],[810,"urban"],[811,"and"],[812,"rural"],[813,"areas"],[814,"with"],[815,"children"],[816,"to"],[817,"spread"],[818,"awareness"],[819,"about"],[820,"wildlife"],[821,"and"],[822,"biodiversity,"],[823,"and"],[824