47,"fell"],[348,"with"],[349,"his"],[350,"face"],[351,"down."]]},{"n":13,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/27029/size6/44fe88b50aea26a592bb55ce7818fc34.jpg","text":"Somehow,\nhe managed to sit up again, his mouth full of leaves and mud and\ntwigs. When he looked up, the monkeys had gone.","words":[[352,"Somehow,"],[353,"he"],[354,"managed"],[355,"to"],[356,"sit"],[357,"up"],[358,"again,"],[359,"his"],[360,"mouth"],[361,"full"],[362,"of"],[363,"leaves"],[364,"and"],[365,"mud"],[366,"and"],[367,"twigs."],[368,"When"],[369,"he"],[370,"looked"],[371,"up,"],[372,"the"],[373,"monkeys"],[374,"had"],[375,"gone."]]},{"n":14,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/27030/size6/b711efa4ed37c8777c7e89bc019e41d1.jpg","text":"Sringeri\nSrinivas looked down at himself. His nice shirt was brown. His hands\nwere dirty and scratched. He could not even find his own legs. They\nwere all mixed up in the soil.","words":[[376,"Sringeri"],[377,"Srinivas"],[378,"looked"],[379,"down"],[380,"at"],[381,"himself."],[382,"His"],[383,"nice"],[384,"shirt"],[385,"was"],[386,"brown."],[387,"His"],[388,"hands"],[389,"were"],[390,"dirty"],[391,"and"],[392,"scratched."],[393,"He"],[394,"could"],[395,"not"],[396,"even"],[397,"find"],[398,"his"],[399,"own"],[400,"legs."],[401,"They"],[402,"were"],[403,"all"],[404,"mixed"],[405,"up"],[406,"in"],[407,"the"],[408,"soil."]]},{"n":15,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/27031/size6/c2e45a5d173125380e9ad72f49ec2f24.jpg","text":"Suddenly,\nhe realised that he looked very funny. Sringeri Srinivas, the famous\nfarmer.\nHe\nwas now sitting all by himself on a pile of leaves, mud and bananas.\nIt was all very funny.\nAnd Sringeri Srinivas began to laugh. It was a\nlittle laugh at first. Hee\nHee.\nThen\nit became bigger. Ha  Ha!","words":[[409,"Suddenly,"],[410,"he"],[411,"realised"],[412,"that"],[413,"he"],[414,"looked"],[415,"very"],[416,"funny."],[417,"Sringeri"],[418,"Srinivas,"],[419,"the"],[420,"famous"],[421,"farmer."],[422,"He"],[423,"was"],[424,"now"],[425,"sitting"],[426,"all"],[427,"by"],[428,"himself"],[429,"on"],[430,"a"],[431,"pile"],[432,"of"],[433,"leaves,"],[434,"mud"],[435,"and"],[436,"bananas."],[437,"It"],[438,"was"],[439,"all"],[440,"very"],[441,"funny."],[442,"And"],[443,"Sringeri"],[444,"Srinivas"],[445,"began"],[446,"to"],[447,"laugh."],[448,"It"],[449,"was"],[450,"a"],[451,"little"],[452,"laugh"],[453,"at"],[454,"first."],[455,"Hee"],[456,"Hee"],[457,"."],[458,"Then"],[459,"it"],[460,"became"],[461,"bigger."],[462,"Ha"],[463,"Ha!"]]},{"n":16,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/27032/size6/12c7e320aee34201091f735cb50f7adb.jpg","text":"The\nmore he laughed, the more Sringeri Srinivas wanted to laugh.\nThe\nlaugh grew bigger. HA HA  HA. And\nbigger!\nSoon, he was clutching his stomach, and rolling on the\nmud. HA  HA HA  HAAAA!\nTears\nwere rolling out of his eyes.","words":[[464,"The"],[465,"more"],[466,"he"],[467,"laughed,"],[468,"the"],[469,"more"],[470,"Sringeri"],[471,"Srinivas"],[472,"wanted"],[473,"to"],[474,"laugh."],[475,"The"],[476,"laugh"],[477,"grew"],[478,"bigger."],[479,"HA"],[480,"HA"],[481,"HA"],[482,"."],[483,"And"],[484,"bigger!"],[485,"Soon,"],[486,"he"],[487,"was"],[488,"clutching"],[489,"his"],[490,"stomach,"],[491,"and"],[492,"rolling"],[493,"on"],[494,"the"],[495,"mud."],[496,"HA"],[497,"HA"],[498,"HA"],[499,"HAAAA!"],[500,"Tears"],[501,"were"],[502,"rolling"],[503,"out"],[504,"of"],[505,"his"],[506,"eyes."]]},{"n":17,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/27033/size6/332e79c7cc3ace6b05f72fbb4fa0dd20.jpg","text":"The\nlaugh was so musical that the birds nearby came to listen. The laugh\nwas so loud that the monkeys came back. The laugh was so funny that\nmany kids came along. The laugh was so new that his whole family came\nout to hear it, too.","words":[[507,"The"],[508,"laugh"],[509,"was"],[510,"so"],[511,"musical"],[512,"that"],[513,"the"],[514,"birds"],[515,"nearby"],[516,"came"],[517,"to"],[518,"listen."],[519,"The"],[520,"laugh"],[521,"was"],[522,"so"],[523,"loud"],[524,"that"],[525,"the"],[526,"monkeys"],[527,"came"],[528,"back."],[529,"The"],[530,"laugh"],[531,"was"],[532,"so"],[533,"funny"],[534,"that"],[535,"many"],[536,"kids"],[537,"came"],[538,"along."],[539,"The"],[540,"laugh"],[541,"was"],[542,"so"],[543,"new"],[544,"that"],[545,"his"],[546,"whole"],[547,"family"],[548,"came"],[549,"out"],[550,"to"],[551,"hear"],[552,"it,"],[553,"too."]]},{"n":18,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/27034/size6/4b6c595df21d7c702d5c1ee9970affe3.jpg","text":"Sringeri\nSrinivas laughed so much that everyone else began to laugh as well.\nThe birds twittered. The crows cawed. The monkeys chattered. The kids\nbegan to giggle. The banana plants began to sway. The barber in the\nshop grinned. The tailor began to chortle. Even the tiger sleeping\nfar away in his cave smiled into his whiskers.","words":[[554,"Sringeri"],[555,"Srinivas"],[556,"laughed"],[557,"so"],[558,"much"],[559,"that"],[560,"everyone"],[561,"else"],[562,"began"],[563,"to"],[564,"laugh"],[565,"as"],[566,"well."],[567,"The"],[568,"birds"],[569,"twittered."],[570,"The"],[571,"crows"],[572,"cawed."],[573,"The"],[574,"monkeys"],[575,"chattered."],[576,"The"],[577,"kids"],[578,"began"],[579,"to"],[580,"giggle."],[581,"The"],[582,"banana"],[583,"plants"],[584,"began"],[585,"to"],[586,"sway."],[587,"The"],[588,"barber"],[589,"in"],[590,"the"],[591,"shop"],[592,"grinned."],[593,"The"],[594,"tailor"],[595,"began"],[596,"to"],[597,"chortle."],[598,"Even"],[599,"the"],[600,"tiger"],[601,"sleeping"],[602,"far"],[603,"away"],[604,"in"],[605,"his"],[606,"cave"],[607,"smiled"],[608,"into"],[609,"his"],[610,"whiskers."]]},{"n":19,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/27035/size6/6b82a7434d