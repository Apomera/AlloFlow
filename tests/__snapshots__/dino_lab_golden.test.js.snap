<button id="dinotab-ecosystem" role="tab" aria-selected="true" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:700;background:#15803d;color:#fff;white-space:nowrap">🌍 Ecosystems</button>
<button id="dinotab-compare" role="tab" aria-selected="false" aria-controls="dinopanel" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">⚖️ Compare</button>
