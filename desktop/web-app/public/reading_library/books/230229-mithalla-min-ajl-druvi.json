[29,"لِتَنْظُرَ"],[30,"إِلَى"],[31,"أَعْشَاشِ"],[32,"الطُّيُورِ"],[33,"وَبُيُوتِ"],[34,"الْعَنْكَبُوتِ."],[35,"وَلَكِنَّهَا"],[36,"لَا"],[37,"تَرَى"],[38,"الْغُيُومَ"],[39,"الْمُتَجَمِّعَةَ"],[40,"فِي"],[41,"السَّمَاءِ."]]},{"n":3,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/56288/size6/fde94911dbd2c660688a433b1565b506.jpg","text":"سَقَطَتْ قَطْرَةُ مَطَرٍ عَلَى رَأْسِ دَارِين.\nتُرِيدُ دَارِين الذَّهَابَ إِلَى الْمَنْزِلِ،\nلَكِنَّهَا لَا تُرِيدُ أَنْ تَبْتَلَّ أَجْنِحَتُهَا.","words":[[42,"سَقَطَتْ"],[43,"قَطْرَةُ"],[44,"مَطَرٍ"],[45,"عَلَى"],[46,"رَأْسِ"],[47,"دَارِين."],[48,"تُرِيدُ"],[49,"دَارِين"],[50,"الذَّهَابَ"],[51,"إِلَى"],[52,"الْمَنْزِلِ،"],[53,"لَكِنَّهَا"],[54,"لَا"],[55,"تُرِيدُ"],[56,"أَنْ"],[57,"تَبْتَلَّ"],[58,"أَجْنِحَتُهَا."]]},{"n":4,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/56290/size6/308ac3c58e532bda15d503d1b1fd46ee.jpg","text":"قَالَتْ دَارِين لِنَفْسِهَا: \"أَحْتَاجُ إِلَى مِظَلَّةٍ\"!\nفَطَارَتْ إِلَى أَقْرَبِ شَجَرَةِ بُونْسِيَانَا،\nلِأَنَّهَا تُشْبِهُ الْمِظَلَّةَ الْكَبِيرَةَ الْحَمْرَاءَ.","words":[[59,"قَالَتْ"],[60,"دَارِين"],[61,"لِنَفْسِهَا:"],[62,"\"أَحْتَاجُ"],[63,"إِلَى"],[64,"مِظَلَّةٍ\"!"],[65,"فَطَارَتْ"],[66,"إِلَى"],[67,"أَقْرَبِ"],[68,"شَجَرَةِ"],[69,"بُونْسِيَانَا،"],[70,"لِأَنَّهَا"],[71,"تُشْبِهُ"],[72,"الْمِظَلَّةَ"],[73,"الْكَبِيرَةَ"],[74,"الْحَمْرَاءَ."]]},{"n":5,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/56291/size6/bfb252da178955f048e4b49cbdc25a86.jpg","text":"لَكِنَّ أَوْرَاقَهَا صَغِيرَةٌ جِدًّا!\nقَالَتْ دَارِين لِنَفْسِهَا: \"أَوْرَاقُهَا صَغِيرَةٌ بِالْكَادِ تُغَطِّي نَمْلَةً! أَحْتَاجُ إِلَى شَيْءٍ أَكْبَرَ\".","words":[[75,"لَكِنَّ"],[76,"أَوْرَاقَهَا"],[77,"صَغِيرَةٌ"],[78,"جِدًّا!"],[79,"قَالَتْ"],[80,"دَارِين"],[81,"لِنَفْسِهَا:"],[82,"\"أَوْرَاقُهَا"],[83,"صَغِيرَةٌ"],[84,"بِالْكَادِ"],[85,"تُغَطِّي"],[86,"نَمْلَةً!"],[87,"أَحْتَاجُ"],[88,"إِلَى"],[89,"شَيْءٍ"],[90,"أَكْبَرَ\"."]]},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/56292/size6/7b2c3f28a1cb592ebeb28ba33f32f11b.jpg","text":"ثُمَّ رَأَتْ دَارِين أَوْرَاقَ شَجَرَةٍ كَبِيرَةٍ تُشْبِهُ النُّجُومَ.\nفَقَالَتْ دَارِين لِنَفْسِهَا: \"يُمْكِنُ لِأَوْرَاقِ شَجَرَةِ الْبَابَايَا أَنْ تَكُونَ مِظَلَّةً رَائِعَةً\"!\nوَلَكِنْ بَعْدَ أَنْ حَاوَلَتْ الِاخْتِبَاءَ تَحْتَهَا صَاحَتْ: \"أُوهْ، لَا! أَوْرَاقُ هَذِهِ الشَّجَرَةِ لَا تَحْمِي مِنَ الْمَطَرِ\"!","words":[[91,"ثُمَّ"],[92,"رَأَتْ"],[93,"دَارِين"],[94,"أَوْرَاقَ"],[95,"شَجَرَةٍ"],[96,"كَبِيرَةٍ"],[97,"تُشْبِهُ"],[98,"النُّجُومَ."],[99,"فَقَالَتْ"],[100,"دَارِين"],[101,"لِنَفْسِهَا:"],[102,"\"يُمْكِنُ"],[103,"لِأَوْرَاقِ"],[104,"شَجَرَةِ"],[105,"الْبَابَايَا"],[106,"أَنْ"],[107,"تَكُونَ"],[108,"مِظَلَّةً"],[109,"رَائِعَةً\"!"],[110,"وَلَكِنْ"],[111,"بَعْدَ"],[112,"أَنْ"],[113,"حَاوَلَتْ"],[114,"الِاخْتِبَاءَ"],[115,"تَحْتَهَا"],[116,"صَاحَتْ:"],[117,"\"أُوهْ،"],[118,"لَا!"],[119,"أَوْرَاقُ"],[120,"هَذِهِ"],[121,"الشَّجَرَةِ"],[122,"لَا"],[123,"تَحْمِي"],[124,"مِنَ"],[125,"الْمَطَرِ\"!"]]},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/56293/size6/d8c7b721cf67e77d56ab25c2c55bf851.jpg","text":"هَبَّتْ رِيَاحٌ قَوِيَّةٌ وَلَمْ تَسْتَطِعْ دَارِين حَتَّى الْآنَ إِيجَادَ مِظَلَّةٍ مُنَاسِبَةٍ.\nفَحَطَّتْ دَارِين عَلَى وَرَقَةِ نَبْتَةٍ، لَكِنَّهَا رَقِيقَةٌ جِدًّا وَانْكَمَشَتْ تَحْتَهَا.\nفَقَالَتْ دَارِين لِنَبْتَةِ الْمِيمُوزَا الْمُسْتَحِيَةِ: \"يَا لَكِ مِنْ نَبْتَةٍ غَيْرِ لَطِيفَةٍ\".","words":[[126,"هَبَّتْ"],[127,"رِيَاحٌ"],[128,"قَوِيَّةٌ"],[129,"وَلَمْ"],[130,"تَسْتَطِعْ"],[131,"دَارِين"],[132,"حَتَّى"],[133,"الْآنَ"],[134,"إِيجَادَ"],[135,"مِظَلَّةٍ"],[136,"مُنَاسِبَةٍ."],[137,"فَحَطَّتْ"],[138,"دَارِين"],[139,"عَلَى"],[140,"وَرَقَةِ"],[141,"نَبْتَةٍ،"],[142,"لَكِنَّهَا"],[143,"رَقِيقَةٌ"],[144,"جِدًّا"],[145,"وَانْكَمَشَتْ"],[146,"تَحْتَهَا."],[147,"فَقَالَتْ"],[148,"دَارِين"],[149,"لِنَبْتَةِ"],[150,"الْمِيمُوزَا"],[151,"الْمُسْتَحِيَةِ:"],[152,"\"يَا"],[153,"لَكِ"],[154,"مِنْ"],[155,"نَبْتَةٍ"],[156,"غَيْرِ"],[157,"لَطِيفَةٍ\"."]]},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/56294/size6/4f85da00aaca20b377bb64a06deb9ceb.jpg","text":"حَزِنَتْ دَارِين؛ فَالْأَدْغَالُ مَلِيئَةٌ بَأَوْرَاقِ الشَّجَرِ وَالنَّبَاتَاتِ.\nفِيهَا أَوْرَاقٌ رَقِيقَةٌ وَغَيْرُهَا سَمِيكَةٌ، وَأَوْرَاقٌ كَبِيرَةٌ وَأُخْرَى صَغِيرَةٌ.\nلَكِنَّ جَمِيعَهَا لَا تَصْلُحُ أَنْ تَكُونَ مِظَلَّةً.","words":[[158,"حَزِنَتْ"],[159,"دَارِين؛"],[160,"فَالْأَدْغَالُ"],[161,"مَلِيئَةٌ"],[162,"بَأَوْرَاقِ"],[163,"الشَّجَرِ"],[164,"وَالنَّبَاتَاتِ."],[165,"فِيهَا"],[166,"أَوْرَاقٌ"],[167,"رَقِيقَةٌ"],[168,"وَغَيْرُهَا"],[169,"سَمِيكَةٌ،"],[170,"وَأَوْرَاقٌ"],[171,"كَبِيرَةٌ"],[172,"وَأُخْرَى"],[173,"صَغِيرَةٌ."],[174,"لَكِنَّ"],[175,"جَمِيعَهَا"],[176,"لَا"],[177,"تَصْلُحُ"],[178,"أَنْ"],[179,"تَكُونَ"],[180,"مِظَلَّةً."]]},{"n":9,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/56295/size6/9ffb5fd5b56781cae61af9f640ed277e.jpg","text":"فَجْأَةً، رَأَتْ دَارِين شَجَرَةَ تِينٍ هِنْدِيٍّ.\nأَوْرَاقُهَا لَيْسَتْ عَلَى شَكْلِ نَجْمَةٍ وَلَا بِهَا أَشْوَاكٌ.\nكَمَا أَنَّ أَوْرَاقَهَا لَيْسَتْ ثَقِيلَةً أَوْ صَغِيرَةً.","words":[[181,"فَجْأَةً،"],[182,"رَأَتْ"],[183,"دَارِين"],[184,"شَجَرَةَ"],[185,"تِينٍ"],[186,"هِنْدِيٍّ."],[187,"أَوْرَاقُهَا"],[188,"لَيْسَتْ"],[189,"عَلَى"],[190,"شَكْلِ"],[191,"نَجْمَةٍ"],[192,"وَلَا"],[193,"بِهَا"],[194,"أَشْوَاكٌ."],[195,"كَمَا"],[196,"أَنَّ"],[197,"أَوْرَاقَهَا"],[198,"لَيْسَتْ"],[199,"ثَقِيلَةً"],[200,"أَوْ"],[201,"صَغِيرَةً."]]},{"n":10,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/56296/size6/77b2c72d6314b6be135d3c493e3767c8.jpg","text":"فَطَارَتْ دَارِين نَحْوَ شَجَرَةِ التِّينِ الْهِنْدِيِّ،\nوَحَطَّتْ عَلَى أَوْرَاقِهَا.\nأَخِيرًا وَجَدَتْ دَارِين مِظَلَّتَهَا!","words":[[202,"فَطَارَتْ"],[203,"دَارِين"],[204,"نَحْوَ"],[205,"شَجَرَةِ"],[206,"التِّينِ"],[207,"الْهِنْدِيِّ،"],[208,"وَحَطَّتْ"],[209,"عَلَى"],[210,"أَوْرَاقِهَا."],[211,"أَخِيرًا"],[212,"وَجَدَتْ"],[213,"دَارِين"],[214,"مِظَلَّتَهَا!"]]},{"n":11,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/56297/size6/73b0734219e7130eac4e46348a261558.jpg","text":"الْمَزِيدُ عَنِ الْيَعَاسِيبِ\nتُعَدُّ الْيَعَاسِيبُ مِنَ الْحَشَرَاتِ الْمُهَاجِرَةِ. بَعْضُ الْيَعَاسِيبِ، مِثْلُ الَّتِي نَجِدُهَا فِي الْحَدَائِقِ الْعَامَّةِ أَوْ حَدِيقَةِ الْمَنْزِلِ، تُهَاجِرُ وَتَطِيرُ مِنَ الْهِنْدِ إِلَى إِفْرِيقْيَا، فَتَطِيرُ لِمَسَافَاتٍ تَمْتَدُّ أَكْثَرَ مِنْ ١٦٠٠٠ كِيلُو مِتْرٍ عَبْرَ الْمُحِيطِ الْهِنْدِيِّ.\nتَبْدَأُ الْيَعَاسِيبُ رِحْلَتَهَا مِنَ الْهِنْدِ فِي شَهْرِ أُكْتُوبَرَ وَتَصِلُ إِلَى بِلْدَانٍ مِثْلِ تَنْزَانْيَا فِي شَهْرِ يَنَايِرَ. وَفِي طَرِيقِهَا، تَحُطُّ الْيَعَاسِيبُ فِي جُزُرٍ مِثْلِ الْمَالْدِيفِ وَالسِّيشِيلْ (جُزُرِ الْقُمَرِ).\nلَا تَسْتَطِيعُ الْيَعَاسِيبُ الطَّيَرَانَ عِنْدَمَا تَشْعُرُ بِالْبَرْدِ أَوِ الْحَرِّ. فِي الصَّبَاحِ، تَفْرِدُ أَجْنِحَتَهَا لِتَمْتَصَّ حَرَارَةَ الشَّمْسِ. وَبَعْدَ الظَّهِيرَةِ، تَرْفَعُ بَعْضُ الْيَعَاسِيبِ أَجْسَامَهَا وَتُوَجِّهُ بَطْنَهَا نَحْوَ الشَّمْسِ لِتَبْقَى بَارِدَةً.","words":[[215,"الْمَزِيدُ"],[216,"عَنِ"],[217,"الْيَعَاسِيبِ"],[218,"تُعَدُّ"],[219,"الْيَعَاسِيبُ"],[220,"مِنَ"],[221,"الْحَشَرَاتِ"],[222,"الْمُهَاجِرَةِ."],[223,"بَعْضُ"],[224,"الْيَعَاسِيبِ،"],[225,"مِثْلُ"],[226,"الَّتِي"],[227,"نَجِدُهَا"],[228,"فِي"],[229,"الْحَدَائِقِ"],[230,"الْعَامَّةِ"],[231,"أَوْ"],[232,"حَدِيقَةِ"],[233,"الْمَنْزِلِ،"],[234,"تُهَاجِرُ"],[235,"وَتَطِيرُ"],[236,"مِنَ"],[237,"الْهِنْدِ"],[238,"إِلَى"],[239,"إِفْرِيقْيَا،"],[240,"فَتَطِيرُ"],[241,"لِمَسَافَاتٍ"],[242,"تَمْتَدُّ"],[243,"أَكْثَرَ"],[244,"مِنْ"],[245,"١٦٠٠٠"],[246,"كِيلُو"],[247,"مِتْرٍ"],[248,"عَبْرَ"],[249,"الْمُحِيطِ"],[250,"الْهِنْدِيِّ."],[251,"تَبْدَأُ"],[252,"الْيَعَاسِيبُ"],[253,"رِحْلَتَهَا"],[254,"مِنَ"],[255,"الْهِنْدِ"],[256,"فِي"],[257,"شَهْرِ"],[258,"أُكْتُوبَرَ"],[259,"وَتَصِلُ"],[260,"إِلَى"],[261,"بِلْدَانٍ"],[262,"مِثْلِ"],[263,"تَنْزَانْيَا"],[264,"فِي"],[265,"شَهْرِ"],[266,"يَنَايِرَ."],[267,"وَفِي"],[268,"طَرِيقِهَا،"],[269,"تَحُطُّ"],[270,"الْيَعَاسِيبُ"],[271,"فِي"],[272,"جُزُرٍ"],[273,"مِثْلِ"],[274,"الْمَالْدِيفِ"],[275,"وَالسِّيشِيلْ"],[276,"(جُزُرِ"],[277,"الْقُمَرِ)."],[278,"لَا"],[279,"تَسْتَطِيعُ"],[280,"الْيَعَاسِيبُ"],[281,"الطَّيَرَانَ"],[282,"عِنْدَمَا"],[283,"تَشْعُرُ"],[284,"بِالْبَرْدِ"],[285,"أَوِ"],[286,"الْحَرِّ."],[287,"فِي"],[288,"الصَّبَاحِ،"],[289,"تَفْرِدُ"],[290,"أَجْنِحَتَهَا"],[291,"لِتَمْتَصَّ"],[292,"حَرَارَةَ"],[293,"الشَّمْسِ."],[294,"وَبَعْدَ"],[295,"الظَّهِيرَةِ،"],[296,"تَرْفَعُ"],[297,"بَعْضُ"],[298,"الْيَعَاسِيبِ"],[299,"أَجْسَامَهَا"],[300,"وَتُوَجِّهُ"],[301,"بَطْنَهَا"],[302,"نَحْوَ"],[303,"الشَّمْسِ"],[304,"لِتَبْقَى"],[305,"بَارِدَةً."]]}],"stats":{"pages":11,"words":305}}