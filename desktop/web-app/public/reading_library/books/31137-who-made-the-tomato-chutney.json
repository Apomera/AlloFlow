,"goes:"],[48,"-"],[49,"1"],[50,"kg"],[51,"fresh"],[52,"red"],[53,"tomatoes"],[54,"-"],[55,"½"],[56,"kg"],[57,"onions"],[58,"-"],[59,"½"],[60,"kg"],[61,"potatoes"],[62,"-"],[63,"1"],[64,"coconut"],[65,"-"],[66,"6"],[67,"limes"],[68,"*Half"],[69,"is"],[70,"written"],[71,"as"],[72,"½."],[73,"It"],[74,"means"],[75,"one"],[76,"out"],[77,"of"],[78,"two"],[79,"equal"],[80,"parts"],[81,"of"],[82,"something."],[83,"*A"],[84,"kilogram"],[85,"is"],[86,"written"],[87,"as"],[88,"kg."]]},{"n":3,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/64802/size6/c6edff58d34f231acfb316b02347b891.jpg","text":"Tara and Ravi walk home singing:\n\"We want ...\nTomato chutney, tomato chutney.\nAmma's tasty tomato chutney!\"","words":[[89,"Tara"],[90,"and"],[91,"Ravi"],[92,"walk"],[93,"home"],[94,"singing:"],[95,"\"We"],[96,"want"],[97,"..."],[98,"Tomato"],[99,"chutney,"],[100,"tomato"],[101,"chutney."],[102,"Amma's"],[103,"tasty"],[104,"tomato"],[105,"chutney!\""]]},{"n":4,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/64803/size6/10d85afd43f95b6b437e850121f8c491.jpg","text":"Suddenly Ravi asks Tara,\n\"Is something dripping on your feet too?\"\nTheir bag is wet. Oh no! The tomatoes are \nall squashed at the bottom.\nTara whispers to Ravi,\n\"Our tomato chutney looks so horrible.\nNot at all like Amma's!\"","words":[[106,"Suddenly"],[107,"Ravi"],[108,"asks"],[109,"Tara,"],[110,"\"Is"],[111,"something"],[112,"dripping"],[113,"on"],[114,"your"],[115,"feet"],[116,"too?\""],[117,"Their"],[118,"bag"],[119,"is"],[120,"wet."],[121,"Oh"],[122,"no!"],[123,"The"],[124,"tomatoes"],[125,"are"],[126,"all"],[127,"squashed"],[128,"at"],[129,"the"],[130,"bottom."],[131,"Tara"],[132,"whispers"],[133,"to"],[134,"Ravi,"],[135,"\"Our"],[136,"tomato"],[137,"chutney"],[138,"looks"],[139,"so"],[140,"horrible."],[141,"Not"],[142,"at"],[143,"all"],[144,"like"],[145,"Amma's!\""]]},{"n":5,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/67922/size6/a89ad53683c851c6294a1b74d416da1e.jpg","text":"The next week, Tara and Ravi are careful.\n\"Heavy vegetables at the bottom; soft and light ones \non top,\" Ravi keeps repeating.\nInto the bag goes:\n- 1 watermelon\n- ½ kg potatoes\n- 1 coconut\n- ½ kg grapes\n- 6 raw bananas\n- ½ kg tomatoes, right on top.","words":[[146,"The"],[147,"next"],[148,"week,"],[149,"Tara"],[150,"and"],[151,"Ravi"],[152,"are"],[153,"careful."],[154,"\"Heavy"],[155,"vegetables"],[156,"at"],[157,"the"],[158,"bottom;"],[159,"soft"],[160,"and"],[161,"light"],[162,"ones"],[163,"on"],[164,"top,\""],[165,"Ravi"],[166,"keeps"],[167,"repeating."],[168,"Into"],[169,"the"],[170,"bag"],[171,"goes:"],[172,"-"],[173,"1"],[174,"watermelon"],[175,"-"],[176,"½"],[177,"kg"],[178,"potatoes"],[179,"-"],[180,"1"],[181,"coconut"],[182,"-"],[183,"½"],[184,"kg"],[185,"grapes"],[186,"-"],[187,"6"],[188,"raw"],[189,"bananas"],[190,"-"],[191,"½"],[192,"kg"],[193,"tomatoes,"],[194,"right"],[195,"on"],[196,"top."]]},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/67923/size6/31c2c0520c1ded2ff0bf3a647a8d7601.jpg","text":"But at home, they find the grapes have become \ngrape juice under the raw bananas!\n\"Last time we made the tomatoes into chutney. This time we made the grapes into juice. Wonder what we will do next!\" Tara says sadly.","words":[[197,"But"],[198,"at"],[199,"home,"],[200,"they"],[201,"find"],[202,"the"],[203,"grapes"],[204,"have"],[205,"become"],[206,"grape"],[207,"juice"],[208,"under"],[209,"the"],[210,"raw"],[211,"bananas!"],[212,"\"Last"],[213,"time"],[214,"we"],[215,"made"],[216,"the"],[217,"tomatoes"],[218,"into"],[219,"chutney."],[220,"This"],[221,"time"],[222,"we"],[223,"made"],[224,"the"],[225,"grapes"],[226,"into"],[227,"juice."],[228,"Wonder"],[229,"what"],[230,"we"],[231,"will"],[232,"do"],[233,"next!\""],[234,"Tara"],[235,"says"],[236,"sadly."]]},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/68024/size6/904c7c2fd179e9a98c5a8ef4b1e44303.jpg","text":"Next time, Amma's list also has oranges.\n \nThey are soft and light. So they go on top, next to the tomatoes.","words":[[237,"Next"],[238,"time,"],[239,"Amma's"],[240,"list"],[241,"also"],[242,"has"],[243,"oranges."],[244,"They"],[245,"are"],[246,"soft"],[247,"and"],[248,"light."],[249,"So"],[250,"they"],[251,"go"],[252,"on"],[253,"top,"],[254,"next"],[255,"to"],[256,"the"],[257,"tomatoes."]]},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/67925/size6/5050466b7e1b7a4b938c9723b2cfbd58.jpg","text":"Just as Tara and Ravi are walking home singing their chutney song, their friends see them.\nThey are thirsty, so they eat up all the oranges!","words":[[258,"Just"],[259,"as"],[260,"Tara"],[261,"and"],[262,"Ravi"],[263,"are"],[264,"walking"],[265,"home"],[266,"singing"],[267,"their"],[268,"chutney"],[269,"song,"],[270,"their"],[271,"friends"],[272,"see"],[273,"them."],[274,"They"],[275,"are"],[276,"thirsty,"],[277,"so"],[278,"they"],[279,"eat"],[280,"up"],[281,"all"],[282,"the"],[283,"oranges!"]]},{"n":9,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/67926/size6/7a1874c21edeff6949ac5e4cb49d414a.jpg","text":"At home, Amma hugs them when she hears about the missing oranges. \nShe tells them not to feel sad.","words":[[284,"At"],[285,"home,"],[286,"Amma"],[287,"hugs"],[288,"them"],[289,"when"],[290,"she"],[291,"hears"],[292,"about"],[293,"the"],[294,"missing"],[295,"oranges."],[296,"She"],[297,"tells"],[298,"them"],[299,"not"],[300,"to"],[301,"feel"],[302,"sad."]]},{"n":10,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/64811/size6/f1ea10ec065bc89191b052c7a2b20e99.jpg","text":"Next week, Tara and Ravi are clever.\nThey hide the oranges under the lightest thing -\na bunch of pudina leaves. Now their thirsty friends \nwill not spot the oranges!","words":[[303,"Next"],[304,"week,"],[305,"Tara"],[306,"and"],[307,"Ravi"],[308,"are"],[309,"clever."],[310,"They"],[311,"hide"],[312,"the"],[313,"oranges"],[314,"under"],[315,"the"],[316,"lightest"],[317,"thing"],[318,"-"],[319,"a"],[320,"bunch"],[321,"of"],[322,"pudina"],[323,"leaves."],[324,"Now"],[325,"their"],[326,"thirsty"],[327,"friends"],[328,"will"],[329,"not"],[330,"spot"],[331,"the"],[332,"oranges!"]]},{"n":11,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/67927/size6/eb444f036933c78a1e1bb511107d56c4.jpg","text":"That night, Amma makes her tasty tomato chutney\nand lemon rice. Tara and Ravi gobble up their dinner.\nAnd what do they get later? Sweet, juicy oranges, of course!","words":[[333,"That"],[334,"night,"],[335,"Amma"],[336,"makes"],[337,"her"],[338,"tasty"],[339,"tomato"],[340,"chutney"],[341,"and"],[342,"lemon"],[343,"rice."],[344,"Tara"],[345,"and"],[346,"Ravi"],[347,"gobble"],[348,"up"],[349,"their"],[350,"dinner."],[351,"And"],[352,"what"],[353,"do"],[354,"they"],[355,"get"],[356,"later?"],[357,"Sweet,"],[358,"juicy"],[359,"oranges,"],[360,"of"],[361,"course!"]]},{"n":12,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/64813/size6/15359003d33e4d771a77efa89aa190d4.jpg","text":"1. If your mother sent you to the shop to buy apples, watermelon and bananas, which fruit would you NEVER put at the bottom?","words":[[362,"1."],[363,"If"],[364,"your"],[365,"mother"],[366,"sent"],[367,"you"],[368,"to"],[369,"the"],[370,"shop"],[371,"to"],[372,"buy"],[373,"apples,"],[374,"watermelon"],[375,"and"],[376,"bananas,"],[377,"which"],[378,"fruit"],[379,"would"],[380,"you"],[381,"NEVER"],[382,"put"],[383,"at"],[384,"the"],[385,"bottom?"]]},{"n":13,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/67435/size6/9cd4c44559991f7e80bde1622a24b4b5.jpg","text":"2. Your shopping bag has ½ kg sugar, ½ kg tea, and two packets of biscuits. Which one goes on top?","words":[[386,"2."],[387,"Your"],[388,"shopping"],[389,"b