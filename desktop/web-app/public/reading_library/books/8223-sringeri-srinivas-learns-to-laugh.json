[7,"He"],[8,"grew"],[9,"the"],[10,"best"],[11,"bananas,"],[12,"which"],[13,"made"],[14,"the"],[15,"best"],[16,"banana"],[17,"halwa."]]},{"n":2,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/27015/size6/8fb3bd7a48ae1a7ec3f1b7d47b95e894.jpg","text":"But\nhe also had the scariest frown in the world.\nWhen\nhe was angry, his forehead became full of deep lines.\nHis\nnose became red. His eyes became very sharp.","words":[[18,"But"],[19,"he"],[20,"also"],[21,"had"],[22,"the"],[23,"scariest"],[24,"frown"],[25,"in"],[26,"the"],[27,"world."],[28,"When"],[29,"he"],[30,"was"],[31,"angry,"],[32,"his"],[33,"forehead"],[34,"became"],[35,"full"],[36,"of"],[37,"deep"],[38,"lines."],[39,"His"],[40,"nose"],[41,"became"],[42,"red."],[43,"His"],[44,"eyes"],[45,"became"],[46,"very"],[47,"sharp."]]},{"n":3,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/27017/size6/1fb58aadfa8d4a03a868555b37119cfb.jpg","text":"When\nSringeri Srinivas frowned, everyone ran away from him. His wife, his\nchildren and his friends tried to hide. His cows and his dogs ran\naway. Even the crows in the field flew away when Sringeri Srinivas\nfrowned.","words":[[48,"When"],[49,"Sringeri"],[50,"Srinivas"],[51,"frowned,"],[52,"everyone"],[53,"ran"],[54,"away"],[55,"from"],[56,"him."],[57,"His"],[58,"wife,"],[59,"his"],[60,"children"],[61,"and"],[62,"his"],[63,"friends"],[64,"tried"],[65,"to"],[66,"hide."],[67,"His"],[68,"cows"],[69,"and"],[70,"his"],[71,"dogs"],[72,"ran"],[73,"away."],[74,"Even"],[75,"the"],[76,"crows"],[77,"in"],[78,"the"],[79,"field"],[80,"flew"],[81,"away"],[82,"when"],[83,"Sringeri"],[84,"Srinivas"],[85,"frowned."]]},{"n":4,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/27018/size6/3ba0d7dbd6b87815278fe76eeb71b73c.jpg","text":"And\nSringeri Srinivas frowned often. When his crops were not growing\nwell. When his barber had no time to cut his hair. When the TV did\nnot work. And so on. And on.","words":[[86,"And"],[87,"Sringeri"],[88,"Srinivas"],[89,"frowned"],[90,"often."],[91,"When"],[92,"his"],[93,"crops"],[94,"were"],[95,"not"],[96,"growing"],[97,"well."],[98,"When"],[99,"his"],[100,"barber"],[101,"had"],[102,"no"],[103,"time"],[104,"to"],[105,"cut"],[106,"his"],[107,"hair."],[108,"When"],[109,"the"],[110,"TV"],[111,"did"],[112,"not"],[113,"work."],[114,"And"],[115,"so"],[116,"on."],[117,"And"],[118,"on."]]},{"n":5,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/27021/size6/76816ba874415ed70c9f65010a161098.jpg","text":"One\nday, Sringeri Srinivas went into his field to look at his banana\nharvest. He was in a bad mood. No one knew why.","words":[[119,"One"],[120,"day,"],[121,"Sringeri"],[122,"Srinivas"],[123,"went"],[124,"into"],[125,"his"],[126,"field"],[127,"to"],[128,"look"],[129,"at"],[130,"his"],[131,"banana"],[132,"harvest."],[133,"He"],[134,"was"],[135,"in"],[136,"a"],[137,"bad"],[138,"mood."],[139,"No"],[140,"one"],[141,"knew"],[142,"why."]]},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/27022/size6/67431d9e8452a192af445a5e528c879a.jpg","text":"He\nwalked quickly to his biggest banana plant. There were big bunches of\nlovely fruit.\nSoon,\nhe would begin to make his famous banana halwa. His frown changed to\na small smile.","words":[[143,"He"],[144,"walked"],[145,"quickly"],[146,"to"],[147,"his"],[148,"biggest"],[149,"banana"],[150,"plant."],[151,"There"],[152,"were"],[153,"big"],[154,"bunches"],[155,"of"],[156,"lovely"],[157,"fruit."],[158,"Soon,"],[159,"he"],[160,"would"],[161,"begin"],[162,"to"],[163,"make"],[164,"his"],[165,"famous"],[166,"banana"],[167,"halwa."],[168,"His"],[169,"frown"],[170,"changed"],[171,"to"],[172,"a"],[173,"small"],[174,"smile."]]},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/27023/size6/19866310f2c98958371f6783d55545d6.jpg","text":"Just\nthen, a troop of monkeys came swinging from a tree nearby. The\nbiggest one, with a fiery red bottom, jumped exactly onto the plant\nthat Sringeri Srinivas was looking at proudly.","words":[[175,"Just"],[176,"then,"],[177,"a"],[178,"troop"],[179,"of"],[180,"monkeys"],[181,"came"],[182,"swinging"],[183,"from"],[184,"a"],[185,"tree"],[186,"nearby."],[187,"The"],[188,"biggest"],[189,"one,"],[190,"with"],[191,"a"],[192,"fiery"],[193,"red"],[194,"bottom,"],[195,"jumped"],[196,"exactly"],[197,"onto"],[198,"the"],[199,"plant"],[200,"that"],[201,"Sringeri"],[202,"Srinivas"],[203,"was"],[204,"looking"],[205,"at"],[206,"proudly."]]},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/27024/size6/07ddc3105e459265c37d9bd8713687b9.jpg","text":"This\nmade him frown again. His frown grew and grew. It was his biggest\nfrown ever. It began from his head and spread right to his toes.","words":[[207,"This"],[208,"made"],[209,"him"],[210,"frown"],[211,"again."],[212,"His"],[213,"frown"],[214,"grew"],[215,"and"],[216,"grew."],[217,"It"],[218,"was"],[219,"his"],[220,"biggest"],[221,"frown"],[222,"ever."],[223,"It"],[224,"began"],[225,"from"],[226,"his"],[227,"head"],[228,"and"],[229,"spread"],[230,"right"],[231,"to"],[232,"his"],[233,"toes."]]},{"n":9,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/27025/size6/50831898a9bb55f188a4dbd5d199c58a.jpg","text":"The\nmonkey, with his own nasty temper, was surprised. He had never seen a\nfrown like that. He dropped a half-peeled banana on the ground, then\nhe dropped a few more. Quickly, he jumped to the next plant and then\nthe next. Soon, he was far away and safe from the frown.","words":[[234,"The"],[235,"monkey,"],[236,"with"],[237,"his"],[238,"own"],[239,"nasty"],[240,"temper,"],[241,"was"],[242,"surprised."],[243,"He"],[244,"had"],[245,"never"],[246,"seen"],[247,"a"],[248,"frown"],[249,"like"],[250,"that."],[251,"He"],[252,"dropped"],[253,"a"],[254,"half-peeled"],[255,"banana"],[256,"on"],[257,"the"],[258,"ground,"],[25