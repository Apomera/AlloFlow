eapis.com/static.storyweaver.org.in/illustration_crops/26552/size6/2e1134b683a98c39df3c662ac5152985.jpg","text":"Aha,\nBholu is cutting purple brinjals.","words":[[40,"Aha,"],[41,"Bholu"],[42,"is"],[43,"cutting"],[44,"purple"],[45,"brinjals."]]},{"n":5,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/26553/size6/91e1769c6b2d5484f13ebb52b0b13f8a.jpg","text":"Rani Didi has sunshine\nyellow\nlemons.","words":[[46,"Rani"],[47,"Didi"],[48,"has"],[49,"sunshine"],[50,"yellow"],[51,"lemons."]]},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/26554/size6/5fc114717f9cb3015ccfde50dd72abee.jpg","text":"Colours are fun to see. Now to\neat something colourful too! Yummy!\nShould we eat a pink chuski?","words":[[52,"Colours"],[53,"are"],[54,"fun"],[55,"to"],[56,"see."],[57,"Now"],[58,"to"],[59,"eat"],[60,"something"],[61,"colourful"],[62,"too!"],[63,"Yummy!"],[64,"Should"],[65,"we"],[66,"eat"],[67,"a"],[68,"pink"],[69,"chuski?"]]},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/26555/size6/52f921c4c1eaa03f60f95aaa7d8c6ac6.jpg","text":"Or a creamy white kulfi?","words":[[70,"Or"],[71,"a"],[72,"creamy"],[73,"white"],[74,"kulfi?"]]},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/26556/size6/09fc92689909a4ffff616dfe8b29775e.jpg","text":"We can drink tangy green\njaljeera.","words":[[75,"We"],[76,"can"],[77,"drink"],[78,"tangy"],[79,"green"],[80,"jaljeera."]]},{"n":9,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/26557/size6/639449f2714f8336e22a7a170cd1f1bb.jpg","text":"Or we can have sweet brown\ndates?","words":[[81,"Or"],[82,"we"],[83,"can"],[84,"have"],[85,"sweet"],[86,"brown"],[87,"dates?"]]},{"n":10,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/26558/size6/c70f2a1c93ae7a6e7f40153589a92362.jpg","text":"But Ramu's guavas are the\nbest.","words":[[88,"B