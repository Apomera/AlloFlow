4]]},"pages":[{"n":1,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/80402/size6/5569146fa91df259537695c8e3a95820.jpg","text":"I love going for walks.\nEspecially with my Pishi.","words":[[1,"I"],[2,"love"],[3,"going"],[4,"for"],[5,"walks."],[6,"Especially"],[7,"with"],[8,"my"],[9,"Pishi."]]},{"n":2,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/80436/size6/46961831e1a1a59fc81d90163547a260.jpg","text":"I like it when Pishi holds my hand.\nBut I like it even more… when she lets it go.","words":[[10,"I"],[11,"like"],[12,"it"],[13,"when"],[14,"Pishi"],[15,"holds"],[16,"my"],[17,"hand."],[18,"But"],[19,"I"],[20,"like"],[21,"it"],[22,"even"],[23,"more…"],[24,"when"],[25,"she"],[26,"lets"],[27,"it"],[28,"go."]]},{"n":3,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/80405/size6/2eac929eb2a598b0484e072ed96c90ad.jpg","text":"We never walk fast.\nWe often stop to say hello to…","words":[[29,"We"],[30,"never"],[31,"walk"],[32,"fast."],[33,"We"],[34,"often"],[35,"stop"],[36,"to"],[37,"say"],[38,"hello"],[39,"to…"]]},{"n":4,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/80396/size6/a1e160dde323596b450138058d5eee08.jpg","text":"a dog, a cat, a rat, a crow, a tree.","words":[[40,"a"],[41,"dog,"],[42,"a"],[43,"cat,"],[44,"a"],[45,"rat,"],[46,"a"],[47,"crow,"],[48,"a"],[49,"tree."]]},{"n":5,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/80407/size6/2a2bba015acaf0899aaa2941f8bd1087.jpg","text":"Pishi loves picking up flowers from the street.\nI love picking up stones.\nBig ones, small ones,\nround ones, flat ones.","words":[[50,"Pishi"],[51,"loves"],[52,"picking"],[53,"up"],[54,"flowers"],[55,"from"],[56,"the"],[57,"street."],[58,"I"],[59,"love"],[60,"picking"],[61,"up"],[62,"stones."],[63,"Big"],[64,"ones,"],[65,"small"],[66,"ones,"],[67,"round"],[68,"ones,"],[69,"flat"],[70,"ones."]]},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/80408/size6/456c6f0efc81433df3dacc3c3d95f163.jpg","text":"But the best are the really tiny ones.\nSo tiny, they get lost in my pocket.","words":[[71,"But"],[72,"the"],[73,"best"],[74,"are"],[75,"the"],[76,"really"],[77,"tiny"],[78,"ones."],[79,"So"],[80,"tiny,"],[81,"they"],[82,"get"],[83,"lost"],[84,"in"],[85,"my"],[86,"pocket."]]},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/80410/size6/9a125adfa283859d982edd1d1176930a.jpg","text":"My pockets are full of things after my walks with Pishi.","words":[[87,"My"],[88,"pockets"],[89,"are"],[90,"full"],[91,"of"],[92,"things"],[93,"after"],[94,"my"],[95,"walks"],[96,"with"],[97,"Pishi."]]},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/80412/size6/bf4a52b348c2f0b1527b69bba64b17fa.jpg","text":"Today, Ajji gave me a pod of peas from her basket.","words":[[98,"Today,"],[99,"Ajji"],[100,"gave"],[101,"me"],[102,"a"],[103,"pod"],[104,"of"],[105,"peas"],[106,"from"],[107,"her"],[108,"basket."]]},{"n":9,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/80414/size6/4f093c4120add000614d99b9f61a2bd0.jpg","text":"Dilip bhau gave me this clip from his magical shop.","words":[[109,"Dilip"],[110,"bhau"],[111,"gave"],[112,"me"],[113,"this"],[114,"clip"],[115,"from"],[116,"his"],[117,"magical"],[118,"shop."]]},{"n":10,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/80415/size6/71d919fa95fcc3491d7bb593f7bb1509.jpg","text":"Nirmal didi gave me this sticker for quietly waiting, waiting and waiting.","words":[[119,"Nirmal"],[120,"didi"],[121,"gave"],[122,"me"],[123,"this"],[124,"sticker"],[125,"for"],[126,"quietly"],[127,"waiting,"],[128,"waiting"],[129,"and"],[130,"waiting."]]},{"n":11,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/80427/size6/3e7acd7b378df16e41f3a7e680ab9c60.jpg","text":"Anjum aunty gave me this button from her big button jar.","words":[[131,"Anjum"],[132,"aunty"],[133,"gave"],[134,"me"],[135,"this"],[136,"button"],[137,"from"],[138,"her"],[139,"big"],[140,"button"],[141,"jar."]]},{"n":12,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/80435/size6/2daf82795d01958a5222d016c614b1eb.jpg","text":"When I get home, I’ll empty my pockets and keep it all in my yellow box.","words":[[142,"When"],[143,"I"],[144,"get"],[145,"home,"],[146,"I’ll"],[147,"empty"],[148,"my"],[149,"pockets"],[150,"and"],[151,"keep"],[152,"it"],[153,"all"],[154,"in"],[155,"my"],[156,"yellow"],[157,"box."]]},{"n":13,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/80400/size6/548a068f18aede706a87fa913ce2bd7b.jpg","text":"If I find the tiny stone in my pocket, I’ll give it to my Pishi.","words":[[158,"If"],[159,"I"],[160,"find"],[161,"the"],[162,"tiny"],[163,"stone"],[164,"in"],[165,"my"],[166,"pocket,"],[167,"I’ll"],[168,"give"],[169,"it"],[170,"to"],[171,"my"],[172,"Pishi."]]}],"stats":{"pages":13,"words":172}}