rg.in/illustration_crops/1260/size6/f4d176ee155ecc04b5b41e7659a27149.jpg","text":"आज माझ्या शाळेचा पहिला दिवस! आई माझा हात धरून मला घेऊन चालली आहे.\n“आई गं, आता मी मोठी झालेय हं.” मी म्हणते.\n“सोड माझा हात, मला एकटीला चालू दे!” आई माझा हात आणखी घट्ट पकडते.","words":[[1,"आज"],[2,"माझ्या"],[3,"शाळेचा"],[4,"पहिला"],[5,"दिवस!"],[6,"आई"],[7,"माझा"],[8,"हात"],[9,"धरून"],[10,"मला"],[11,"घेऊन"],[12,"चालली"],[13,"आहे."],[14,"“आई"],[15,"गं,"],[16,"आता"],[17,"मी"],[18,"मोठी"],[19,"झालेय"],[20,"हं.”"],[21,"मी"],[22,"म्हणते."],[23,"“सोड"],[24,"माझा"],[25,"हात,"],[26,"मला"],[27,"एकटीला"],[28,"चालू"],[29,"दे!”"],[30,"आई"],[31,"माझा"],[32,"हात"],[33,"आणखी"],[34,"घट्ट"],[35,"पकडते."]]},{"n":2,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/1261/size6/cd0778186f6e9e4a901f4513cefca304.jpg","text":"शाळेपाशी मुलांची खूपच गर्दी आहे. कुणी बसनं येतंय, कुणी कारमधून.\nकाही जण रिक्षानं तर काही सायकलवरून. माझ्यासारखी चालत येणारी मुलंपण आहेत.","words":[[36,"शाळेपाशी"],[37,"मुलांची"],[38,"खूपच"],[39,"गर्दी"],[40,"आहे."],[41,"कुणी"],[42,"बसनं"],[43,"येतंय,"],[44,"कुणी"],[45,"कारमधून."],[46,"काही"],[47,"जण"],[48,"रिक्षानं"],[49,"तर"],[50,"काही"],[51,"सायकलवरून."],[52,"माझ्यासारखी"],[53,"चालत"],[54,"येणारी"],[55,"मुलंपण"],[56,"आहेत."]]},{"n":3,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/1262/size6/2d47b6ee6c91bc239e6d30262332ffd2.jpg","text":"आम्ही आता शाळेच्या दाराशी पोचलोय.\nआई माझा हात सोडते. आतमध्ये मला एकटीलाच जायचंय.\nमाझ्या भोवती कितीतरी नवे चेहरे दिसतायत.","words":[[57,"आम्ही"],[58,"आता"],[59,"शाळेच्या"],[60,"दाराशी"],[61,"पोचलोय."],[62,"आई"],[63,"माझा"],[64,"हात"],[65,"सोडते."],[66,"आतमध्ये"],[67,"मला"],[68,"एकटीलाच"],[69,"जायचंय."],[70,"माझ्या"],[71,"भोवती"],[72,"कितीतरी"],[73,"नवे"],[74,"चेहरे"],[75,"दिसतायत."]]},{"n":4,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/1263/size6/e29771bf74c00222399d944390f410f7.jpg","text":"मी एक पाऊल पुढे टाकते. मग दुसरं. मागे वळून बघते, तर आई लहान लहान होत चाललीय. ती दिसेनाशीच होईल का? मी धावत आईकडे जाते.\nआता मला मी इतकी मोठी झालेय असं नाही वाटत. मी तिचा हात पकडते.\nआणि म्हणते, \"तू मला सोडून जाऊ नको.\"","words":[[76,"मी"],[77,"एक"],[78,"पाऊल"],[79,"पुढे"],[80,"टाकते."],[81,"मग"],[82,"दुसरं."],[83,"मागे"],[84,"वळून"],[85,"बघते,"],[86,"तर"],[87,"आई"],[88,"लहान"],[89,"लहान"],[90,"होत"],[91,"चाललीय."],[92,"ती"],[93,"दिसेनाशीच"],[94,"होईल"],[95,"का?"],[96,"मी"],[97,"धावत"],[98,"आईकडे"],[99,"जाते."],[100,"आता"],[101,"मला"],[102,"मी"],[103,"इतकी"],[104,"मोठी"],[105,"झालेय"],[106,"असं"],[107,"नाही"],[108,"वाटत."],[109,"मी"],[110,"तिचा"],[111,"हात"],[112,"पकडते."],[113,"आणि"],[114,"म्हणते,"],[115,"\"तू"],[116,"मला"],[117,"सोडून"],[118,"जाऊ"],[119,"नको.\""]]},{"n":5,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/1264/size6/aabc27989e15ba7b1604488f52d86b31.jpg","text":"आता सगळी मुलं आत गेलीत. बाहेर मी एकटीच आहे. बाई बाहेर येतात आणि माझ्याकडे बघून हसतात. मीपण हसते.\nआई म्हणते, “तू शाळा सुटल्यावर बाहेर येशील नं, तेव्हा मी इथेच असेन, बरं का.”  \nमी तिचा हात सोडते. ती माझ्याकडे बघत हात हलवते.","words":[[120,"आता"],[121,"सगळी"],[122,"मुलं"],[123,"आत"],[124,"गेलीत."],[125,"बाहेर"],[126,"मी"],[127,"एकटीच"],[128,"आहे."],[129,"बाई"],[130,"बाहेर"],[131,"येतात"],[132,"आणि"],[133,"माझ्याकडे"],[134,"बघून"],[135,"हसतात."],[136,"मीपण"],[137,"हसते."],[138,"आई"],[139,"म्हणते,"],[140,"“तू"],[141,"शाळा"],[142,"सुटल्यावर"],[143,"बाहेर"],[144,"येशील"],[145,"नं,"],[146,"तेव्हा"],[147,"मी"],[148,"इथेच"],[149,"असेन,"],[150,"बरं"],[151,"का.”"],[152,"मी"],[153,"तिचा"],[154,"हात"],[155,"सोडते."],[156,"ती"],[157,"माझ्याकडे"],[158,"बघत"],[159,"हात"],[160,"हलवते."]]},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/1265/size6/0400eb4ceb025592a48339ad6d4de85c.jpg","text":"मी धावत आत जाते.\nशाळा सुटली की आई परत इथेच भेटणार!","words":[[161,"मी"],[162,"धावत"],[163,"आत"],[164,"जाते."],[165,"शाळा"],[166,"सुटली"],[167,"की"],[168,"आई"],[169,"परत"],[170,"इथेच"],[171,"भेटणार!"]]}