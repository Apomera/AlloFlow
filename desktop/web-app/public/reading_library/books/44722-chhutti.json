nding"],[31,"to"],[32,"be"],[33,"asleep."],[34,"Holidays"],[35,"are"],[36,"an"],[37,"island"],[38,"where"],[39,"I"],[40,"am"],[41,"free"],[42,"An"],[43,"island"],[44,"that’s"],[45,"been"],[46,"made"],[47,"just"],[48,"for"],[49,"me!"]]},{"n":3,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/79640/size6/bf130ce754941fb020027600dba515d4.jpg","text":"Holidays are a gift coupon, life is study-free!\nWith a bonus of playtime. Whoopee!\nHoliday are sweet and sour like tasty treats,\nAnd as thrilling as playing hide and seek!\nHolidays jingle like loose change in my pocket, Vroom!\nBut they go by too fast, like a rocket.","words":[[50,"Holidays"],[51,"are"],[52,"a"],[53,"gift"],[54,"coupon,"],[55,"life"],[56,"is"],[57,"study-free!"],[58,"With"],[59,"a"],[60,"bonus"],[61,"of"],[62,"playtime."],[63,"Whoopee!"],[64,"Holiday"],[65,"are"],[66,"sweet"],[67,"and"],[68,"sour"],[69,"like"],[70,"tasty"],[71,"treats,"],[72,"And"],[73,"as"],[74,"thrilling"],[75,"as"],[76,"playing"],[77,"hide"],[78,"and"],[79,"seek!"],[80,"Holidays"],[81,"jingle"],[82,"like"],[83,"loose"],[84,"change"],[85,"in"],[86,"my"],[87,"pocket,"],[88,"Vroom!"],[89,"But"],[90,"they"],[91,"go"],[92,"by"],[93,"too"],[94,"fast,"],[95,"like"],[96,"a"],[97,"rocket."]]},{"n":4,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/79641/size6/9c283380a2017daf8c17a3e84dc0ee36.jpg","text":"Holidays, oh these weak-hearted fools\nAre a slave to the calendar and its rules.\nPerhaps, holidays are like my favourite toffee!\nOho! But they melt away oh-so-very quickly.","words":[[98,"Holidays,"],[99,"oh"],[100,"these"],[101,"weak-hearted"],[102,"fools"],[103,"Are"],[104,"a"],[105,"slave"],[106,"to"],[107,"the"],[108,"calendar"],[109,"and"],[110,"its"],[111,"rules."],[112,"Perhaps,"],[113,"holidays"],[114,"are"],[115,"like"],[116,"my"],[117,"favourite"],[118,"toffee!"],[119,"Oho!"],[120,"But"],[121,"they"],[122,"melt"],[123,"away"],[124,"oh-so-very"],[125,"quickly."]]