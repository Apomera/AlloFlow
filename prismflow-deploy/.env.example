# AlloFlow Environment Configuration
# Copy this file to .env and fill in YOUR public Firebase Web app values.
# Never place provider, LMS, or other billing credentials in REACT_APP_*.

REACT_APP_API_KEY=
REACT_APP_AUTH_DOMAIN=
REACT_APP_PROJECT_ID=
REACT_APP_STORAGE_BUCKET=
REACT_APP_MESSAGING_SENDER_ID=
REACT_APP_APP_ID=
REACT_APP_MEASUREMENT_ID=

# Optional, required before enabling Firestore live sessions or searchProxy.
# Firebase Console -> App Check -> reCAPTCHA Enterprise.
REACT_APP_FIREBASE_APP_CHECK_SITE_KEY=

GENERATE_SOURCEMAP=false
ESLINT_NO_DEV_ERRORS=true
DISABLE_ESLINT_PLUGIN=true
