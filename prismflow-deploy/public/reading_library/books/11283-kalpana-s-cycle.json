,[335,"would"],[336,"ride"],[337,"the"],[338,"cycle."],[339,"She"],[340,"was"],[341,"even"],[342,"wearing"],[343,"her"],[344,"lucky"],[345,"red"],[346,"hairclip."],[347,"\"Push"],[348,"and"],[349,"just"],[350,"let"],[351,"me"],[352,"go,\""],[353,"she"],[354,"told"],[355,"Prabhu."],[356,"He"],[357,"did"],[358,"just"],[359,"that."],[360,"Kalpana"],[361,"closed"],[362,"her"],[363,"eyes"],[364,"and"],[365,"tried"],[366,"to"],[367,"find"],[368,"the"],[369,"pedals."],[370,"The"],[371,"wind"],[372,"rushed"],[373,"in"],[374,"her"],[375,"ears."],[376,"The"],[377,"cycle"],[378,"wobbled"],[379,"on"],[380,"the"],[381,"road"],[382,"and"],[383,"then..."],[384,"DUMMMMMMMMMMMMMMMM!"],[385,"Kalpana"],[386,"fell."],[387,"AGAIN."]]},{"n":12,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/32660/size6/ab4bd940cf20ebe0e608bb1a88a5d5bc.jpg","text":"This time, the pain was so bad, she couldn’t breathe.\nNobody was laughing. Not even Manikandan, who was always so mean.","words":[[388,"This"],[389,"time,"],[390,"the"],[391,"pain"],[392,"was"],[393,"so"],[394,"bad,"],[395,"she"],[396,"couldn’t"],[397,"breathe."],[398,"Nobody"],[399,"was"],[400,"laughing."],[401,"Not"],[402,"even"],[403,"Manikandan,"],[404,"who"],[405,"was"],[406,"always"],[407,"so"],[408,"mean."]]},{"n":13,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/32665/size6/ab19903177168b1e19bd2727a139f97a.jpg","text":"The doctor was very stern.\nLike her school principal. He told Kalpana that she’d bruised her\nleg badly.\n\"You’ve\nto take care of it till it heals,\" he said. He gave Amma a long list of\nmedicines.\n\"No\nmore cycling till the bruise goes off,\" Amma said. Kalpana nodded.\n\"You\ncan still sit on the cycle though,\" said Prabhu.\n\"How?\"\nasked Kalpana.","words":[[409,"The"],[410,"doctor"],[411,"was"],[412,"very"],[413,"stern."],[414,"Like"],[415,"her"],[416,"school"],[417,"principal."],[418,"He"],[419,"told"],[420,"Kalpana"],[421,"that"],[422,"she’d"],[423,"bruised"],[424,"her"],[425,"leg"],[426,"badly."],[427,"\"You’ve"],[428,"to"],[429,"take"],[430,"care"],[431,"of"],[432,"it"],[433,"till"],[434,"it"],[435,"heals,\""],[436,"he"],[437,"said."],[438,"He"],[439,"gave"],[440,"Amma"],[441,"a"],[442,"long"],[443,"list"],[444,"of"],[445,"medicines."],[446,"\"No"],[447,"more"],[448,"cycling"],[449,"till"],[450,"the"],[451,"bruise"],[452,"goes"],[453,"off,\""],[454,"Amma"],[455,"said."],[456,"Kalpana"],[457,"nodded."],[458,"\"You"],[459,"can"],[460,"still"],[461,"sit"],[462,"on"],[463,"the"],[464,"cycle"],[465,"though,\""],[466,"said"],[467,"Prabhu."],[468,"\"How?\""],[469,"asked"],[470,"Kalpana."]]},{"n":14,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/32657/size6/42d63bbdd8efdf856c616c66f3c93732.jpg","text":"Appa showed her the cycle. It\nhad a brand new pillion seat.\n\"We\ngot it fixed when you were at the doctor’s!\" grinned Prabhu.\n\"But\nI will ride it myself soon,\" she said.\n\"Yes,\"\nsaid Prabhu. \"You will.\"","words":[[471,"Appa"],[472,"showed"],[473,"her"],[474,"the"],[475,"cycle."],[476,"It"],[477,"had"],[478,"a"],[479,"brand"],[480,"new"],[481,"pillion"],[482,"seat."],[483,"\"We"],[484,"got"],[485,"it"],[486,"fixed"],[487,"when"],[488,"you"],[489,"were"],[490,"at"],[491,"the"],[492,"doctor’s!\""],[493,"grinned"],[494,"Prabhu."],[495,"\"But"],[496,"I"],[497,"will"],[498,"ride"],[499,"it"],[500,"myself"],[501,"soon,\""],[502,"she"],[503,"said."],[504,"\"Yes,\""],[505,"said"],[506,"Prabhu."],[507,"\"You"],[508,"will.\""]]},{"n":15,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/32658/size6/8c9abfb3a28ab7e6e96e174471018d36.jpg","text":"16/17","words":null},{"n":16,"img":null,"text":"Kalpana\nfell off the cycle but so what?\nEveryone\ntells you to keep trying even if you don't succeed. Why?\nTrying\nsometimes gives you results that you're not looking for. It teaches\nyou something about yourself that you never knew. If Kalpana had\nlearnt to ride the cycle on the very first day, she might have never\nknown how determined a person she is! Her family might have never\nrealised this about her too.\nMaybe\nsomeday in the future, when Kalpana becomes tall and strong after\ndrinking many cups of milk, she will think back to the day she fell\nfrom her cycle. Maybe it will happen when Kalpana has a difficult\nexam to write or is hiking up a mountain. Maybe it will happen when\nshe is baking a cake or taking pictures of a tiger. And maybe Kalpana\nwill make up her mind not to give up because she still remembers what\nshe learned that day on her cycle.","words":[[509,"Kalpana"],[510,"fell"],[511,"off"],[512,"the"],[513,"cycle"],[514,"but"],[515,"so"],[516,"what?"],[517,"Everyone"],[518,"tells"],[519,"you"],[520,"to"],[521,"keep"],[522,"trying"],[523,"even"],[524,"if"],[525,"you"],[526,"don't"],[527,"succeed."],[528,"Why?"],[529,"Trying"],[530,"sometimes"],[531,"gives"],[532,"you"],[533,"results"],[534,"that"],[535,"you're"],[536,"not"],[537,"looking"],[538,"for."],[539,"It"],[540,"teaches"],[541,"you"],[542,"something"],[543,"about"],[544,"yourself"],[545,"that"],[546,"you"],[547,"never"],[548,"knew."],[549,"If"],[550,"Kalpana"],[551,"had"],[552,"learnt"],[553,"to"],[554,"ride"],[555,"the"],[556,"cycle"],[557,"on"],[558,"the"],[559,"very"],[560,"first"],[561,"day,"],[562,"she"],[563,"might"],[564,"have"],[565,"never"],[566,"known"],[567,"how"],[568,"determined"],[569,"a"],[570,"person"],[571,"she"],[572,"is!"],[573,"Her"],[574,"family"],[575,"might"],[576,"have"],[577,"never"],[578,"realised"],[579,"this"],[580,"about"],[581,"her"],[582,"too."],[583,"Maybe"],[584,"someday"],[585,"in"],[586,"the"],[587,"future,"],[588,"when"],[589,"Kalpana"],[590,"becomes"],[591,"tall"],[592,"and"],[593,"strong"],[594,"after"],[595,"drinking"],[596,"many"],[597,"cups"],[598,"of"],[599,"milk,"],[600,"she"],[601,"will"],[602,"think"],[603,"back"],[604,"to"],[605,"the"],[606,"day"],[607,"she"],[608,"fell"],[609,"from"],[6