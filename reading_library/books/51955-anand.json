"],[34,"a"],[35,"sensitive"],[36,"nose!"]]},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/91230/size6/515406c7130b1ec0099b25473a74822d.jpg","text":"The new people on 4th cross are friendly, but their dog is NOT!","words":[[37,"The"],[38,"new"],[39,"people"],[40,"on"],[41,"4th"],[42,"cross"],[43,"are"],[44,"friendly,"],[45,"but"],[46,"their"],[47,"dog"],[48,"is"],[49,"NOT!"]]},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/90856/size6/b28f6a293e3e40239c67e151ec781b0f.jpg","text":"Oh no! This will take forever to clean up.","words":[[50,"Oh"],[51,"no!"],[52,"This"],[53,"will"],[54,"take"],[55,"forever"],[56,"to"],[57,"clean"],[58,"up."]]},{"n":9,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/90857/size6/f3bc90929d9d9486b968e6a4d9aa35f8.jpg","text":"I like visiting Salim's street.","words":[[59,"I"],[60,"like"],[61,"visiting"],[62,"Salim's"],[63,"street."]]},{"n":10,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/90858/size6/ede2c4b652121cce43c49498bc125d24.jpg","text":"Salim and I are friends.","words":[[64,"Salim"],[65,"and"],[66,"I"],[67,"are"],[68,"friends."]]},{"n":11,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/91231/size6/2b2085196f9a78e2a10e6ab4aff707ca.jpg","text":"He likes to play drums. I like dancing.","words":[[69,"He"],[70,"likes"],[71,"to"],[72,"play"],[73,"drums."],[74,"I"],[75,"like"],[76,"dancing."]]},{"n":12,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/90860/size6/f0441a8f1ad00d9af684bee80d655a26.jpg","text":"It's soon time to go.","words":[[77,"It's"],[78,"soon"],[79,"time"],[80,"to"],[81,"go."]]},{"n":13,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/91241/size6/50ffe308b9a99ed45877827cf9d6af4f.jpg","text":"Bye!","words":[[82,"Bye!"]]},{"n":14,"img":"https://storage.googleapis.com/st