 feast.”","words":[[54,"One"],[55,"kind"],[56,"of"],[57,"smell"],[58,"says,"],[59,"“Follow"],[60,"me"],[61,"this"],[62,"way"],[63,"for"],[64,"a"],[65,"feast.”"]]},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/13079/size6/16a843e35736981d828a9e6427f6ccc6.jpg","text":"Another smell says, “Danger! Do not go there.”","words":[[66,"Another"],[67,"smell"],[68,"says,"],[69,"“Danger!"],[70,"Do"],[71,"not"],[72,"go"],[73,"there.”"]]},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/13080/size6/830248e8b11e9e7916ec154f0df68215.jpg","text":"I love cakes and all kinds of sweets, just like you.","words":[[74,"I"],[75,"love"],[76,"cakes"],[77,"and"],[78,"all"],[79,"kinds"],[80,"of"],[81,"sweets,"],[82,"just"],[83,"like"],[84,"you."]]},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/13081/size6/8745c7edb8e0008518f0a4f305717985.jpg","text":"Want to see my muscles at work? I may look very tiny to you, but I am very strong.","words":[[85,"Want"],[86,"to"],[87,"see"],[88,"my"],[89,"muscles"],[90,"at"],[91,"work?"],[92,"I"],[93,"may"],[94,"look"],[95,"very"],[96,"tiny"],[97,"to"],[98,"you,"],[99,"but"],[100,"I"],[101,"am"],[102,"very"],[103,"strong."]]},{"n":9,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/13082/size6/2d6959400605bcf6866869e09e411f4b.jpg","text":"Never mind if the door is shut. I can slip through the smallest crack.","words":[[104,"Never"],[105,"mind"],[106,"if"],[107,"the"],[108,"door"],[109,"is"],[110,"shut."],[111,"I"],[112,"can"],[113,"slip"],[114,"through"],[115,"the"],[116,"smallest"],[117,"crack."]]},{"n":10,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/13083/size6/ffca370f5d6841d1b40319e71feaa4b8.jpg","text":"Believe it or not, hundreds of us live happily in a colony.","words":[[118,"Believe"],[119,"it"],[120,"or"],[121,"not,"],[122,"hundreds"],[123,"of"],[124,"us"],[125,"live"],[126,"happily"],[127,"in"],[128,"a"],[129,"colony."]]},{"n":11,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/13084/size6/2a921d6470d9372bd2697500681c4558.jpg","text":"LET US LEARN SOME NEW WORDS.\nSmall - Big\nSlow - Fast\nShort - Tall\nThin - Fat\nHard - Soft\nNoisy - Quiet\n \nHere are some words with their opposites. Can you make a sentence for each pair of opposite words?\n \nFor example, ‘An ant is small; an elephant is big’.\n \n“As busy as an ant” is a nice way to describe someone who is very hard working.","words":[[130,"LET"],[131,"US"],[132,"LEARN"],[133,"SOME"],[134,"NEW"],[135,"WORDS."],[136,"Small"],[137,"-"],[138,"Big"],[139,"Slow"],[140,"-"],[141,"Fast"],[142,"Short"],[143,"-"],[144,"Tall"],[145,"Thin"],[146,"-"],[147,"Fat"],[148,"Hard"],[149,"-"],[150,"Soft"],[151,"Noisy"],[152,"-"],[153,"Quiet"],[154,"Here"],[155,"are"],[156,"some"],[157,"words"],[158,"with"],[159,"their"],[160,"opposites."],[161,"Can"],[162,"you"],[163,"make"],[164,"a"],[165,"sentence"],[166,"for"],[167,"each"],[168,"pair"],[169,"of"],[170,"opposite"],[171,"words?"],[172,"For"],[173,"example,"],[174,"‘An"],[175,"ant"],[176,"is"],[177,"small;"],[178,"an"],[179,"elephant"],[180,"is"],[181,"big’."],[182,"“As"],[183,"busy"],[184,"as"],[185,"an"],[186,"ant”"],[187,"is"],[188,"a"],[189,"nice"],[190,"way"],[191,"to"],[192,"describe"],[193,"someone"],[194,"who"],[195,"is"],[196,"very"],[197,"hard"],[198,"working."]]}],"stats":{"pages":11,"words":198}}