{
  "name": "alloflow-admin",
  "version": "0.2.0",
  "description": "AlloFlow Admin Center — manage local AI stack across buildings",
  "main": "main.js",
  "author": "AlloFlow Contributors",
  "license": "AGPL-3.0",
  "homepage": "./",
  "dependencies": {
    "axios": "^1.6.0",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.405.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4",
    "react-scripts": "5.0.1",
    "wait-on": "^7.0.0"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "electron": "electron .",
    "electron-dev": "concurrently \"npm start\" \"wait-on http://localhost:3000 && electron .\"",
    "electron-build": "npm run build && electron-builder --publish never",
    "dist-win": "npm run build && electron-builder --win nsis --publish never",
    "dist-mac": "npm run build && electron-builder --mac dmg --publish never",
    "dist": "npm run build && electron-builder -mw --publish never",
    "publish-test": "npm run build && electron-builder -mw --publish always",
    "publish-production": "npm run build && electron-builder -mw --publish always"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
