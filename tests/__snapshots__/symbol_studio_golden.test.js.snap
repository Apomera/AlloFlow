<button aria-label="Use template: Using the Toilet" style="padding:3px 8px;background:#f3f4f6;border:1px solid #e5e7eb;border-radius:12px;font-size:10px;cursor:pointer;color:#374151;white-space:nowrap;transition:background 0.1s;position:relative">Using the Toilet</button>
