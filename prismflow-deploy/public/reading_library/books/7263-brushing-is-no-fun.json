ngs\nThat is a good way to end my day!\nAnd I feel better in every way\nI feel better in every way!\nI FEEL BETTER IN EVERY WAY!!!!!\nNow make up your secret song and hum it\nwhen you have to do boring things!","words":[[545,"Germs"],[546,"say,"],[547,"yucky,"],[548,"mucky"],[549,"and"],[550,"dirty"],[551,"is"],[552,"FUN!"],[553,"I"],[554,"say,"],[555,"I"],[556,"brush"],[557,"and"],[558,"wash"],[559,"and"],[560,"I"],[561,"know"],[562,"I"],[563,"have"],[564,"won!"],[565,"Germs"],[566,"say,"],[567,"never"],[568,"bathe,"],[569,"it’s"],[570,"a"],[571,"waste"],[572,"of"],[573,"time!"],[574,"I"],[575,"say,"],[576,"smelling"],[577,"nice"],[578,"with"],[579,"soap"],[580,"is"],[581,"so"],[582,"fine."],[583,"Naughty"],[584,"germ"],[585,"says"],[586,"don’t"],[587,"pick"],[588,"up"],[589,"your"],[590,"things,"],[591,"The"],[592,"house"],[593,"looks"],[594,"better"],[595,"that"],[596,"way."],[597,"I"],[598,"say,"],[599,"I"],[600,"tidy"],[601,"up"],[602,"because"],[603,"I"],[604,"like"],[605,"my"],[606,"things"],[607,"That"],[608,"is"],[609,"a"],[610,"good"],[611,"way"],[612,"to"],[613,"end"],[614,"my"],[615,"day!"],[616,"And"],[617,"I"],[618,"feel"],[619,"better"],[620,"in"],[621,"every"],[622,"way"],[623,"I"],[624,"feel"],[625,"better"],[626,"in"],[627,"every"],[628,"way!"],[629,"I"],[630,"FEEL"],[631,"BETTER"],[632,"IN"],[633,"EVERY"],[634,"WAY!!!!!"],[635,"Now"],[636,"make"],[637,"up"],[638,"your"],[639,"secret"],[640,"song"],[641,"and"],[642,"hum"],[643,"it"],[644,"when"],[645,"you"],[646,"have"],[647,"to"],[648,"do"],[649,"boring"],[650,"things!"]]}],"stats":{"pages":13,"words":651}}