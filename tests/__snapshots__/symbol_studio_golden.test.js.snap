<button aria-label="Quick set label: snack" style="padding:2px 7px;background:#fef3c7;border:1px solid #fbbf24;border-radius:10px;font-size:9px;cursor:pointer;color:#92400e;font-weight:500">snack</button>
<button aria-label="Quick set label: tired" style="padding:2px 7px;background:#fef3c7;border:1px solid #fbbf24;border-radius:10px;font-size:9px;cursor:pointer;color:#92400e;font-weight:500">tired</button>
<button aria-label="Quick set label: bath" style="padding:2px 7px;background:#fef3c7;border:1px solid #fbbf24;border-radius:10px;font-size:9px;cursor:pointer;color:#92400e;font-weight:500">bath</button>
<button aria-label="Quick set label: dinner" style="padding:2px 7px;background:#fef3c7;border:1px solid #fbbf24;border-radius:10px;font-size:9px;cursor:pointer;color:#92400e;font-weight:500">dinner</button>
<button aria-label="Quick set label: goodnight" style="padding:2px 7px;background:#fef3c7;border:1px solid #fbbf24;border-radius:10px;font-size:9px;cursor:pointer;color:#92400e;font-weight:500">goodnight</button>
</div>
</div>
<div style="display:flex;flex-direction:column;gap:7px">
<div>
<label style="font-size:11px;font-weight:600;color:#374151;display:block;margin-bottom:3px">Label</label>
<input type="text" placeholder="e.g. wash hands" aria-label="Symbol label" style="width:100%;border:1px solid #d1d5db;border-radius:6px;padding:7px 9px;font-size:13px;box-sizing:border-box;font-family:inherit;background:#fff;color:inherit" autofocus="" value=""/>
</div>
<div>
