ed.","words":[[23,"Oh"],[24,"my"],[25,"God!"],[26,"There"],[27,"is"],[28,"a"],[29,"tiger"],[30,"under"],[31,"my"],[32,"bed."]]},{"n":3,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/12809/size6/0054be91fc6c7e599091f788d907175f.jpg","text":"Now what should I do?","words":[[33,"Now"],[34,"what"],[35,"should"],[36,"I"],[37,"do?"]]},{"n":4,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/12810/size6/26491dcc39e2989073786c1446ae23d7.jpg","text":"Should I call Ma? What if the tiger roars?","words":[[38,"Should"],[39,"I"],[40,"call"],[41,"Ma?"],[42,"What"],[43,"if"],[44,"the"],[45,"tiger"],[46,"roars?"]]},{"n":5,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/12811/size6/1dc9e080cb1f1da3540e1a5856872b50.jpg","text":"Should I just go back to sleep? But I am not sleepy any more.","words":[[47,"Should"],[48,"I"],[49,"just"],[50,"go"],[51,"back"],[52,"to"],[53,"sleep?"],[54,"But"],[55,"I"],[56,"am"],[57,"not"],[58,"sleepy"],[59,"any"],[60,"more."]]},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/12812/size6/bcc4b54374451efc0e2ffb921f11dd1f.jpg","text":"Then someone turns on the light. Ma is standing at the door.","words":[[61,"Then"],[62,"someone"],[63,"turns"],[64,"on"],[65,"the"],[66,"light."],[67,"Ma"],[68,"is"],[69,"standing"],[70,"at"],[71,"the"],[72,"door."]]},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/12813/size6/0c279bb8986760ac853b11e8af9003a3.jpg","text":"“What happened dear?Did you call me?” asks Ma.","words":[[73,"“What"],[74,"happened"],[75,"dear?Did"],[76,"you"],[77,"call"],[78,"me?”"],[79,"asks"],[80,"Ma."]]},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/12814/size6/d828c5e484809073adddd6fc68b180f6.jpg","text":"I point towards the tiger. Ma bends and pulls the tiger out from under the bed!","words":[[81,"I"],[82,"point"],[83,"t