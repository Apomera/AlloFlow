hs."]]},{"n":3,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/58739/size6/13968f76b23b023940f6045e96495364.jpg","text":"Harrr harrr harrr!\nShe snorts and digs up the garden.","words":[[49,"Harrr"],[50,"harrr"],[51,"harrr!"],[52,"She"],[53,"snorts"],[54,"and"],[55,"digs"],[56,"up"],[57,"the"],[58,"garden."]]},{"n":4,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/58601/size6/3a7126c5ba6aff24304569e704d0152f.jpg","text":"Grrrrr grrrrr grrrrr!\nLalita tears up all the newspapers. Even the one Mini hasn’t read yet.","words":[[59,"Grrrrr"],[60,"grrrrr"],[61,"grrrrr!"],[62,"Lalita"],[63,"tears"],[64,"up"],[65,"all"],[66,"the"],[67,"newspapers."],[68,"Even"],[69,"the"],[70,"one"],[71,"Mini"],[72,"hasn’t"],[73,"read"],[74,"yet."]]},{"n":5,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/58599/size6/3a40ae6f1b252d0350953ecbd3177eb8.jpg","text":"Phurrrr phurrrr phurrrr!\nShe blows bubbles into her water bowl and spills water all over!","words":[[75,"Phurrrr"],[76,"phurrrr"],[77,"phurrrr!"],[78,"She"],[79,"blows"],[80,"bubbles"],[81,"into"],[82,"her"],[83,"water"],[84,"bowl"],[85,"and"],[86,"spills"],[87,"water"],[88,"all"],[89,"over!"]]},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/58600/size6/68b1cb36a645e78d6b135c852d6e481f.jpg","text":"Chapaak! Jhapaak!\nLalita chews up all \nthe lilies and scares \nthe fish in the pond.","words":[[90,"Chapaak!"],[91,"Jhapaak!"],[92,"Lalita"],[93,"chews"],[94,"up"],[95,"all"],[96,"the"],[97,"lilies"],[98,"and"],[99,"scares"],[100,"the"],[101,"fish"],[102,"in"],[103,"the"],[104,"pond."]]},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/58740/size6/1b1696e84b8f6a277ef7e3ced74695b2.jpg","text":"“Lock her up,” says Mini's Aai. \n“Tie her up,” says Mini's Tai.\n“Never ever!” says Mini. “She never ever messes with my pots and jugs.”","words":[[105,"“Lock"],[106,"her"],[107,"up,”"],[108,"says"],[109,"Mini's"],[110,"Aai."],[111,"“Tie"],[112,"her"],[113,"up,”"],[114,"says"],[115,"Mini's"],[116,"Tai."],[117,"“Never"],[118,"ever!”"],[119,"says"],[120,"Mini."],[121,"“She"],[122,"never"],[123,"ever"],[124,"messes"],[125,"with"],[126,"my"],[127,"pots"],[128,"and"],[129,"jugs.”"]]},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/58604/size6/01ee294de84f5d7a56eb8b7cc00ecb2f.jpg","text":"One day, Mini comes to work bright and early. He whistles happily to Lalita.\n“Harrumph, harrumph,” she grunts back.","words":[[130,"One"],[131,"day,"],[132,"Mini"],[133,"comes"],[134,"to"],[135,"work"],[136,"bright"],[137,"and"],[138,"early."],[139,"He"],[140,"whistles"],[141,"happily"],[142,"to"],[143,"Lalita."],[144,"“"],[145,"Harrumph,"],[146,"harrumph"],[147,",”"],[148,"she"],[149,"grunts"],[150,"back."]]},{"n":9,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/58753/size6/e51fe75ea74c0dd7ce079195d238c175.jpg","text":"His happiness vanishes when he sees…\nBroken bowls, shattered jugs\nCracked cups, smashed teapots\nEverywhere!","words":[[151,"His"],[152,"happiness"],[153,"vanishes"],[154,"when"],[155,"he"],[156,"sees…"],[157,"Broken"],[158,"bowls,"],[159,"s"],[160,"hattered"],[161,"jugs"],[162,"Cracked"],[163,"cups,"],[164,"s"],[165,"mashed"],[166,"teapots"],[167,"Everywhere!"]]},{"n":10,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/58607/size6/c3f0dfa6aa1f3b2c106197ade77a82d6.jpg","text":"Mini gets angrier and angrier and angrier!","words":[[168,"Mini"],[169,"gets"],[170,"angrier"],[171,"and"],[172,"angrier"],[173,"and"],[174,"angrier!"]]},{"n":11,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/58608/size6/2d550dab2aa8c04f1f32c1a6828bd481.jpg","text":"He ties Lalita up under the shady bougainvillea.","words":[[175,"He"],[176,"ties"],[177,"Lalita"],[178,"up"],[179,"under"],[180,"the"],[181,"shady"],[182,"bougainvillea."]]},{"n":12,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/58609/size6/ee93fedcbe379383dd65b4c95a8c8c80.jpg","text":"Lalita doesn’t understand why she is tied up. She whines and whimpers. She cries and sighs. But Mini is too angry to listen.","words":[[183,"Lalita"],[184,"doesn’t"],[185,"understand"],[186,"why"],[187,"she"],[188,"is"],[189,"tied"],[190,"up."],[191,"She"],[192,"whines"],[193,"and"],[194,"whimpers."],[195,"She"],[196,"cries"],[197,"and"],[198,"sighs."],[199,"But"],[200,"Mini"],[201,"is"],[202,"too"],[203,"angry"],[204,"to"],[205,"listen."]]},{"n":13,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/58610/size6/5635f7aac89d78262d7f092f7018c7cc.jpg","text":"All day Mini works angrily and Lalita stays tied up. Then, Mini hears a noise.\nIt isn’t a harrumph, it isn’t a harrr.\nIt isn’t a grrr, it isn’t a phurrr.\nAnd it isn’t a chapaak or a jhapaak!","words":[[206,"All"],[207,"day"],[208,"Mini"],[209,"works"],[210,"angrily"],[211,"and"],[212,"Lalita"],[213,"stays"],[214,"tied"],[215,"up."],[216,"Then,"],[217,"Mini"],[218,"hears"],[219,"a"],[220,"noise."],[221,"It"],[222,"isn’t"],[223,"a"],[224,"harrumph"],[225,","],[226,"it"],[227,"isn’t"],[228,"a"],[229,"harrr"],[230,"."],[231,"It"],[232,"isn’t"],[233,"a"],[234,"grrr"],[235,","],[236,"i"],[237,"t"],[238,"isn’t"],[239,"a"],[240,"phurrr"],[241,"."],[242,"And"],[243,"it"],[244,"isn’t"],[245,"a"],[246,"chapaak"],[247,"or"],[248,"a"],[249,"jhapaak"],[250,"!"]]},{"n":14,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/58611/size6/89e2167eb2787138e3d752a6c4705719.jpg","text":"MEOOWWW!\nCRASH!\nMEOOOWWW!\nTHUNK! \nIt is a large, orange cat!\nIt is the large, orange cat that knocked over the pots and jugs.","words":[[251,"MEOOWWW!"],[252,"CRASH!"],[253,"MEOOOWWW!"],[254,"THUNK!"],[255,"It"],[256,"is"],[257,"a"],[258,"large,"],[259,"orange"],[260,"cat!"],[261,"It"],[262,"is"],[263,"the"],[264,"large,"],[265,"orange"],[266,"cat"],[267,"that"],[268,"knocked"],[269,"over"],[270,"the"],[271,"pots"],[272,"and"],[273,"jugs."]]},{"n":15,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/58612/size6/3dbabc01e79d069245d7c5fe72843c15.jpg","text":"Mini unties Lalita.\n“Harrumph, harrumph,” she grunts.\nLalita chases the cat. Round and round, and right out of the pottery!","words":[[274,"Mini"],[275,"unties"],[276,"Lalita."],[277,"“"],[278,"Harrumph,"],[279,"harrumph"],[280,",”"],[281,"she"],[282,"grunts."],[283,"Lalita"],[284,"chases"],[285,"the"],[286,"cat."],[287,"Round"],[288,"and"],[289,"round,"],[290,"and"],[291,"right"],[292,"out"],[293,"of"],[294,"the"],[295,"pottery!"]]},{"n":16,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/58613/size6/bdb744bbc1cf15f84b679e8fc2cbdafa.jpg","text":"Then Lalita goes right back \nto doing pig-headed things.\nBecause that’s what pigs do.","words":[[296,"Then"],[297,"Lalita"],[298,"goes"],[299,"right"],[300,"back"],[301,"to"],[302,"doing"],[303,"pig-headed"],[304,"things."],[305,"Because"],[306,"that’s"],[307,"what"],[308,"pigs"],[309,"do."]]}],"stats":{"pages":16,"words":297}}