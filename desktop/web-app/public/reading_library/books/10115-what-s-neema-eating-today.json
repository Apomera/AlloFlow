,[16,"and"],[17,"eating."]]},{"n":2,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/29822/size6/56bde55ccb188b3ea72d43edcb07a002.jpg","text":"CHOMP! CHOMP!\nCHEW… CHEW!\nMMM… MMM!\nOho! Close your mouth while\nchewing, Neema!","words":[[18,"CHOMP!"],[19,"CHOMP!"],[20,"CHEW…"],[21,"CHEW!"],[22,"MMM…"],[23,"MMM!"],[24,"Oho!"],[25,"Close"],[26,"your"],[27,"mouth"],[28,"while"],[29,"chewing,"],[30,"Neema!"]]},{"n":3,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/29823/size6/9aa69fc8ca24c51099d879491e083549.jpg","text":"When it’s summer,\nThe days are happy and long,\nAnd it’s warm outside.\nWhat’s Neema eating today?","words":[[31,"When"],[32,"it’s"],[33,"summer,"],[34,"The"],[35,"days"],[36,"are"],[37,"happy"],[38,"and"],[39,"long,"],[40,"And"],[41,"it’s"],[42,"warm"],[43,"outside."],[44,"What’s"],[45,"Neema"],[46,"eating"],[47,"today?"]]},{"n":4,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/29824/size6/272782543a080b96ae7b3a5c480841ce.jpg","text":"Summer is the season to eat\nmangoes – yellow, green and red.\nSlippery white lychees with\nbright red coats,\nGreen, striped and butter yellow\nwatermelons,\nJuicy mulberries that burst in\nthe mouth,\nOho! Neema’s hands are all\nsticky and purple now!","words":[[48,"Summer"],[49,"is"],[50,"the"],[51,"season"],[52,"to"],[53,"eat"],[54,"mangoes"],[55,"–"],[56,"yellow,"],[57,"green"],[58,"and"],[59,"red."],[60,"Slippery"],[61,"white"],[62,"lychees"],[63,"with"],[64,"bright"],[65,"red"],[66,"coats,"],[67,"Green,"],[68,"striped"],[69,"and"],[70,"butter"],[71,"yellow"],[72,"watermelons,"],[73,"Juicy"],[74,"mulberries"],[75,"that"],[76,"burst"],[77,"in"],[78,"the"],[79,"mouth,"],[80,"Oho!"],[81,"Neema’s"],[82,"hands"],[83,"are"],[84,"all"],[85,"sticky"],[86,"and"],[87,"purple"],[88,"now!"]]},{"n":5,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/29825/size6/f82556f92ace510e2ee7054499251473.jpg","text":"When it’s monsoon,\nThe dark and frowning clouds roll\nin,\nAnd it’s raining outside.\nWhat’s Neema eating today?","words":[[89,"When"],[90,"it’s"],[91,"monsoon,"],[92,"The"],[93,"dark"],[94,"and"],[95,"frowning"],[96,"clouds"],[97,"roll"],[98,"in,"],[99,"And"],[100,"it’s"],[101,"raining"],[102,"outside."],[103,"What’s"],[104,"Neema"],[105,"eating"],[106,"today?"]]},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/29826/size6/019ed34255bb7b147f9bf15b9334512a.jpg","text":"Monsoon is the season to eat corn\n– yellow, white and purple.\nFresh and juicy sweet limes,\nPineapples with crowns on their heads,\nPurple and squishy jamuns,\nOho! Neema’s tongue is all\nfuzzy and blue!","words":[[107,"Monsoon"],[108,"is"],[109,"the"],[110,"season"],[111,"to"],[112,"eat"],[113,"corn"],[114,"–"],[115,"yellow,"],[116,"white"],[117,"and"],[118,"purple."],[119,"Fresh"],[120,"and"],[121,"juicy"],[122,"sweet"],[123,"limes,"],[124,"Pineapples"],[125,"with"],[126,"crowns"],[127,"on"],[128,"their"],[129,"heads,"],[130,"Purple"],[131,"and"],[132,"squishy"],[133,"jamuns,"],[134,"Oho!"],[135,"Neema’s"],[136,"tongue"],[137,"is"],[138,"all"],[139,"fuzzy"],[140,"and"],[141,"blue!"]]},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/29827/size6/d823f3d93c563fb41a2b771cbaa3c824.jpg","text":"When it’s winter,\nAnd the days get shorter.\nAnd it’s cold outside.\nWhat’s Neema eating today?","words":[[142,"When"],[143,"it’s"],[144,"winter,"],[145,"And"],[146,"the"],[147,"days"],[148,"get"],[149,"shorter."],[150,"And"],[151,"it’s"],[152,"cold"],[153,"outside."],[154,"What’s"],[155,"Neema"],[156,"eating"],[157,"today?"]]},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/29828/size6/d043761e1213e14d540b38d33cf36d65.jpg","text":"Winter is the season for shiny leafy vegetables.\nBeetroot, red like the setting\nsun,  \nPlump green custard apples.\nLook, look, Neema’s climbing up a tree now,\nOho! She’s plucked all the\nsour, brown tamarinds!","words":[[158,"Winter"],[159,"is"],[160,"the"],[161,"season"],[162,"for"],[163,"shiny"],[164,"leafy"],[165,"vegetables."],[166,"Beetroot,"],[167,"red"],[168,"like"],[169,"the"],[170,"setting"],[171,"sun,"],[172,"Plump"],[173,"green"],[174,"custard"],[175,"apples."],[176,"Look,"],[177,"look,"],[178,"Neema’s"],[179,"climbing"],[180,"up"],[181,"a"],[182,"tree"],[183,"now,"],[184,"Oho!"],[185,"She’s"],[186,"plucked"],[187,"all"],[188,"the"],[189,"sour,"],[190,"brown"],[191,"tamarinds!"]]},{"n":9,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/29829/size6/83bd3d69e3ada13f3424c29c05d219e0.jpg","text":"Neema loves to eat,\nBut she loves to eat with the\nseason!\nCHOMP! CHOMP!\nCHEW… CHEW!\nMMM… MMM!","words":[[192,"Neema"],[193,"loves"],[194,"to"],[195,"eat,"],[196,"But"],[197,"she"],[198,"loves"],[199,"to"],[200,"eat"],[201,"with"],[202,"the"],[203,"season!"],[204,"CHOMP!"],[205,"CHOMP!"],[206,"CHEW…"],[207,"CHEW!"],[208,"MMM…"],[209,"MMM!"]]},{"n":10,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/29830/size6/ee29feec1fb017e8dcf844053c945cbd.jpg","text":"Across\nthe world, there are five types of seasons – Spring, Summer,\nMonsoon, Autumn and Winter. But in some places in India, like where\nNeema lives, the seasons are Summer, Monsoon and Winter.","words":[[210,"Across"],[211,"the"],[212,"world,"],[213,"there"],[214,"are"],[215,"five"],[216,"types"],[217,"of"],[218,"seasons"],[219,"–"],[220,"Spring,"],[221,"Summer,"],[222,"Monsoon,"],[223,"Autumn"],[224,"and"],[225,"Winter."],[226,"But"],[227,"in"],[228,"some"],[229,"places"],[230,"in"],[231,"India,"],[232,"like"],[233,"where"],[234,"Neema"],[235,"lives,"],[236,"the"],[237,"seasons"],[238,"are"],[239,"Summer,"],[240,"Monsoon"],[241,"and"],[242,"Winter."]]},{"n":11,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/88953/size6/059934dba148250d47e67b1f0d300ee9.jpg","text":"Eat with the season!\nLike Neema, you can eat colourful and tasty fruits and vegetables across the year. Here’s a seasonal calendar so that you know which fruits and vegetables to eat through the year.\nTamarind: January to February\nChikoos: January to February and May to July\nMulberries: March to May and October to November","words":[[243,"Eat"],[244,"with"],[245,"the"],[246,"season!"],[247,"Like"],[248,"Neema,"],[249,"you"],[250,"can"],[251,"eat"],[252,"colourful"],[253,"and"],[254,"tasty"],[255,"fruits"],[256,"and"],[257,"vegetables"],[258,"across"],[259,"the"],[260,"year."],[261,"Here’s"],[262,"a"],[263,"seasonal"],[264,"calendar"],[265,"so"],[266,"that"],[267,"you"],[268,"know"],[269,"which"],[270,"fruits"],[271,"and"],[272,"vegetables"],[273,"to"],[274,"eat"],[275,"through"],[276,"the"],[277,"year."],[278,"Tamarind:"],[279,"January"],[280,"to"],[281,"February"],[282,"Chikoos:"],[283,"January"],[284,"to"],[285,"February"],[286,"and"],[287,"May"],[288,"to"],[289,"July"],[290,"Mulberries:"],[291,"March"],[292,"to"],[293,"May"],[294,"and"],[295,"October"],[296,"to"],[297,"November"]]},{"n":12,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/29832/size6/9f23c8314f01903043b29b6679c31989.jpg","text":"Spinach:  March to May, and October to January\nMango: March to August\nWatermelon\n: April to June","words":[[298,"Spinach"],[299,":"],[300,"March"],[301,"to"],[302,"May,"],[303,"and"],[304,"October"],[305,"to"],[306,"January"],[307,"Mango"],[308,":"],[309,"March"],[310,"to"],[311,"August"],[312,"Watermelon"],[313,":"],[314,"April"],[315,"to"],[316,"June"]]},{"n":13,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/29833/size6/52d2ee26b4d872a4a12bcf4418e1ed5c.jpg","text":"Lychees: May to June\nJamuns: May to July\nCorn\n: June to August","words":[[317,"Lychees"],[318,":"],[319,"May"],[320,"to"],[321,"June"],[322,"Jamuns"],[323,":"],[324,"May"],[325,"to"],[326,"July"],[327,"Corn"],[328,":"],[329,"June"],[330,"to"],[331,"August"]]},{"n":14,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/30021/size6/7fa351f9a855c7e5968aefc0b31ee518.jpg","text":"Sweet Lime\n: July-August\nCustard apple: October-February\nBeetroot: All year,\nbut best eaten\n  in winter","words":[[332,"Sweet"],[333,"Lime"],[334,":"],[335,"July-August"],[336,"Custard"],[337,"apple"],[338,":"],[339,"October-February"],[340,"Beetroot"],[341,":"],[342,"All"],[343,"year,"],[344,"but"],[345,"best"],[346,"eaten"],[347,"in"],[348,"winter"]]}],"stats":{"pages":14,"words":342}}