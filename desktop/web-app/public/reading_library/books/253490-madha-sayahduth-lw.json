xt":"مَاذَا سَيَحْدُثُ لَوْ سَحَبْتُ أُذُنَيَّ وَمَدَدْتُهُمَا لِلْخَارِجِ؟\nوِييييييييييييي!\nأَنَا ساره الطَّائِرَةُ، أُحَلِّقُ مَعَ الْعَصَافِيرِ.","words":[[64,"مَاذَا"],[65,"سَيَحْدُثُ"],[66,"لَوْ"],[67,"سَحَبْتُ"],[68,"أُذُنَيَّ"],[69,"وَمَدَدْتُهُمَا"],[70,"لِلْخَارِجِ؟"],[71,"وِييييييييييييي!"],[72,"أَنَا"],[73,"ساره"],[74,"الطَّائِرَةُ،"],[75,"أُحَلِّقُ"],[76,"مَعَ"],[77,"الْعَصَافِيرِ."]]},{"n":9,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/88662/size6/3944e42d955b74cef810a1007d6671f7.jpg","text":"وَلَكِنْ شِشْشْ!\nلَا تُخْبِرُوا أَيَّ أَحَدٍ عَنْ ساره الَّتِي تَنْزَلِقُ مِنْ تَحْتِ الْبَابِ، وَلَا الْفَتَاةِ ذَاتِ أَذْرُعِ الطَّمَاطِمِ، \nوَلَا الْبَالُونَةِ ساره، وَلَا ساره الْمُخْتَفِيَةِ، وَلَا حَتَّى ساره الطَّائِرَةِ.","words":[[78,"وَلَكِنْ"],[79,"شِشْشْ!"],[80,"لَا"],[81,"تُخْبِرُوا"],[82,"أَيَّ"],[83,"أَحَدٍ"],[84,"عَنْ"],[85,"ساره"],[86,"الَّتِي"],[87,"تَنْزَلِقُ"],[88,"مِنْ"],[89,"تَحْتِ"],[90,"الْبَابِ،"],[91,"وَلَا"],[92,"الْفَتَاةِ"],[93,"ذَاتِ"],[94,"أَذْرُعِ"],[95,"الطَّمَاطِمِ،"],[96,"وَلَا"],[97,"الْبَالُونَةِ"],[98,"ساره،"],[99,"وَلَا"],[100,"ساره"],[101,"الْمُخْتَفِيَةِ،"],[102,"وَلَا"],[103,"حَتَّى"],[104,"ساره"],[105,"الطَّائِرَةِ."]]},{"n":10,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/88619/size6/5052786d55b35afdfb6fbcbdc194727a.jpg","text":"فِي يَوْمٍ مِنَ الْأَيَّامِ، \nكُلُّ قُوَايَ هَذِهِ سَتَجْعَلُنِي سُوبَرْ ساره.\nحِينَهَا سَأُنْقِذُ الْعَالَمَ!","words":[[106,"فِي"],[107,"يَوْمٍ"],[108,"مِنَ"],[109,"الْأَيَّامِ،"],[110,"كُلُّ"],[111,"قُوَايَ"],[112,"هَذِهِ"],[113,"سَتَجْعَلُنِي"],[114,"سُوبَرْ"],[115,"ساره."],[116,"حِينَهَا"],[117,"سَأُنْقِذُ"],[118,"الْعَالَمَ!"]]},{"n":11,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/88741/size6/da61b0076fb3a075eda810892d48197e.jpg","text":"12/12","words":null}],"stats":{"pages":11,"words":119}}