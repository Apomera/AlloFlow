{"schema":"allo-reading-book@1","slug":"1042-my-best-friend","title":"My Best Friend","description":"Would you like to have a very special friend? Look into this book and you may find that you already have a very special friend!","language":"English","langCode":"en","isRtl":false,"level":"1","orientation":"landscape","authors":["Anupa Lal"],"illustrators":["Suvidha Mistry"],"originalAuthors":[],"publisher":"Pratham Books","license":"CC BY 4.0","licenseUrl":"https://creativecommons.org/licenses/by/4.0/","sourceId":"storyweaver","contentType":"story","source":{"id":"storyweaver","name":"StoryWeaver, Pratham Books","url":"https://storyweaver.org.in/en/stories/1042-my-best-friend"},"cover":{"card":"https://static.storyweaver.org.in/illustration_crops/704882/size3/b1586d957cd76fc5ad2d07442f85401c.jpg","large":"https://static.storyweaver.org.in/illustration_crops/704882/size6/b1586d957cd76fc5ad2d07442f85401c.jpg"},"audio":{"src":"https://storage.googleapis.com/story-weaver-e2e-production/stories/1042/audios/story/1042-my-best-friend.mp3","cues":[[1,0,1.2],[2,1.2,1.52],[3,1.52,1.72],[4,1.72,2.68],[5,2.68,2.92],[6,2.92,3.52],[7,3.52,3.72],[8,3.72,4],[9,4,5.12],[10,5.12,7.16],[11,7.16,7.4],[12,7.4,7.52],[13,7.52,8.12],[14,8.12,8.8],[15,8.8,8.92],[16,8.92,10.52],[17,10.52,11.72],[18,11.72,11.88],[19,11.88,12.68],[20,12.68,13.08],[21,13.08,13.64],[22,13.64,14.12],[23,14.12,16.08],[24,16.08,16.52],[25,16.52,17.08],[26,17.08,17.4],[27,17.4,17.8],[28,17.8,18.8],[29,18.8,19.08],[30,19.08,19.52],[31,19.52,20.96],[32,20.96,21.44],[33,21.44,21.64],[34,21.64,22.2],[35,22.2,24.56],[36,24.56,25.16],[37,25.16,25.68],[38,25.68,25.92],[39,25.92,26.4],[40,26.4,26.64],[41,26.64,26.96],[42,26.96,28.2],[43,28.2,28.48],[44,28.48,28.84],[45,28.84,29.12],[46,29.12,29.36],[47,29.36,31.84],[48,31.84,32.52],[49,32.52,32.6],[50,32.6,32.8],[51,32.8,34],[52,34,34.2],[53,34.2,34.5],[54,34.5,34.9],[55,34.9,37.2],[56,37.2,37.68],[57,37.68,38.08],[58,38.08,38.44],[59,38.44,38.56],[60,38.56,38.84],[61,38.84,39.32],[62,39.32,39.88],[63,39.88,40.12],[64,40.12,41.44],[65,41.44,42],[66,42,42.24],[67,42.24,42.6],[68,42.6,44.04],[69,44.04,45.54],[70,45.54,46.36],[71,46.36,46.8],[72,46.8,47.16],[73,47.16,47.72],[74,47.72,48.36],[75,48.36,48.72],[76,48.72,49.4],[77,49.4,51],[78,51,53.06],[79,53.06,53.36],[80,53.36,53.66],[81,53.66,53.96],[82,53.96,54.76],[83,54.76,55.08],[84,55.08,55.64],[85,55.64,55.96],[86,55.96,56.24],[87,56.24,57.64],[88,57.64,58.42],[89,58.42,58.76],[90,58.76,59.6],[91,59.6,59.82],[92,59.82,60.36],[93,60.36,60.64],[94,60.64,60.8],[95,60.8,61.6],[96,61.6,61.84],[97,61.84,62.28],[98,62.28,63.44],[99,63.44,64.56],[100,64.56,65.26],[101,65.26,65.66],[102,65.66,66.12],[103,66.12,66.48],[104,66.48,67.04],[105,67.04,67.28],[106,67.28,67.76],[107,67.76,68.12],[108,68.12,68.68],[109,68.68,68.84],[110,68.84,69.12],[111,69.12,129.12]]},"pages":[{"n":1,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/12939/size6/26f3c562e8fcf285da64ace4885497a2.jpg","text":"I have a friend. She lives in my house.","words":[[1,"I"],[2,"have"],[3,"a"],[4,"friend."],[5,"She"],[6,"lives"],[7,"in"],[8,"my"],[9,"house."]]},{"n":2,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/12940/size6/d07a196027366d86d218485a16115cef.jpg","text":"When I am happy, so is she.","words":[[10,"When"],[11,"I"],[12,"am"],[13,"happy,"],[14,"so"],[15,"is"],[16,"she."]]},{"n":3,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/12941/size6/9968ed9b842685f573b114b9a2be8e6a.jpg","text":"When I cry, she cries too.","words":[[17,"When"],[18,"I"],[19,"cry,"],[20,"she"],[21,"cries"],[22,"too."]]},{"n":4,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/12942/size6/7f19ca3a7f4392ae1737ad6f7ba722e6.jpg","text":"But I cannot hear her voice. My friend lives inside the mirror.","words":[[23,"But"],[24,"I"],[25,"cannot"],[26,"hear"],[27,"her"],[28,"voice."],[29,"My"],[30,"friend"],[31,"lives"],[32,"inside"],[33,"the"],[34,"mirror."]]},{"n":5,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/12943/size6/f77bed787eca6e623588fd4492456666.jpg","text":"“Come out,” I tell her, “we will play.” She does not come out.","words":[[35,"“Come"],[36,"out,”"],[37,"I"],[38,"tell"],[39,"her,"],[40,"“we"],[41,"will"],[42,"play.”"],[43,"She"],[44,"does"],[45,"not"],[46,"come"],[47,"out."]]},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/12944/size6/0ab978d66dc04fbd958537accfaf3474.jpg","text":"I am not happy. I go to sleep.","words":[[48,"I"],[49,"am"],[50,"not"],[51,"happy."],[52,"I"],[53,"go"],[54,"to"],[55,"sleep."]]},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/12945/size6/f2d91399e3710afc2ab72f1a4251ae1f.jpg","text":"She comes out of the mirror in my sleep! And we have fun.","words":[[56,"She"],[57,"comes"],[58,"out"],[59,"of"],[60,"the"],[61,"mirror"],[62,"in"],[63,"my"],[64,"sleep!"],[65,"And"],[66,"we"],[67,"have"],[68,"fun."]]},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/12946/size6/99927082c4c7183837255183b81f106f.jpg","text":"We play, we run, we shout and scream together.","words":[[69,"We"],[70,"play,"],[71,"we"],[72,"run,"],[73,"we"],[74,"shout"],[75,"and"],[76,"scream"],[77,"together."]]},{"n":9,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/12947/size6/193694c2078e2b794802233069bfca43.jpg","text":"When I talk to her, she also talks to me.","words":[[78,"When"],[79,"I"],[80,"talk"],[81,"to"],[82,"her,"],[83,"she"],[84,"also"],[85,"talks"],[86,"to"],[87,"me."]]},{"n":10,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/12948/size6/2fdc1d0c194d45e607462e4a77a7b9b4.jpg","text":"In the morning, my friend will go back into the mirror.","words":[[88,"In"],[89,"the"],[90,"morning,"],[91,"my"],[92,"friend"],[93,"will"],[94,"go"],[95,"back"],[96,"into"],[97,"the"],[98,"mirror."]]},{"n":11,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/12949/size6/e6d48b6c13538e56e67d69f9f907c03e.jpg","text":"But I don't mind at all. We will play again in my dreams!","words":[[99,"But"],[100,"I"],[101,"don't"],[102,"mind"],[103,"at"],[104,"all."],[105,"We"],[106,"will"],[107,"play"],[108,"again"],[109,"in"],[110,"my"],[111,"dreams!"]]}],"stats":{"pages":11,"words":111}}