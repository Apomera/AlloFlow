rg.in/illustration_crops/2021/size6/b18e429effd87b75efceaf3dbf8c096f.jpg","text":"सोनपंखी के धब्बे,\nपेड़ों के तने में दिखते गोले,\nबनी हुई चीज़ों के आकार,\nमधुमक्खी के छत्ते में बने नन्हे घर।","words":[[49,"सोनपंखी"],[50,"के"],[51,"धब्बे,"],[52,"पेड़ों"],[53,"के"],[54,"तने"],[55,"में"],[56,"दिखते"],[57,"गोले,"],[58,"बनी"],[59,"हुई"],[60,"चीज़ों"],[61,"के"],[62,"आकार,"],[63,"मधुमक्खी"],[64,"के"],[65,"छत्ते"],[66,"में"],[67,"बने"],[68,"नन्हे"],[69,"घर।"]]},{"n":5,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/2022/size6/e88f7192c6acc8de97655509f7eed195.jpg","text":"पत्तों पर रेखाएँ बनीं,\nजैसी उसके हाथ पर।\nसागर किनारे की गीली रेत में,\nनिशान उसके पैरों के।","words":[[70,"पत्तों"],[71,"पर"],[72,"रेखाएँ"],[73,"बनीं,"],[74,"जैसी"],[75,"उसके"],[76,"हाथ"],[77,"पर।"],[78,"सागर"],[79,"किनारे"],[80,"की"],[81,"गीली"],[82,"रेत"],[83,"में,"],[84,"निशान"],[85,"उसके"],[86,"पैरों"],[87,"के।"]]},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/2023/size6/92ffe50a250577704f52657a985cb08d.jpg","text":"पानी में लहरें,\nघुँघराले बालों में लहर।\nपेड़ों की छाल पर उगते कुकुरमुत्ते,\nहवा में उड़ते हुए पंछी।","words":[[88,"पानी"],[89,"में"],[90,"लहरें,"],[91,"घुँघराले"],[92,"बालों"],[93,"में"],[94,"लहर।"],[95,"पेड़ों"],[96,"की"],[97,"छाल"],[98,"पर"],[99,"उगते"],[100,"कुकुरमुत्ते,"],[101,"हवा"],[102,"में"],[103,"उड़ते"],[104,"हुए"],[105,"पंछी।"]]},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/2024/size6/e138b17425bdc2b248e274a242d1164e.jpg","text":"किताब में छपे हुए शब्द जो\nउसे कहीं भी ले जा सकते हैं,\nनए रंगों से भरपूर,\nनई कहानियाँ, नए चेहरे।","words":[[106,"किताब"],[107,"में"],[108,"छपे"],[109,"हुए"],[110,"शब्द"],[111,"जो"],[112,"उसे"],[113,"कहीं"],[114,"भी"],[115,"ले"],[116,"जा"],[117,"सकते"],[118,"हैं,"],[119,"नए"],[120,"रंगों"],[121,"से"],[122,"भरपूर,"],[123,"नई"],[124,"कहानियाँ,"],[125,"नए"],[126,"चेहरे।"]]},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/2025/size6/bbf7e383cd58be98448e5bcb546d50f9.jpg","text":"चीज़ों का वह रंग जो\nउसे सबसे प्यारा है- लाल!\nछोटे भाई बुबू के सिर पर उगते\nतीन छोटे घुँघराले बाल।","words":[[127,"चीज़ों"],[128,"का"],[129,"वह"],[130,"रंग"],[131,"जो"],[132,"उसे"],[133,"सबसे"],[134,"प्यारा"],[135,"है-"],[136,"लाल!"],[137,"छोटे"],[138,"भाई"],[139,"बुबू"],[140,"के"],[141,"सिर"],[142,"पर"],[143,"उगते"],[144,"तीन"],[145,"छोटे"],[146,"घुँघराले"],[147,"बाल।"]]},{"n":9,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/2026/size6/0a45394fd6df39c785036f1747d1df56.jpg","text":"पापा ने जो आज बनाया\nउस केक पर छिड़की शक्कर,\nचमक रही है ऐसे\nमानो दूर तारे हों जैसे।","words":[[148,"पापा"],[149,"ने"],[150,"जो"],[151,"आज"],[152,"बनाया"],[153,"उस"],[154,"केक"],[155,"पर"],[156,"छिड़की"],[157,"शक्कर,"],[158,"चमक"],[159,"रही"],[160,"है"],[161,"ऐसे"],[162,"मानो"],[163,"दूर"],[164,"तारे"],[165,"हों"],[166,"जैसे।"]]},{"n":10,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/2027/size6/cafc0270ebff9f82e3593c21f599a7cb.jpg","text":"बादलों में छुपे हैं खरगोश\nफुदकते फिरते हैं आसमान में\nपरछाई से बन सकता है हाथी\nआओ, बनाओ तुम भी।","words":[[167,"बादलों"],[168,"में"],[169,"छुपे"],[170,"हैं"],[171,"खरगोश"],[172,"फुदकते"],[173,"फिरते"],[174,"हैं"],[175,"आसमान"],[176,"में"],[177,"परछाई"],[178,"से"],[179,"बन"],[180,"सकता"],[181,"है"],[182,"हाथी"],[183,"आओ,"],[184,"बनाओ"],[185,"तुम"],[186,"भी।"]]},{"n":11,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/2028/size6/a6474fb6d2fb71cd54566099d9a9fb43.jpg","text":"अनु ख़ुश है सब चीज़ों से\nदेखती रहती है जिनको वह।\nक्या तुम भी वह सब देखोगे\nजो देखती है छोटी अनु?","words":[[187,"अनु"],[188,"ख़ुश"],[189,"है"],[190,"सब"],[191,"चीज़ों"],[192,"से"],[193,"देखती"],[194,"रहती"],[195,"है"],[196,"जिनको"],[197,"वह।"],[198,"क्या"],[199,"तुम"],[200,"भी"],[201,"वह"],[202,"सब"],[203,"देखोगे"],[204,"जो"],[205,"देखती"],[206,"है"],[207,"छोटी"],[208,"अनु?"]]}],"stats":{"pages":11,"wo