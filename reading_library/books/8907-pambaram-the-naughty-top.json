ost-box"],[548,"at"],[549,"the"],[550,"street"],[551,"corner."],[552,"Before"],[553,"he"],[554,"knew"],[555,"what"],[556,"was"],[557,"happening,"],[558,"Pambaram"],[559,"raced"],[560,"towards"],[561,"him"],[562,"and"],[563,"fell"],[564,"‘plop!’"],[565,"into"],[566,"a"],[567,"can"],[568,"of"],[569,"red"],[570,"paint!"],[571,"Pambaram"],[572,"was"],[573,"tired"],[574,"out."]]},{"n":14,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/27882/size6/fe5dd591f54bc8fb55c22abe6e4111ed.jpg","text":"Priya and Bala laughed at the sight of the top dripping with paint. They waited for it to dry and then Muthu painted black stripes on it with his brush. \nThe naughty top now looks as good as new and Pambaram loves its new red and black stripes!","words":[[575,"Priya"],[576,"and"],[577,"Bala"],[578,"laughed"],[579,"at"],[580,"the"],[581,"sight"],[582,"of"],[583,"the"],[584,"top"],[585,"dripping"],[586,"with"],[587,"paint."],[588,"They"],[589,"waited"],[590,"for"],[591,"it"],[592,"to"],[593,"dry"],[594,"and"],[595,"then"],[596,"Muthu"],[597,"painted"],[598,"black"],[599,"stripes"],[600,"on"],[601,"it"],[602,"with"],[603,"his"],[604,"brush."],[605,"The"],[606,"naughty"],[607,"top"],[608,"now"],[609,"looks"],[610,"as"],[611,"good"],[612,"as"],[613,"new"],[614,"and"],[615,"Pambaram"],[616,"loves"],[617,"its"],[618,"new"],[619,"red"],[620,"and"],[621,"black"],[622,"stripes!"]]},{"n":15,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/27871/size6/6df8e601adbba328ff4cf77668e3653d.jpg","text":"Glossary:\nPambaram\n– Top in Tamil\nAnna – Elder brother in Tamil\nChitappa\n– Paternal uncle in Tamil\nPaati – Grandmother in Tamil","words":[[623,"Glossary:"],[624,"Pambaram"],[625,"–"],[626,"Top"],[627,"in"],[628,"Tamil"],[629,"Anna"],[630,"–"],[631,"Elder"],[632,"brother"],[633,"in"],[634,"Tamil"],[635,"Chitappa"],[636,"–"],[637,"Paternal"],[638,"uncle"],[639,"in"],[640,"Tamil"],[641,"Paati"],[642,"–"],[643,"Grandmother"],[644,"in"],[645,"Tamil"]]}],"stats":{"pages":15,"words":645}}