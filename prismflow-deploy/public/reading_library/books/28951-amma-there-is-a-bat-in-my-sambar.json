5,"flying"],[56,"in"],[57,"circles"],[58,"around"],[59,"my"],[60,"face,"],[61,"Flapping"],[62,"her"],[63,"wings,"],[64,"making"],[65,"my"],[66,"heart"],[67,"race."]]},{"n":5,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/57861/size6/7c95b45313a0d4a2032399f9ecf0b20b.jpg","text":"Watch out! Hide! Run for your life!\nShe's dropping poop bombs. They are not very nice.","words":[[68,"Watch"],[69,"out!"],[70,"Hide!"],[71,"Run"],[72,"for"],[73,"your"],[74,"life!"],[75,"She's"],[76,"dropping"],[77,"poop"],[78,"bombs."],[79,"They"],[80,"are"],[81,"not"],[82,"very"],[83,"nice."]]},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/57896/size6/4024df65accce940af394673cf71cf31.jpg","text":"\"Suppi, relax\" Amma whispers, \n\"I think she wants to go back to her brothers and sisters.\"","words":[[84,"\"Suppi,"],[85,"relax\""],[86,"Amma"],[87,"whispers,"],[88,"\"I"],[89,"think"],[90,"she"],[91,"wants"],[92,"to"],[93,"go"],[94,"back"],[95,"to"],[96,"her"],[97,"brothers"],[98,"and"],[99,"sisters.\""]]},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/57863/size6/9a4ca7f704d3137e160e46347973f58b.jpg","text":"Amma turns off the fan and all the lights.\nI open the windows and don’t put up a fight.","words":[[100,"Amma"],[101,"turns"],[102,"off"],[103,"the"],[104,"fan"],[105,"and"],[106,"all"],[107,"the"],[108,"lights."],[109,"I"],[110,"open"],[111,"the"],[112,"windows"],[113,"and"],[114,"don’t"],[115,"put"],[116,"up"],[117,"a"],[118,"fight."]]},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/57864/size6/4a59589d8e19e6a624030a001c9b2d87.jpg","text":"Amma is right! (Is she ever wrong?)\nThe bat takes off on her wings, webbed and long.","words":[[119,"Amma"],[120,"is"],[121,"right!"],[122,"(Is"],[123,"she"],[124,"ever"],[125,"wrong?)"],[126,"The"],[127,"bat"],[128,"takes"],[129,"off"],[130,"on"],[131,"her"],[132,"wings,"],[133,"webbed"],[134,"and"],[135,"long."]]},{"n":9,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/57946/size6/0af75ddb71607970dbc3c85a68a17fc9.jpg","text":"I rush to the window and wave goodbye,\nAs she swoops up a tree that touches the sky.","words":[[136,"I"],[137,"rush"],[138,"to"],[139,"the"],[140,"window"],[141,"and"],[142,"wave"],[143,"goodbye,"],[144,"As"],[145,"she"],[146,"swoops"],[147,"up"],[148,"a"],[149,"tree"],[150,"that"],[151,"touches"],[152,"the"],[153,"sky."]]},{"n":10,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/57866/size6/0a44f5a58145848e1d21ac392a279889.jpg","text":"It is back to the table for dinner now,\nThough I'm not sure we should eat that sambar somehow!","words":[[154,"It"],[155,"is"],[156,"back"],[157,"to"],[158,"the"],[159,"table"],[160,"for"],[161,"dinner"],[162,"now,"],[163,"Though"],[164,"I'm"],[165,"not"],[166,"sure"],[167,"we"],[168,"should"],[169,"eat"],[170,"that"],[171,"sambar"],[172,"somehow!"]]},{"n":11,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/57895/size6/93452002ca990b74d8827b41a71efbce.jpg","text":"What to do if a bat comes to visit you? \nHave you ever seen a bat flying about and felt scared? Did you think the bat was going to sleep in your hair for the night?\nBats are not at all interested in hanging upside down from your hair. They would rather rest their feet in the branches of a tree or the roof of a cave or the wall of a building!\nIf a bat comes into your house, don’t get frightened. Our winged friend may be just as scared as you are. Instead, turn off all the lights and fans, leave the windows wide open and wait patiently. They will find their way out in the dark!","words":[[173,"What"],[174,"to"],[175,"do"],[176,"if"],[177,"a"],[178,"bat"],[179,"comes"],[180,"to"],[181,"visit"],[182,"you?"],[183,"Have"],[184,"you"],[185,"ever"],[186,"seen"],[187,"a"],[188,"bat"],[189,"flying"],[190,"about"],[191,"and"],[192,"felt"],[193,"scared?"],[194,"Did"],[195,"you"],[196,"think"],[197,"the"],[198,"bat"],[199,"was"],[200,"going"],[201,"to"],[202,"sleep"],[203,"in"],[204,"your"],[205,"hair"],[206,"for"],[207,"the"],[208,"night?"],[209,"Bats"],[210,"are"],[211,"not"],[212,"at"],[213,"all"],[214,"interested"],[215,"in"],[216,"hanging"],[217,"upside"],[218,"down"],[219,"from"],[220,"your"],[221,"hair."],[222,"They"],[223,"would"],[224,"rather"],[225,"rest"],[226,"their"],[227,"feet"],[228,"in"],[229,"the"],[230,"branches"],[231,"of"],[232,"a"],[233,"tree"],[234,"or"],[235,"the"],[236,"roof"],[237,"of"],[238,"a"],[239,"cave"],[240,"or"],[241,"the"],[242,"wall"],[243,"of"],[244,"a"],[245,"building!"],[246,"If"],[247,"a"],[248,"bat"],[249,"comes"],[250,"into"],[251,"your"],[252,"house,"],[253,"don’t"],[254,"get"],[255,"frightened."],[256,"Our"],[257,"winged"],[258,"friend"],[259,"may"],[260,"be"],[261,"just"],[262,"as"],[263,"scared"],[264,"as"],[265,"you"],[266,"are."],[267,"Instead,"],[268,"turn"],[269,"off"],[270,"all"],[271,"the"],[272,"lights"],[273,"and"],[274,"fans,"],[275,"leave"],[276,"the"],[277,"windows"],[278,"wide"],[279,"open"],[280,"and"],[281,"wait"],[282,"patiently."],[283,"They"],[284,"will"],[285,"find"],[286,"their"],[287,"way"],[288,"out"],[289,"in"],[290,"the"],[291,"dark!"]]}],"stats":{"pages":11,"words":291}}