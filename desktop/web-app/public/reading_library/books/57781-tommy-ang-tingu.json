gu.\nAng tawag namin sa kaniya ay Tingu Tigre.","words":null},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/33288/size6/a233e7744667432d12124457196ef3cc.jpg","text":"7/7","words":null}],"stats":{"pages":6,"words":53}}