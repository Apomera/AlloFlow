َافِلَةِ، أَوْ يَأْتُونَ بِالسَّيَّارَةِ. \nيَأْتُونَ بِالدَّرَّاجَةِ، أَوْ مَشْيًا عَلَى الْأَقْدَامِ مِثْلِي.","words":[[23,"هُنَاكَ"],[24,"الْكَثِيرُ"],[25,"مِنَ"],[26,"الْأَطْفَالِ"],[27,"قُرْبَ"],[28,"الْمَدْرَسَةِ."],[29,"يَأْتُونَ"],[30,"بِالْحَافِلَةِ،"],[31,"أَوْ"],[32,"يَأْتُونَ"],[33,"بِالسَّيَّارَةِ."],[34,"يَأْتُونَ"],[35,"بِالدَّرَّاجَةِ،"],[36,"أَوْ"],[37,"مَشْيًا"],[38,"عَلَى"],[39,"الْأَقْدَامِ"],[40,"مِثْلِي."]]},{"n":3,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/1248/size6/2d47b6ee6c91bc239e6d30262332ffd2.jpg","text":"عِنْدَمَا اقْتَرَبْنَا مِنَ الْبَوَّابَةِ، أَفْلَتَتْ أُمِّي يَدِي وَبَقِيَتْ خَارِجَ الْبَوَّابَةِ. كَانَ عَلَيَّ الدُّخُولُ إِلَى الْمَدْرَسَةِ وَحْدِي. هُنَاكَ الْكَثِيرُ مِنَ الْوُجُوهِ الْجَدِيدَةِ حَوْلِي.","words":[[41,"عِنْدَمَا"],[42,"اقْتَرَبْنَا"],[43,"مِنَ"],[44,"الْبَوَّابَةِ،"],[45,"أَفْلَتَتْ"],[46,"أُمِّي"],[47,"يَدِي"],[48,"وَبَقِيَتْ"],[49,"خَارِجَ"],[50,"الْبَوَّابَةِ."],[51,"كَانَ"],[52,"عَلَيَّ"],[53,"الدُّخُولُ"],[54,"إِلَى"],[55,"الْمَدْرَسَةِ"],[56,"وَحْدِي."],[57,"هُنَاكَ"],[58,"الْكَثِيرُ"],[59,"مِنَ"],[60,"الْوُجُوهِ"],[61,"الْجَدِيدَةِ"],[62,"حَوْلِي."]]},{"n":4,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/1249/size6/e29771bf74c00222399d944390f410f7.jpg","text":"تَقَدَّمْتُ خُطْوَةً، ثُمَّ خُطْوَةً أُخْرَى. نَظَرْتُ لِلْوَرَاءِ. أُمِّي تُصْبِحُ أَصْغَرَ كُلَّمَا تَقَدَّمْتُ أَكْثَرَ، هَلْ سَتَخْتَفِي؟!\nرَكَضْتُ إِلَيْهَا مُسْرِعَةً، لَسْتُ كَبِيرَةً كِفَايَةً، وأَمْسَكْتُ يَدَهَا وَقُلْتُ: \"لَا تَذْهَبِي\".","words":[[63,"تَقَدَّمْتُ"],[64,"خُطْوَةً،"],[65,"ثُمَّ"],[66,"خُطْوَةً"],[67,"أُخْرَى."],[68,"نَظَرْتُ"],[69,"لِلْوَرَاءِ."],[70,"أُمِّي"],[71,"تُصْبِحُ"],[72,"أَصْغَرَ"],[73,"كُلَّمَا"],[74,"تَقَدَّمْتُ"],[75,"أَكْثَرَ،"],[76,"هَلْ"],[77,"سَتَخْتَفِي؟!"],[78,"رَكَضْتُ"],[79,"إِلَيْهَا"],[80,"مُسْرِعَةً،"],[81,"لَسْتُ"],[82,"كَبِيرَةً"],[83,"كِفَايَةً،"],[84,"وأَمْسَكْتُ"],[85,"يَدَهَا"],[86,"وَقُلْتُ:"],[87,"\"لَا"],[88,"تَذْهَبِي\"."]]},{"n":5,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/1250/size6/aabc27989e15ba7b1604488f52d86b31.jpg","text":"الْجَمِيعُ فِي الدَّاخِلِ الْآنَ. أَنَا الْوَحِيدَةُ فِي الْخَارِجِ. أَتَتِ الْمُعَلِّمَةُ وَهِيَ تَبْتَسِمُ، فَابْتَسَمْتُ لَهَا.\nقَالَتْ أُمِّي: \"رَانِي، سَأَكُونُ هُنَا عِنْدَمَا تَخْرُجِينَ\".\nتَرَكْتُ يَدَهَا، وَلَوَّحَتْ لِي.","words":[[89,"الْجَمِيعُ"],[90,"فِي"],[91,"الدَّاخِلِ"],[92,"الْآنَ."],[93,"أَنَا"],[94,"الْوَحِيدَةُ"],[95,"فِي"],[96,"الْخَارِجِ."],[97,"أَتَتِ"],[98,"الْمُعَلِّمَةُ"],[99,"وَهِيَ"],[100,"تَبْتَسِمُ،"],[101,"فَابْتَسَمْتُ"],[102,"لَهَا."],[103,"قَالَتْ"],[104,"أُمِّي:"],[105,"\"رَانِي،"],[106,"سَأَكُونُ"],[107,"هُنَا"],[108,"عِنْدَمَا"],[109,"تَخْرُجِينَ\"."],[110,"تَرَكْتُ"],[111,"يَدَهَا،"],[112,"وَلَوَّحَتْ"],[113,"لِي."]]},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/1251/size6/0400eb4ceb025592a48339ad6d4de85c.jpg","text":"اتَّجَهْتُ إِلَى الدَّاخِلِ. أُمِّي سَتَكُونُ هُنَا عِنْدَمَا أَخْرُجُ!","words":[[114,"اتَّجَهْتُ"],[115,"إِلَى"],[116,"الدَّاخِلِ."],[117,"أُمِّي"],[118,"سَتَكُونُ"],[119,"هُنَا"],[120,"عِنْدَمَا"],[121,"أَخْرُجُ!"]]}],"stats":{"pages":6,"words":121}}