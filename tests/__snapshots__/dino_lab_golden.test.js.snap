exports[`Dino Lab — render per tab (golden master) > renders the ecosystem tab (snapshot) 1`] = `
"<div class="dinolab-root" style="min-height:100%;background:var(--allo-stem-canvas, #0f172a);color:var(--allo-stem-text, #f1f5f9)">
<style>.dinolab-root button:focus-visible,.dinolab-root input:focus-visible,.dinolab-root select:focus-visible,.dinolab-root textarea:focus-visible,.dinolab-root [tabindex]:focus-visible{outline:3px solid #f8fafc!important;outline-offset:2px;box-shadow:0 0 0 5px #0f766e!important}@media(max-width:720px){.dinolab-root .dinolab-explore-layout{grid-template-columns:minmax(0,1fr)!important}.dinolab-root .dinolab-mission-stats{grid-template-columns:repeat(auto-fit,minmax(120px,1fr))!important}.dinolab-root .dinolab-compare-grid,.dinolab-root .dinolab-compare-pickers{grid-template-columns:minmax(0,1fr)!important}.dinolab-root .dinolab-map-stats{grid-template-columns:repeat(auto-fit,minmax(120px,1fr))!important}.dinolab-root .dinolab-3d-viewer{min-height:380px!important}.dinolab-root .dinolab-3d-canvas{height:380px!important}.dinolab-root .dinolab-3d-readouts{max-height:88px;overflow:hidden}.dinolab-root .dinolab-3d-chip{font-size:10px!important;padding:4px 7px!important}}@media(max-width:480px){.dinolab-root #dinopanel{padding:10px!important}.dinolab-root .dinolab-tablist{padding:8px!important;flex-wrap:nowrap!important;overflow-x:auto!important;scrollbar-width:thin}.dinolab-root .dinolab-section-cue{padding-left:10px!important;padding-right:10px!important}.dinolab-root .dinolab-3d-viewer{min-height:340px!important}.dinolab-root .dinolab-3d-canvas{height:340px!important}.dinolab-root .dinolab-3d-readouts{left:7px!important;right:7px!important;top:7px!important;gap:4px!important;max-height:70px}.dinolab-root .dinolab-3d-camera-readout{right:7px!important;bottom:58px!important;font-size:10px!important}.dinolab-root .dinolab-3d-status{left:7px!important;right:7px!important;bottom:7px!important;font-size:10px!important;padding:6px 8px!important}.dinolab-root .dinolab-3d-view-controls{align-items:stretch!important}.dinolab-root .dinolab-3d-view-controls&gt;button{flex:1 1 72px}}</style>
<nav aria-label="Dino Lab section navigation" style="background:var(--allo-stem-deeper, #0b1220)">
<div class="dinolab-section-cue" style="display:flex;align-items:center;gap:7px;padding:7px 12px 0;color:var(--allo-stem-text-soft, #94a3b8);font-size:11.5px">
<span style="text-transform:uppercase;letter-spacing:0.06em;font-weight:900;color:#5eead4">Discover</span>
<span aria-hidden="true">›</span>
<span style="font-weight:800;color:var(--allo-stem-text, #f1f5f9)">Ecosystems</span>
<span style="margin-left:auto">6 of 18</span>
</div>
<div class="dinolab-tablist" role="tablist" aria-label="Dino Lab sections" aria-orientation="horizontal" style="display:flex;flex-wrap:wrap;gap:4px;padding:10px 12px;border-bottom:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220)">
<button id="dinotab-explore" role="tab" data-tab-group="Discover" title="Discover: Explore" tabindex="-1" aria-selected="false" aria-controls="dinopanel" aria-keyshortcuts="ArrowLeft ArrowRight ArrowUp ArrowDown Home End" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;box-shadow:none;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🔍 Explore</button>
<button id="dinotab-timeline" role="tab" data-tab-group="Discover" title="Discover: Timeline" tabindex="-1" aria-selected="false" aria-controls="dinopanel" aria-keyshortcuts="ArrowLeft ArrowRight ArrowUp ArrowDown Home End" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;box-shadow:none;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">⏳ Timeline</button>
<button id="dinotab-deeptime" role="tab" data-tab-group="Discover" title="Discover: Deep Time" tabindex="-1" aria-selected="false" aria-controls="dinopanel" aria-keyshortcuts="ArrowLeft ArrowRight ArrowUp ArrowDown Home End" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;box-shadow:none;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🕰️ Deep Time</button>
<button id="dinotab-sites" role="tab" data-tab-group="Discover" title="Discover: Sites" tabindex="-1" aria-selected="false" aria-controls="dinopanel" aria-keyshortcuts="ArrowLeft ArrowRight ArrowUp ArrowDown Home End" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;box-shadow:none;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🗺️ Sites</button>
<button id="dinotab-map" role="tab" data-tab-group="Discover" title="Discover: Map" tabindex="-1" aria-selected="false" aria-controls="dinopanel" aria-keyshortcuts="ArrowLeft ArrowRight ArrowUp ArrowDown Home End" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;box-shadow:none;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🌎 Map</button>
<button id="dinotab-ecosystem" role="tab" data-tab-group="Discover" title="Discover: Ecosystems" tabindex="0" aria-selected="true" aria-controls="dinopanel" aria-keyshortcuts="ArrowLeft ArrowRight ArrowUp ArrowDown Home End" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:700;box-shadow:0 1px 4px rgba(21,128,61,0.45);background:#15803d;color:#fff;white-space:nowrap">🌍 Ecosystems</button>
<button id="dinotab-compare" role="tab" data-tab-group="Investigate" title="Investigate: Compare" tabindex="-1" aria-selected="false" aria-controls="dinopanel" aria-keyshortcuts="ArrowLeft ArrowRight ArrowUp ArrowDown Home End" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;box-shadow:none;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">⚖️ Compare</button>
<button id="dinotab-field3d" role="tab" data-tab-group="Investigate" title="Investigate: Field Station" tabindex="-1" aria-selected="false" aria-controls="dinopanel" aria-keyshortcuts="ArrowLeft ArrowRight ArrowUp ArrowDown Home End" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;box-shadow:none;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">3D Field Station</button>
<button id="dinotab-dig" role="tab" data-tab-group="Investigate" title="Investigate: Dig Site" tabindex="-1" aria-selected="false" aria-controls="dinopanel" aria-keyshortcuts="ArrowLeft ArrowRight ArrowUp ArrowDown Home End" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;box-shadow:none;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">⛏️ Dig Site</button>
<button id="dinotab-classify" role="tab" data-tab-group="Investigate" title="Investigate: Classify" tabindex="-1" aria-selected="false" aria-controls="dinopanel" aria-keyshortcuts="ArrowLeft ArrowRight ArrowUp ArrowDown Home End" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;box-shadow:none;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🌳 Classify</button>
<button id="dinotab-birds" role="tab" data-tab-group="Explain" title="Explain: Bird Link" tabindex="-1" aria-selected="false" aria-controls="dinopanel" aria-keyshortcuts="ArrowLeft ArrowRight ArrowUp ArrowDown Home End" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;box-shadow:none;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🐦 Bird Link</button>
<button id="dinotab-extinction" role="tab" data-tab-group="Explain" title="Explain: Extinction" tabindex="-1" aria-selected="false" aria-controls="dinopanel" aria-keyshortcuts="ArrowLeft ArrowRight ArrowUp ArrowDown Home End" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;box-shadow:none;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">☄️ Extinction</button>
<button id="dinotab-anatomy" role="tab" data-tab-group="Investigate" title="Investigate: Anatomy" tabindex="-1" aria-selected="false" aria-controls="dinopanel" aria-keyshortcuts="ArrowLeft ArrowRight ArrowUp ArrowDown Home End" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;box-shadow:none;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🦴 Anatomy</button>
<button id="dinotab-records" role="tab" data-tab-group="Explain" title="Explain: Records" tabindex="-1" aria-selected="false" aria-controls="dinopanel" aria-keyshortcuts="ArrowLeft ArrowRight ArrowUp ArrowDown Home End" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;box-shadow:none;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🏆 Records</button>
<button id="dinotab-quiz" role="tab" data-tab-group="Practice and teach" title="Practice and teach: Quiz" tabindex="-1" aria-selected="false" aria-controls="dinopanel" aria-keyshortcuts="ArrowLeft ArrowRight ArrowUp ArrowDown Home End" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;box-shadow:none;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🧠 Quiz</button>
<button id="dinotab-notes" role="tab" data-tab-group="Practice and teach" title="Practice and teach: Field Notes" tabindex="-1" aria-selected="false" aria-controls="dinopanel" aria-keyshortcuts="ArrowLeft ArrowRight ArrowUp ArrowDown Home End" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;box-shadow:none;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">📓 Field Notes</button>
<button id="dinotab-glossary" role="tab" data-tab-group="Practice and teach" title="Practice and teach: Glossary" tabindex="-1" aria-selected="false" aria-controls="dinopanel" aria-keyshortcuts="ArrowLeft ArrowRight ArrowUp ArrowDown Home End" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;box-shadow:none;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">📖 Glossary</button>
<button id="dinotab-classroom" role="tab" data-tab-group="Practice and teach" title="Practice and teach: Classroom" tabindex="-1" aria-selected="false" aria-controls="dinopanel" aria-keyshortcuts="ArrowLeft ArrowRight ArrowUp ArrowDown Home End" style="padding:7px 11px;border-radius:9px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;box-shadow:none;background:transparent;color:var(--allo-stem-text-soft, #94a3b8);white-space:nowrap">🍎 Classroom</button>
