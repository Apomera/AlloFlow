ic.storyweaver.org.in/illustration_crops/53341/size6/67b9a931bec853b4523505e6048cc06c.jpg","text":"“पुचकू! कक्षा में जाओ!”\n“पुचकू! बस में जाओ!”\n“पुचकू! अपना होमवर्क पूरा करो!”","words":[[13,"“"],[14,"पुचकू"],[15,"!"],[16,"कक्षा"],[17,"में"],[18,"जाओ!”"],[19,"“"],[20,"पुचकू"],[21,"!"],[22,"बस"],[23,"में"],[24,"जाओ!”"],[25,"“"],[26,"पुचकू"],[27,"!"],[28,"अपना"],[29,"होमवर्क"],[30,"पूरा"],[31,"करो!”"]]},{"n":3,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/53342/size6/5af95d4c3e399bdafa2a98812fcc9c72.jpg","text":"“मगर पुचकू है कहाँ?”","words":[[32,"“मगर"],[33,"पुचकू"],[34,"है"],[35,"कहाँ?”"]]},{"n":4,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/53343/size6/05223332714993f241e630d5a9fb661d.jpg","text":"5/22","words":null},{"n":5,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/53479/size6/b5686410e8e435b47e60e5e5a1d2cc99.jpg","text":"पुचकू व्यस्त है।\nउसके पास पढ़़ने को किताब है।\nपुचकू हमेशा पढ़़ती रहती\nहै, घर पर, पाठशाला में, पार्क में, बिस्तर में भी। पन्ने के बाद पन्ना, एक किताब के बाद दूसरी किताब, एक के बाद एक, वह सारी की सारी किताबें पढ़़कर ख़त्म कर चुकी है।","words":[[36,"पुचकू"],[37,"व्यस्त"],[38,"है।"],[39,"उसके"],[40,"पास"],[41,"पढ़़ने"],[42,"को"],[43,"किताब"],[44,"है।"],[45,"पुचकू"],[46,"हमेशा"],[47,"पढ़़ती"],[48,"रहती"],[49,"है,"],[50,"घर"],[51,"पर,"],[52,"पाठशाला"],[53,"में,"],[54,"पार्क"],[55,"में,"],[56,"बिस्तर"],[57,"में"],[58,"भी।"],[59,"पन्ने"],[60,"के"],[61,"बाद"],[62,"पन्ना,"],[63,"एक"],[64,"किताब"],[65,"के"],[66,"बाद"],[67,"दूसरी"],[68,"किताब,"],[69,"एक"],[70,"के"],[71,"बाद"],[72,"एक,"],[73,"वह"],[74,"सारी"],[75,"की"],[76,"सारी"],[77,"किताबें"],[78,"पढ़़कर"],[79,"ख़त्म"],[80,"कर"],[81,"चुकी"],[82,"है।"]]},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/53443/size6/fc1651d836dc2f378e3d45d2d4491431.jpg","text":"“पर तुम हमेशा पढ़़ती क्यों रहती हो पुचकू?” \nबोल्टू बोला।\n“इधर आओ ना, कार्टून देखते हैं,” \nडोडला ने पुकारा।","words":[[83,"“पर"],[84,"तुम"],[85,"हमेशा"],[86,"पढ़़ती"],[87,"क्यों"],[88,"रहती"],[89,"हो"],[90,"पुचकू?”"],[91,"बोल्टू"],[92,"बोला।"],[93,"“इधर"],[94,"आओ"],[95,"ना,"],[96,"कार्टून"],[97,"देखते"],[98,"हैं,”"],[99,"डोडला"],[100,"ने"],[101,"पुकारा।"]]},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/54557/size6/885b4e357f03d58e792d239bd82ef3da.jpg","text":"“किताब पढ़़ने का तो मज़ा कुछ और ही है!”\nपुचकू बोली, “देखो! यह जो गोला देखते हो? और यह एक रेखा है। इसको थोड़ा दबाओ और उसको ज़रा खींचो। लो! एक अक्षर बन गया।\nकुछ अक्षरों को साथ में रखो और यह एक शब्द बन गया। शब्द कभी पते की बात कहते हैं, कभी गुदगुदाते हैं, कभी दुःख बाँटते हैं तो कभी आशा की रोशनी दिखाते हैं। शब्द एक दूसरे से जुड़़कर वाक्य बनते हैं और वाक्यों से कहानी \nबन जाती है। कहानी पढ़़ते ही आप आनन फ़ानन में \nदूसरी ही दुनिया में पहुँच जाते हैं!”","words":[[102,"“किताब"],[103,"पढ़़ने"],[104,"का"],[105,"तो"],[106,"मज़ा"],[107,"कुछ"],[108,"और"],[109,"ही"],[110,"है!”"],[111,"पुचकू"],[112,"बोली,"],[113,"“देखो!"],[114,"यह"],[115,"जो"],[116,"गोला"],[117,"देखते"],[118,"हो?"],[119,"और"],[120,"यह"],[121,"एक"],[122,"रेखा"],[123,"है।"],[124,"इसको"],[125,"थोड़ा"],[126,"दबाओ"],[127,"और"],[128,"उसको"],[129,"ज़रा"],[130,"खींचो।"],[131,"लो!"],[132,"एक"],[133,"अक्षर"],[134,"बन"],[135,"गया।"],[136,"कुछ"],[137,"अक्षरों"],[138,"को"],[139,"साथ"],[140,"में"],[141,"रखो"],[142,"और"],[143,"यह"],[144,"एक"],[145,"शब्द"],[146,"बन"],[147,"गया।"],[148,"शब्द"],[149,"कभी"],[150,"पते"],[151,"की"],[152,"बात"],[153,"कहते"],[154,"हैं,"],[155,"कभी"],[156,"गुदगुदाते"],[157,"हैं,"],[158,"कभी"],[159,"दुःख"],[160,"बाँटते"],[161,"हैं"],[162,"तो"],[163,"कभी"],[164,"आशा"],[165,"की"],[166,"रोशनी"],[167,"दिखाते"],[168,"हैं।"],[169,"शब्द"],[170,"एक"],[171,"दूसरे"],[172,"से"],[173,"जुड़़कर"],[174,"वाक्य"],[175,"बनते"],[176,"हैं"],[177,"और"],[178,"वाक्यों"],[179,"से"],[180,"कहानी"],[181,"बन"],[182,"जाती"],[183,"है।"],[184,"कहानी"],[185,"पढ़़ते"],[186,"ही"],[187,"आप"],[188,"आनन"],[189,"फ़ानन"],[190,"में"],[191,"दूसरी"],[192,"ही"],[193,"दुनिया"],[194,"में"],[195,"पहुँच"],[196,"जाते"],[197,"हैं!”"]]},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/53485/size6/04fa79c47f0b7a7dc00ed301bb764d65.jpg","text":"मगर आज पुचकू एक उलझन में थी।\nवह सारी किताबें पढ़़ चुकी थी। \nपुस्तकालय की सारी पुस्तकें, जिन तक उसकी पहुँच थी,\nएक सिरे से दूसरे सिरे तक, सब पढ़़कर समाप्त कर चुकी थी।","words":[[198,"मगर"],[199,"आज"],[200,"पुचकू"],[201,"एक"],[202,"उलझन"],[203,"में"],[204,"थी।"],[205,"वह"],[206,"सारी"],[207,"किताबें"],[208,"पढ़़"],[209,"चुकी"],[210,"थी।"],[211,"पुस्तकालय"],[212,"की"],[213,"सारी"],[214,"पुस्तकें,"],[215,"जिन"],[216,"तक"],[217,"उसकी"],[218,"पहुँच"],[219,"थी,"],[220,"एक"],[221,"सिरे"],[222,"से"],[223,"दूसरे"],[224,"सिरे"],[225,"तक,"],[226,"सब"],[227,"पढ़़कर"],[228,"समाप्त"],[229,"कर"],[230,"चुकी"],[231,"थी।"]]},{"n":9,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/53481/size6/14491fc96dda9871e4cc6fa507166465.jpg","text":"“अब मैं क्या करूँ? और कोई किताब नहीं बची है पढ़़ने को।” \nपुचकू रोने को आ गई।","words":[[232,"“अब"],[233,"मैं"],[234,"क्या"],[235,"करूँ?"],[236,"और"],[237,"कोई"],[238,"किताब"],[239,"नहीं"],[240,"बची"],[241,"है"],[242,"पढ़़ने"],[243,"को।”"],[244,"पुचकू"],[245,"रोने"],[246,"को"],[247,"आ"],[248,"गई।"]]},{"n":10,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/53482/size6/e0c539045aa2c67cb5d6fae614e8f17d.jpg","text":"मगर तभी, वहाँ क्या है?\nपुचकू की नज़र ऊपर गयी तो एक नहीं, दो नहीं, पूरे तीन खाने, \nकिताबों से भरे हुए!\n“और बहुत सी किताबें!” पुचकू खुशी से झूम उठी।","words":[[249,"मगर"],[250,"तभी,"],[251,"वहाँ"],[252,"क्या"],[253,"है?"],[254,"पुचकू"],[255,"की"],[256,"नज़र"],[257,"ऊपर"],[258,"गयी"],[259,"तो"],[260,"एक"],[261,"नहीं,"],[262,"दो"],[263,"नहीं,"],[264,"पूरे"],[265,"तीन"],[266,"खाने,"],[267,"किताबों"],[268,"से"],[269,"भरे"],[270,"हुए!"],[271,"“और"],[272,"बहुत"],[273,"सी"],[274,"किताबें!”"],[275,"पुचकू"],[276,"खुशी"],[277,"से"],[278,"झूम"],[279,"उठी।"]]},{"n":11,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/53450/size6/4212f8d761658fbd18a67645ab886cb8.jpg","text":"मगर एक गड़़बड़़ थी। पुचकू तो छुटकी सी थी, और पुस्तकों की अलमारी के वे खाने ऊँचे थे, \nउसकी पहुँच से कहीं बाहर।\nअब पुचकू पुस्तकों तक कैसे पहुँच पाएगी?","words":[[280,"मगर"],[281,"एक"],[282,"गड़़बड़़"],[283,"थी।"],[284,"पुचकू"],[285,"तो"],[286,"छुटकी"],[287,"सी"],[288,"थी,"],[289,"और"],[290,"पुस्तकों"],[291,"की"],[292,"अलमारी"],[293,"के"],[294,"वे"],[295,"खाने"],[296,"ऊँचे"],[297,"थे,"],[298,"उसकी"],[299,"पहुँच"],[300,"से"],[301,"कहीं"],[302,"बाहर।"],[303,"अब"],[304,"पुचकू"],[305,"पुस्तकों"],[306,"तक"],[307,"कैसे"],[308,"पहुँच"],[309,"पाएगी?"]]},{"n":12,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/54558/size6/bb44d1aa8aca2f59f82ea0558db172fc.jpg","text":"क्या वह रस्सी का उपयोग करे?\nया फिर माँ की साड़़ी के सहारे ऊपर चढ़़ जाए?\nऔर अगर वह कमरे में रखी \nकुर्सियों और मेज़ों का उपयोग करे तो?","words":[[310,"क्या"],[311,"वह"],[312,"रस्सी"],[313,"का"],[314,"उपयोग"],[315,"करे?"],[316,"या"],[317,"फिर"],[318,"माँ"],[319,"की"],[320,"साड़़ी"],[321,"के"],[322,"सहारे"],[323,"ऊपर"],[324,"चढ़़"],[325,"जाए?"],[326,"और"],[327,"अगर"],[328,"वह"],[329,"कमरे"],[330,"में"],[331,"रखी"],[332,"कुर्सियों"],[333,"और"],[334,"मेज़ों"],[335,"का"],[336,"उपयोग"],[337,"करे"],[338,"तो?"]]},{"n":13,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/53352/size6/769c2d9c63b51de785e54f95747c1bbe.jpg","text":"पुचकू ने सोचा अगर उसके पास एक जिराफ होता तो ये काम कितना आसान हो जाता। या कम से कम एक बन्दर।\nया फिर दोनों!","words":[[339,"पुचकू"],[340,"ने"],[341,"सोचा"],[342,"अगर"],[343,"उसके"],[344,"पास"],[345,"एक"],[346,"जिराफ"],[347,"होता"],[348,"तो"],[349,"ये"],[350,"काम"],[351,"कितना"],[352,"आसान"],[353,"हो"],[354,"जाता।"],[355,"या"],[356,"कम"],[357,"से"],[358,"कम"],[359,"एक"],[360,"बन्दर।"],[361,"या"],[362,"फिर"],[363,"दोनों!"]]},{"n":14,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/53353/size6/716b2cb7aaab755a0840782073899f91.jpg","text":"पुचकू को एक तरकीब सूझी। उसने बोल्टू और डोडला को मदद के लिए बुला लिया।\nचुपचाप, बिना कोई आवाज़ किये,\nसब एक के ऊपर एक चढ़़ गए।\n“बोल्टू, तू बड़़ा भारी है”, डोडला कुड़़कुड़़ाया, “मैंने तुझसे कहा था ना वह आखिरी रसगुल्ला मत खा।”\n“यह मैं नहीं,” बोल्टू फुसफुसाया, “यह पुचकू है।”\nपुचकू ने धीमे से कहा, \n“श..... श.... बस हो गया।”\nतभी, सब गड़़बड़़ हो गई।","words":[[364,"पुचकू"],[365,"को"],[366,"एक"],[367,"तरकीब"],[368,"सूझी।"],[369,"उसने"],[370,"बोल्टू"],[371,"और"],[372,"डोडला"],[373,"को"],[374,"मदद"],[375,"के"],[376,"लिए"],[377,"बुला"],[378,"लिया।"],[379,"चुपचाप,"],[380,"बिना"],[381,"कोई"],[382,"आवाज़"],[383,"किये,"],[384,"सब"],[385,"एक"],[386,"के"],[387,"ऊपर"],[388,"एक"],[389,"चढ़़"],[390,"गए।"],[391,"“बोल्टू,"],[392,"तू"],[393,"बड़़ा"],[394,"भारी"],[395,"है”,"],[396,"डोडला"],[397,"कुड़़कुड़़ाया,"],[398,"“मैंने"],[399,"तुझसे"],[400,"कहा"],[401,"था"],[402,"ना"],[403,"वह"],[404,"आखिरी"],[405,"रसगुल्ला"],[406,"मत"],[407,"खा।”"],[408,"“यह"],[409,"मैं"],[410,"नहीं,”"],[411,"बोल्टू"],[412,"फुसफुसाया,"],[413,"“यह"],[414,"पुचकू"],[415,"है।”"],[416,"पुचकू"],[417,"ने"],[418,"धीमे"],[419,"से"],[420,"कहा,"],[421,"“श....."],[422,"श...."],[423,"बस"],[424,"हो"],[425,"गया।”"],[426,"तभी"],[427,","],[428,"सब"],[429,"गड़़बड़़"],[430,"हो"],[431,"गई।"]]},{"n":15,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/53487/size6/865fa33cd3528aff3701e5880bbfd21d.jpg","text":"आ..... ह!","words":[[432,"आ"],[433,"....."],[435,"ह"],[436,"!"]]},{"n":16,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/53355/size6/4df9f70079471eb732a68eea7a20da54.jpg","text":"“क्या हो रहा है यहाँ?” बहुत ही लम्बी सी लाइब्रेरियन की आवाज़ गूँजी।\n           उसने पुचकू को धीरे से नीचे उतारा।\n           बोल्टू\nऔर डोडला नौ दो ग्यारह हो चुके थे।\n           पुचकू ने लगभग हाथ में आई किताब की ओर दु:खी होकर देखा।\n           “क्या मैं कुछ मदद करूँ?”, लम्बी लाइब्रेरियन ने कहा।","words":[[437,"“क्या"],[438,"हो"],[439,"रहा"],[440,"है"],[441,"यहाँ?”"],[442,"बहुत"],[443,"ही"],[444,"लम्बी"],[445,"सी"],[446,"लाइब्रेरियन"],[447,"की"],[448,"आवाज़"],[449,"गूँजी।"],[450,"उसने"],[451,"पुचकू"],[452,"को"],[453,"धीरे"],[454,"से"],[455,"नीचे"],[456,"उतारा।"],[457,"बोल्टू"],[458,"और"],[459,"डोडला"],[460,"नौ"],[461,"दो"],[462,"ग्यारह"],[463,"हो"],[464,"चुके"],[465,"थे।"],[466,"पुचकू"],[467,"ने"],[468,"लगभग"],[469,"हाथ"],[470,"में"],[471,"आई"],[472,"किताब"],[473,"की"],[474,"ओर"],[475,"दु:खी"],[476,"होकर"],[477,"देखा।"],[478,"“क्या"],[479,"मैं"],[480,"कुछ"],[481,"मदद"],[482,"करूँ?”,"],[483,"लम्बी"],[484,"लाइब्रेरियन"],[485,"ने"],[486,"कहा।"]]},{"n":17,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/53441/size6/547ef0695d53d421583602414c70f439.jpg","text":"“पुचकू ने रुआँसी होकर कहा, मैं तो बस \nअलमारी पर चढ़़ने की कोशिश कर रही थी, \nक्योंकि मेरे पास पढ़़ने के लिए किताबें ही नहीं बची हैं।”\n“तुमने मुझसे क्यों नहीं कहा?”, लम्बी लाइब्रेरियन बोली, \n“जब तक मैं यहाँ हूँ, तुम्हें अलमारी पर चढ़़ने की कोई ज़रुरत नहीं। \nक्या मैं तुम्हें ऊपर उठाऊँ?” पुचकू ने सर हिलाया।","words":[[487,"“पुचकू"],[488,"ने"],[489,"रुआँसी"],[490,"होकर"],[491,"कहा,"],[492,"मैं"],[493,"तो"],[494,"बस"],[495,"अलमारी"],[496,"पर"],[497,"चढ़़ने"],[498,"की"],[499,"कोशिश"],[500,"कर"],[501,"रही"],[502,"थी,"],[503,"क्योंकि"],[504,"मेरे"],[505,"पास"],[506,"पढ़़ने"],[507,"के"],[508,"लिए"],[509,"किताबें"],[510,"ही"],[511,"नहीं"],[512,"बची"],[513,"हैं।”"],[514,"“तुमने"],[515,"मुझसे"],[516,"क्यों"],[517,"नहीं"],[518,"कहा?”,"],[519,"लम्बी"],[520,"लाइब्रेरियन"],[521,"बोली,"],[522,"“जब"],[523,"तक"],[524,"मैं"],[525,"यहाँ"],[526,"हूँ,"],[527,"तुम्हें"],[528,"अलमारी"],[529,"पर"],[530,"चढ़़ने"],[531,"की"],[532,"कोई"],[533,"ज़रुरत"],[534,"नहीं।"],[535,"क्या"],[536,"मैं"],[537,"तुम्हें"],[538,"ऊपर"],[539,"उठाऊँ?”"],[540,"पुचकू"],[541,"ने"],[542,"सर"],[543,"हिलाया।"]]},{"n":18,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/53357/size6/731f661b3dec3cdf26220fdd3ba992ed.jpg","text":"पुचकू किताबें 