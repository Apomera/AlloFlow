,"to"],[39,"bowl."],[40,"And…"],[41,"you"],[42,"are"],[43,"OUT!"]]},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/79851/size6/f8f6ce4db1412cc86f58c0f3f83a1592.jpg","text":"Today, I am a botanist.","words":[[44,"Today,"],[45,"I"],[46,"am"],[47,"a"],[48,"botanist."]]},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/80013/size6/38eddd9f67af4042a5c6c59f27ccca51.jpg","text":"I’ve discovered a new plant. I’ll name it after myself.","words":[[49,"I’ve"],[50,"discovered"],[51,"a"],[52,"new"],[53,"plant."],[54,"I’ll"],[55,"name"],[56,"it"],[57,"after"],[58,"myself."]]},{"n":9,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/79853/size6/c60ae14f325211467333dd90f2dc3d5e.jpg","text":"Today, I am a drummer.","words":[[59,"Today,"],[60,"I"],[61,"am"],[62,"a"],[63,"drummer."]]},{"n":10,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/79854/size6/90ef5f7c7a184ec7371c2c1a6d410830.jpg","text":"Dhushh! Tsshh! My sticks are moving so fast, you cannot even see them.","words":[[64,"Dhushh!"],[65,"Tsshh!"],[66,"My"],[67,"sticks"],[68,"are"],[69,"moving"],[70,"so"],[71,"fast,"],[72,"you"],[73,"cannot"],[74,"even"],[75,"see"],[76,"them."]]},{"n":11,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/79855/size6/0296786590d7aa884ec45c3905f0245b.jpg","text":"Today, I am so many things.\nTomorrow, what will I be?","words":[[77,"Today,"],[78,"I"],[79,"am"],[80,"so"],[81,"many"],[82,"things."],[83,"Tomorrow,"],[84,"what"],[85,"will"],[86,"I"],[87,"be?"]]}],"stats":{"pages":11,"words":87}}