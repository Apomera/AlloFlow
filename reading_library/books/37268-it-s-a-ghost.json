.","words":[[1,"Once,"],[2,"there"],[3,"was"],[4,"a"],[5,"ghost."],[6,"He"],[7,"thought"],[8,"he"],[9,"was"],[10,"very"],[11,"scary."]]},{"n":2,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/70902/size6/f266dc746627e6b3054115542a5e2f16.jpg","text":"Every day, he tried to scare someone.","words":[[12,"Every"],[13,"day,"],[14,"he"],[15,"tried"],[16,"to"],[17,"scare"],[18,"someone."]]},{"n":3,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/70903/size6/7204f98cc1192c364f9407042e61f7a7.jpg","text":"One day, he frightened a savage lion.","words":[[19,"One"],[20,"day,"],[21,"he"],[22,"frightened"],[23,"a"],[24,"savage"],[25,"lion."]]},{"n":4,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/70904/size6/3d428710bd3fb2c0881cfdd0d6def40f.jpg","text":"Another day, a giant elephant.","words":[[26,"Another"],[27,"day,"],[28,"a"],[29,"giant"],[30,"elephant."]]},{"n":5,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/70905/size6/3cb007ab47b17c201f44a24d4e8aaad4.jpg","text":"The next day, a muscular wrestler.","words":[[31,"The"],[32,"next"],[33,"day,"],[34,"a"],[35,"muscular"],[36,"wrestler."]]},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/70906/size6/927bd83bcc8d65d7a7f8f253c600751c.jpg","text":"On another day, a police constable with a big moustache.","words":[[37,"On"],[38,"another"],[39,"day,"],[40,"a"],[41,"police"],[42,"constable"],[43,"with"],[44,"a"],[45,"big"],[46,"moustache."]]},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/70907/size6/46817fab2c01d9ac2f89e51a51d61a66.jpg","text":"He was fond of seeing people run away in fear.","words":[[47,"He"],[48,"was"],[49,"fond"],[50,"of"],[51,"seeing"],[52,"people"],[53,"run"],[54,"away"],[55,"in"],[56,"fear."]]},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/70908/size6/1d72826ceea492d8c755e23d6fd69d62.jpg","text":"He couldn’t sleep until he had scared someone.","words":[[57,"He"],[58,"couldn’t"],[59,"sleep"],[60,"until"],[61,"he"],[62,"had"],[63,"scared"],[64,"someone."]]},{"n":9,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/70909/size6/c2850d8e095e59166c9989f4b435e972.jpg","text":"One day, he fell sick. \nBut he still wanted to scare someone!","words":[[65,"One"],[66,"day,"],[67,"he"],[68,"fell"],[69,"sick."],[70,"But"],[71,"he"],[72,"still"],[73,"wanted"],[74,"to"],[75,"scare"],[76,"someone!"]]},{"n":10,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/70910/size6/c619c24f3050e319d75d4f248e64a398.jpg","text":"He thought of scaring a mouse as a mouse would be easy to scare.","words":[[77,"He"],[78,"thought"],[79,"of"],[80,"scaring"],[81,"a"],[82,"mouse"],[83,"as"],[84,"a"],[85,"mouse"],[86,"would"],[87,"be"],[88,"easy"],[89,"to"],[90,"scare."]]},{"n":11,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/70911/size6/438a5583ff6062cde21b6933a75b48cc.jpg","text":"He entered the mouse’s home deep into the night. \nMouse was sleeping peacefully.","words":[[91,"He"],[92,"entered"],[93,"the"],[94,"mouse’s"],[95,"home"],[96,"deep"],[97,"into"],[98,"the"],[99,"night."],[100,"Mouse"],[101,"was"],[102,"sleeping"],[103,"peacefully."]]},{"n":12,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/70912/size6/d00de9757a52a8ab7c3c42d294b7e1e5.jpg","text":"Dhhummm Dhhummm... walked the ghost. The mouse woke up.","words":[[104,"Dhhummm"],[105,"Dhhummm..."],[106,"walked"],[107,"the"],[108,"ghost."],[109,"The"],[110,"mouse"],[111,"woke"],[112,"up."]]},{"n":13,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/70913/size6/9b069924be3fafb9ef7f15869a33ba34.jpg","text":"He shivered in fear and stammered, “W..wh..who is there?”","words":[[113,"He"],[114,"shivered"],[115,"in"],[116,"fear"],[117,"and"],[118,"stammered,"],[119,"“W..wh..who"],[120,"is"],[121,"there?”"]]},{"n":14,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/85105/size6/1bd2895396868b850a38de641c9896c0.jpg","text":"The ghost said in his most frightening voice,\n“I…. AM…. A…. GHOST!”","words":[[122,"The"],[123,"ghost"],[124,"said"],[125,"in"],[126,"his"],[127,"most"],[128,"frightening"],[129,"voice,"],[130,"“I…."],[131,"AM…."],[132,"A…."],[133,"GHOST!”"]]},{"n":15,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/70914/size6/eaa4b78095c1be9091ce64efe57128ff.jpg","text":"Mouse said, “Oh! It’s a ghost. I thought it was a cat.”","words":[[134,"Mouse"],[135,"said,"],[136,"“Oh!"],[137,"It’s"],[138,"a"],[139,"ghost."],[140,"I"],[141,"thought"],[142,"it"],[143,"was"],[144,"a"],[145,"cat.”"]]},{"n":16,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/70915/size6/7d10511438aaaffc81b499d7b4e600e3.jpg","text":"The mouse pulled a blanket over his head and went back to sleep.","words":[[146,"The"],[147,"mouse"],[148,"pulled"],[149,"a"],[150,"blanket"],[151,"over"],[152,"his"],[153,"head"],[154,"and"],[155,"went"],[156,"back"],[157,"to"],[158,"sleep."]]}],"stats":{"pages":16,"words":158}}