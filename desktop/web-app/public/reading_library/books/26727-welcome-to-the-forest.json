,"announces"],[554,"a"],[555,"surprise."],[556,"“Some"],[557,"of"],[558,"our"],[559,"camp"],[560,"elephants"],[561,"are"],[562,"here."],[563,"They"],[564,"won’t"],[565,"mind"],[566,"if"],[567,"you"],[568,"touch"],[569,"them"],[570,"gently.”"],[571,"Everyone"],[572,"starts"],[573,"squealing"],[574,"in"],[575,"delight."],[576,"Soon"],[577,"Tulsa"],[578,"is"],[579,"led"],[580,"to"],[581,"the"],[582,"elephant,"],[583,"Tara."]]},{"n":16,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/56812/size6/81ca201da7986e8376eed1b1a030651b.jpg","text":"The guide places her hand on Tara’s prickly stomach. Whoomp! Tulsa hears the sound of Tara’s feet moving. Tulsa can feel the powerful muscles under her hand. Trumpeting softly, Tara places her trunk in Tulsa’s hand, looking for food. Tulsa can’t stop smiling, as she feels the wet trunk. \nIt's time to go back. On the way, they pass a gaur. “The gaur is chewing grass. The body is black but the bottoms of the legs are white. It looks like the gaur is wearing socks,” says Ranveer Uncle. Everyone laughs. Suddenly, the air is split by a call, deep and loud.","words":[[584,"The"],[585,"guide"],[586,"places"],[587,"her"],[588,"hand"],[589,"on"],[590,"Tara’s"],[591,"prickly"],[592,"stomach."],[593,"Whoomp!"],[594,"Tulsa"],[595,"hears"],[596,"the"],[597,"sound"],[598,"of"],[599,"Tara’s"],[600,"feet"],[601,"moving."],[602,"Tulsa"],[603,"can"],[604,"feel"],[605,"the"],[606,"powerful"],[607,"muscles"],[608,"under"],[609,"her"],[610,"hand."],[611,"Trumpeting"],[612,"softly,"],[613,"Tara"],[614,"places"],[615,"her"],[616,"trunk"],[617,"in"],[618,"Tulsa’s"],[619,"hand,"],[620,"looking"],[621,"for"],[622,"food."],[623,"Tulsa"],[624,"can’t"],[625,"stop"],[626,"smiling,"],[627,"as"],[628,"she"],[629,"feels"],[630,"the"],[631,"wet"],[632,"trunk."],[633,"It's"],[634,"time"],[635,"to"],[636,"go"],[637,"back."],[638,"On"],[639,"the"],[640,"way,"],[641,"they"],[642,"pass"],[643,"a"],[644,"gaur."],[645,"“The"],[646,"gaur"],