<button aria-label="Open Guanlong" style="font-size:11px;padding:3px 9px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Guanlong</button>
<button aria-label="Open Ornitholestes" style="font-size:11px;padding:3px 9px;border-radius:999px;cursor:pointer;border:1px solid var(--allo-stem-border, #334155);background:var(--allo-stem-deeper, #0b1220);color:var(--allo-stem-text, #f1f5f9)">Ornitholestes</button>
