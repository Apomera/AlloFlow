r.org.in/illustration_crops/4095/size6/97f1e8add4f0a185b5782dc6dc730447.jpg","text":"فِي يَوْمٍ مِنَ الْأَيَّامِ، سَأَلَتْهُ الْبَقَرَةُ لبنى: \"جبار، لِمَاذَا أَنْتَ حَزِينٌ جِدًّا\"؟\nقَالَ جبار: \"لَا يُمْكِنُنِي الِاسْتِيقَاظُ مُبَكِّرًا، وَ مالك يَصْرُخُ فِي وَجْهِي كُلَّ يَوْمٍ. هَلْ يُمْكِنُكِ أَنْ تُوقِظِينِي كُلَّ صَبَاحٍ، أَرْجُوكِ\"؟\nقَالَتْ لبنى: \"نَعَمْ، سَأَفْعَلُ\". فِي الصَّبَاحِ التَّالِي، قَامَتْ لبنى بِالْخُوَارِ بِصَوْتٍ عَالٍ، لَكِنَّ بَهِيمَا لَمْ يَسْتَيْقِظْ!","words":[[17,"فِي"],[18,"يَوْمٍ"],[19,"مِنَ"],[20,"الْأَيَّامِ،"],[21,"سَأَلَتْهُ"],[22,"الْبَقَرَةُ"],[23,"لبنى:"],[24,"\"جبار،"],[25,"لِمَاذَا"],[26,"أَنْتَ"],[27,"حَزِينٌ"],[28,"جِدًّا\"؟"],[29,"قَالَ"],[30,"جبار:"],[31,"\"لَا"],[32,"يُمْكِنُنِي"],[33,"الِاسْتِيقَاظُ"],[34,"مُبَكِّرًا،"],[35,"وَ"],[36,"مالك"],[37,"يَصْرُخُ"],[38,"فِي"],[39,"وَجْهِي"],[40,"كُلَّ"],[41,"يَوْمٍ."],[42,"هَلْ"],[43,"يُمْكِنُكِ"],[44,"أَنْ"],[45,"تُوقِظِينِي"],[46,"كُلَّ"],[47,"صَبَاحٍ،"],[48,"أَرْجُوكِ\"؟"],[49,"قَالَتْ"],[50,"لبنى:"],[51,"\"نَعَمْ،"],[52,"سَأَفْعَلُ\"."],[53,"فِي"],[54,"الصَّبَاحِ"],[55,"التَّالِي،"],[56,"قَامَتْ"],[57,"لبنى"],[58,"بِالْخُوَارِ"],[59,"بِصَوْتٍ"],[60,"عَالٍ،"],[61,"لَكِنَّ"],[62,"بَهِيمَا"],[63,"لَمْ"],[64,"يَسْتَيْقِظْ!"]]},{"n":3,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/4096/size6/5726375eee7880f4c8591519857b9523.jpg","text":"الْتَقَى جبار الْكَلْبَ كريم عِنْدَمَا كَانَ عَائِدًا مِنَ النَّهْرِ فِي الْمَسَاءِ.\nجبار سَأَلَ كريم: \"لَا يُمْكِنُنِي الِاسْتِيقَاظُ مُبَكِّرًا فِي الْوَقْتِ الْمُحَدَّدِ، هَلَّا أَيْقَظْتَنِي\"؟\nقَالَ كريم: \"نَعَمْ، سَأَفْعَلُ\". وَفِي الصَّبَاحِ التَّالِي قَامَ بِالنُّبَاحِ وَالنُّبَاحِ، لَكِنْ هَلِ اسْتَيْقَظَ جبار؟ لَا يَا سَيِّدِي!","words":[[65,"الْتَقَى"],[66,"جبار"],[67,"الْكَلْبَ"],[68,"كريم"],[69,"عِنْدَمَا"],[70,"كَانَ"],[71,"عَائِدًا"],[72,"مِنَ"],[73,"النَّهْرِ"],[74,"فِي"],[75,"الْمَسَاءِ."],[76,"جبار"],[77,"سَأَلَ"],[78,"كريم:"],[79,"\"لَا"],[80,"يُمْكِنُنِي"],[81,"الِاسْتِيقَاظُ"],[8