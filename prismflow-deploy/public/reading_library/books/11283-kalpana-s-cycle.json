..","words":[[89,"All"],[90,"the"],[91,"children"],[92,"from"],[93,"their"],[94,"area"],[95,"went"],[96,"to"],[97,"play"],[98,"there."],[99,"On"],[100,"the"],[101,"first"],[102,"day,"],[103,"Kalpana"],[104,"couldn’t"],[105,"wait"],[106,"to"],[107,"start."],[108,"But..."]]},{"n":5,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/32652/size6/6c4d108524e227f5d997461b7c1ce651.jpg","text":"DUMMMMMM! \nKalpana fell to\nthe ground.\nHer knees were on fire. She\ndidn’t want to cry.\nBut she did. Great, big sobs\nescaped from her mouth.","words":[[109,"DUMMMMMM!"],[110,"Kalpana"],[111,"fell"],[112,"to"],[113,"the"],[114,"ground."],[115,"Her"],[116,"knees"],[117,"were"],[118,"on"],[119,"fire."],[120,"She"],[121,"didn’t"],[122,"want"],[123,"to"],[124,"cry."],[125,"But"],[126,"she"],[127,"did."],[128,"Great,"],[129,"big"],[130,"sobs"],[131,"escaped"],[132,"from"],[133,"her"],[134,"mouth."]]},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/32663/size6/cf20f113bf2338d35bdde98fa1fccc24.jpg","text":"Her ears felt hot. She could\nhear the boys laughing.\nKalpana got up and ran home.\nShe left the cycle where it was.\nPrabhu\nwould ride it back. He knew how to.\nAfter he was done playing\ncricket with his friends.\nAfter the sun had set.\nAfter Appa was home from the\nmechanic shop.","words":[[135,"Her"],[136,"ears"],[137,"felt"],[138,"hot."],[139,"She"],[140,"could"],[141,"hear"],[142,"the"],[143,"boys"],[144,"laughing."],[145,"Kalpana"],[146,"got"],[147,"up"],[148,"and"],[149,"ran"],[150,"home."],[151,"She"],[152,"left"],[153,"the"],[154,"cycle"],[155,"where"],[156,"it"],[157,"was."],[158,"Prabhu"],[159,"would"],[160,"ride"],[161,"it"],[162,"back."],[163,"He"],[164,"knew"],[165,"how"],[166,"to."],[167,"After"],[168,"he"],[169,"was"],[170,"done"],[171,"playing"],[172,"cricket"],[173,"with"],[174,"his"],[175,"friends."],[176,"After"],[177,"the"],[178,"sun"],[179,"had"],[180,"set."],[181,"After"],[182,"Appa"],