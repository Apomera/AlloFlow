<input type="text" placeholder="e.g. wash hands" aria-label="Symbol label" style="width:100%;border:1px solid #d1d5db;border-radius:6px;padding:7px 9px;font-size:13px;box-sizing:border-box;font-family:inherit;background:#fff;color:inherit" autofocus="" value=""/>
</div>
<div>
