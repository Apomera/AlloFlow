{"schema":"allo-reading-book@1","slug":"229018-madinati-walkilab","title":"مَدِينَتِي... وَالْكِلَابُ","description":"تَعَرَّفْ فِي هَذِهِ الْقِصَّةِ عَلَى كِلَابِ الشَّوَارِعِ الشَّهِيرَةِ فِي مَدِينَةِ مُومْبَايْ؛ فَجَمِيعُ الطُّرُقَاتِ مَلَاعِبُ لَهَا، وَتَبْدُو كَمَا لَوْ أَنَّهَا تَسْتَحْوِذُ عَلَى الْمَدِينَةِ بِأَكْمَلِهَا، بَلْ وَالنَّاسِ أَيْضًا. تَمَّ تَصْمِيمُ الصُّوَرِ الْمُسْتَخْدَمَةِ فِي هَذَا الْكِتَابِ بِالدَّمْجِ بَيْنَ الرُّسُومِ التَّوْضِيحِيَّةِ وَالصُّوَرِ الْفُوتُوغْرَافِيَّةِ. الرُّسُومُ مِنْ إِبْدَاعِ سُومِيدَا سَاهْ، وَالصُّوَرُ بِعَدَسَةِ هَاشِمْ بَدَانِي.","language":"Arabic","langCode":"ar","isRtl":true,"level":"2","orientation":"landscape","authors":["Faten Ashour"],"illustrators":["Hashim Badani","Sumedha Sah"],"originalAuthors":[],"publisher":"Education Above All (EAA)","license":"CC BY 4.0","licenseUrl":"https://creativecommons.org/licenses/by/4.0/","sourceId":"storyweaver","contentType":"story","source":{"id":"storyweaver","name":"StoryWeaver, Pratham Books","url":"https://storyweaver.org.in/en/stories/229018-madinati-walkilab"},"cover":{"card":"https://static.storyweaver.org.in/illustration_crops/726564/size3/99ac9080d52ee336b888f95df4f3ac71.jpg","large":"https://static.storyweaver.org.in/illustration_crops/726564/size6/99ac9080d52ee336b888f95df4f3ac71.jpg"},"audio":{"src":"https://storage.googleapis.com/story-weaver-e2e-production/stories/229018/audios/story/229018-madinati-walkilab.mp3","cues":[[1,0,2.04],[2,2.04,2.26],[3,2.26,2.88],[4,2.88,3.88],[5,3.88,4.53],[6,4.53,4.9],[7,4.9,5.48],[8,5.48,6.32],[9,6.32,6.88],[10,6.88,8.34],[11,8.34,8.98],[12,8.98,9.44],[13,9.44,9.98],[14,9.98,10.52],[15,10.52,10.92],[16,10.92,11.48],[17,11.48,12.44],[18,12.44,12.68],[19,12.68,13.24],[20,13.24,13.44],[21,13.44,16.06],[22,16.06,16.54],[23,16.54,16.98],[24,16.98,17.26],[25,17.26,17.82],[26,17.82,18.3],[27,18.3,19.04],[28,19.04,19.84],[29,19.84,20.32],[30,20.32,20.68],[31,20.68,23.92],[32,23.92,24.64],[33,24.64,25.65],[34,25.65,26.46],[35,26.46,