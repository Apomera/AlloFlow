कीड़ा"],[17,"अपनी"],[18,"चोंच"],[19,"में!"]]},{"n":2,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/58439/size6/b7f72bcd3edfa61074cae8e504cdc384.jpg","text":"3/23","words":null},{"n":3,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/58775/size6/249b5a7e0da8e234eaaf21cb6305e8a0.jpg","text":"रंग-बिरंगी तितलियाँ उड़ रहीं\nमंडराती सुंदर दिख रहीं\nउसे खोजो जो लगे नवेली सी\nएक ही रंग में रंगी हुई सी!","words":[[20,"रंग-बिरंगी"],[21,"तितलियाँ"],[22,"उड़"],[23,"रहीं"],[24,"मंडराती"],[25,"सुंदर"],[26,"दिख"],[27,"रहीं"],[28,"उसे"],[29,"खोजो"],[30,"जो"],[31,"लगे"],[32,"नवेली"],[33,"सी"],[34,"एक"],[35,"ही"],[36,"रंग"],[37,"में"],[38,"रंगी"],[39,"हुई"],[40,"सी!"]]},{"n":4,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/58440/size6/b75257a2d8e32cbd7ded615f88b043f0.jpg","text":"5/23","words":null},{"n":5,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/58416/size6/79101d77b5b8d20dd443ee03b1160161.jpg","text":"झुंड में हँसमुख\nपतंगें उड़\nरहीं\nझूमतीं ख़ुशी ख़ुशी घूम रहीं\nपर एक उनमें से कुछ अलग दीखें\nज़रा आप भी गौर से देखें!","words":[[41,"झुंड"],[42,"में"],[43,"हँसमुख"],[44,"पतंगें"],[45,"उड़"],[46,"रहीं"],[47,"झूमतीं"],[48,"ख़ुशी"],[49,"ख़ुशी"],[50,"घूम"],[51,"रहीं"],[52,"पर"],[53,"एक"],[54,"उनमें"],[55,"से"],[56,"कुछ"],[57,"अलग"],[58,"दीखें"],[59,"ज़रा"],[60,"आप"],[61,"भी"],[62,"गौर"],[63,"से"],[64,"देखें!"]]},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/58441/size6/1de7fde397f495b8330bb134ad565329.jpg","text":"7/23","words":null},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/58417/size6/92be7a9825846259c6632ac89e40ae77.jpg","text":"बड़े और छोटे चौकोर\nखाने\nइसी अकार के ताने बाने\nएक जंगला कुछ \nअलग सा है\nकहाँ छिपा वह यहाँ या वहाँ?","words":[[65,"बड़े"],[66,"और"],[67,"छोटे"],[68,"चौकोर"],[69,"खाने"],[70,"इसी"],[71,"अकार"],[72,"के"],[73,"ताने"],[74,"बाने"],[75,"एक"],[76,"जंगला"],[77,"कुछ"],[78,"अलग"],[79,"सा"],[80,"है"],[81,"कहाँ"],[82,"छिपा"],[83,"वह"],[84,"यहाँ"],[85,"या"],[86,"वहाँ?"]]},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/58442/size6/cd5d459877df1aa2afdbf62b98738622.jpg","text":"9/23","words":null},{"n":9,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/58776/size6/14ec86ac3abb2524bd9f4dbd5250e2a9.jpg","text":"हरे पत्तों के बीच में झाँको!\nइस बड़े, पुराने\nपेड़ को देखो।\nरंगों के छींटे वाली इक डाल \n ढूँढिए ज़रा आप सम्भाल-सम्भाल।","words":[[87,"हरे"],[88,"पत्तों"],[89,"के"],[90,"बीच"],[91,"में"],[92,"झाँको!"],[93,"इस"],[94,"बड़े,"],[95,"पुराने"],[96,"पेड़"],[97,"को"],[98,"देखो।"],[99,"रंगों"],[100,"के"],[101,"छींटे"],[102,"वाली"],[103,"इक"],[104,"डाल"],[105,"ढूँढिए"],[106,"ज़रा"],[107,"आप"],[108,"सम्भाल-सम्भाल।"]]},{"n":10,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/58443/size6/dc20e286430fba9158773cd273a99ff8.jpg","text":"11/23","words":null},{"n":11,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/58420/size6/ece4d86dfab2853deaa87f25328ff863.jpg","text":"आसमान में जहाज़ उड़ रहे\nएक सीधा निशान पीछे छोड़ रहे\nपर उनमें\nसे एक, कुछ\nअलग है \nयह घुमावदार पूँछ बना रहा है।","words":[[109,"आसमान"],[110,"में"],[111,"जहाज़"],[112,"उड़"],[113,"रहे"],[114,"एक"],[115,"सीधा"],[116,"निशान"],[117,"पीछे"],[118,"छोड़"],[119,"रहे"],[120,"पर"],[121,"उनमें"],[122,"से"],[123,"एक,"],[124,"कुछ"],[125,"अलग"],[126,"है"],[127,"यह"],[128,"घुमावदार"],[129,"पूँछ"],[130,"बना"],[131,"रहा"],[132,"है।"]]},{"n":12,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/58444/size6/9e8baab82c42021785a9a052fd511670.jpg","text":"13/23","words":null},{"n":13,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/58421/size6/6bba366ae51123b025be9b4a03287cfe.jpg","text":"चहचहाते पँछी क़तार में हैं बैठे\nदेखिए ज़रा कैसे हैं एंठे!\nपर उनमें से एक चुप रहना चाहे \nकौन सा है, क्यों मौन है धारे?","words":[[133,"चहचहाते"],[134,"पँछी"],[135,"क़तार"],[136,"में"],[137,"हैं"],[138,"बैठे"],[139,"देखिए"],[140,"ज़रा"],[141,"कैसे"],[142,"हैं"],[143,"एंठे!"],[144,"पर"],[145,"उनमें"],[146,"से"],[147,"एक"],[148,"चुप"],[149,"रहना"],[150,"चाहे"],[151,"कौन"],[152,"सा"],[153,"है,"],[154,"क्यों"],[155,"मौन"],[156,"है"],[157,"धारे?"]]},{"n":14,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/58445/size6/abb8ea69be8b916b45a0b29467c0be08.jpg","text":"15/23","words":null},{"n":15,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/58422/size6/7400b185cf41891711ee6a39846fdf8f.jpg","text":"उजले बादल चमक रहे हैं,\nनीले आकाश की ओट लिए।\nपर उनमें से एक बरसना चाहे, \nबिना किसी की परवाह किए।","words":[[158,"उजले"],[159,"बादल"],[160,"चमक"],[161,"रहे"],[162,"हैं,"],[163,"नीले"],[164,"आकाश"],[165,"की"],[166,"ओट"],[167,"लिए।"],[168,"पर"],[169,"उनमें"],[170,"से"],[171,"एक"],[172,"बरसना"],[173,"चाहे,"],[174,"बिना"],[175,"किसी"],[176,"की"],[177,"परवाह"],[178,"किए।"]]},{"n":16,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/58446/size6/a89eda17e10386d1e9e9c64213528b14.jpg","text":"17/23","words":null},{"n":17,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/58423/size6/daeb7a5636c2e5bcb372598dbf8599e1.jpg","text":"एक लम्बा दिन\nबीता बस\nअभी\nरात शुरू हुई तभी-तभी।\nगली की सभी बत्तियों में गुपचुप \nखोजिए उसे चमक रहा जो सूरज सा चुपचुप।","words":[[179,"एक"],[180,"लम्बा"],[181,"दिन"],[182,"बीता"],[183,"बस"],[184,"अभी"],[185,"रात"],[186,"शुरू"],[187,"हुई"],[188,"तभी-तभी।"],[189,"गली"],[190,"की"],[191,"सभी"],[192,"बत्तियों"],[193,"में"],[194,"गुपचुप"],[195,"खोजिए"],[196,"उसे"],[197,"चमक"],[198,"रहा"],[199,"जो"],[200,"सूरज"],[201,"सा"],[202,"चुपचुप।"]]},{"n":18,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/58447/size6/ba57fdfdd97a63076d7c6ea37f27bcfb.jpg","text":"19/23","words":null},{"n":19,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/58424/size6/741ec2c4843ebfeed91476980747fd20.jpg","text":"सूरज निकले तो सोता है चमगादड़\nऔर जगता तब, जब होती है रात।\nक्या खोज पाएंगे\nउस अजीब को? \nहै रात में उल्टा\n, यह क्या हुई बात।","words":[[203,"सूरज"],[204,"निकले"],[205,"तो"],[206,"सोता"],[207,"है"],[208,"चमगादड़"],[209,"और"],[210,"जगता"],[211,"तब,"],[212,"जब"],[213,"होती"],[214,"है"],[215,"रात।"],[216,"क्या"],[217,"खोज"],[218,"पाएंगे"],[219,"उस"],[220,"अजीब"],[221,"को?"],[222,"है"],[223,"रात"],[224,"में"],[225,"उल्टा"],[226,","],[227,"यह"],[228,"क्या"],[229,"हुई"],[230,"बात।"]]},{"n":20,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/58448/size6/45567e9fdba562f8d5be653cabb257b8.jpg","text":"21/23","words":null},{"n":21,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/58425/size6/f7c91870e9bad05ef2da7eeca56c9753.jpg","text":"अन्तरिक्ष में कई ग्रह हैं\nउनमें जगमगाहट का डेरा है।\nढूँढिए, उनमें से एक जो निराला है \nक्योंकि उसके चारों ओर एक घेरा है।","words":[[231,"अन्तरिक्ष"],[232,"में"],[233,"कई"],[234,"ग्रह"],[235,"हैं"],[236,"उनमें"],[237,"जगमगाहट"],[238,"का"],[239,"डेरा"],[240,"है।"],[241,"ढूँढिए,"],[242,"उनमें"],[243,"से"],[244,"एक"],[245,"जो"],[246,"निराला"],[247,"है"],[248,"क्योंकि"],[249,"उसके"],[250,"चारों"],[251,"ओर"],[252,"एक"],[253,"घेरा"],[254,"है।"]]},{"n":22,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/58450/size6/0fcc216029c652a8f0ccb9ad98fbe591.jpg","text":"23/23","words":null}],"stats":{"pages":22,"words":265}}