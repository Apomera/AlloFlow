ing bigger.”","words":[[96,"The"],[97,"leaves"],[98,"are"],[99,"too"],[100,"tiny."],[101,"“Too"],[102,"small"],[103,"to"],[104,"even"],[105,"cover"],[106,"an"],[107,"ant,”"],[108,"thinks"],[109,"Druvi."],[110,"“I"],[111,"need"],[112,"something"],[113,"bigger.”"]]},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/56292/size6/7b2c3f28a1cb592ebeb28ba33f32f11b.jpg","text":"Druvi sees big, star-shaped leaves.\n“The Papaya tree leaves would make a lovely umbrella,” thinks Druvi. “Oh no, it is letting all the rain in.”","words":[[114,"Druvi"],[115,"sees"],[116,"big,"],[117,"star-shaped"],[118,"leaves."],[119,"“The"],[120,"Papaya"],[121,"tree"],[122,"leaves"],[123,"would"],[124,"make"],[125,"a"],[126,"lovely"],[127,"umbrella,”"],[128,"thinks"],[129,"Druvi."],[130,"“Oh"],[131,"no,"],[132,"it"],[133,"is"],[134,"letting"],[135,"all"],[136,"the"],[137,"rain"],[138,"in.”"]]},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/56293/size6/d8c7b721cf67e77d56ab25c2c55bf851.jpg","text":"The wind blows strong but Druvi has still not found her umbrella.\nShe perches under a plant but the thin leaves fold up!\n“How unkind you are,” Druvi says to the Touch-Me-Not plant.","words":[[139,"T"],[140,"he"],[141,"wind"],[142,"blows"],[143,"strong"],[144,"but"],[145,"Druvi"],[146,"has"],[147,"still"],[148,"not"],[149,"found"],[150,"her"],[151,"umbrella."],[152,"She"],[153,"perches"],[154,"under"],[155,"a"],[156,"plant"],[157,"but"],[158,"the"],[159,"thin"],[160,"leaves"],[161,"fold"],[162,"up!"],[163,"“How"],[164,"unkind"],[165,"you"],[166,"are,”"],[167,"Druvi"],[168,"says"],[169,"to"],[170,"the"],[171,"Touch-Me-Not"],[172,"plant."]]},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/56294/size6/4f85da00aaca20b377bb64a06deb9ceb.jpg","text":"Druvi is upset. The jungle is full of leaves.\nThere are thin leaves and fat ones, big ones and small ones.\nBut none are umbrella leaves.","words":[[173,"Druvi"],[174,"is"],[175,"upset."],[176,"The"],[177,"jungle"],[178,"is"],[179,"full"],[180,"of"],[181,"leaves."],[182,"There"],[183,"are"],[184,"thin"],[185,"leaves"],[186,"and"],[187,"fat"],[188,"ones,"],[189,"big"],[190,"ones"],[191,"and"],[192,"small"],[193,"ones."],[194,"But"],[195,"none"],[196,"are"],[197,"umbrella"],[198,"leaves."]]},{"n":9,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/56295/size6/9ffb5fd5b56781cae61af9f640ed277e.jpg","text":"Suddenly Druvi sees a Banyan tree.\nIt does not have star-shaped leaves or prickly leaves.\nThe leaves are not too heavy or too small.","words":[[199,"Suddenly"],[200,"Druvi"],[201,"sees"],[202,"a"],[203,"Banyan"],[204,"tree."],[205,"It"],[206,"does"],[207,"not"],[208,"have"],[209,"star-shaped"],[210,"leaves"],[211,"or"],[212,"prickly"],[213,"leaves."],[214,"The"],[215,"leaves"],[216,"are"],[217,"not"],[218,"too"],[219,"heavy"],[220,"or"],[221,"too"],[222,"small."]]},{"n":10,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/56296/size6/77b2c72d6314b6be135d3c493e3767c8.jpg","text":"Druvi flies towards the Banyan tree.\nShe perches under the leaf.\nShe has found her umbrella!","words":[[223,"Druvi"],[224,"flies"],[225,"towards"],[226,"the"],[227,"Banyan"],[228,"tree."],[229,"She"],[230,"perches"],[231,"under"],[232,"the"],[233,"leaf."],[234,"She"],[235,"has"],[236,"found"],[237,"her"],[238,"umbrella!"]]},{"n":11,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/56297/size6/73b0734219e7130eac4e46348a261558.jpg","text":"More about dragonflies\nDragonflies are great travellers! Some dragonflies – like the \nWandering Glider that we find in our fields and gardens – \ntravel across the open seas from India to Africa. They travel \nmore than 16,000 kilometres to cross the Indian Ocean. \nThey start their journey from India in October and reach \ncountries like Tanzania in January. On the way,\nthey stop at islands like the Maldives and Seychelles.\nDragonflies cannot fly if they are too hot or too cold. \nIn the morning, they spread their wings to \nget heat from the sun. In the afternoon, some \ndragonflies perch with their body raised and \ntheir stomach pointing to the sun, to stay cool.","words":[[239,"More"],[240,"about"],[241,"dragonflies"],[242,"Dragonflies"],[243,"are"],[244,"great"],[245,"travellers!"],[246,"Some"],[247,"dragonflies"],[248,"–"],[249,"like"],[250,"the"],[251,"Wandering"],[252,"Glider"],[253,"that"],[254,"we"],[255,"find"],[256,"in"],[257,"our"],[258,"fields"],[259,"and"],[260,"gardens"],[261,"–"],[262,"travel"],[263,"across"],[264,"the"],[265,"open"],[266,"seas"],[267,"from"],[268,"India"],[269,"to"],[270,"Africa."],[271,"They"],[272,"travel"],[273,"more"],[274,"than"],[275,"16,000"],[276,"kilometres"],[277,"to"],[278,"cross"],[279,"the"],[280,"Indian"],[281,"Ocean."],[282,"They"],[283,"start"],[284,"their"],[285,"journey"],[286,"from"],[287,"India"],[288,"in"],[289,"October"],[290,"and"],[291,"reach"],[292,"countries"],[293,"like"],[294,"Tanzania"],[295,"in"],[296,"January."],[297,"On"],[298,"the"],[299,"way,"],[300,"they"],[301,"stop"],[302,"at"],[303,"islands"],[304,"like"],[305,"the"],[306,"Maldives"],[307,"and"],[308,"Seychelles."],[309,"Dragonflies"],[310,"cannot"],[311,"fly"],[312,"if"],[313,"they"],[314,"are"],[315,"too"],[316,"hot"],[317,"or"],[318,"too"],[319,"cold."],[320,"In"],[321,"the"],[322,"morning,"],[323,"they"],[324,"spread"],[325,"their"],[326,"wings"],[327,"to"],[328,"get"],[329,"heat"],[330,"from"],[331,"the"],[332,"sun."],[333,"In"],[334,"the"],[335,"afternoon,"],[336,"some"],[337,"dragonflies"],[338,"perch"],[339,"with"],[340,"their"],[341,"body"],[342,"raised"],[343,"and"],[344,"their"],[345,"stomach"],[346,"pointing"],[347,"to"],[348,"the"],[349,"sun,"],[350,"to"],[351,"stay"],[352,"cool."]]}],"stats":{"pages":11,"words":351}}