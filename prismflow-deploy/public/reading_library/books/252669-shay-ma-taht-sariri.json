,[26,"أَفْعَلَ؟"]]},{"n":4,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/12810/size6/26491dcc39e2989073786c1446ae23d7.jpg","text":"هَلْ أُنَادِي أُمِّي؟ مَاذَا لَوْ بَدَأَ النَّمِرُ فِي الْهَرِيرِ؟","words":[[27,"هَلْ"],[28,"أُنَادِي"],[29,"أُمِّي؟"],[30,"مَاذَا"],[31,"لَوْ"],[32,"بَدَأَ"],[33,"النَّمِرُ"],[34,"فِي"],[35,"الْهَرِيرِ؟"]]},{"n":5,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/12811/size6/1dc9e080cb1f1da3540e1a5856872b50.jpg","text":"هَلْ يَجِبُ أَنْ أَعُودَ لِلنَّوْمِ؟ لَكِنَّنِي لَمْ أَعُدْ أَشْعُرُ بِالنُّعَاسِ.","words":[[36,"هَلْ"],[37,"يَجِبُ"],[38,"أَنْ"],[39,"أَعُودَ"],[40,"لِلنَّوْمِ؟"],[41,"لَكِنَّنِي"],[42,"لَمْ"],[43,"أَعُدْ"],[44,"أَشْعُرُ"],[45,"بِالنُّعَاسِ."]]},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/12812/size6/bcc4b54374451efc0e2ffb921f11dd1f.jpg","text":"فَجْأَةً أَضَاءَ أَحَدُهُمْ نُورَ الْغُرْفَةِ. إِنَّهَا أُمِّي وَاقِفَةٌ عِنْدَ الْبَابِ.","words":[[46,"فَجْأَةً"],[47,"أَضَاءَ"],[48,"أَحَدُهُمْ"],[49,"نُورَ"],[50,"الْغُرْفَةِ."],[51,"إِنَّهَا"],[52,"أُمِّي"],[53,"وَاقِفَةٌ"],[54,"عِنْدَ"],[55,"الْبَابِ."]]},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/12813/size6/0c279bb8986760ac853b11e8af9003a3.jpg","text":"قَالَتْ أُمِّي: \"مَاذَا بِكَ يَا صَغِيرِي؟ هَلْ نَادَيْتَنِي\"؟","words":[[56,"قَالَتْ"],[57,"أُمِّي:"],[58,"\"مَاذَا"],[59,"بِكَ"],[60,"يَا"],[61,"صَغِيرِي؟"],[62,"هَلْ"],[63,"نَادَيْتَنِي\"؟"]]},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/12814/size6/d828c5e484809073adddd6fc68b180f6.jpg","text":"أ\nأَشَرْتُ نَحْوَ النَّمِرِ.\nأَلْقَتْ أُمِّي نَظْرَةً وَسَحَبَتِ النَّمِرَ مِنْ تَحْتِ السَّرِيرِ!","words":[[64,"أ"],[65,"أَشَرْتُ"],[66,"نَحْوَ"],[67,"النَّمِرِ."],[68,"أَلْقَتْ"],[69,"أُمِّي"],[70,"نَظْرَةً"],[71,"وَسَحَبَتِ"],[72,"النَّمِرَ"],[73,"مِنْ"],[74,"تَحْتِ"],[75,"السَّرِيرِ!"]]},{"n":9,"img":"https://stora