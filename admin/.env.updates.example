# AlloFlow Update Server Configuration

# Update channels
TEST_CHANNEL=test
PRODUCTION_CHANNEL=production

# Update server URLs
# Replace with your actual server URLs
TEST_UPDATE_SERVER=http://test-updates.alloflow.local/test
PRODUCTION_UPDATE_SERVER=https://updates.alloflow.com/production

# For local testing (use http-server or python)
LOCAL_UPDATE_SERVER=http://localhost:8080

# GitHub Releases (alternative to custom server)
# GITHUB_OWNER=yourusername
# GITHUB_REPO=AlloFlow
# GH_TOKEN=your_github_token

# Code signing (optional, but recommended for production)
# Windows
# CSC_LINK=/path/to/certificate.pfx
# CSC_KEY_PASSWORD=certificate_password

# macOS
# CSC_NAME="Developer ID Application: Your Name (TEAM_ID)"
# APPLE_ID=your@email.com
# APPLE_ID_PASSWORD=app-specific-password

# Build configuration
AUTO_UPDATE=true
CHECK_ON_STARTUP=true
AUTO_DOWNLOAD=false  # Ask user before downloading
AUTO_INSTALL_ON_QUIT=true  # Install when user quits app
