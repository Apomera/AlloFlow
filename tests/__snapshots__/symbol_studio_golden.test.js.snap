<button aria-label="Use template: Loud Noises" style="padding:3px 8px;background:#f3f4f6;border:1px solid #e5e7eb;border-radius:12px;font-size:10px;cursor:pointer;color:#374151;white-space:nowrap;transition:background 0.1s;position:relative">Loud Noises</button>
<button aria-label="Use template: Going Swimming" style="padding:3px 8px;background:#f3f4f6;border:1px solid #e5e7eb;border-radius:12px;font-size:10px;cursor:pointer;color:#374151;white-space:nowrap;transition:background 0.1s;position:relative">Going Swimming</button>
<button aria-label="Use template: Sleepover" style="padding:3px 8px;background:#f3f4f6;border:1px solid #e5e7eb;border-radius:12px;font-size:10px;cursor:pointer;color:#374151;white-space:nowrap;transition:background 0.1s;position:relative">Sleepover</button>
<button aria-label="Use template: Getting Dressed" style="padding:3px 8px;background:#f3f4f6;border:1px solid #e5e7eb;border-radius:12px;font-size:10px;cursor:pointer;color:#374151;white-space:nowrap;transition:background 0.1s;position:relative">Getting Dressed</button>
<button aria-label="Use template: Assembly Time" style="padding:3px 8px;background:#f3f4f6;border:1px solid #e5e7eb;border-radius:12px;font-size:10px;cursor:pointer;color:#374151;white-space:nowrap;transition:background 0.1s;position:relative">Assembly Time</button>
<button aria-label="Use template: Visiting Dentist" style="padding:3px 8px;background:#f3f4f6;border:1px solid #e5e7eb;border-radius:12px;font-size:10px;cursor:pointer;color:#374151;white-space:nowrap;transition:background 0.1s;position:relative">Visiting Dentist</button>
<button aria-label="Use template: Using an iPad" style="padding:3px 8px;background:#f3f4f6;border:1px solid #e5e7eb;border-radius:12px;font-size:10px;cursor:pointer;color:#374151;white-space:nowrap;transition:background 0.1s;position:relative">Using an iPad</button>
<button aria-label="Use template: Personal Space" style="padding:3px 8px;background:#f3f4f6;border:1px solid #e5e7eb;border-radius:12px;font-size:10px;cursor:pointer;color:#374151;white-space:nowrap;transition:background 0.1s;position:relative">Personal Space</button>
</div>
</div>
<div>
<label style="font-size:11px;font-weight:600;color:#374151;display:block;margin-bottom:3px">Additional context (optional)</label>
<textarea placeholder="e.g. likes trains, gets nervous at drop-off (avoid real names / diagnoses)" aria-label="Additional context for social story" style="width:100%;border:1px solid #d1d5db;border-radius:6px;padding:7px 9px;font-size:12px;box-sizing:border-box;font-family:inherit;resize:vertical;background:#fff;color:inherit;height:55px">
</textarea>
<p style="font-size:10px;color:#92400e;background:#fef3c7;border:1px solid #fde68a;border-radius:6px;padding:4px 8px;margin:4px 0 0">Story and image prompts are sent to a cloud AI (Google Gemini / Imagen). Do not enter real student names, diagnoses, or other identifying details (FERPA).</p>
</div>
<button disabled="" aria-label="Generate social story" style="padding:8px 14px;background:#d1d5db;color:#6b7280;border:none;border-radius:7px;font-weight:600;font-size:12px;cursor:not-allowed;white-space:nowrap">✨ Create Social Story</button>
<p style="font-size:10px;color:#6b7280">Carol Gray-informed draft (descriptive, perspective, and directive sentences) — review and edit for fidelity before use. Illustrations auto-generate for each page.</p>
</div>
<div style="flex:1;display:flex;align-items:center;justify-content:center;color:#6b7280;flex-direction:column;gap:10px;padding:20px">
<div style="font-size:52px">📖</div>
<p style="font-weight:600">Create an AI-illustrated Social Story</p>
<div style="max-width:420px;font-size:13px;line-height:1.7;text-align:center">
<p>Describe a social situation and AlloFlow drafts a Carol Gray-informed story (review and edit before use), then generates a custom illustration for every page.</p>
<p>Add a Student Avatar to make every illustration feature your specific student.</p>
</div>
</div>
</div>
</div>
</div>
</div>
</div>"
`;

