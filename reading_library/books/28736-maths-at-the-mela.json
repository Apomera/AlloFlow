,"horses"],[165,"do"],[166,"we"],[167,"need?\""],[168,"Bittu"],[169,"proudly"],[170,"says,"],[171,"\"12.\""]]},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/57538/size6/777b217716033230562a3b87de6a8a26.jpg","text":"It is the end of the day. They are all tired. Sir wants to make sure all 36 children are safely back in the bus. This time, Didu wants to count. She notices that each row in the bus has four seats. So she counts loudly in fours.","words":[[172,"It"],[173,"is"],[174,"the"],[175,"end"],[176,"of"],[177,"the"],[178,"day."],[179,"They"],[180,"are"],[181,"all"],[182,"tired."],[183,"Sir"],[184,"wants"],[185,"to"],[186,"make"],[187,"sure"],[188,"all"],[189,"36"],[190,"children"],[191,"are"],[192,"safely"],[193,"back"],[194,"in"],[195,"the"],[196,"bus."],[197,"This"],[198,"time,"],[199,"Didu"],[200,"wants"],[201,"to"],[202,"count."],[203,"She"],[204,"notices"],[205,"that"],[206,"each"],[207,"row"],[208,"in"],[209,"the"],[210,"bus"],[211,"has"],[212,"four"],[213,"seats."],[214,"So"],[215,"she"],[216,"counts"],[217,"loudly"],[218,"in"],[219,"fours."]]},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/60017/size6/9a9db3f2363d9860c15412f073c4713f.jpg","text":"\"4, 8, 12, 16, 20, 24, 28, 32... \"\nShe stops just before saying '36'.\n\"Sir, two kids seem to be missing and\nare not in the bus!\" she gasps.\nThe bus driver, Didu and Sir count the sleeping class again. Who could be missing?","words":[[220,"\"4,"],[221,"8,"],[222,"12,"],[223,"16,"],[224,"20,"],[225,"24,"],[226,"28,"],[227,"32..."],[228,"\""],[229,"She"],[230,"stops"],[231,"just"],[232,"before"],[233,"saying"],[234,"'36'."],[235,"\"Sir,"],[236,"two"],[237,"kids"],[238,"seem"],[239,"to"],[240,"be"],[241,"missing"],[242,"and"],[243,"are"],[244,"not"],[245,"in"],[246,"the"],[247,"bus!\""],[248,"she"],[249,"gasps."],[250,"The"],[251,"bus"],[252,"driver,"],[253,"Didu"],[254,"and"],[255,"Sir"],[256,"count"],[257,"the"],[258,"sleeping"],[259,"class"],[260,"again."],[261,"Who"],[262,"could"],[263,"be"],[264,"missing?"]]},{"n":9,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/57542/size6/b1a9c175480af4ecbc1e37c5f8b8efe5.jpg","text":"\"Aaaah! Come, see... here is one missing fellow,\"\nthe driver says from the back of the bus.\nOn the last row is Montu, fast asleep and snoring!","words":[[265,"\"Aaaah!"],[266,"Come,"],[267,"see..."],[268,"here"],[269,"is"],[270,"one"],[271,"missing"],[272,"fellow,\""],[273,"the"],[274,"driver"],[275,"says"],[276,"from"],[277,"the"],[278,"back"],[279,"of"],[280,"the"],[281,"bus."],[282,"On"],[283,"the"],[284,"last"],[285,"row"],[286,"is"],[287,"Montu,"],[288,"fast"],[289,"asleep"],[290,"and"],[291,"snoring!"]]},{"n":10,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/64214/size6/e29afd48e93efb90506134d0527c9217.jpg","text":"But that only adds up to 35 children.\nJust as Sir steps out to search for the missing child,\nDidu shouts, \"Sir, come back please... \nwe found her!\"\n\"Who is this naughty girl?\" Sir asks.","words":[[292,"But"],[293,"that"],[294,"only"],[295,"adds"],[296,"up"],[297,"to"],[298,"35"],[299,"children."],[300,"Just"],[301,"as"],[302,"Sir"],[303,"steps"],[304,"out"],[305,"to"],[306,"search"],[307,"for"],[308,"the"],[309,"missing"],[310,"child,"],[311,"Didu"],[312,"shouts,"],[313,"\"Sir,"],[314,"come"],[315,"back"],[316,"please..."],[317,"we"],[318,"found"],[319,"her!\""],[320,"\"Who"],[321,"is"],[322,"this"],[323,"naughty"],[324,"girl?\""],[325,"Sir"],[326,"asks."]]},{"n":11,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/57545/size6/333d3fef1e3ea099a1cf957be5d7b0e9.jpg","text":"Didu points at herself.\n\"Me, Sir. I had forgotten to count myself!\"","words":[[327,"Didu"],[328,"points"],[329,"at"],[330,"herself."],[331,"\"Me,"],[332,"Sir."],[333,"I"],[334,"had"],[335,"forgotten"],[336,"to"],[337,"count"],[338,"myself!\""]]},{"n":12,"img":"http