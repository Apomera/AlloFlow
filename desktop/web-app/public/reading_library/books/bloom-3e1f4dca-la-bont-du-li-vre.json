          "dur": 3.960091
        },
        {
          "src": "https://s3.amazonaws.com/BloomLibraryBooks/72FD1KSMyV%2f1760005153687%2fLa+bont%c3%a9+du+li%c3%a8vre%2faudio%2fb65dd898-a526-4ea3-aee8-3a33139062ed.mp3",
          "dur": 8.160091
        },
        {
