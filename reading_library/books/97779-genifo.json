:null},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/141860/size6/a2b682f2087cd8498847783ca32ca7b6.jpg","text":"“አባቴ፣ ይህ ገንፎ ተጨማሪ ስኳር ያስፈልገዋል” አለ አየለ፡፡.","words":null},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/141861/size6/7aac4c2874c843847c1747d0b5f87132.jpg","text":"አየለ ''የእናቴ ገንፎ ከአባቴ በጣም የተሻለ ነው'' ብሎ አሰበ፡፡.","words":null},{"n":9,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/141862/size6/e2ac152253964a4c3b543eef15bd33b6.jpg","text":"“አባቴ፣ እባክህ ተጨማሪ ስኳር ማግኘት እችላለሁ?” በማለት አየለ ጠየቀ፡፡.","words":null},{"n":10,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/141863/size6/6f520232f273f90f4df1c89c45e455bd.jpg","text":"ለአየለ አባቱ ተጨማሪ ስኳር አደረገለት፡፡","words":null},{"n":11,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/141864/size6/7e74af661b7abf1979c707ade452a399.jpg","text":"“ዋው! አባቴ! ገንፎዬ ውስጥ ጨው ጨመርክበት!”.","words":null},{"n":12,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/141865/size6/1a8f793015f676dea123007a291092da.jpg","text":"“አባቴ መቼ ነው እናቴ እቤት የምትመጣው?”.","words":null}],"stats":{"pages":12,"words":71}}