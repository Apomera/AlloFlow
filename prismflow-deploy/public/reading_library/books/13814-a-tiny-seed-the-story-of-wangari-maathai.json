],[45,"pressed"],[46,"tiny"],[47,"seeds"],[48,"into"],[49,"the"],[50,"warm"],[51,"earth."]]},{"n":4,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/38306/size6/8370b591567a77bb84801a7751021933.jpg","text":"Her favourite\ntime of day was just after sunset.\nWhen it got too dark to see the plants, \nWangari knew it was time to go home.\nShe would follow\nthe narrow paths \nthrough the fields, crossing rivers as she went.","words":[[52,"Her"],[53,"favourite"],[54,"time"],[55,"of"],[56,"day"],[57,"was"],[58,"just"],[59,"after"],[60,"sunset."],[61,"When"],[62,"it"],[63,"got"],[64,"too"],[65,"dark"],[66,"to"],[67,"see"],[68,"the"],[69,"plants,"],[70,"Wangari"],[71,"knew"],[72,"it"],[73,"was"],[74,"time"],[75,"to"],[76,"go"],[77,"home."],[78,"She"],[79,"would"],[80,"follow"],[81,"the"],[82,"narrow"],[83,"paths"],[84,"through"],[85,"the"],[86,"fields,"],[87,"crossing"],[88,"rivers"],[89,"as"],[90,"she"],[91,"went."]]},{"n":5,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/38363/size6/b52ca49c987f4db559f2dade33d1967f.jpg","text":"Wangari was a\nclever child and couldn’t wait \nto go to school. But her mother and father \nwanted her to stay and help them at home.\nWhen she was\nseven years old, her big brother \npersuaded her parents to let her go to school.","words":[[92,"Wangari"],[93,"was"],[94,"a"],[95,"clever"],[96,"child"],[97,"and"],[98,"couldn’t"],[99,"wait"],[100,"to"],[101,"go"],[102,"to"],[103,"school."],[104,"But"],[105,"her"],[106,"mother"],[107,"and"],[108,"father"],[109,"wanted"],[110,"her"],[111,"to"],[112,"stay"],[113,"and"],[114,"help"],[115,"them"],[116,"at"],[117,"home."],[118,"When"],[119,"she"],[120,"was"],[121,"seven"],[122,"years"],[123,"old,"],[124,"her"],[125,"big"],[126,"brother"],[127,"persuaded"],[128,"her"],[129,"parents"],[130,"to"],[131,"let"],[132,"her"],[133,"go"],[134,"to"],[135,"school."]]},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/38308/size6/4915e79dadd67955a22210e001eb2a5e.jpg","text":"She liked to\nlearn!\nWangari learnt\nmore and more with every book she read.\nShe did so well\nat school that she was invited to study in the United States of America.\nWangari was\nexcited! She wanted to know more about the world.","words":[[136,"She"],[137,"liked"],[138,"to"],[139,"learn!"],[140,"Wangari"],[141,"learnt"],[142,"more"],[143,"and"],[144,"more"],[145,"with"],[146,"every"],[147,"book"],[148,"she"],[149,"read."],[150,"She"],[151,"did"],[152,"so"],[153,"well"],[154,"at"],[155,"school"],[156,"that"],[157,"she"],[158,"was"],[159,"invited"],[160,"to"],[161,"study"],[162,"in"],[163,"the"],[164,"United"],[165,"States"],[166,"of"],[167,"America."],[168,"Wangari"],[169,"was"],[170,"excited!"],[171,"She"],[172,"wanted"],[173,"to"],[174,"know"],[175,"more"],[176,"about"],[177,"the"],[178,"world."]]},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/38309/size6/09ae0f38d14e64183afd0aeabd7af33a.jpg","text":"At the American\nuniversity Wangari learnt many new things. She studied plants and how they\ngrow. \nAnd she remembered how she grew: playing games with her brothers in the\nshade of the trees in the beautiful Kenyan forests.","words":[[179,"At"],[180,"the"],[181,"American"],[182,"university"],[183,"Wangari"],[184,"learnt"],[185,"many"],[186,"new"],[187,"things."],[188,"She"],[189,"studied"],[190,"plants"],[191,"and"],[192,"how"],[193,"they"],[194,"grow."],[195,"And"],[196,"she"],[197,"remembered"],[198,"how"],[199,"she"],[200,"grew:"],[201,"playing"],[202,"games"],[203,"with"],[204,"her"],[205,"brothers"],[206,"in"],[207,"the"],[208,"shade"],[209,"of"],[210,"the"],[211,"trees"],[212,"in"],[213,"the"],[214,"beautiful"],[215,"Kenyan"],[216,"forests."]]},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/38310/size6/8bb11d3eb7d904b077185921f791d615.jpg","text":"The more she\nlearnt, the more she realised \nthat she loved the people of Kenya. \nShe wanted\nthem to be happy and free.\nThe more she\nlearnt, the more she \nremembered her African home.","words":[[217,"The"],[218,"more"],[219,"she"],[220,"learnt,"],[221,"the"],[222,"more"],[223,"she"],[224,"realised"],[225,"that"],[226,"she"],[227,"loved"],[228,"the"],[229,"people"],[230,"of"],[231,"Kenya."],[232,"She"],[233,"wanted"],[234,"them"],[235,"to"],[236,"be"],[237,"happy"],[238,"and"],[239,"free."],[240,"The"],[241,"more"],[242,"she"],[243,"learnt,"],[244,"the"],[245,"more"],[246,"she"],[247,"remembered"],[248,"her"],[249,"African"],[250,"home."]]},{"n":9,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/38311/size6/5e2ff6b73809b5201ad3979d4328adc8.jpg","text":"When she had\nfinished her studies, \nshe returned to Kenya. \nBut her country had changed. \nHuge\nfarms stretched across the land.","words":[[251,"When"],[252,"she"],[253,"had"],[254,"finished"],[255,"her"],[256,"studies,"],[257,"she"],[258,"returned"],[259,"to"],[260,"Kenya."],[261,"But"],[262,"her"],[263,"country"],[264,"had"],[265,"changed."],[266,"Huge"],[267,"farms"],[268,"stretched"],[269,"across"],[270,"the"],[271,"land."]]},{"n":10,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/38312/size6/82a7ed97427e8140ff9de0d5446efd66.jpg","text":"Women had no wood\nto make cooking fires. \nThe people were poor and the children were hungry.","words":[[272,"Women"],[273,"had"],[274,"no"],[275,"wood"],[276,"to"],[277,"make"],[278,"cooking"],[279,"fires."],[280,"The"],[281,"people"],[282,"were"],[283,"poor"],[284,"and"],[285,"the"],[286,"children"],[287,"were"],[288,"hungry."]]},{"n":11,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/38313/size6/5fd3b76cb8315b58a91937ca5303e789.jpg","text":"Wangari knew what\nto do. She taught the women how to plant trees from seeds.\nThe women sold\nthe trees and used the money to look after their families.","words":[[289,"Wangari"],[290,"k