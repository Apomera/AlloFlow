"],[70,"to"],[71,"explore"],[72,"Chinatown."],[73,"Rickshaws"],[74,"zig-zag."],[75,"Their"],[76,"wooden"],[77,"wheels"],[78,"go"],[79,"clackety-clack."],[80,"Their"],[81,"bells"],[82,"go"],[83,"jingle-jangle."],[84,"The"],[85,"air"],[86,"smells"],[87,"good"],[88,"enough"],[89,"to"],[90,"eat."]]},{"n":4,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/53935/size6/8d40ebb80f547a21f41e7eeda53d5dc9.jpg","text":"The first stop is Mr. Lee’s. “Mr. Lee, I am going home to Mumbai tomorrow. What can I\ntake back?”\n“How about these purple plum candies?”\n“Mmmm! Sweet and tangy!” says Janice. “My brother will love them.”","words":[[91,"The"],[92,"first"],[93,"stop"],[94,"is"],[95,"Mr."],[96,"Lee’s."],[97,"“Mr."],[98,"Lee,"],[99,"I"],[100,"am"],[101,"going"],[102,"home"],[103,"to"],[104,"Mumbai"],[105,"tomorrow."],[106,"What"],[107,"can"],[108,"I"],[109,"take"],[110,"back?”"],[111,"“How"],[112,"about"],[113,"these"],[114,"purple"],[115,"plum"],[116,"candies?”"],[117,"“Mmmm!"],[118,"Sweet"],[119,"and"],[120,"tangy!”"],[121,"says"],[122,"Janice."],[123,"“My"],[124,"brother"],[125,"will"],[126,"love"],[127,"them.”"]]},{"n":5,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/53936/size6/9ae694046b4926379c41d4f3a13d7534.jpg","text":"6/13","words":null},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/53937/size6/0a4635961189fe661eaf829b25ee6cfb.jpg","text":"The next stop is Mrs. Chen’s shop. “Mrs. Chen, I am going home to Mumbai tomorrow. What can I take back?”\n“How about this black fungus? Put some in soup and it will cure sniffles.”\n“Oooo! That looks like a huge black ear!” says Janice. “My mother will love it.”","words":[[128,"The"],[129,"next"],[130,"stop"],[131,"is"],[132,"Mrs."],[133,"Chen’s"],[134,"shop."],[135,"“Mrs."],[136,"Chen,"],[137,"I"],[138,"am"],[139,"g"],[140,"oing"],[141,"home"],[142,"to"],[143,"Mumbai"],[144,"tomorrow."],[145,"What"],[146,"can"],[147,"I"],