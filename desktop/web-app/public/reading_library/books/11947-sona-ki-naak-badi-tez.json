"ज़ोर"],[186,"से"],[187,"बोला।"]]},{"n":9,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/33345/size6/ba077b736ddd75454ac48673333060d5.jpg","text":"चाचा ने पलट कर झाँका।\nरबड़ी के पतीले को झटपट आग से उतार लिया।","words":[[188,"चाचा"],[189,"ने"],[190,"पलट"],[191,"कर"],[192,"झाँका।"],[193,"रबड़ी"],[194,"के"],[195,"पतीले"],[196,"को"],[197,"झटपट"],[198,"आग"],[199,"से"],[200,"उतार"],[201,"लिया।"]]},{"n":10,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/33346/size6/8073c4dc38c3f5c6832e932e529157c1.jpg","text":"\"शाबाश सोना!\" चाचा ने रबड़ी \nको दूसरे साफ़ पतीले में पलटा। \n\"रबड़ी चुस्की को बचा लिया! \nयह तो पतीले में लगने ही लगी थी।\"","words":[[202,"\"शाबाश"],[203,"सोना!\""],[204,"चाचा"],[205,"ने"],[206,"रबड़ी"],[207,"को"],[208,"दूसरे"],[209,"साफ़"],[210,"पतीले"],[211,"में"],[212,"पलटा।"],[213,"\"रबड़ी"],[214,"चुस्की"],[215,"को"],[216,"बचा"],[217,"लिया!"],[218,"यह"],[219,"तो"],[220,"पतीले"],[221,"में"],[222,"लगने"],[223,"ही"],[224,"लगी"],[225,"थी।\""]]},{"n":11,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/33347/size6/327ad4a717421e8f133794061ee27661.jpg","text":"सबसे पहली ‘रबड़ी-चुस्की’ सोना को देते हुए, \nचाचा ने सोना को प्यार से थपथपाया! \n\"हमारी बहुत ही सयानी सोना!\"","words":[[226,"सबसे"],[227,"पहली"],[228,"‘रबड़ी-चुस्की’"],[229,"सोना"],[230,"को"],[231,"देते"],[232,"हुए,"],[233,"चाचा"],[234,"ने"],[235,"सोना"],[236,"को"],[237,"प्यार"],[238,"से"],[239,"थपथपाया!"],[240,"\"हमारी"],[241,"बहुत"],[242,"ही"],[243,"सयानी"],[244,"सोना!\""]]}],"stats":{"pages":11,"words":243}}