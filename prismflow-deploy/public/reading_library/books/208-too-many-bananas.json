ngeri"],[340,"Srinivas"],[341,"offered"],[342,"one"],[343,"to"],[344,"the"],[345,"priest."]]},{"n":22,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/2487/size6/9760e337f10ca753a4f8d656ad1f483e.jpg","text":"“Each one has the pulp of 4 bananas. There are 27 packets. So here are your 108 ripe bananas!”","words":[[346,"“Each"],[347,"one"],[348,"has"],[349,"the"],[350,"pulp"],[351,"of"],[352,"4"],[353,"bananas."],[354,"There"],[355,"are"],[356,"27"],[357,"packets."],[358,"So"],[359,"here"],[360,"are"],[361,"your"],[362,"108"],[363,"ripe"],[364,"bananas!”"]]},{"n":23,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/2488/size6/101e6d13cf709558b2a44b4928ac7dd9.jpg","text":"The priest was so surprised that he forgot to chant. In the silence, one child began to laugh.","words":[[365,"The"],[366,"priest"],[367,"was"],[368,"so"],[369,"surprised"],[370,"that"],[371,"he"],[372,"forgot"],[373,"to"],[374,"chant."],[375,"In"],[376,"the"],[377,"silence,"],[378,"one"],[379,"child"],[380,"began"],[381,"to"],[382,"laugh."]]},{"n":24,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/2489/size6/e6428279c1b384c1b84e9dde4fe30ad9.jpg","text":"Soon the whole village was laughing and clapping.","words":[[383,"Soon"],[384,"the"],[385,"whole"],[386,"village"],[387,"was"],[388,"laughing"],[389,"and"],[390,"clapping."]]},{"n":25,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/2490/size6/4d2f73cfdf1b8974adae00df08d5b7b0.jpg","text":"Now we know what Sringeri Srinivas does with all the bananas that he grows!","words":[[391,"Now"],[392,"we"],[393,"know"],[394,"what"],[395,"Sringeri"],[396,"Srinivas"],[397,"does"],[398,"with"],[399,"all"],[400,"the"],[401,"bananas"],[402,"that"],[403,"he"],[404,"grows!"]]},{"n":26,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/2491/size6/5e5ec46710e116b68242e5ad7c0d3ead.jpg","text":"DID YOU KNOW?\nFacts About Bananas\n \nThe word banana is derived from the Arabic word for ‘finger’. India is the largest producer of bananas in the world. There are over 120 edible varieties of bananas grown here. The National Research Centre on Bananas in Trichy has a collection of 1120 banana varieties!\n \nBananas are high in minerals that help increase brain power. Bananas make students more active and alert. Many Indian sweets are made out of bananas - Banana Payasam in Kerala, Banana Rasayana in Karnataka, Banana Halwa, Rawa Kela-Gur Mithai. Do you know some more?","words":[[405,"DID"],[406,"YOU"],[407,"KNOW?"],[408,"Facts"],[409,"About"],[410,"Bananas"],[411,"The"],[412,"word"],[413,"banana"],[414,"is"],[415,"derived"],[416,"from"],[417,"the"],[418,"Arabic"],[419,"word"],[420,"for"],[421,"‘finger’."],[422,"India"],[423,"is"],[424,"the"],[425,"largest"],[426,"producer"],[427,"of"],[428,"bananas"],[429,"in"],[430,"the"],[431,"world."],[432,"There"],[433,"are"],[434,"over"],[435,"120"],[436,"edible"],[437,"varieties"],[438,"of"],[439,"bananas"],[440,"grown"],[441,"here."],[442,"The"],[443,"National"],[444,"Research"],[445,"Centre"],[446,"on"],[447,"Bananas"],[448,"in"],[449,"Trichy"],[450,"has"],[451,"a"],[452,"collection"],[453,"of"],[454,"1120"],[455,"banana"],[456,"varieties!"],[457,"Bananas"],[458,"are"],[459,"high"],[460,"in"],[461,"minerals"],[462,"that"],[463,"help"],[464,"increase"],[465,"brain"],[466,"power."],[467,"Bananas"],[468,"make"],[469,"students"],[470,"more"],[471,"active"],[472,"and"],[473,"alert."],[474,"Many"],[475,"Indian"],[476,"sweets"],[477,"are"],[478,"made"],[479,"out"],[480,"of"],[481,"bananas"],[482,"-"],[483,"Banana"],[484,"Payasam"],[485,"in"],[486,"Kerala,"],[487,"Banana"],[488,"Rasayana"],[489,"in"],[490,"Karnataka,"],[491,"Banana"],[492,"Halwa,"],[493,"Rawa"],[494,"Kela-Gur"],[495,"Mithai."],[496,"Do"],[497,"you"],[498,"know"],[499,"some"],[500,"more?"]]}],"stats":{"pages":26,"words":500}}