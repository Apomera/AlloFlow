0fb81ff68c5ea3b798e7fa8e789.jpg","text":"A week later…\nNo more sniffles!\nDivya can’t wait to see all her friends!","words":[[78,"A"],[79,"week"],[80,"later…"],[81,"No"],[82,"more"],[83,"sniffles!"],[84,"Divya"],[85,"can’t"],[86,"wait"],[87,"to"],[88,"see"],[89,"all"],[90,"her"],[91,"friends!"]]},{"n":11,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/32193/size6/563b0ee2bc924c9069f957de08b260e4.jpg","text":"Sniffle, sniffle.\nUh-oh! What’s this? \nIt looks like Rustam has the sniffles now…\nSniffle, sniffle.\nAnd Gurmeet...","words":[[92,"Sniffle,"],[93,"sniffle."],[94,"Uh-oh!"],[95,"What’s"],[96,"this?"],[97,"It"],[98,"looks"],[99,"like"],[100,"Rustam"],[101,"has"],[102,"the"],[103,"sniffles"],[104,"now…"],[105,"Sniffle,"],[106,"sniffle."],[107,"And"],[108,"Gurmeet..."]]},{"n":12,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/32194/size6/f2da981301decea29382bda2d6752089.jpg","text":"Sniffle, sniffle.\n... And Mohit...\nSniffle, sniffle.\n... And Pooja too!","words":[[109,"Sniffle,"],[110,"sniffle."],[111,"..."],[112,"And"],[113,"Mohit..."],[114,"Sniffle,"],[115,"sniffle."],[116,"..."],[117,"And"],[118,"Pooja"],[119,"too!"]]},{"n":13,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/32354/size6/c00cbb4f5887869f6cc98b9a40bc3c81.jpg","text":"OH NO!\nEVERYONE has the sniffles!\nSniffle, sniffle.","words":[[120,"OH"],[121,"NO!"],[122,"EVERYONE"],[123,"has"],[124,"the"],[125,"sniffles!"],[126,"Sniffle,"],[127,"sniffle."]]},{"n":14,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/32196/size6/c751e9c7247a58c25341637bd85dfe1e.jpg","text":"15/17","words":null},{"n":15,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/32276/size6/73df3a802f62c425efa27a66eb42b0cf.jpg","text":"Colds are caused by tiny particles called viruses. They can float around in the air that we breathe, and sit on things we touch. When these viruses get into your nose and throat, they give you a sore throat, or a headache, or a clogged nose -- or even all three at the same time!\nA cold can move very quickly from you to your friends. If you touch your friends when you have a cold, or sneeze or cough near them, they too will fall sick. Did you know that a single cough or sneeze can shoot your nose and throat viruses 12 feet through the air? How terrible!","words":[[128,"Colds"],[129,"are"],[130,"caused"],[131,"by"],[132,"tiny"],[133,"particles"],[134,"called"],[135,"viruses."],[136,"They"],[137,"can"],[138,"float"],[139,"around"],[140,"in"],[141,"the"],[142,"air"],[143,"that"],[144,"we"],[145,"breathe,"],[146,"and"],[147,"sit"],[148,"on"],[149,"things"],[150,"we"],[151,"touch."],[152,"When"],[153,"these"],[154,"viruses"],[155,"get"],[156,"into"],[157,"your"],[158,"nose"],[159,"and"],[160,"throat,"],[161,"they"],[162,"give"],[163,"you"],[164,"a"],[165,"sore"],[166,"throat,"],[167,"or"],[168,"a"],[169,"headache,"],[170,"or"],[171,"a"],[172,"clogged"],[173,"nose"],[174,"--"],[175,"or"],[176,"even"],[177,"all"],[178,"three"],[179,"at"],[180,"the"],[181,"same"],[182,"time!"],[183,"A"],[184,"cold"],[185,"can"],[186,"move"],[187,"very"],[188,"quickly"],[189,"from"],[190,"you"],[191,"to"],[192,"your"],[193,"friends."],[194,"If"],[195,"you"],[196,"touch"],[197,"your"],[198,"friends"],[199,"when"],[200,"you"],[201,"have"],[202,"a"],[203,"cold,"],[204,"or"],[205,"sneeze"],[206,"or"],[207,"cough"],[208,"near"],[209,"them,"],[210,"they"],[211,"too"],[212,"will"],[213,"fall"],[214,"sick."],[215,"Did"],[216,"you"],[217,"know"],[218,"that"],[219,"a"],[220,"single"],[221,"cough"],[222,"or"],[223,"sneeze"],[224,"can"],[225,"shoot"],[226,"your"],[227,"nose"],[228,"and"],[229,"throat"],[230,"viruses"],[231,"12"],[232,"feet"],[233,"through"],[234,"the"],[235,"air?"],[236,"How"],[237,"terrible!"]]},{"n":16,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/32199/size6/a249f3b1dcb957b2931fd4fec8bc3ec4.jpg","text":"This is how you can avoid catching a cold:\nStay far away from anyone who has a bad cold.\nIf you meet or shake hands with someone who has a cold, wash your hands well. Otherwise, the virus will travel from your hands to your nose.\nDo not share drinking glasses, eating utensils or clothes with someone who has a cold.\nEat lots of vegetables and fruits, drink plenty of water, exercise, keep warm and stay healthy!","words":[[238,"This"],[239,"is"],[240,"how"],[241,"you"],[242,"can"],[243,"avoid"],[244,"catching"],[245,"a"],[246,"cold:"],[247,"Stay"],[248,"far"],[249,"away"],[250,"from"],[251,"anyone"],[252,"who"],[253,"has"],[254,"a"],[255,"bad"],[256,"cold."],[257,"If"],[258,"you"],[259,"meet"],[260,"or"],[261,"shake"],[262,"hands"],[263,"with"],[264,"someone"],[265,"who"],[266,"has"],[267,"a"],[268,"cold,"],[269,"wash"],[270,"your"],[271,"hands"],[272,"well."],[273,"Otherwise,"],[274,"the"],[275,"virus"],[276,"will"],[277,"travel"],[278,"from"],[279,"your"],[280,"hands"],[281,"to"],[282,"your"],[283,"nose."],[284,"Do"],[285,"not"],[286,"share"],[287,"drinking"],[288,"glasses,"],[289,"eating"],[290,"utensils"],[291,"or"],[292,"clothes"],[293,"with"],[294,"someone"],[295,"who"],[296,"has"],[297,"a"],[298,"cold."],[299,"Eat"],[300,"lots"],[301,"of"],[302,"vegetables"],[303,"and"],[304,"fruits,"],[305,"drink"],[306,"plenty"],[307,"of"],[308,"water,"],[309,"exercise,"],[310,"keep"],[311,"warm"],[312,"and"],[313,"stay"],[314,"healthy!"]]}],"stats":{"pages":16,"words":316}}