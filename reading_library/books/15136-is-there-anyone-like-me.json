ars.","words":[[24,"Someone"],[25,"with"],[26,"my"],[27,"eyes"],[28,"my"],[29,"ears."]]},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/40757/size6/f61759d3f8d99673a3fe2b67d305f787.jpg","text":"Who even has my\nlaugh.","words":[[30,"Who"],[31,"even"],[32,"has"],[33,"my"],[34,"laugh."]]},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/40749/size6/bc6a809544d8ef633d2db6add04d5e31.jpg","text":"Who can do what I\ncan do.","words":[[35,"Who"],[36,"can"],[37,"do"],[38,"what"],[39,"I"],[40,"can"],[41,"do."]]},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/40750/size6/719acc25c23eb3e74260d9ab4f2446a0.jpg","text":"And can't do what\nI can't.","words":[[42,"And"],[43,"can't"],[44,"do"],[45,"what"],[46,"I"],[47,"can't."]]},{"n":9,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/40751/size6/54b182ac8ae0bee8c86f8bb94d2e78bf.jpg","text":"I've looked and\nlooked everywhere to find another me. \nI went down to the park and looked behind\nthe trees.","words":[[48,"I've"],[49,"looked"],[50,"and"],[51,"looked"],[52,"everywhere"],[53,"to"],[54,"find"],[55,"another"],[56,"me."],[57,"I"],[58,"went"],[59,"down"],[60,"to"],[61,"the"],[62,"park"],[63,"and"],[64,"looked"],[65,"behind"],[66,"the"],[67,"trees."]]},{"n":10,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/40752/size6/5020fc3c77a1b70868012853c7087425.jpg","text":"I looked around,\nup and down.","words":[[68,"I"],[69,"looked"],[70,"around,"],[71,"up"],[72,"and"],[73,"down."]]},{"n":11,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/40758/size6/27d1f38b92ee1a98f38a13c3ecd2ef16.jpg","text":"At every single\nface.","words":[[74,"At"],[75,"every"],[76,"single"],[77,"face."]]},{"n":12,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/40759/size6/717b857873f71742855d44cacd1b3f92.jpg","text":"I couldn't find another\nme in any single place.","words":[[78,"I"],[79,"couldn't"],[80,"find"],[81,"another"],[82,"me"],[83,"in"],[84,"any"],[85,"single"],[86,"place."]]},{"n":13,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/40755/size6/a6c7e4d51dc66c7b040ebe4326dbc608.jpg","text":"There's only one\nme in the world! \nI'm special, oh it's true!","words":[[87,"There's"],[88,"only"],[89,"one"],[90,"me"],[91,"in"],[92,"the"],[93,"world!"],[94,"I'm"],[95,"special,"],[96,"oh"],[97,"it's"],[98,"true!"]]},{"n":14,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/40756/size6/3dfb2092c7ef236c4ff3d3e19135e887.jpg","text":"But not just me,\ndon't you see? \nThere's only one of you!","words":[[99,"But"],[100,"not"],[101,"just"],[102,"me,"],[103,"don't"],[104,"you"],[105,"see?"],[106,"There's"],[107,"only"],[108,"one"],[109,"of"],[110,"you!"]]}],"stats":{"pages":14,"words":110}}