.storyweaver.org.in/illustration_crops/102810/size6/457feadf786b6382a6e89c3c60dc1741.jpg","text":"It can detect Seema’s house by the sea and Iqbal’s house in the city.\nA drone is not a spy.","words":[[46,"It"],[47,"can"],[48,"detect"],[49,"Seema’s"],[50,"house"],[51,"by"],[52,"the"],[53,"sea"],[54,"and"],[55,"Iqbal’s"],[56,"house"],[57,"in"],[58,"the"],[59,"city."],[60,"A"],[61,"drone"],[62,"is"],[63,"not"],[64,"a"],[65,"spy."]]},{"n":5,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/102839/size6/9647e063d11ae897f47cd0d4bbf77114.jpg","text":"It delivers parcels in 30 minutes.\nA drone is not a postman.","words":[[66,"It"],[67,"delivers"],[68,"parcels"],[69,"in"],[70,"30"],[71,"minutes."],[72,"A"],[73,"drone"],[74,"is"],[75,"not"],[76,"a"],[77,"postman."]]},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/102842/size6/596b57079a0c95d054477d3a26e5a833.jpg","text":"Then what is a drone?\nA drone is a clever machine.","words":[[78,"Then"],[79,"what"],[80,"is"],[81,"a"],[82,"drone?"],[83,"A"],[84,"drone"],[85,"is"],[86,"a"],[87,"clever"],[88,"machine."]]},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/102844/size6/9675065ac64a6900300f75725a656afb.jpg","text":"It flies. It finds addresses.\nIt takes photographs from up above.\nIt carries parcels from\none place to another.","words":[[89,"It"],[90,"flies."],[91,"It"],[92,"finds"],[93,"addresses."],[94,"It"],[95,"takes"],[96,"photographs"],[97,"from"],[98,"up"],[99,"above."],[100,"It"],[101,"carries"],[102,"parcels"],[103,"from"],[104,"one"],[105,"place"],[106,"to"],[107,"another."]]},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/102847/size6/e6ac050dccc4e05a728bda730dc5de7a.jpg","text":"Right now, drones are busy\nlearning their jobs.\nSometimes they make mistakes.\nThey crash into buildings.\nThey fall from the sky.\nBut there are rules that stop them\nfrom flying everywhere.","words":[[108,"Right"],[109,"now,"],[110,"drones"],[111,"are"],[112,"busy"],[113,"learning"],[114,"their"],[115,"jobs."],[116,"Sometimes"],[117,"they"],[118,"make"],[119,"mistakes."],[120,"They"],[121,"crash"],[122,"into"],[123,"buildings."],[124,"They"],[125,"fall"],[126,"from"],[127,"the"],[128,"sky."],[129,"But"],[130,"there"],[131,"are"],[132,"rules"],[133,"that"],[134,"stop"],[135,"them"],[136,"from"],[137,"flying"],[138,"everywhere."]]},{"n":9,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/102849/size6/a069189790dfb9f6a02ebec8933843ec.jpg","text":"One day, drones will criss-cross the skies.\nThey will rush and deliver medicines\nto villages in the hills.\nThey will count tigers in forests\nand help protect them.\nThey will photograph hidden corners\nof our planet.","words":[[139,"One"],[140,"day,"],[141,"drones"],[142,"will"],[143,"criss-cross"],[144,"the"],[145,"skies."],[146,"They"],[147,"will"],[148,"rush"],[149,"and"],[150,"deliver"],[151,"medicines"],[152,"to"],[153,"villages"],[154,"in"],[155,"the"],[156,"hills."],[157,"They"],[158,"will"],[159,"count"],[160,"tigers"],[161,"in"],[162,"forests"],[163,"and"],[164,"help"],[165,"protect"],[166,"them."],[167,"They"],[168,"will"],[169,"photograph"],[170,"hidden"],[171,"corners"],[172,"of"],[173,"our"],[174,"planet."]]},{"n":10,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/102852/size6/9513ba18b83ba6dbb3b25b9bff985e40.jpg","text":"One day, drones will carry biryani\nfrom a restaurant to Seema’s house.\nDrones will carry books from\nthe library to Iqbal’s house.\nDrones will fly with birds\noutside your window.\nMaybe someday soon,\nyou will meet a drone.","words":[[175,"One"],[176,"day,"],[177,"drones"],[178,"will"],[179,"carry"],[180,"biryani"],[181,"from"],[182,"a"],[183,"restaurant"],[184,"to"],[185,"Seema’s"],[186,"house."],[187,"Drones"],[188,"will"],[189,"carry"],[190,"books"],[191,"from"],[192,"the"],[193,"library"],[194,"to"],[195,"Iqbal’s"],[196,"house."],[197,"Drones"],[198,"will"],[199,"fly"],[200,"with"],[201,"birds"],[202,"outside"],[203,"your"],[204,"window."],[205,"Maybe"],[206,"someday"],[207,"soon,"],[208,"you"],[209,"will"],[210,"meet"],[211,"a"],[212,"drone."]]}],"stats":{"pages":10,"words":211}}