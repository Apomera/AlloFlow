ِيدَةِ، وَنَلْتَقِي بِكِلَابِ الشَّوَارِعِ فِي الْمَدِينَةِ.","words":[[1,"يُوجَدُ"],[2,"فِي"],[3,"مَدِينَةِ"],[4,"مُومْبَايْ"],[5,"الْكَثِيرُ"],[6,"مِنَ"],[7,"النَّاسِ"],[8,"وَالْقِطَارَاتِ"],[9,"وَسَيَّارَاتِ"],[10,"الْأُجْرَةِ."],[11,"كَمَا"],[12,"يُوجَدُ"],[13,"فِيهَا"],[14,"الْعَدِيدُ"],[15,"مِنَ"],[16,"الْكِلَابِ"],[17,"السَّعِيدَةِ"],[18,"الَّتِي"],[19,"تَعِيشُ"],[20,"فِي"],[21,"شَوَارِعِهَا."],[22,"لِنَأْخُذْ"],[23,"جَوْلَةً"],[24,"فِي"],[25,"الْمَمَرَّاتِ"],[26,"الْعَدِيدَةِ،"],[27,"وَنَلْتَقِي"],[28,"بِكِلَابِ"],[29,"الشَّوَارِعِ"],[30,"فِي"],[31,"الْمَدِينَةِ."]]},{"n":2,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/59115/size6/3bced0faecccee1f737003df2514fc3f.jpg","text":"يُحِبُّ الْكَلْبُ \"تِرَافِكْ\" مُسَاعَدَةَ شُرْطَةِ الْمُرُورِ.\nعِنْدَمَا يُخَالِفُ أَحَدٌ مَا الْقَانُونَ، يَقُومُ \"تِرَافِكْ\" بِمُطَارَدَةِ الْمَرْكَبَةِ الْمُخَالِفَةِ وَالْوُقُوفِ بِجَانِبِهَا. لَا أَحَدَ يَسْتَطِيعُ الْهُرُوبَ مِنْ مُرَاقَبَتِهِ.","words":[[32,"يُحِبُّ"],[33,"الْكَلْبُ"],[34,"\"تِرَافِكْ\""],[35,"مُسَاعَدَةَ"],[36,"شُرْطَةِ"],[37,"الْمُرُورِ."],[38,"عِنْدَمَا"],[39,"يُخَالِفُ"],[40,"أَحَدٌ"],[41,"مَا"],[42,"الْقَانُونَ،"],[43,"يَقُومُ"],[44,"\"تِرَافِكْ\""],[45,"بِمُطَارَدَةِ"],[46,"الْمَرْكَبَةِ"],[47,"الْمُخَالِفَةِ"],[48,"وَالْوُقُوفِ"],[49,"بِجَانِبِهَا."],[50,"لَا"],[51,"أَحَدَ"],[52,"يَسْتَطِيعُ"],[53,"الْهُرُوبَ"],[54,"مِنْ"],[55,"مُرَاقَبَتِهِ."]]},{"n":3,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/59117/size6/db84e716262d0409ddb75d160489e5fd.jpg","text":"يَعِيشُ الْكَلْبُ \"تِشِيكُو\" بِالْقُرْبِ مِنَ السِّينِمَا، فَهُوَ يَأْكُلُ وَيَلْعَبُ مَعَ حَارِسِ الْأَمْنِ.\nوَفِي اللَّيَالِي الْبَارِدَةِ، يَلْتَحِفُ \"تِشِيكُو\" بِالْمِعْطَفِ الَّذِي صَنَعَهُ لَهُ صَدِيقُهُ الحَارِسُ.","words":[[56,"يَعِيشُ"],[57,"الْكَلْبُ"],[58,"\"تِشِيكُو\""],[59,"بِالْقُرْبِ"],[60,"مِنَ"],[61,"السِّينِمَا،"],[62,"فَهُوَ"],[63,"يَأْكُلُ"],[64,"وَيَلْعَبُ"],[65,"مَعَ"],[66,"حَارِسِ"],[67,"الْأَمْنِ."],[68,"وَفِي"],[69,"اللَّيَالِي"],[70,"الْبَارِدَةِ،"],[71,"يَلْتَحِفُ"],[72,"\""],[73,"تِشِيكُو\""],[74,"بِالْمِعْطَفِ"],[75,"الَّذِي"],[76,"صَنَعَهُ"],[77,"لَهُ"],[78,"صَدِيقُهُ"],[79,"الحَارِسُ."]]},{"n":4,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/59118/size6/5a46c90d21db2ecbdc1bf24322b11924.jpg","text":"أَمَّا الْكَلْبُ \"بِيرْيَابَا\" فَطَعَامُهُ الْمُفَضَّلُ هُوَ الْإِدْلِي (كَعْكَةُ الْأُرْزِ) وَالدُّوسَا (الْخُبْزُ الرَّقِيقُ).\nفِي كُلِّ يَوْمٍ يَزُورُ \"بِيرْيَابَا\" ثَلَاثَةَ مَطَاعِمَ مُخْتَلِفَةً لِلْحُصُولِ عَلَى وَجَبَاتِ الْإِفْطَارِ وَالْغَدَاءِ وَالْعَشَاءِ!\nلَا تَرَى \"بِيرْيَابَا\" إِلَّا وَهُوَ يَأْكُلُ دَائِمًا أَوْ يَحْلُمُ بِالطَّعَامِ.","words":[[80,"أَمَّا"],[81,"الْكَلْبُ"],[82,"\"بِيرْيَابَا\""],[83,"فَطَعَامُهُ"],[84,"الْمُفَضَّلُ"],[85,"هُوَ"],[86,"الْإِدْلِي"],[87,"(كَعْكَةُ"],[88,"الْأُرْزِ)"],[89,"وَالدُّوسَا"],[90,"(الْخُبْزُ"],[91,"الرَّقِيقُ)."],[92,"فِي"],[93,"كُلِّ"],[94,"يَوْمٍ"],[95,"يَزُورُ"],[96,"\""],[97,"بِيرْيَابَا\""],[98,"ثَلَاثَةَ"],[99,"مَطَاعِمَ"],[100,"مُخْتَلِفَةً"],[101,"لِلْحُصُولِ"],[102,"عَلَى"],[103,"وَجَبَاتِ"],[104,"الْإِفْطَارِ"],[105,"وَالْغَدَاءِ"],[106,"وَالْعَشَاءِ!"],[107,"لَا"],[108,"تَرَى"],[109,"\"بِيرْيَابَا\""],[110,"إِلَّا"],[111,"وَهُوَ"],[112,"يَأْكُلُ"],[113,"دَائِمًا"],[114,"أَوْ"],[115,"يَحْلُمُ"],[116,"بِالطَّعَامِ."]]},{"n":5,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/59120/size6/2a7cef4b37eddf3ac2dd66aeff551e97.jpg","text":"تَعِيشُ الْكَلْبَةُ \"شَامْبِي\" بِالْقُرْبِ مِنْ أَرْضٍ كَبِيرَةٍ، يَلْعَبُ بِهَا الْأَطْفَالُ الْكُرِيكِيتْ وَكُرَةَ الْقَدَمِ.\nوَجَدَهَا مُورْيَاجِي، بَائِعُ عَصِيرِ الْقَصَبِ. فِي ذَلِكَ الْوَقْتِ، كَانَ يَسْتَمْتِعُ بِتَدْلِيكِ رَأْسِهِ، وَهُوَ مَا يُطْلِقُ عَلَيْهِ شَامْبِي، وَهَكَذَا حَصَلَتِ الْكَلْبَةُ عَلَى اسْمِهَا!","words":[[117,"تَعِيشُ"],[118,"الْكَلْبَةُ"],[119,"\"شَامْبِي\""],[120,"بِالْقُرْبِ"],[121,"مِنْ"],[122,"أَرْضٍ"],[123,"كَبِيرَةٍ،"],[124,"يَلْعَبُ"],[125,"بِهَا"],[126,"الْأَطْفَالُ"],[127,"الْكُرِيكِيتْ"],[128,"وَكُرَةَ"],[129,"الْقَدَمِ."],[130,"وَجَدَهَا"],[131,"مُورْيَاجِي،"],[132,"بَائِعُ"],[133,"عَصِيرِ"],[134,"الْقَصَبِ."],[135,"فِي"],[136,"ذَلِكَ"],[137,"الْوَقْتِ،"],[138,"كَانَ"],[139,"يَسْتَمْتِعُ"],[140,"بِتَدْ"],[141,"لِيكِ"],[142,"رَأْسِهِ،"],[143,"وَهُوَ"],[144,"مَا"],[145,"يُطْلِقُ"],[146,"عَلَيْهِ"],[147,"شَامْبِي،"],[148,"وَهَكَذَا"],[149,"حَصَلَتِ"],[150,"الْكَلْبَةُ"],[151,"عَلَى"],[152,"اسْمِهَا!"]]},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/59121/size6/6b0b2caa79e941f9e984c44c0ae26a31.jpg","text":"كَانَ الْكَلْبُ \"هُولْ\" لَا يَزَالُ جَرْوًا عِنْدَمَا أَنْقَذَهُ مُدِيرُ الْمَكَانِ مِنْ حُفْرَةِ فِئْرَانٍ، لِذَلِكَ قَرَّرُوا تَسْمِيَتَهُ \"هُولْ\"؛ أَيْ: حُفْرَةٌ.\nيَجْلِسُ الْكَلْبُ \"هُولْ\" عَلَى دَرَجِ دَارِ السِّينِمَا، يُلَوِّحُ بِذَيْلِهِ وَيُحَيِّي رُوَّادَ السِّينِمَا.","words":[[153,"كَانَ"],[154,"الْكَلْبُ"],[155,"\"هُولْ\""],[156,"لَا"],[157,"يَزَالُ"],[158,"جَرْوًا"],[159,"عِنْدَمَا"],[160,"أَنْقَذَهُ"],[161,"مُدِيرُ"],[162,"الْمَكَانِ"],[163,"مِنْ"],[164,"حُفْرَةِ"],[165,"فِئْرَانٍ،"],[166,"لِذَلِكَ"],[167,"قَرَّرُوا"],[168,"تَسْمِيَتَهُ"],[169,"\"هُولْ\"؛"],[170,"أَيْ:"],[171,"حُفْرَةٌ."],[172,"يَجْلِسُ"],[173,"الْكَلْبُ"],[174,"\"هُولْ\""],[175,"عَلَى"],[176,"دَرَجِ"],[177,"دَارِ"],[178,"السِّينِمَا،"],[179,"يُلَوِّحُ"],[180,"بِذَيْلِهِ"],[181,"وَيُحَيِّي"],[182,"رُوَّادَ"],[183,"السِّينِمَا."]]},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/59122/size6/747535adbaa9188f4603ad6eaaa68f1d.jpg","text":"يَعِيشُ الْكَلْبُ \"كَابْتِنْ\" فِي الْحَدِيقَةِ الَّتِي لَعِبَ فِيهَا الْكُرِيكِيتْ اللَّاعِبُ الْمَشْهُورُ سَاشِينْ تِينْدُولْكَارْ. كَمَا أَنَّ \"كَابْتِنْ\" يُحِبُّ الْجَرْيَ.\nكُلَّ سَنَةٍ، يَعْدُو \"كَابْتِنْ\" جَنْبًا إِلَى جَنْبٍ مَعَ الْأَشْخَاصِ الَّذِينَ يَجْرُونَ فِي سِبَاقِ مَارَاثُونْ مُومْبَايْ. وَعِنْدَمَا يُكْمِلُ \"كَابْتِنْ\" السِّبَاقَ، لَا أَحَدَ يُعْطِيهِ مِيدَالْيَةً، وَلَكِنَّهُ يَكُونُ سَعِيدًا بِقِطْعَةٍ مِنَ الْبِسْكُوِيتْ!","words":[[184,"يَعِيشُ"],[185,"الْكَلْبُ"],[186,"\"كَابْتِنْ\""],[187,"فِي"],[188,"الْحَدِيقَةِ"],[189,"الَّتِي"],[190,"لَعِبَ"],[191,"فِيهَا"],[192,"الْكُرِيكِيتْ"],[193,"اللَّاعِبُ"],[194,"الْمَشْهُورُ"],[195,"سَاشِينْ"],[196,"تِينْدُولْكَارْ."],[197,"كَمَا"],[198,"أَنَّ"],[199,"\"كَابْتِنْ\""],[200,"يُحِبُّ"],[201,"الْجَرْيَ."],[202,"كُلَّ"],[203,"سَنَةٍ،"],[204,"يَعْدُو"],[205,"\"كَابْتِنْ\""],[206,"جَنْبًا"],[207,"إِلَى"],[208,"جَنْبٍ"],[209,"مَعَ"],[210,"الْأَشْخَاصِ"],[211,"الَّذِينَ"],[212,"يَجْرُونَ"],[213,"فِي"],[214,"سِبَاقِ"],[215,"مَارَاثُونْ"],[216,"مُومْبَايْ."],[217,"وَعِنْدَمَا"],[218,"يُكْمِلُ"],[219,"\"كَابْتِنْ\""],[220,"السِّبَاقَ،"],[221,"لَا"],[222,"أَحَدَ"],[223,"يُعْطِيهِ"],[224,"مِيدَالْيَةً،"],[225,"وَلَكِنَّهُ"],[226,"يَكُونُ"],[227,"سَعِيدًا"],[228,"بِقِطْعَةٍ"],[229,"مِنَ"],[230,"الْبِسْكُوِيتْ!"]]},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/59123/size6/a71a61d771f66c585c83ac40bc7af333.jpg","text":"الْكَلْبَةُ \"بُوجِي\" مَفْتُونَةٌ بِالْقِطَارَاتِ.\nوُجِدَتْ \"بُوجِي\" فِي عَرَبةِ السَّيِّدَاتِ بِالدَّرَجَةِ الْأُولَى فِي الْقِطَارِ. وَعَلَى مَتْنِ الْقِطَارِ كَانَتْ \"بُوجِي\" تَبْحَثُ عَنْ مُغَامَرَةٍ، وَلَكِنْ لَمْ يَكُنْ مَعَهَا تَذْكَرَةٌ.","words":[[231,"الْكَلْبَةُ"],[232,"\"بُوجِي\""],[233,"مَفْتُونَةٌ"],[234,"بِالْقِطَارَاتِ."],[235,"وُجِدَتْ"],[236,"\"بُوجِي\""],[237,"فِي"],[238,"عَرَبةِ"],[239,"السَّيِّدَاتِ"],[240,"بِالدَّرَجَةِ"],[241,"الْأُولَى"],[242,"فِي"],[243,"الْقِطَارِ."],[244,"وَ"],[245,"عَلَى"],[246,"مَتْنِ"],[247,"الْقِطَارِ"],[248,"كَانَتْ"],[249,"\""],[250,"بُوجِي\""],[251,"تَبْحَثُ"],[252,"عَنْ"],[253,"مُغَامَرَةٍ،"],[254,"وَلَكِنْ"],[255,"لَمْ"],[256,"يَكُنْ"],[257,"مَعَهَا"],[258,"تَذْكَرَةٌ."]]},{"n":9,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/59124/size6/548ed9952de568911ed42ad9ac861881.jpg","text":"فِي كَثِيرٍ مِنَ الْأَحْيَانِ، يَسْتَكْشِفُ الْكَلْبُ \"كَالُو\" أَجْزَاءً مُخْتَلِفَةً مِنْ مَدِينَتِهِ، فَهُوَ لَا يَحْتَاجُ حَتَّى إِلَى خَرِيطَةٍ.\nفِي بَعْضِ الْأَيَّامِ، يَمْشِي عَلَى شَاطِئِ الْبَحْرِ، وَفِي أَيَّامٍ أُخْرَى يَتَّجِهُ إِلَى مَحَطَّةِ السِّكَّةِ الْحَدِيدِيَّةِ.\nوَفِي يَوْمٍ مِنَ الْأَيَّامِ، قَفَزَ كَالُو إِلَى دَاخِلِ قِطَارٍ لِيَتْبَعَ صَدِيقًا لَهُ.","words":[[259,"فِي"],[260,"كَثِيرٍ"],[261,"مِنَ"],[262,"الْأَحْيَانِ،"],[263,"يَسْتَكْشِفُ"],[264,"الْكَلْبُ"],[265,"\"كَالُو\""],[266,"أَجْزَاءً"],[267,"مُخْتَلِفَةً"],[268,"مِنْ"],[269,"مَدِينَتِهِ،"],[270,"فَهُوَ"],[271,"لَا"],[272,"يَحْتَاجُ"],[273,"حَتَّى"],[274,"إِلَى"],[275,"خَرِيطَةٍ."],[276,"فِي"],[277,"بَعْضِ"],[278,"الْأَيَّامِ،"],[279,"يَمْشِي"],[280,"عَلَى"],[281,"شَاطِئِ"],[282,"الْبَحْرِ،"],[283,"وَفِي"],[284,"أَيَّامٍ"],[285,"أُخْرَى"],[286,"يَتَّجِهُ"],[287,"إِلَى"],[288,"مَحَطَّةِ"],[289,"السِّكَّةِ"],[290,"الْحَدِيدِيَّةِ."],[291,"وَفِي"],[292,"يَوْمٍ"],[293,"مِنَ"],[294,"الْأَيَّامِ،"],[295,"قَفَزَ"],[296,"كَالُو"],[297,"إِلَى"],[298,"دَاخِلِ"],[299,"قِطَارٍ"],[300,"لِيَتْبَعَ"],[301,"صَدِيقًا"],[302,"لَهُ."]]},{"n":10,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/59125/size6/02fda3dbf004387423146c2a435013c3.jpg","text":"أَمَّا الْكَلْبَةُ \"كَالِي\" فَتُحِبُّ اللَّعِبَ مَعَ الْأَطْفَالِ؛ فَهِيَ تَسْتَمْتِعُ عِنْدَمَا يُعَانِقُونَهَا، وَتَسْمَحُ لَهُمْ حَتَّى بِالرُّكُوبِ عَلَى ظَهْرِهَا!\nتَعْتَنِي بِالْكَلْبَةِ \"كَالِي\" أُسْرَةٌ تَعِيشُ فِي الشَّوَارِعِ.","words":[[303,"أَمَّا"],[304,"الْكَلْبَةُ"],[305,"\"كَالِي\""],[306,"فَتُحِبُّ"],[307,"اللَّعِبَ"],[308,"مَعَ"],[309,"الْأَطْفَالِ؛"],[310,"فَهِيَ"],[311,"تَسْتَمْتِعُ"],[312,"عِنْدَمَا"],[313,"يُعَانِقُونَهَا،"],[314,"وَتَسْمَحُ"],[315,"لَهُمْ"],[316,"حَتَّى"],[317,"بِالرُّكُوبِ"],[318,"عَلَى"],[319,"ظَهْرِهَا!"],[320,"تَعْتَنِي"],[321,"بِالْكَلْبَةِ"],[322,"\"كَالِي\""],[323,"أُسْرَةٌ"],[324,"تَعِيشُ"],[325,"فِي"],[326,"الشَّوَارِعِ."]]},{"n":11,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/59135/size6/4f74e0e4cd551c917fca1c929815f1f9.jpg","text":"كِلَابُ مَدِينَةِ مُومْبَايْ\n مِنَ الصَّعْبِ تَخَيُّلُ شَوَارِعِ مَدِينَةِ مُومْبَايْ خَالِيَةً مِنَ الْكِلَابِ. وَهَذِهِ الْكِلَابُ الضَّالَّةُ، بِالْإِضَافَةِ إِلَى الْكِلَابِ الَّتِي تَعَرَّفْتُمْ عَلَيْهَا فِي هَذِهِ الْقِصَّةِ، يَعْتَنِي بِهَا وَيُطْعِمُهَا الْآلَافُ مِنَ النَّاسِ فِي أَنْحَاءِ الْمَدِينَةِ. قَدْ يَكُونُ مِنْ بَيْنِهِمْ مُلَمِّعُ الْأَحْذِيَةِ فِي الْحَيِّ، أَوْ رَجُلُ الشُّرْطَةِ، أَوْ بَائِعٌ مُتَجَوِّلٌ، أَوْ سَاكِنُ الشَّارِعِ، أَوْ حَتَّى الْأَشْخَاصُ الَّذِينَ يَعِيشُونَ فِي الْمَبَانِي الْعَالِيَةِ.\nيَتِمُّ تَسْمِيَةُ هَذِهِ الْكِلَابِ بِأَسْمَاءٍ مِثْلِ: كَالُو، وَتُومِي، وَجُولِي، بَلْ وَأَسْمَاءِ نُجُومِ أَفْلَامٍ مِثْلِ: إِيشْوَارْيَا، وَسَلْمَانَ، وَشَارُوخَ. تَقُومُ الْجَمْعِيَّةُ الْمَعْنِيَّةُ بِرِعَايَةِ الْكِلَابِ الضَّالَّةِ (WSD) بِتَوْفِيرِ الرِّعَايَةِ الطِّبِّيَّةِ وَالتَّطْعِيمِ لِهَذِهِ الْحَيَوَانَاتِ الضَّالَّةِ لِأَكْثَرَ مِنْ عِشْرِينَ عَامًا.","words":[[327,"كِلَابُ"],[328,"مَدِينَةِ"],[329,"مُومْبَايْ"],[330,"مِنَ"],[331,"الصَّعْبِ"],[332,"تَخَيُّلُ"],[333,"شَوَارِعِ"],[334,"مَدِينَةِ"],[335,"مُومْبَايْ"],[336,"خَالِيَةً"],[337,"مِنَ"],[338,"الْكِلَابِ."],[339,"وَهَذِهِ"],[340,"الْكِلَابُ"],[341,"الضَّالَّةُ،"],[342,"بِالْإِضَافَةِ"],[343,"إِلَى"],[344,"الْكِلَابِ"],[345,"الَّتِي"],[346,"تَعَرَّفْتُمْ"],[347,"عَلَيْهَا"],[348,"فِي"],[349,"هَذِهِ"],[350,"الْقِصَّةِ،"],[351,"يَعْتَنِي"],[352,"بِهَا"],[353,"وَيُطْعِمُهَا"],[354,"الْآلَافُ"],[355,"مِنَ"],[356,"النَّاسِ"],[357,"فِي"],[358,"أَنْحَاءِ"],[359,"الْمَدِينَةِ."],[360,"قَدْ"],[361,"يَكُونُ"],[362,"مِنْ"],[363,"بَيْنِهِمْ"],[364,"مُلَمِّعُ"],[365,"الْأَحْذِيَةِ"],[366,"فِي"],[367,"الْحَيِّ،"],[368,"أَوْ"],[369,"رَجُلُ"],[370,"الشُّرْطَةِ،"],[371,"أَوْ"],[372,"بَائِعٌ"],[373,"مُتَجَوِّلٌ،"],[374,"أَوْ"],[375,"سَاكِنُ"],[376,"الشَّارِعِ،"],[377,"أَوْ"],[378,"حَتَّى"],[379,"الْأَشْخَاصُ"],[380,"الَّذِينَ"],[381,"يَعِيشُونَ"],[382,"فِي"],[383,"الْمَبَانِي"],[384,"الْعَالِيَةِ."],[385,"يَتِمُّ"],[386,"تَسْمِيَةُ"],[387,"هَذِهِ"],[