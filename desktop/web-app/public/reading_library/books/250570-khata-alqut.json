,"لَمْ"],[12,"تَعْلَقْ"],[13,"فِي"],[14,"أَعْلَى"],[15,"الشَّجَرَةِ،"],[16,"مَا"],[17,"كُنْتُ"],[18,"لِأُحْضِرَ"],[19,"السُّلَّمَ"],[20,"لِأَصْعَدَ"],[21,"لَهَا."]]},{"n":3,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/13957/size6/82dcc28b0ebb8f0b4d44834aefe31da9.jpg","text":"وَلَوْ لَمْ أُحْضِرِ السُّلَّمَ لِأَصْعَدَ لَهَا، لَمَا كُنْتُ بِحَاجَةٍ لِإِصْلَاحِهِ.\nوَلَوْ لَمْ أَكُنْ فِي حَاجَةٍ لِإِصْلَاحِهِ، لَمَا أَيْقَظْتُ الطِّفْلَ.","words":[[22,"وَلَوْ"],[23,"لَمْ"],[24,"أُحْضِرِ"],[25,"السُّلَّمَ"],[26,"لِأَصْعَدَ"],[27,"لَهَا،"],[28,"لَمَا"],[29,"كُنْتُ"],[30,"بِحَاجَةٍ"],[31,"لِإِصْلَاحِهِ."],[32,"وَلَوْ"],[33,"لَمْ"],[34,"أَكُنْ"],[35,"فِي"],[36,"حَاجَةٍ"],[37,"لِإِصْلَاحِهِ،"],[38,"لَمَا"],[39,"أَيْقَظْتُ"],[40,"الطِّفْلَ."]]},{"n":4,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/13958/size6/cbebcafd09ccafb93a53ccbf97d5212d.jpg","text":"وَلَوْ لَمْ أُوقِظِ الطِّفْلَ، لَمَا خَرَجَتْ أُمِّي مِنَ الْمَطْبَخِ بِسُرْعَةٍ.\nوَلَوْ لَمْ تُسْرِعْ أُمِّي لِلْخُرُوجِ مِنَ الْمَطْبَخِ، لَمَا دَخَلَ الْقِرْدُ.","words":[[41,"وَلَوْ"],[42,"لَمْ"],[43,"أُوقِظِ"],[44,"الطِّفْلَ،"],[45,"لَمَا"],[46,"خَرَجَتْ"],[47,"أُمِّي"],[48,"مِنَ"],[49,"الْمَطْبَخِ"],[50,"بِسُرْعَةٍ."],[51,"وَلَوْ"],[52,"لَمْ"],[53,"تُسْرِعْ"],[54,"أُمِّي"],[55,"لِلْخُرُوجِ"],[56,"مِنَ"],[57,"الْمَطْبَخِ،"],[58,"لَمَا"],[59,"دَخَلَ"],[60,"الْقِرْدُ."]]},{"n":5,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/13959/size6/6afe4b32d72fda92b47269657fdd7f5e.jpg","text":"وَلَوْ لَمْ يَدْخُلِ الْقِرْدُ، لَمَا أَكَلَ كُلَّ الطَّعَامِ.\nوَلَوْ لَمْ يَأْكُلْ كُلَّ الطَّعَامِ، لَمَا كَانَ أَبِي لِيَذْهَبَ لِشِرَاءِ الرُّوتِي وَكَارِي الدَّجَاجِ مِنْ دُكَّانِ الشَّايِ.","words":[[61,"وَلَوْ"],[62,"لَمْ"],[63,"يَدْخُلِ"],[64,"الْقِرْدُ،"],[65,"لَمَا"],[66,"أَكَلَ"],[67,"كُلَّ"],[68,"الطَّعَامِ."],[69,"وَلَوْ"],[70,"لَمْ"],[71,"يَأْكُلْ"],[72,"كُلَّ"],[73,"الطَّعَامِ،"],[74,"لَمَا"],[75,"كَانَ"],[76,"أَبِي"],[