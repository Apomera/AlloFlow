xt":"“દાદાજી, શું થયું? તમે છાપું કેમ વાંચતા નથી?” એક સવારે ગુલ્લીએ પૂછ્યું.\n“અરે ભાઈ, મારાં વાંચવાનાં ચશ્માં તૂટી ગયાં છે અને ચશ્માં વિના તો મારાથી વંચાતું નથી.” દાદાજી એજવાબ આપ્યો.","words":[[1,"“દાદાજી,"],[2,"શું"],[3,"થયું?"],[4,"તમે"],[5,"છાપું"],[6,"કેમ"],[7,"વાંચતા"],[8,"નથી?”"],[9,"એક"],[10,"સવારે"],[11,"ગુલ્લીએ"],[12,"પૂછ્યું."],[13,"“અરે"],[14,"ભાઈ,"],[15,"મારાં"],[16,"વાંચવાનાં"],[17,"ચશ્માં"],[18,"તૂટી"],[19,"ગયાં"],[20,"છે"],[21,"અને"],[22,"ચશ્માં"],[23,"વિના"],[24,"તો"],[25,"મારાથી"],[26,"વંચાતું"],[27,"નથી.”"],[28,"દાદાજી"],[29,"એજવાબ"],[30,"આપ્યો."]]},{"n":2,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/6302/size6/b71fabc5c39bd8c44dfcc2aecf093198.jpg","text":"“અરે, મૂંઝાવ છો શું કરવા, દાદાજી. હમણાં જ મારો પટારો લઈ આવું છું.”\nગુલ્લી દોડતો ગયો, અને એનો કથ્થાઈ રંગનો નાનકડો પટારો લઈને પાછો આવ્યો.","words":[[31,"“અરે,"],[32,"મૂંઝાવ"],[33,"છો"],[34,"શું"],[35,"કરવા,"],[36,"દાદાજી."],[37,"હમણાં"],[38,"જ"],[39,"મારો"],[40,"પટારો"],[41,"લઈ"],[42,"આવું"],[43,"છું.”"],[44,"ગુલ્લી"],[45,"દોડતો"],[46,"ગયો,"],[47,"અને"],[48,"એનો"],[49,"કથ્થાઈ"],[50,"રંગનો"],[51,"નાનકડો"],[52,"પટારો"],[53,"લઈને"],[54,"પાછો"],[55,"આવ્યો."]]},{"n":3,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/6303/size6/7e4ca193c0a8c6b6759ea6d253211e39.jpg","text":"ક્લિંક, ક્લોંક, ડડ્મ-ડમ. શું શોધી કાઢ્યું એણે?\nએક ચકાચક ચમકતો બિલોરી કાચ!\nએમાંથી જોતાં શું દેખાય ખબર છે તમને?\nબધું જ મોટું-મોટું અને વળી ચોખ્ખું!","words":[[56,"ક્લિંક,"],[57,"ક્લોંક,"],[58,"ડડ્મ-ડમ."],[59,"શું"],[60,"શોધી"],[61,"કાઢ્યું"],[62,"એણે?"],[63,"એક"],[64,"ચકાચક"],[65,"ચમકતો"],[66,"બિલોરી"],[67,"કાચ!"],[68,"એમાંથી"],[69,"જોતાં"],[70,"શું"],[71,"દેખાય"],[72,"ખબર"],[73,"છે"],[74,"તમને?"],[75,"બધું"],[76,"જ"],[77,"મોટું-મોટું"],[78,"અને"],[79,"વળી"],[80,"ચોખ્ખું!"]]},{"n":4,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/6304/size6/d2c916bf3f9d4825c2d643cb0b2953f5.jpg","text":"“અરે વાહ! તારો ખૂબ-ખૂબ આભાર. આ તો બહુ સરસ છે ને!\nહવે તો હું એક-એક લીટી વાંચી શકીશ” દાદાજીએ કહ્યું.","words":[[81,"“અરે"],[82,"વાહ!"],[83,"તારો"],[84,"ખૂબ-ખૂબ"],[85,"આભાર."],[86,"આ"],[87,"તો"],[88,"બહુ"],[89,"સરસ"],[90,"છે"],[91,"ને!"],[92,"હવે"],[93,"તો"],[94,"હું"],[95,"એક-એક"],[96,"લીટી"],[97,"વાંચી"],[98,"શકીશ”"],[99,"દાદાજીએ"],[100,"કહ્યું."]]},{"n":5,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/6305/size6/e135c76f84e0a3c7a02399b807cc9c09.jpg","text":"“અરે મંગળકાકા, શું થયું?” ગુલ્લીએ એક રવિવારે પૂછ્યું.\n“બેટા, આ પેકેટમાંથી મારે આ બાટલીમાં તેલ કાઢવું છે પણ બાટલીનું મોં સાવ સાંકડું છે. મને લાગે છે કે મારાથી તો આ તેલ ઢોળાઈ જ જશે અને આખું રસોડું ગંદું થશે,” મંગળકાકાએ જવાબ આપ્યો. “કંઈ વાંધો નહીં મંગળકાકા. હું હમણાં જ તમારા માટે કોઈ રસ્તો શોધી કાઢું છું.” ગુલ્લીએ જવાબ આપ્યો.","words":[[101,"“અરે"],[102,"મંગળકાકા,"],[103,"શું"],[104,"થયું?”"],[105,"ગુલ્લીએ"],[106,"એક"],[107,"રવિવારે"],[108,"પૂછ્યું."],[109,"“બેટા,"],[110,"આ"],[111,"પેકેટમાંથી"],[112,"મારે"],[113,"આ"],[114,"બાટલીમાં"],[115,"તેલ"],[116,"કાઢવું"],[117,"છે"],[118,"પણ"],[119,"બાટલીનું"],[120,"મોં"],[121,"સાવ"],[122,"સાંકડું"],[123,"છે."],[124,"મને"],[125,"લાગે"],[126,"છે"],[127,"કે"],[128,"મારાથી"],[129,"તો"],[130,"આ"],[131,"તેલ"],[132,"ઢોળાઈ"],[133,"જ"],[134,"જશે"],[135,"અને"],[136,"આખું"],[137,"રસોડું"],[138,"ગંદું"],[139,"થશે,”"],[140,"મંગળકાકાએ"],[141,"જવાબ"],[142,"આપ્યો."],[143,"“કંઈ"],[144,"વાંધો"],[145,"નહીં"],[146,"મંગળકાકા."],[147,"હું"],[148,"હમણાં"],[149,"જ"],[150,"તમારા"],[151,"માટે"],[152,"કોઈ"],[153,"રસ્તો"],[154,"શોધી"],[155,"કાઢું"],[156,"છું.”"],[157,"ગુલ્લીએ"],[158,"જવાબ"],[159,"આપ્યો."]]},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/6306/size6/3b234147280ec883d96a6c48afd25eee.jpg","text":"ક્લિંક, ક્લોંક, ડડ્મ-ડમ. ચાલો, જોઈએ તો ખરા, આ વખતે ગુલ્લીએ શું શોધી કાઢ્યું છે!","words":[[160,"ક્લિંક,"],[161,"ક્લોંક,"],[162,"ડડ્મ-ડમ."],[163,"ચાલો,"],[164,"જોઈએ"],[165,"તો"],[166,"ખરા,"],[167,"આ"],[168,"વખતે"],[169,"ગુલ્લીએ"],[170,"શું"],[171,"શોધી"],[172,"કાઢ્યું"],[173,"છે!"]]},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/6307/size6/1cbd97f0437ffcc3c0820e684f8270d6.jpg","text":"અરે વાહ, એક મોટી, પહોળા મોંવાળી ગળણી!\nએમાં ઉપરથી કંઈ પણ રેડો અને જુઓ, કે કેવી સફાઈથી ટીપે-ટીપે બહાર આવે છે!\n“લો મંગળકાકા, આ વાપરો. રસોડું ચોખ્ખું રહેશે અને રસોઈ કરવાની મજા આવશે.”","words":[[174,"અરે"],[175,"વાહ,"],[176,"એક"],[177,"મોટી,"],[178,"પહોળા"],[179,"મોંવાળી"],[180,"ગળણી!"],[181,"એમાં"],[182,"ઉપરથી"],[183,"કંઈ"],[184,"પણ"],[185,"રેડો"],[186,"અને"],[187,"જુઓ,"],[188,"કે"],[189,"કેવી"],[190,"સફાઈથી"],[191,"ટીપે-ટીપે"],[192,"બહાર"],[193,"આવે"],[194,"છે!"],[195,"“લો"],[196,"મંગળકાકા,"],[197,"આ"],[198,"વાપરો."],[199,"રસોડું"],[200,"ચોખ્ખું"],[201,"રહેશે"],[202,"અને"],[203,"રસોઈ"],[204,"કરવાની"],[205,"મજા"],[206,"આવશે.”"]]},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/6308/size6/e1dd9253f8e77a5e84ce134694ae3199.jpg","text":"“તારો ખૂબ-ખૂબ આભાર ગુલ્લી. તેં બહુ મદદ કરી!”","words":[[207,"“તારો"],[208,"ખૂબ-ખૂબ"],[209,"આભાર"],[210,"ગુલ્લી."],[211,"તેં"],[212,"બહુ"],[213,"મદદ"],[214,"કરી!”"]]},{"n":9,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/6309/size6/404b70ff46a562eaffc3ce08c0a77e98.jpg","text":"“દાદીમા, શું શોધો છો?” ગુલ્લીએ પૂછ્યું.\n“અરે, હું દાદાજીની બુઢિયાટોપી સાંધતી હતી, ત્યાં ખોળામાંથી સોય ક્યાંક પડી ગઈ!” દાદીમા બોલ્યાં.\n“દાદીમા, તમે આરામથી આ ખુરશીમાં બેસો અને ઝૂલો. તમારી સોય હું શોધી આપું છું!” ગુલ્લીએ જવાબ આપ્યો.","words":[[215,"“દાદીમા,"],[216,"શું"],[217,"શોધો"],[218,"છો?”"],[219,"ગુલ્લીએ"],[220,"પૂછ્યું."],[221,"“અરે,"],[222,"હું"],[223,"દાદાજીની"],[224,"બુઢિયાટોપી"],[225,"સાંધતી"],[226,"હતી,"],[227,"ત્યાં"],[228,"ખોળામાંથી"],[229,"સોય"],[230,"ક્યાંક"],[231,"પડી"],[232,"ગઈ!”"],[233,"દાદીમા"],[234,"બોલ્યાં."],[235,"“દાદીમા,"],[236,"તમે"],[237,"આરામથી"],[238,"આ"],[239,"ખુરશીમાં"],[240,"બેસો"],[241,"અને"],[242,"ઝૂલો."],[243,"તમારી"],[244,"સોય"],[245,"હું"],[246,"શોધી"],[247,"આપું"],[248,"છું!”"],[249,"ગુલ્લીએ"],[250,"જવાબ"],[251,"આપ્યો."]]},{"n":10,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/6310/size6/54ef6bb0c6a3a2793725a0378bb4ff0a.jpg","text":"ક્લિંક, ક્લોંક, ડડ્મ-ડમ. ગુલ્લીએ આ શું શોધી કાઢ્યું આ વખતે?\nએક લોહચુંબક! નાની-નાની બધી જ વસ્તુઓ એની સાથે ચોંટી જશે હવે!\n“હમણાં ફળિયામાં ફરી વળું છું અને તમારી સોય શોધી કાઢું છું.” ગુલ્લીએ કહ્યું.","words":[[252,"ક્લિંક,"],[253,"ક્લોંક,"],[254,"ડડ્મ-ડમ."],[255,"ગુલ્લીએ"],[256,"આ"],[257,"શું"],[258,"શોધી"],[259,"કાઢ્યું"],[260,"આ"],[261,"વખતે?"],[262,"એક"],[263,"લોહચુંબક!"],[264,"નાની-નાની"],[265,"બધી"],[266,"જ"],[267,"વસ્તુઓ"],[268,"એની"],[269,"સાથે"],[270,"ચોંટી"],[271,"જશે"],[272,"હવે!"],[273,"“હમણાં"],[274,"ફળિયામાં"],[275,"ફરી"],[276,"વળું"],[277,"છું"],[278,"અને"],[279,"તમારી"],[280,"સોય"],[281,"શોધી"],[282,"કાઢું"],[283,"છું.”"],[284,"ગુલ્લીએ"],[285,"કહ્યું."]]},{"n":11,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/6311/size6/f19d6902c7c925bce0bdcfe1afdacab1.jpg","text":"“જુઓ દાદીમા. તમારી સોય કેવી ચોંટી ગઈ છે! અને એની સાથે અગાઉ ખોવાયેલી લોખંડની કેટલી વસ્તુઓ મળી આવી, જુઓ!”\n“તારો ખૂબ આભાર ગુલ્લી. તું તો બહુ જ શાણો છે. અને તારો આ નાનકડો કથ્થાઈ પટારો તો ખરેખર બહુ મજાનો છે!” દાદીમા ખુશ થઈ બોલ્યાં.","words":[[286,"“જુઓ"],[287,"દાદીમા."],[288,"તમારી"],[289,"સોય"],[290,"કેવી"],[291,"ચોંટી"],[292,"ગઈ"],[293,"છે!"],[294,"અને"],[295,"એની"],[296,"સાથે"],[297,"અગાઉ"],[298,"ખોવાયેલી"],[299,"લોખંડની"],[300,"કેટલી"],[301,"વસ્તુઓ"],[302,"મળી"],[303,"આવી,"],[304,"જુઓ!”"],[305,"“તારો"],[306,"ખૂબ"],[307,"આભાર"],[308,"ગુલ્લી."],[309,"તું"],[310,"તો"],[311,"બહુ"],[312,"જ"],[313,"શાણો"],[314,"છે."],[315,"અને"],[316,"તારો"],[317,"આ"],[318,"નાનકડો"],[319,"કથ્થાઈ"],[320,"પટારો"],[321,"તો"],[322,"ખરેખર"],[323,"બહુ"],[324,"મજાનો"],[325,"છે!”"],[326,"દાદીમા"],[327,"ખુશ"],[328,"થઈ"],[329,"બોલ્યાં."]]}],"stats":{"pages":11,"words":329}}