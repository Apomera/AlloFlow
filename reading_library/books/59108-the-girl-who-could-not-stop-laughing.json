weaver.org.in/illustration_crops/105955/size6/82a8f388393ae4462f6702f92a3fafe7.jpg","text":"Every joke evoked a different reaction from T. Sundari.\nSometimes a polite laugh\nTra la la ha ha\nSometimes a giggle\nPehehehehhee\nSometimes a guffaw\nAHAHAHAHA","words":[[131,"Every"],[132,"joke"],[133,"evoked"],[134,"a"],[135,"different"],[136,"reaction"],[137,"from"],[138,"T."],[139,"Sundari."],[155,"Sometimes"],[156,"a"],[157,"polite"],[158,"laugh"],[159,"Tra"],[160,"la"],[161,"la"],[162,"ha"],[163,"ha"],[147,"Sometimes"],[148,"a"],[149,"giggle"],[150,"Pe"],[151,"he"],[152,"heh"],[153,"eh"],[154,"hee"],[140,"Sometimes"],[141,"a"],[142,"guffaw"],[143,"AH"],[144,"A"],[145,"HA"],[146,"HAHA"]]},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/106424/size6/062739df5785ee66cfe0c3ef33a5e78d.jpg","text":"Sometimes a Ghatotkacha* laugh\nMUHAHAHAHAHA\n*In the Indian epic, Mahabharata, Ghatotkacha is a huge and powerful rakshasa with a loud and rumbling laugh.\nSometimes, when T. Sundari tried really hard to suppress her laughter, it would burst out of her like a bomb.\nmmmmmmprrrrffttrrrrrahhaahaha\nHAHAHAHAHAHAAHAHAHA","words":[[164,"Sometimes"],[165,"a"],[166,"Ghatotkacha*"],[167,"laugh"],[168,"MUHAHAHAHAHA"],[169,"*In"],[170,"the"],[171,"Indian"],[172,"epic,"],[173,"Mahabharata,"],[174,"Ghatotkacha"],[175,"is"],[176,"a"],[177,"huge"],[178,"and"],[179,"powerful"],[180,"rakshasa"],[181,"with"],[182,"a"],[183,"loud"],[184,"and"],[185,"rumbling"],[186,"laugh."],[187,"Sometimes,"],[188,"when"],[189,"T."],[190,"Sundari"],[191,"tried"],[192,"really"],[193,"hard"],[194,"to"],[195,"suppress"],[196,"her"],[197,"laughter,"],[198,"it"],[199,"would"],[200,"burst"],[201,"out"],[202,"of"],[203,"her"],[204,"like"],[205,"a"],[206,"bomb."],[207,"mmmmmm"],[208,"prrrrffttrrrrr"],[209,"ahhaahaha"],[210,"HAHAHAHAHA"],[211,"H"],[212,"AAHAHAHA"]]},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/105966/size6/205bab87ddfce7772889aa3c6e1042f3.jpg","text":"T. Sundari was worried. Was there something wrong with her? Why couldn’t she stop laughing?\nShe needed to do something.\nStuffing a hanky in her mouth didn’t help.\nIt just popped out of her mouth when she laughed.","words":[[213,"T."],[214,"Sundari"],[215,"was"],[216,"worried."],[217,"Was"],[218,"there"],[219,"something"],[220,"wrong"],[221,"with"],[222,"her?"],[223,"Why"],[224,"couldn’t"],[225,"she"],[226,"stop"],[227,"laughing?"],[228,"She"],[229,"needed"],[230,"to"],[231,"do"],[232,"something."],[233,"Stuffing"],[234,"a"],[235,"hanky"],[236,"in"],[237,"her"],[238,"mouth"],[239,"didn’t"],[240,"help."],[241,"It"],[242,"just"],[243,"popped"],[244,"out"],[245,"of"],[246,"her"],[247,"mouth"],[248,"when"],[249,"she"],[250,"laughed."]]},{"n":9,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/105900/size6/8ec646edea70f94e46e7d8b8e21b60a1.jpg","text":"T. Sundari made a list of things she found funny:\n5. Tickling\n3. The word bonda\n4. People slipping\non banana peels\n2. Toilet jokes\n1. Farts","words":[[251,"T."],[252,"Sundari"],[253,"made"],[254,"a"],[255,"list"],[256,"of"],[257,"things"],[258,"she"],[259,"found"],[260,"funny:"],[276,"5."],[277,"Tickling"],[266,"3."],[267,"The"],[268,"word"],[269,"bonda"],[270,"4."],[271,"People"],[272,"slipping"],[273,"on"],[274,"banana"],[275,"peels"],[263,"2."],[264,"Toilet"],[265,"jokes"],[261,"1."],[262,"Farts"]]},{"n":10,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/105933/size6/1309b2dcb0f24c6f9c6801429a96288f.jpg","text":"“I will make sure I never laugh \nat these again,” decided T. Sundari.\n“I will make sure I never laugh\nat these again,” decided T. Sundari.","words":[[291,"“I"],[292,"will"],[293,"make"],[294,"sure"],[295,"I"],[296,"never"],[297,"laugh"],[298,"at"],[299,"these"],[300,"again,”"],[301,"decided"],[302,"T."],[303,"Sundari."],[278,"“I"],[279,"will"],[280,"make"],[281,"sure"],[282,"I"],[283,"never"],[284,"laugh"],[285,"at"],[286,"these"],[287,"again,”"],[288,"decided"],[289,"T."],[290,"Sundari."]]},{"n":11,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/105911/size6/1bf1502803866e4b4f9663711d62dc35.jpg","text":"Next day, during library, \nP. Manigantan moved behind a bookcase and let out a delicate sound right next to T. Sundari.\nT. Sundari, who knew a fart when she heard one, erupted in laughter, forgetting all about her list! \nThis was not going to work. It was time for plan B.\nPoot poot potrrrrrrr","words":[[294,"Next"],[295,"day,"],[296,"during"],[297,"library,"],[298,"P."],[299,"Manigantan"],[300,"moved"],[301,"behind"],[302,"a"],[303,"bookcase"],[304,"and"],[305,"let"],[306,"out"],[307,"a"],[308,"delicate"],[309,"sound"],[310,"right"],[311,"next"],[312,"to"],[313,"T."],[314,"Sundari."],[315,"T."],[316,"Sundari,"],[317,"who"],[318,"knew"],[319,"a"],[320,"fart"],[321,"when"],[322,"she"],[323,"heard"],[324,"one,"],[325,"erupted"],[326,"in"],[327,"laughter,"],[328,"forgetting"],[329,"all"],[330,"about"],[331,"her"],[332,"list!"],[333,"This"],[334,"was"],[335,"not"],[336,"going"],[337,"to"],[338,"work."],[339,"It"],[340,"was"],[341,"time"],[342,"for"],[343,"plan"],[344,"B."],[291,"Poot"],[292,"poot"],[293,"potrrrrrrr"]]},{"n":12,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/105969/size6/b277c08fd08c816df054901a7feff91d.jpg","text":"Skandu Anna, T. Sundari’s older brother\nand a scientist, was plan B.\nMaybe he could invent a machine\nthat could stop her from laughing?\nWhen T. Sundari told him what was bothering her, Skandu Anna, who was usually the serious sort, burst out laughing.","words":[[345,"Skandu"],[346,"Anna,"],[347,"T."],[348,"Sundari’s"],[349,"older"],[350,"brother"],[351,"and"],[352,"a"],[353,"scientist,"],[354,"was"],[355,"plan"],[356,"B."],[357,"Maybe"],[358,"he"],[359,"could"],[360,"invent"],[361,"a"],[362,"machine"],[363,"that"],[364,"could"],[365,"stop"],[366,"her"],[367,"fro