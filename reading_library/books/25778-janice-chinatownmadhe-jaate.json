79,260,260.52],[380,260.52,261.4],[381,261.4,262.36],[382,262.36,262.76],[383,262.76,264.08],[384,264.08,264.48],[385,264.48,264.96],[386,264.96,265.24],[387,265.24,265.64],[388,265.64,265.76],[389,265.76,266],[390,266,266.36],[391,266.36,267.4],[392,267.4,267.48],[393,267.48,267.8],[394,267.8,268.44],[395,268.44,269.28],[396,269.28,269.92],[397,269.92,270.92],[398,270.92,271.16],[399,271.16,272.76],[400,272.76,273.24],[401,273.24,273.92],[402,273.92,274.28],[403,274.28,274.36],[404,274.36,274.6],[405,274.6,274.92],[406,274.92,334.92]]},"pages":[{"n":1,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/53932/size6/ce6764e56c5bd338ac76ffe9591096b6.jpg","text":"“जेनिस,\nऊठ बाळा!”, आजी हाका मारतेय.\nजेनिस बिछान्यातून\nटुणकन उडी मारून उठलीय.\nलिऊआजीकडचा आज तिचा शेवटचा दिवस.","words":[[1,"“जेनिस,"],[2,"ऊठ"],[3,"बाळा!”,"],[4,"आजी"],[5,"हाका"],[6,"मारतेय."],[7,"जेनिस"],[8,"बिछान्यातून"],[9,"टुणकन"],[10,"उडी"],[11,"मारून"],[12,"उठलीय."],[13,"लिऊआजीकडचा"],[14,"आज"],[15,"तिचा"],[16,"शेवटचा"],[17,"दिवस."]]},{"n":2,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/53933/size6/6d2f86015bbe635eb3a9973cd992fb9a.jpg","text":"मुंबईतून\nनिघताना जेनिसनं घरच्या सगळ्यांना सांगितलं होतं, \nकी ती त्यांच्यासाठी काहीतरी गम्मत-जम्मत\nघेऊन येईल.\nपण तिनं\nतर अजून काहीच खरेदी केली नाहीय...\n“लिऊआजी,\nआज बाजारात खरेदी करायला नेशील मला?”, \nजेनिस विचारते.\nलिऊ आजीचं घर\nकोलकता शहरातल्या \nतिरेत्ती बाजारामध्ये आहे. या\nभागाला\nचायना टाऊन\n \nअसंही म्हणतात.","words":[[18,"मुंबईतून"],[19,"निघताना"],[20,"जेनिसनं"],[21,"घरच्या"],[22,"सगळ्यांना"],[23,"सांगितलं"],[24,"होतं,"],[25,"की"],[26,"ती"],[27,"त्यांच्यासाठी"],[28,"काहीतरी"],[29,"गम्मत-जम्मत"],[30,"घेऊन"],[31,"येईल."],[32,"पण"],[33,"तिनं"],[34,"तर"],[35,"अजून"],[36,"काहीच"],[37,"खरेदी"],[38,"केली"],[39,"नाहीय..."],[40,"“लिऊआजी,"],[41,"आज"],[42,"बाजारात"],[43,"खरेदी"],[44,"करायला"],[45,"नेशील"],[46,"मला?”,"],[47,"जेनिस"],[48,"विचारते."],[49,"लिऊ"],[50,"आजीचं"],[51,"घर"],[52,"कोलकता"],[53,"शहरातल्या"],[54,"तिरेत्ती"],[55,"बाजारामध्ये"],[56,"आहे."],[57,"या"],[58,"भागाला"],[59,"चायना"],[60,"टाऊन"],[61,"असंही"],[62,"म्हणतात."]]},{"n":3,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/53934/size6/a5cc06c282035ab59abed616ded39052.jpg","text":"जेनिस\nआणि लिऊआजी चायना टाऊन पालथं घालायला निघाल्यात.\nरिक्षा\nइकडून तिकडे पळत आहेत. त्यांची लाकडी चाकं\nकुरूकुरू\nवाजत आहेत. \nत्यांच्यावर\nबांधलेल्या घंटा रुणुझुणु वाजत आहेत. \nसगळीकडे छान छान पदार्थांचा घमघमाट सुटलाय,\nतोंडाला पाणी सुटतंय.","words":[[63,"जेनिस"],[64,"आणि"],[65,"लिऊआजी"],[66,"चायना"],[67,"टाऊन"],[68,"पालथं"],[69,"घालायला"],[70,"निघाल्यात."],[71,"रिक्षा"],[72,"इकडून"],[73,"तिकडे"],[74,"पळत"],[75,"आहेत."],[76,"त्यांची"],[77,"लाकडी"],[78,"चाकं"],[79,"कुरूकुरू"],[80,"वाजत"],[81,"आहेत."],[82,"त्यांच्यावर"],[83,"बांधलेल्या"],[84,"घंटा"],[85,"रुणुझुणु"],[86,"वाजत"],[87,"आहेत."],[88,"सगळीकडे"],[89,"छान"],[90,"छान"],[91,"पदार्थांचा"],[92,"घमघमाट"],[93,"सुटलाय,"],[94,"तोंडाला"],[95,"पाणी"],[96,"सुटतंय."]]},{"n":4,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/53935/size6/8d40ebb80f547a21f41e7eeda53d5dc9.jpg","text":"पहिला\nथांबा म्हणजे ली काकाचं दुकान.\n“ली\nकाका, मी उद्या माझ्या घरी परत जाणार मुंबईला. मी इथून काय घेऊन जाऊ बरोबर?”\n“या\nबघ छान छान जांभळट रंगाच्या साखरपाकातल्या आलुबुखाराच्या वड्या! प्लम कँडी!”\n“आहा, मस्त, आंबटगोड!”, जेनिस मिटक्या मारत म्हणते. “माझ्या\nभावाला खूप आवडतील त्या!”","words":[[97,"पहिला"],[98,"थांबा"],[99,"म्हणजे"],[100,"ली"],[101,"काकाचं"],[102,"दुकान."],[103,"“ली"],[104,"काका,"],[105,"मी"],[106,"उद्या"],[107,"माझ्या"],[108,"घरी"],[109,"परत"],[110,"जाणार"],[111,"मुंबईला."],[112,"मी"],[113,"इथून"],[114,"काय"],[115,"घेऊन"],[116,"जाऊ"],[117,"बरोबर?”"],[118,"“"],[119,"या"],[120,"बघ"],[121,"छान"],[122,"छान"],[123,"जांभळट"],[124,"रंगाच्या"],[125,"साखरपाकातल्या"],[126,"आलुबुखाराच्या"],[127,"वड्या!"],[128,"प्लम"],[129,"कँडी!”"],[130,"“आहा,"],[131,"मस्त,"],[132,"आंबटगोड!”,"],[133,"जेनिस"],[134,"मिटक्या"],[135,"मारत"],[136,"म्हणते."],[137,"“माझ्या"],[138,"भावाला"],[139,"खूप"],[140,"आवडतील"],[141,"त्या!”"]]},{"n":5,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/53936/size6/9ae694046b4926379c41d4f3a13d7534.jpg","text":"6/13","words":null},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/53937/size6/0a4635961189fe661eaf829b25ee6cfb.jpg","text":"पुढचं\nदुकान चेनमावशीचं.\n“चेनमावशी,\nमी उद्या मुंबईला परत जाणार. इथून काय घेऊन जाऊ मी?”\nहे घे,\nकाळे मश्रूम म्हणतात यांना. हे सूपमध्ये घालून खाल्लं की सर्दीपडसं \nलग्गेच बरं\nहोतं.”\n“अय्या,\nएखाद्या भल्या मोठ्या काळ्याकुट्ट कानासारखं दिसतंय हे.” \nजेनिसला गंमतच वाटते.\n“माझ्या\nआईला फार आवडेल हे.”","words":[[142,"पुढचं"],[143,"दुकान"],[144,"चेनमावशीचं."],[145,"“चेनमावशी,"],[146,"मी"],[147,"उद्या"],[148,"मुंबईला"],[149,"परत"],[150,"जाणार."],[151,"इथून"],[152,"काय"],[153,"घेऊन"],[154,"जाऊ"],[155,"मी?”"],[156,"हे"],[157,"घे,"],[158,"काळे"],[159,"मश्रूम"],[160,"म्हणतात"],[161,"यांना"],[162,"."],[163,"हे"],[164,"सूपमध्ये"],[165,"घालून"],[166,"खाल्लं"],[167,"की"],[168,"सर्दीपडसं"],[169,"लग्गेच"],[170,"बरं"],[171,"होतं.”"],[172,"“अय्या,"],[173,"एखाद्या"],[174,"भल्या"],[175,"मोठ्या"],[176,"काळ्याकुट्ट"],[177,"कानासारखं"],[178,"दिसतंय"],[179,"हे.”"],[180,"जेनिसला"],[181,"गंमतच"],[182,"वाटते."],[183,"“माझ्या"],[184,"आईला"],[185,"फार"],[186,"आवडेल"],[187,"हे.”"]]},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/53940/size6/f4b79bb1830bc9f4e23281fc2c93b819.jpg","text":"आता\nजेनिस शिरतेय वॉन्गताईच्या दुकानात. “वॉन्गताई,\nमी किनई उद्या मुंबईला परत जाणार माझ्या घरी. \nकाय नेऊ मी इथून?”. “हा रंगीबेरंगी\nकंदील कसा वाटतोय बघ?”\n“कित्ती\nसुंदर! अगदी गुलमोहराच्या फुलांसारखा लालचुटुक रंग आहे ह्याचा.” \nजेनिस म्हणते,\n“माझ्या बाबांना नक्कीच आवडेल हा.”","words":[[188,"आता"],[189,"जेनिस"],[190,"शिरतेय"],[191,"वॉन्गताईच्या"],[192,"दुकानात."],[193,"“वॉन्गताई,"],[194,"मी"],[195,"किनई"],[196,"उद्या"],[197,"मुंबईला"],[198,"परत"],[199,"जाणार"],[200,"माझ्या"],[201,"घरी."],[202,"काय"],[203,"नेऊ"],[204,"मी"],[205,"इथून?”."],[206,"“हा"],[207,"रंगीबेरंगी"],[208,"कंदील"],[209,"कसा"],[210,"वाटतोय"],[211,"बघ?”"],[212,"“कित्ती"],[213,"सुंदर!"],[214,"अगदी"],[215,"गुलमोहराच्या"],[216,"फुलांसारखा"],[217,"लालचुटुक"],[218,"रंग"],[219,"आहे"],[220,"ह्याचा.”"],[221,"जेनिस"],[222,"म्हणते,"],[223,"“माझ्या"],[224,"बाबांना"],[225,"नक्कीच"],[226,"आवडेल"],[227,"हा.”"]]},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/53829/size6/36ccaddc4a84e0ca36ecbdead0ac20d6.jpg","text":"सगळी खरेदी उरकलीय आणि जेनिसला आता भूक लागली आहे!\nलिऊआजी डम्पलिंग सूप आणि बावझी पाव मागवते.\n“स्स्सऽऽऽ, आहाऽऽऽ! \nकाय मस्त लागतंय हे!”, \nजेनिस जिभल्या\nचाटत म्हणते.","words":[[228,"सगळी"],[229,"खरेदी"],[230,"उरकलीय"],[231,"आणि"],[232,"जेनिसला"],[233,"आता"],[234,"भूक"],[235,"लागली"],[236,"आहे!"],[237,"लिऊआजी"],[238,"डम्पलिंग"],[239,"सूप"],[240,"आणि"],[241,"बावझी"],[242,"पाव"],[243,"मागवते."],[244,"“स्स्सऽऽऽ,"],[245,"आहाऽऽऽ!"],[246,"काय"],[247,"मस्त"],[248,"लागतंय"],[249,"हे!”,"],[250,"जेनिस"],[251,"जिभल्या"],[252,"चाटत"],[253,"म्हणते."]]},{"n":9,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/53830/size6/489cbffba1c9eeace800dcdb47d05830.jpg","text":"जेनिस आणि आजी एका देवळापाशी थांबतात. तिथं उदबत्त्यांचा मंद\nसुगंध दरवळतो आहे.\nलिऊआजी तिला सांगते, “जेव्हा माणसं मरतात आणि आपल्याला सोडून जातात, \nतेव्हा आत्म्याच्या रूपानं मात्र आपल्या भोवती राहतात. तू प्रवासाला निघण्याआधी आपण\nत्यांचे आशीर्वाद घेऊया.”","words":[[254,"जेनिस"],[255,"आणि"],[256,"आजी"],[257,"एका"],[258,"देवळापाशी"],[259,"थांबतात."],[260,"तिथं"],[261,"उदबत्त्यांचा"],[262,"मंद"],[263,"सुगंध"],[264,"दरवळतो"],[265,"आहे."],[266,"लिऊआजी"],[267,"तिला"],[268,"सांगते,"],[269,"“जेव्हा"],[270,"माणसं"],[271,"मरतात"],[272,"आणि"],[273,"आपल्याला"],[274,"सोडून"],[275,"जातात,"],[276,"तेव्हा"],[277,"आत्म्याच्या"],[278,"रूपानं"],[279,"मात्र"],[280,"आपल्या"],[281,"भोवती"],[282,"राहतात."],[283,"तू"],[284,"प्रवासाला"],[285,"निघण्याआधी"],[286,"आपण"],[287,"त्यांचे"],[288,"आशीर्वाद"],[289,"घेऊया.”"]]},{"n":10,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/53831/size6/491a179974e5334d98401ecc7783d9b9.jpg","text":"एका भल्या मोठ्या हॉलमध्ये बरेच लोक मजोंग नावाचा खेळ खेळत\nआहेत.\n“हे टाईल्सचे तुकडे म्हणजे ड्रॅगन, वारा आणि फुलं”, आजी जेनिसला समजावून सांगते.\n“ठिक्करपाणीच्या चौकोनांपेक्षा हे खूपच मजेदार आहे!” जेनिस\nम्हणते.","words":[[290,"एका"],[291,"भल्या"],[292,"मोठ्या"],[293,"हॉलमध्ये"],[294,"बरेच"],[295,"लोक"],[296,"मजोंग"],[297,"नावाचा"],[298,"खेळ"],[299,"खेळत"],[300,"आहेत."],[301,"“हे"],[302,"टाईल्सचे"],[303,"तुकडे"],[304,"म्हणजे"],[305,"ड्रॅगन,"],[306,"वारा"],[307,"आणि"],[308,"फुलं”,"],[309,"आजी"],[310,"जेनिसला"],[311,"समजावून"],[312,"सांगते."],[313,"“ठिक्करपाणीच्या"],[314,"चौकोनांपेक्षा"],[315,"हे"],[316,"खूपच"],[317,"मजेदार"],[318,"आहे!”"],[319,"जेनिस"],[320,"म्हणते."]]},{"n":11,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/53938/size6/1d5b3b052259d1c1c28653ed66fbee50.jpg","text":"परतीच्या\nवाटेवर जेनिसला एक बाई वर्तमानपत्र वाचताना दिसते.\n“हे चिनी भाषेतलं वर्तमानपत्र आहे का?” जेनिस\nविचारते.\n“होय!” लिऊआजी म्हणते,\n”हे आहे भारतात मिळणारं\nएकमेव चिनी वर्तमानपत्र. फक्त कोलकात्यातच मिळतं हं हे.”","words":[[321,"परतीच्या"],[322,"वाटेवर"],[323,"जेनिसला"],[324,"एक"],[325,"बाई"],[326,"वर्तमानपत्र"],[327,"वाचताना"],[328,"दिसते."],[329,"“हे"],[330,"चिनी"],[331,"भाषेतलं"],[332,"वर्तमानपत्र"],[333,"आहे"],[334,"का?”"],[335,"जेनिस"],[336,"विचारते."],[337,"“होय!”"],[338,"लिऊआजी"],[339,"म्हणते,"],[340,"”हे"],[341,"आहे"],[342,"भारतात"],[343,"मिळणारं"],[344,"एकमेव"],[345,"चिनी"],[346,"वर्तमानपत्र."],[347,"फक्त"],[348,"कोलकात्यातच"],[349,"मिळतं"],[350,"हं"],[351,"हे.”"]]},{"n":12,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/54000/size6/4c61adcad17200c4093ec90d8db52224.jpg","text":"घरी आल्यावर जेनिस सगळ्या भेटवस्तू रंगीत कागदात नीट\nगुंडाळत बसली आहे.\nलिऊआजी विचारते, “जेनिस बेटा, तू सगळ्यांसाठी काही ना काही भेटवस्तू\nघेतलीस, पण स्वतःसाठी इथून काय नेणार आहेस तू?”\n“आजी गं, तुझ्या-माझ्या एवढ्या छान छान आठवणी आहेत ना माझ्या\nमनात! त्या तर खास माझ्याच आहेत ना?”, जेनिस म्हणते.\n“तीच सगळ्यात मोठी भेट आहे\nगं\nमाझ्यासाठी!”","words":[[352,"घरी"],[353,"आल्यावर"],[354,"जेनिस"],[355,"सगळ्या"],[356,"भेटवस्तू"],[357,"रंगीत"],[358,"कागदात"],[359,"नीट"],[360,"गुंडाळत"],[361,"बसली"],[362,"आहे."],[363,"लिऊआजी"],[364,"विचारते,"],[365,"“जेनिस"],[366,"बेटा,"],[367,"तू"],[368,"सगळ्यांसाठी"],[369,"काही"],[370,"ना"],[371,"काही"],[372,"भेटवस्तू"],[373,"घेतलीस,"],[374,"पण"],[375,"स्वतःसाठी"],[376,"इथून"],[377,"काय"],[378,"नेणार"],[379,"आहेस"],[380,"तू?”"],[381,"“आजी"],[382,"गं,"],[383,"तुझ्या-माझ्या"],[384,"एवढ्या"],[385,"छान"],[386,"छान"],[387,"आठवणी"],[388,"आहेत"],[389,"ना"],[390,"माझ्या"],[391,"मनात!"],[392,"त्या"],[393,"तर"],[394,"खास"],[395,"माझ्याच"],[396,"आहेत"],[397,"ना?”,"],[398,"जेनिस"],[399,"म्हणते."],[400,"“तीच"],[401,"सगळ्यात"],[402,"मोठी"],[403,"भेट"],[404,"आहे"],[405,"गं"],[406,"माझ्यासाठी!”"]]}],"stats":{"pages":12,"words":405}}