          "dur": 2.760091
        },
        {
          "src": "https://s3.amazonaws.com/BloomLibraryBooks/72FD1KSMyV%2f1760005153687%2fLa+bont%c3%a9+du+li%c3%a8vre%2faudio%2fcce77aca-da9f-49ff-98a8-c88c29c9ec92.mp3",
          "dur": 5.960091
