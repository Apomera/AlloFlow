<th scope="col" class="px-2 py-1 text-left bg-slate-100 border border-slate-200 font-semibold text-slate-700">wcpm</th>
<th scope="col" class="px-2 py-1 text-left bg-slate-100 border border-slate-200 font-semibold text-slate-700">phase</th>
</tr>
</thead>
<tbody>
<tr>
<td class="px-2 py-1 border border-slate-200 text-slate-700">1</td>
<td class="px-2 py-1 border border-slate-200 text-slate-700">42</td>
<td class="px-2 py-1 border border-slate-200 text-slate-700">baseline</td>
</tr>
<tr>
