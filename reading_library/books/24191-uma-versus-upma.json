],[84,"onto"],[85,"her"],[86,"uniform."]]},{"n":4,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/52759/size6/c22f5305bdad55a5963e673eb6897510.jpg","text":"When it’s vadas for breakfast, Uma slides them onto her fingers like rings and pretends to be a great queen wearing many precious vada-jewels.","words":[[87,"When"],[88,"it’s"],[89,"vadas"],[90,"for"],[91,"breakfast,"],[92,"Uma"],[93,"slides"],[94,"them"],[95,"onto"],[96,"her"],[97,"fingers"],[98,"like"],[99,"rings"],[100,"and"],[101,"pretends"],[102,"to"],[103,"be"],[104,"a"],[105,"great"],[106,"queen"],[107,"wearing"],[108,"many"],[109,"precious"],[110,"vada-jewels."]]},{"n":5,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/52760/size6/cbb4bb101a14455e622e2178a243b62a.jpg","text":"Bondas are her least favourite. \nSo Uma stuffs them into the sides of her mouth and pretends she has chubby cheeks like that girl from Class 4-B.  \n“Bye, Amma!”","words":[[111,"Bondas"],[112,"are"],[113,"her"],[114,"least"],[115,"favourite."],[116,"So"],[117,"Uma"],[118,"stuffs"],[119,"them"],[120,"into"],[121,"the"],[122,"sides"],[123,"of"],[124,"her"],[125,"mouth"],[126,"and"],[127,"pretends"],[128,"she"],[129,"has"],[130,"chubby"],[131,"cheeks"],[132,"like"],[133,"that"],[134,"girl"],[135,"from"],[136,"Class"],[137,"4-B."],[138,"“Bye,"],[139,"Amma!”"]]},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/53110/size6/fd8e686de0a6d4cd59b1e19011939b01.jpg","text":"Amma is a great cook and her idlis are famous in their colony. But Uma doesn’t care much for Amma’s cooking.\nInstead, she fills her pockets with those famous soft-soft idlis and uses them as cushions on the school bus.","words":[[140,"Amma"],[141,"is"],[142,"a"],[143,"great"],[144,"cook"],[145,"and"],[146,"her"],[147,"idlis"],[148,"are"],[149,"famous"],[150,"in"],[151,"their"],[152,"colony."],[153,"But"],[154,"Uma"],[155,"doesn’t"],[156,"care"],[157,"much"],[158,"for"],[159,"Amma’s"],[160,"cooking."],[161,"Instead,"],[162,"she"],[163,"fills"],[164,"her"],[165,"pockets"],[166,"with"],[167,"those"],[168,"famous"],[169,"soft-soft"],[170,"idlis"],[171,"and"],[172,"uses"],[173,"them"],[174,"as"],[175,"cushions"],[176,"on"],[177,"the"],[178,"school"],[179,"bus."]]},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/52762/size6/acfa839aef21dfa18d41b9ce6767f6ac.jpg","text":"Uttapams become hats. \nPongal is fed to Malligai the cat. \nNothing can make Uma eat her breakfast.\nBut today, she has a small problem.\nAmma has made soft, mushy, squishy rawa upma \nand served it on her favourite plate.","words":[[180,"Uttapams"],[181,"become"],[182,"hats."],[183,"P"],[184,"ongal"],[185,"is"],[186,"fed"],[187,"to"],[188,"Malligai"],[189,"the"],[190,"cat."],[191,"Nothing"],[192,"can"],[193,"make"],[194,"Uma"],[195,"eat"],[196,"her"],[197,"breakfast."],[198,"But"],[199,"today,"],[200,"she"],[201,"has"],[202,"a"],[203,"small"],[204,"problem."],[205,"Amma"],[206,"has"],[207,"made"],[208,"soft,"],[209,"mushy,"],[210,"squishy"],[211,"rawa"],[212,"upma"],[213,"and"],[214,"served"],[215,"it"],[216,"on"],[217,"her"],[218,"favourite"],[219,"plate."]]},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/52763/size6/4ccd6cb3e3b8464427354b0559a50469.jpg","text":"But what can Uma do with this upma?\n \nShe can’t pin it to her uniform. \nIt wouldn’t stay.\nShe can’t wear it as rings. \nIt wouldn’t fit.\nShe can’t stuff it into her cheeks. \nIt would melt.\nShe can’t use it as a cushion. \nWhat a useless cushion!\nShe can’t wear it as a hat. \nIt would fall off!\nAnd she can’t feed it to Malligai the cat \nbecause everyone knows \nthat cats hate upma!","words":[[220,"But"],[221,"what"],[222,"can"],[223,"Uma"],[224,"do"],[225,"with"],[226,"this"],[227,"upma?"],[228,"She"],[229,"can’t"],[230,"pin"],[231,"it"],[232,"to"],[233,"her"],[234,"uniform."],[235,"It"],[236,"wouldn’t"],[237,"stay."],[238,"She"],[239,"can’t"],[240,"wear"],[241,"it"],[242,"as"],[243,"rings."],[244,"It"],[245,"wouldn’t"],[246,"fit."],[247,"She"],[248,"can’t"],[249,"stuff"],[250,"it"],[251,"into"],[252,"her"],[253,"cheeks."],[254,"It"],[255,"would"],[256,"melt."],[257,"She"],[258,"can’t"],[259,"use"],[260,"it"],[261,"as"],[262,"a"],[263,"cushion."],[264,"What"],[265,"a"],[266,"useless"],[267,"cushion!"],[268,"She"],[269,"can’t"],[270,"wear"],[271,"it"],[272,"as"],[273,"a"],[274,"hat."],[275,"It"],[276,"would"],[277,"fall"],[278,"off!"],[279,"And"],[280,"she"],[281,"can’t"],[282,"feed"],[283,"it"],[284,"to"],[285,"Malligai"],[286,"the"],[287,"cat"],[288,"because"],[289,"everyone"],[290,"knows"],[291,"that"],[292,"cats"],[293,"hate"],[294,"upma!"]]},{"n":9,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/53218/size6/2bc25188509187d0550a6f13483e8efd.jpg","text":"Uma wonders what to do with the upma. \nAs she thinks and blinks and twirls her curls, she puts a spoon of upma in her mouth by mistake.\nOooh! What was that she just bit into? A salty, roasted cashew filled with ghee! Yum!","words":[[295,"Uma"],[296,"wonders"],[297,"what"],[298,"to"],[299,"do"],[300,"with"],[301,"the"],[302,"upma."],[303,"As"],[304,"she"],[305,"thinks"],[306,"and"],[307,"blinks"],[308,"and"],[309,"twirls"],[310,"her"],[311,"curls,"],[312,"she"],[313,"puts"],[314,"a"],[315,"spoon"],[316,"of"],[317,"upma"],[318,"in"],[319,"her"],[320,"mouth"],[321,"by"],[322,"mistake."],[323,"Oooh!"],[324,"What"],[325,"was"],[326,"that"],[327,"she"],[328,"just"],[329,"bit"],[330,"into?"],[331,"A"],[332,"salty,"],[333,"roasted"],[334,"cashew"],[335,"filled"],[336,"with"],[337,"ghee!"],[338,"Yum!"]]},{"n":10,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/52943/size6/3f255159e5560cac0853e5d79660c4e9.jpg","text":"Uma takes another bite hoping to find more cashews.\nBut she bites into something crunchy, fresh and juicy instead. Carrots! Mmm!","words":[[339,"Uma"],[340,"takes"],[341,"another"],[342,"bite"],[343,"hoping"],[344,"to"],[345,"find"],[346,"more"],[347,"cashews."],[348,"But"],[349,"she"],[350,"bites"],[351,"into"],[352,"something"],[353,"crunchy,"],[354,"fresh"],[355,"and"],[356,"juicy"],[357,"instead."],[358,"Carrots!"],[359,"Mmm!"]]},{"n":11,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/52944/size6/4854a523bacfa703ef58ae5883d146dc.jpg","text":"She takes another bite, wondering what she would find this time.\nOwwwwiee! What is this strong and spicy little piece?\nAh… ginger!","words":[[360,"She"],[361,"takes"],[362,"another"],[363,"bite,"],[364,"wondering"],[365,"what"],[366,"she"],[367,"would"],[368,"find"],[369,"this"],[370,"time."],[371,"Owwwwiee!"],[372,"What"],[373,"is"],[374,"this"],[375,"strong"],[376,"and"],[377,"spicy"],[378,"little"],[379,"piece?"],[380,"Ah…"],[381,"ginger!"]]},{"n":12,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/52945/size6/d08f4b25d389d472f8921cb4c1dd303f.jpg","text":"Curious, Uma can’t stop now.\nBut oooh, aaah, ouch! She just bit into a green chilli and her mouth is burning!\nUma gobbles up all the upma to put out the fire in her mouth.","words":[[382,"Curious,"],[383,"Uma"],[384,"can’t"],[385,"stop"],[386,"now."],[387,"But"],[388,"oooh,"],[389,"aaah,"],[390,"ouch!"],[391,"She"],[392,"just"],[393,"bit"],[394,"into"],[395,"a"],[396,"green"],[397,"chilli"],[398,"and"],[399,"her"],[400,"mouth"],[401,"is"],[402,"burning!"],[403,"Uma"],[404,"gobbles"],[405,"up"],[406,"all"],[407,"the"],[408,"upma"],[409,"to"],[410,"put"],[411,"out"],[412,"the"],[413,"fire"],[414,"in"],[415,"her"],[416,"mouth."]]},{"n":13,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/52946/size6/c01a05aa102aca045857714acfa95b88.jpg","text":"The fire is finally out. And guess what?\nAnd her plate is empty!","words":[[417,"The"],[418,"fire"],[419,"is"],[420,"finally"],[421,"out."],[422,"And"],[423,"guess"],[424,