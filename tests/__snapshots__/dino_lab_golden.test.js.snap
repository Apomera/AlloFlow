</button>
<button aria-label="Cell 9, row 2, column 3, bone fragment uncovered." aria-disabled="true" style="aspect-ratio:1 / 1;border-radius:8px;cursor:default;border:1px solid var(--allo-stem-border, #334155);background:rgba(245,158,11,0.25);color:var(--allo-stem-text, #f1f5f9);font-size:20px;display:flex;align-items:center;justify-content:center">🦴</button>
<button aria-label="Cell 10, row 2, column 4, bone fragment uncovered." aria-disabled="true" style="aspect-ratio:1 / 1;border-radius:8px;cursor:default;border:1px solid var(--allo-stem-border, #334155);background:rgba(245,158,11,0.25);color:var(--allo-stem-text, #f1f5f9);font-size:20px;display:flex;align-items:center;justify-content:center">🦴</button>
