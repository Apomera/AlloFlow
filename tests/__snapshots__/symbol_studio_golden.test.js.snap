<div style="display:flex;flex-direction:column;gap:6px">
<div style="display:flex;gap:6px;flex-wrap:wrap">
<select id="iep-goal-type" aria-label="IEP goal type" style="font-size:11px;border:1px solid #d1d5db;border-radius:6px;padding:4px 6px;background:#fff">
<option value="expressive">Expressive</option>
<option value="receptive">Receptive</option>
<option value="social">Social</option>
<option value="pragmatic">Pragmatic</option>
<option value="articulation">Articulation</option>
</select>
<input id="iep-goal-text" type="text" placeholder="e.g. Request items using 2-word phrases" aria-label="IEP goal description" style="width:100%;border:1px solid #d1d5db;border-radius:6px;padding:7px 9px;font-size:11px;box-sizing:border-box;font-family:inherit;background:#fff;color:inherit;flex:1;margin:0;min-width:200px"/>
<input id="iep-goal-target" type="number" min="1" max="200" placeholder="# target" aria-label="IEP goal target count" style="width:60px;font-size:11px;border:1px solid #d1d5db;border-radius:6px;padding:4px 6px;text-align:center"/>
</div>
<details style="font-size:10px">
<summary style="cursor:pointer;color:#6b7280;font-weight:700;padding:2px 0">+ IEP team details (priority, baseline, target date, cue level)</summary>
<div style="display:grid;grid-template-columns:repeat(auto-fill, minmax(140px, 1fr));gap:6px;margin-top:6px">
<label style="display:flex;flex-direction:column;gap:2px">
<span style="color:#374151;font-weight:700">Priority</span>
<select id="iep-goal-priority" style="font-size:11px;padding:4px 6px;border:1px solid #d1d5db;border-radius:6px">
<option value="standard">Standard</option>
<option value="high">High</option>
<option value="maintenance">Maintenance</option>
</select>
</label>
<label style="display:flex;flex-direction:column;gap:2px">
<span style="color:#374151;font-weight:700">Cue level</span>
<select id="iep-goal-cue" style="font-size:11px;padding:4px 6px;border:1px solid #d1d5db;border-radius:6px" title="Support required for the student to succeed on this goal">
<option value="independent">Independent</option>
<option value="visual">Visual cue</option>
<option value="verbal">Verbal cue</option>
<option value="gestural">Gestural cue</option>
<option value="physical">Physical prompt</option>
</select>
</label>
<label style="display:flex;flex-direction:column;gap:2px">
<span style="color:#374151;font-weight:700">Data method</span>
<select id="iep-goal-datamethod" style="font-size:11px;padding:4px 6px;border:1px solid #d1d5db;border-radius:6px">
<option value="frequency">Frequency count</option>
<option value="percentage">Percentage accuracy</option>
<option value="duration">Duration</option>
<option value="rubric">Rubric score</option>
</select>
</label>
<label style="display:flex;flex-direction:column;gap:2px">
<span style="color:#374151;font-weight:700">Target date</span>
<input id="iep-goal-targetdate" type="date" style="font-size:11px;padding:4px 6px;border:1px solid #d1d5db;border-radius:6px"/>
</label>
<label style="display:flex;flex-direction:column;gap:2px;grid-column:1 / -1">
<span style="color:#374151;font-weight:700">Baseline</span>
<input id="iep-goal-baseline" type="text" placeholder="e.g. 2/10 accuracy on probe trials (Sept 2026)" style="font-size:11px;padding:4px 6px;border:1px solid #d1d5db;border-radius:6px"/>
</label>
<label style="display:flex;flex-direction:column;gap:2px;grid-column:1 / -1">
<span style="color:#374151;font-weight:700">Accommodations</span>
<input id="iep-goal-accom" type="text" placeholder="e.g. AAC device available, visual supports, extended time" style="font-size:11px;padding:4px 6px;border:1px solid #d1d5db;border-radius:6px"/>
</label>
<label style="display:flex;flex-direction:column;gap:2px;grid-column:1 / -1">
<span style="color:#374151;font-weight:700">Linked IEP section (optional)</span>
<input id="iep-goal-iepsection" type="text" placeholder="e.g. Communication — Expressive Language" style="font-size:11px;padding:4px 6px;border:1px solid #d1d5db;border-radius:6px"/>
</label>
</div>
</details>
<button aria-label="Add new IEP goal" style="padding:8px 14px;background:#7c3aed;color:#fff;border:none;border-radius:7px;font-weight:600;font-size:12px;cursor:pointer;white-space:nowrap">+ Add Goal</button>
</div>
</div>
</div>
<div style="flex:1;overflow:hidden;display:flex;flex-direction:column">
<div style="display:flex;flex-direction:column;flex:1;overflow:hidden;padding:16px;gap:12px">
<div style="flex-shrink:0;display:flex;gap:6px;align-items:center;padding:6px 10px;background:#f0fdf4;border-radius:8px;border:1px solid #d1fae5;flex-wrap:wrap">
<span style="font-size:10px;font-weight:600;color:#059669;white-space:nowrap">🌱 Could grow in a schedule:</span>
<button aria-label="Add Take deep breaths to schedule input" title="Add to schedule activities" style="padding:2px 8px;background:#fff;border:1px solid #4ade80;border-radius:12px;font-size:10px;font-weight:600;color:#15803d;cursor:pointer">Take deep breaths<span style="color:#9ca3af;margin-left:2px">+</span>
</button>
<button aria-label="Add Count to 10 to schedule input" title="Add to schedule activities" style="padding:2px 8px;background:#fff;border:1px solid #4ade80;border-radius:12px;font-size:10px;font-weight:600;color:#15803d;cursor:pointer">Count to 10<span style="color:#9ca3af;margin-left:2px">+</span>
</button>
<button aria-label="Add Take a walk to schedule input" title="Add to schedule activities" style="padding:2px 8px;background:#fff;border:1px solid #4ade80;border-radius:12px;font-size:10px;font-weight:600;color:#15803d;cursor:pointer">Take a walk<span style="color:#9ca3af;margin-left:2px">+</span>
</button>
<button aria-label="Add Squeeze a stress ball to schedule input" title="Add to schedule activities" style="padding:2px 8px;background:#fff;border:1px solid #4ade80;border-radius:12px;font-size:10px;font-weight:600;color:#15803d;cursor:pointer">Squeeze a stress ball<span style="color:#9ca3af;margin-left:2px">+</span>
</button>
<button aria-label="Add Ask for help to schedule input" title="Add to schedule activities" style="padding:2px 8px;background:#fff;border:1px solid #4ade80;border-radius:12px;font-size:10px;font-weight:600;color:#15803d;cursor:pointer">Ask for help<span style="color:#9ca3af;margin-left:2px">+</span>
</button>
</div>
<div style="display:flex;gap:10px;align-items:flex-end;flex-wrap:wrap;flex-shrink:0">
<div style="flex:1">
<label style="font-size:11px;font-weight:600;color:#374151;display:block;margin-bottom:3px">Activities (one per line)</label>
<textarea placeholder="brush teeth
get dressed
eat breakfast
board the bus
arrive at school" aria-label="Schedule activities, one per line" style="width:100%;border:1px solid #d1d5db;border-radius:6px;padding:7px 9px;font-size:12px;box-sizing:border-box;font-family:inherit;resize:vertical;background:#fff;color:inherit;height:70px">
</textarea>
</div>
<div style="display:flex;flex-direction:column;gap:6px">
<div>
<label style="font-size:11px;font-weight:600;color:#374151;display:block;margin-bottom:3px">Layout</label>
<select aria-label="Schedule layout" style="width:auto;border:1px solid #d1d5db;border-radius:6px;padding:7px 9px;font-size:13px;box-sizing:border-box;font-family:inherit;background:#fff;color:inherit">
<option value="horizontal" selected="">Horizontal Strip</option>
<option value="vertical">Vertical List</option>
</select>
</div>
<button disabled="" aria-label="Generate visual schedule" style="padding:8px 14px;background:#d1d5db;color:#6b7280;border:none;border-radius:7px;font-weight:600;font-size:12px;cursor:not-allowed;white-space:nowrap">✨ Generate Schedule</button>
</div>
</div>
<div style="flex:1;display:flex;align-items:center;justify-content:center;color:#6b7280;flex-direction:column;gap:10px">
<div style="font-size:48px">📅</div>
<p style="font-weight:600">Build a personalized visual schedule</p>
<p style="font-size:12px;max-width:360px;text-align:center">Enter activities, generate AI symbols, then tap to mark each as complete. Print as a laminated strip for the classroom or home.</p>
</div>
</div>
</div>
</div>
</div>
</div>"
`;

