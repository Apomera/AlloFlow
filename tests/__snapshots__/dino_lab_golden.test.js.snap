<button aria-label="Open Supersaurus" style="font-size:11.5px;padding:4px 10px;border-radius:999px;cursor:pointer;border:1px solid #22c55e66;background:#22c55e18;color:var(--allo-stem-text, #f1f5f9);margin-right:5px;margin-bottom:5px">🌿 Supersaurus</button>
