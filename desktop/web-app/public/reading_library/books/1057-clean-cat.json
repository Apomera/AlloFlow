[47,"clean"],[48,"without"],[49,"water."],[50,"I"],[51,"do"],[52,"not"],[53,"need"],[54,"a"],[55,"bath"],[56,"like"],[57,"Tommy."]]},{"n":5,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/13143/size6/fa4938101bf382482e7a57aeb299f6a9.jpg","text":"Shhh... don’t tell anyone that I am hiding here.\n1... 2... 3... Got you!","words":[[58,"Shhh..."],[59,"don’t"],[60,"tell"],[61,"anyone"],[62,"that"],[63,"I"],[64,"am"],[65,"hiding"],[66,"here."],[67,"1..."],[68,"2..."],[69,"3..."],[70,"Got"],[71,"you!"]]},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/13144/size6/048e1b89ae71c22d4b919b226d682ad8.jpg","text":"Ma shouts at me, when I bring some tasty food from the garden.","words":[[72,"Ma"],[73,"shouts"],[74,"at"],[75,"me,"],[76,"when"],[77,"I"],[78,"bring"],[79,"some"],[80,"tasty"],[81,"food"],[82,"from"],[83,"the"],[84,"garden."]]},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/13145/size6/7a79af6210b86d479916e700ded8c8b6.jpg","text":"I can climb trees. I can jump. I know all the short cuts here.","words":[[85,"I"],[86,"can"],[87,"climb"],[88,"trees."],[89,"I"],[90,"can"],[91,"jump."],[92,"I"],[93,"know"],[94,"all"],[95,"the"],[96,"short"],[97,"cuts"],[98,"here."]]},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/13146/size6/84a9198abaf653b011ff2786bc0070f4.jpg","text":"Sanju lives nearby. He teases me. It makes me very angry.","words":[[99,"Sanju"],[100,"lives"],[101,"nearby."],[102,"He"],[103,"teases"],[104,"me."],[105,"It"],[106,"makes"],[107,"me"],[108,"very"],[109,"angry."]]},{"n":9,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/13147/size6/59ed3dd3eb94ca0f11562dff164cc82f.jpg","text":"Please tell Sanju that the tiger is from our cat family. We have sharp claws.","words":[[110,"Please"],[111,"tell"],[112,"Sanju"],[113,"that"],[114,"the"],[115,"tiger"],[116,"is"],[117,"from"],[118,"our"],[119,"cat"],[120,"family."],[121,"We"],[122,"have"],[123,"sharp"],[124,"claws."]]},{"n":10,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/13148/size6/984fcc79429722dfe614c1991acf1d76.jpg","text":"My friends sometimes make a lot of noise at night. By then I am quietly in bed.","words":[[125,"My"],[126,"friends"],[127,"sometimes"],[128,"make"],[129,"a"],[130,"lot"],[131,"of"],[132,"noise"],[133,"at"],[134,"night."],[135,"By"],[136,"then"],[137,"I"],[138,"am"],[139,"quietly"],[140,"in"],[141,"bed."]]},{"n":11,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/13149/size6/53b5c35a790856ff2942f2778e859eef.jpg","text":"Tails can speak!\n \nDid you know how animals and birds tell us something by using their tails?\nA dog wags its tail when it is happy. A cat puffs up its tail when it is angry.\n \nOften we say, “As clean as a cat”. This is because cats do not like water, yet they are always keeping themselves clean by licking themselves.","words":[[142,"Tails"],[143,"can"],[144,"speak!"],[145,"Did"],[146,"you"],[147,"know"],[148,"how"],[149,"animals"],[150,"and"],[151,"birds"],[152,"tell"],[153,"us"],[154,"something"],[155,"by"],[156,"using"],[157,"their"],[158,"tails?"],[159,"A"],[160,"dog"],[161,"wags"],[162,"its"],[163,"tail"],[164,"when"],[165,"it"],[166,"is"],[167,"happy."],[168,"A"],[169,"cat"],[170,"puffs"],[171,"up"],[172,"its"],[173,"tail"],[174,"when"],[175,"it"],[176,"is"],[177,"angry."],[178,"Often"],[179,"we"],[180,"say,"],[181,"“As"],[182,"clean"],[183,"as"],[184,"a"],[185,"cat”."],[186,"This"],[187,"is"],[188,"because"],[189,"cats"],[190,"do"],[191,"not"],[192,"like"],[193,"water,"],[194,"yet"],[195,"they"],[196,"are"],[197,"always"],[198,"keeping"],[199,"themselves"],[200,"clean"],[201,"by"],[202,"licking"],[203,"themselves."]]}],"stats":{"pages":11,"words":203}}