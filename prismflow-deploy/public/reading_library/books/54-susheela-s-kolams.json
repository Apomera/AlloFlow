.."]]},{"n":4,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/675/size6/7b2037f5ebc2b273a0c6983253c8ea9d.jpg","text":"... on trains and on the sides of tall buildings...","words":[[40,"..."],[41,"on"],[42,"trains"],[43,"and"],[44,"on"],[45,"the"],[46,"sides"],[47,"of"],[48,"tall"],[49,"buildings..."]]},{"n":5,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/676/size6/4146ccffd099837da7dfced5dccd41f6.jpg","text":"... even on kites that skipped in the sky.\nEveryone admired Susheela's kolams!","words":[[50,"..."],[51,"even"],[52,"on"],[53,"kites"],[54,"that"],[55,"skipped"],[56,"in"],[57,"the"],[58,"sky."],[59,"Everyone"],[60,"admired"],[61,"Susheela's"],[62,"kolams!"]]},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/677/size6/a2fe0eb4f77e39a1f74fad8420650f23.jpg","text":"One day, the Air Force asked her to help them make a kolam!\nSusheela told the pilots how to dip, dive and turn their planes...","words":[[63,"One"],[64,"day,"],[65,"the"],[66,"Air"],[67,"Force"],[68,"asked"],[69,"her"],[70,"to"],[71,"help"],[72,"them"],[73,"make"],[74,"a"],[75,"kolam!"],[76,"Susheela"],[77,"told"],[78,"the"],[79,"pilots"],[80,"how"],[81,"to"],[82,"dip,"],[83,"dive"],[84,"and"],[85,"turn"],[86,"their"],[87,"planes..."]]},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/678/size6/c83d4b390d21002fff2f3e75154998e9.jpg","text":"... and in minutes there was a big, beautiful and colourful kolam in the sky, that everyone in the city could see!","words":[[88,"..."],[89,"and"],[90,"in"],[91,"minutes"],[92,"there"],[93,"was"],[94,"a"],[95,"big,"],[96,"beautiful"],[97,"and"],[98,"colourful"],[99,"kolam"],[100,"in"],[101,"the"],[102,"sky,"],[103,"that"],[104,"everyone"],[105,"in"],[106,"the"],[107,"city"],[108,"could"],[109,"see!"]]},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/679/size6/3fead2ce31ec6501f1ded1ab41288988.jpg","text":"That night, Susheela stood on her terrace and looked up at the sky. She saw the stars twinkling down at her.\nWhere do you think Susheela will make her next kolam?","words":[[110,"That"],[111,"night,"],[112,"Susheela"],[113,"stood"],[114,"on"],[115,"her"],[116,"terrace"],[117,"and"],[118,"looked"],[119,"up"],[120,"at"],[121,"the"],[122,"sky."],[123,"She"],[124,"saw"],[125,"the"],[126,"stars"],[127,"twinkling"],[128,"down"],[129,"at"],[130,"her."],[131,"Where"],[132,"do"],[133,"you"],[134,"think"],[135,"Susheela"],[136,"will"],[137,"make"],[138,"her"],[139,"next"],[140,"kolam?"]]},{"n":9,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/680/size6/dd9e423a7ce8165bdc7da1f290619abe.jpg","text":"Know more about Kolams...\n \nKolams are beautiful patterns made freehand or by joining dots. People decorate the outside of their homes with kolams to welcome a new day. They are also thought to bring good luck. Traditionally, the powder used to make kolams is made out of rice flour.\n \nKolams are also known as Moggu, Rangoli, Chowkpurna, Alpana and Hase Chittara. What do you call a kolam in your part of the country?","words":[[141,"Know"],[142,"more"],[143,"about"],[144,"Kolams..."],[145,"Kolams"],[146,"are"],[147,"beautiful"],[148,"patterns"],[149,"made"],[150,"freehand"],[151,"or"],[152,"by"],[153,"joining"],[154,"dots."],[155,"People"],[156,"decorate"],[157,"the"],[158,"outside"],[159,"of"],[160,"their"],[161,"homes"],[162,"with"],[163,"kolams"],[164,"to"],[165,"welcome"],[166,"a"],[167,"new"],[168,"day."],[169,"They"],[170,"are"],[171,"also"],[172,"thought"],[173,"to"],[174,"bring"],[175,"good"],[176,"luck."],[177,"Traditionally,"],[178,"the"],[179,"powder"],[180,"used"],[181,"to"],[182,"make"],[183,"kolams"],[184,"is"],[185,"made"],[186,"out"],[187,"of"],[188,"rice"],[189,"flour."],[190,"Kolams"],[191,"are"],[192,"also"],[193,"known"],[194,"as"],[195,"Moggu,"],[196,"Rangoli,"],[197,"Chowkpurna,"],[198,"Alpana"],[199,"and"],[200,"Hase"],[201,"Chittara."],[202,"What"],[203,"do"],[204,"you"],[205,"call"],[206,"a"],[207,"kolam"],[208,"in"],[209,"your"],[210,"part"],[211,"of"],[212,"the"],[213,"country?"]]}],"stats":{"pages":9,"words":213}}