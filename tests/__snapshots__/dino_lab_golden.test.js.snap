<div id="dinopanel" role="tabpanel" aria-labelledby="dinotab-map" style="padding:16px">
<div>
<div style="margin-bottom:12px">
<div style="font-size:18px;font-weight:800">🌎 Where in the world?</div>
<div style="font-size:12.5px;color:var(--allo-stem-text-soft, #94a3b8);margin-top:2px">Present-day fossil locations, shaped by continental drift and an uneven discovery record.</div>
</div>
<div class="dinolab-world-map" role="group" aria-label="Map of where dinosaur fossils are found today, by continent" style="position:relative;width:100%;height:0;padding-bottom:52%;overflow:hidden;border-radius:12px;background-color:#0c2940;background-image:linear-gradient(rgba(125,211,252,0.10) 1px, transparent 1px),linear-gradient(90deg, rgba(125,211,252,0.10) 1px, transparent 1px),radial-gradient(circle at 50% 42%, rgba(56,189,248,0.18), rgba(2,6,23,0.18));background-size:12.5% 25%, 12.5% 25%, 100% 100%;border:1px solid var(--allo-stem-border, #334155);margin-bottom:8px">
<div aria-hidden="true" style="position:absolute;left:9px;bottom:7px;color:#bae6fd;font-size:10px;font-weight:800;letter-spacing:0.05em">PRESENT-DAY CONTINENTS</div>
<div style="position:absolute;left:0;top:0;right:0;bottom:0">
<button aria-pressed="false" aria-label="North America, 115 dinosaurs in this teaching catalog" style="position:absolute;left:4%;top:7%;width:29%;height:31%;clip-path:polygon(10% 15%,34% 3%,68% 11%,96% 30%,80% 54%,60% 60%,48% 92%,26% 78%,18% 50%,0 36%);cursor:pointer;border:none;background:hsl(145, 58%, 48%);color:#0f172a;font-weight:800;padding:3px;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;box-shadow:inset 0 0 0 2px rgba(15,23,42,0.24);transform:rotate(-3deg);z-index:1">
<span aria-hidden="true" style="font-size:17px;line-height:1">🦬</span>
<span style="font-size:10.5px;line-height:1.1;max-width:88%">North America</span>
<span style="font-size:14px;line-height:1.05;font-weight:900">115</span>
</button>
<button aria-pressed="false" aria-label="South America, 51 dinosaurs in this teaching catalog" style="position:absolute;left:23%;top:47%;width:17%;height:43%;clip-path:polygon(8% 2%,85% 10%,100% 28%,66% 54%,57% 88%,34% 100%,20% 62%,0 24%);cursor:pointer;border:none;background:hsl(145, 58%, 70%);color:#0f172a;font-weight:800;padding:3px;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;box-shadow:inset 0 0 0 2px rgba(15,23,42,0.24);transform:rotate(-5deg);z-index:1">
<span aria-hidden="true" style="font-size:17px;line-height:1">🦥</span>
<span style="font-size:10.5px;line-height:1.1;max-width:88%">South America</span>
<span style="font-size:14px;line-height:1.05;font-weight:900">51</span>
</button>
<button aria-pressed="false" aria-label="Europe, 40 dinosaurs in this teaching catalog" style="position:absolute;left:45%;top:10%;width:14%;height:18%;clip-path:polygon(8% 24%,30% 4%,55% 18%,78% 5%,100% 35%,72% 62%,90% 90%,48% 82%,20% 100%,0 62%);cursor:pointer;border:none;background:hsl(145, 58%, 74%);color:#0f172a;font-weight:800;padding:3px;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;box-shadow:inset 0 0 0 2px rgba(15,23,42,0.24);transform:rotate(2deg);z-index:1">
<span aria-hidden="true" style="font-size:17px;line-height:1">🏰</span>
<span style="font-size:10.5px;line-height:1.1;max-width:88%">Europe</span>
<span style="font-size:14px;line-height:1.05;font-weight:900">40</span>
</button>
<button aria-pressed="false" aria-label="Africa, 32 dinosaurs in this teaching catalog" style="position:absolute;left:44%;top:29%;width:21%;height:39%;clip-path:polygon(12% 8%,52% 0,94% 17%,100% 42%,74% 79%,49% 100%,28% 76%,15% 49%,0 27%);cursor:pointer;border:none;background:hsl(145, 58%, 77%);color:#0f172a;font-weight:800;padding:3px;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;box-shadow:inset 0 0 0 2px rgba(15,23,42,0.24);transform:rotate(1deg);z-index:1">
<span aria-hidden="true" style="font-size:17px;line-height:1">🦒</span>
<span style="font-size:10.5px;line-height:1.1;max-width:88%">Africa</span>
<span style="font-size:14px;line-height:1.05;font-weight:900">32</span>
</button>
<button aria-pressed="true" aria-label="Asia, 114 dinosaurs in this teaching catalog" style="position:absolute;left:58%;top:5%;width:38%;height:39%;clip-path:polygon(0 25%,20% 4%,55% 0,76% 13%,100% 12%,91% 38%,72% 50%,64% 83%,38% 72%,24% 95%,11% 64%);cursor:pointer;border:none;background:hsl(145, 58%, 48%);color:#0f172a;font-weight:800;padding:3px;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;box-shadow:inset 0 0 0 5px #14532d, 0 0 0 3px #5eead4;transform:rotate(1deg);z-index:2">
<span aria-hidden="true" style="font-size:17px;line-height:1">🐼</span>
<span style="font-size:10.5px;line-height:1.1;max-width:88%">Asia</span>
<span style="font-size:14px;line-height:1.05;font-weight:900">114</span>
