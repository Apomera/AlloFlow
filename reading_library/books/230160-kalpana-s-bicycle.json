تِفَيْهَا"],[28,"وَقَالَتْ:"],[29,"\"لَقَدْ"],[30,"حَصَلَ"],[31,"الطِّفْلُ"],[32,"عَلَى"],[33,"دَرَّاجَةٍ"],[34,"أُخْرَى\"."]]},{"n":2,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/32649/size6/742f92d20923061f40baa26138483a7a.jpg","text":"رَكِبَتْ أَمَل الدَّرَّاجَةَ. \nدُمممممممممم!\nلَقَدْ سَقَطَتْ. فَضَحِكَ عَامِرٌ وَقَالَ: \n\"إِنَّكِ لَا تَسْتَطِيعِينَ التَّوَازُنَ بِدَرَّاجَةٍ ذَاتِ عَجَلَتَيْنِ، يَجِبُ أَنْ تَتَعَلَّمِي كَيْفِيَّةَ رُكُوبِهَا\". \nفَتَوَسَّلَتْ إِلَيْهِ أَمَل\nقَائِلَةً: \"عَلِّمْنِي\".","words":[[35,"رَكِبَتْ"],[36,"أَمَل"],[37,"الدَّرَّاجَةَ."],[38,"دُمممممممممم!"],[39,"لَقَدْ"],[40,"سَقَطَتْ."],[41,"فَضَحِكَ"],[42,"عَامِرٌ"],[43,"وَقَالَ:"],[44,"\"إِنَّكِ"],[45,"لَا"],[46,"تَسْتَطِيعِينَ"],[47,"التَّوَازُنَ"],[48,"بِدَرَّاجَةٍ"],[49,"ذَاتِ"],[50,"عَجَلَتَيْنِ،"],[51,"يَجِبُ"],[52,"أَنْ"],[53,"تَتَعَلَّمِي"],[54,"كَيْفِيَّةَ"],[55,"رُكُوبِهَا\"."],[56,"فَتَوَسَّلَتْ"],[57,"إِلَيْهِ"],[58,"أَمَل"],[59,"قَائِلَةً:"],[60,"\"عَلِّمْنِي\"."]]},{"n":3,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/32650/size6/d7fabdb4672f2203e602951a3e5bc03a.jpg","text":"لِذَلِكَ كُلَّ مَسَاءٍ بَعْدَ الْمَدْرَسَةِ، كَانَ عَامِرٌ وَأَمَل يَذْهَبَانِ إِلَى طَرِيقِ بِنْغِلُو.\nلَا تُوجَدُ حَرَكَةُ مُرُورٍ كَثِيفَةٌ هُنَاكَ؛ فَقَطِ الْمَنَازِلُ الْكَبِيرَةُ وَالْكِلَابُ الْكَبِيرَةُ.","words":[[61,"لِذَلِكَ"],[62,"كُلَّ"],[63,"مَسَاءٍ"],[64,"بَعْدَ"],[65,"الْمَدْرَسَةِ،"],[66,"كَانَ"],[67,"عَامِرٌ"],[68,"وَأَمَل"],[69,"يَذْهَبَانِ"],[70,"إِلَى"],[71,"طَرِيقِ"],[72,"بِنْغِلُو."],[73,"لَا"],[74,"تُوجَدُ"],[75,"حَرَكَةُ"],[76,"مُرُورٍ"],[77,"كَثِيفَةٌ"],[78,"هُنَاكَ؛"],[79,"فَقَطِ"],[80,"الْمَنَازِلُ"],[81,"الْكَبِيرَةُ"],[82,"وَالْكِلَابُ"],[83,"الْكَبِيرَةُ."]]},{"n":4,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/32651/size6/81b9063b6a6db7edccf1c719c8ac3cb8.jpg","text":"اعْتَادَ جَمِيعُ الْأَطْفَالِ فِي مِنْطَقَتِهِمُ الذَّهَابَ لِلَّعِبِ فِي هَذَا الشَّارِعِ.\nفِي الْيَوْمِ الْأَوَّلِ، كَانَتْ أَمَل مُتَشَوِّقَةً لِبَدْءِ التَّعَلُّمِ.\nوَلَكِنْ...","words":[[84,"اعْتَادَ"],[85,"جَمِيعُ"],[86,"الْأَطْفَالِ"],[87,"فِي"],[88,"مِنْطَقَتِهِمُ"],[89,"الذَّهَابَ"],[90,"لِلَّعِبِ"],[91,"فِي"],[92,"هَذَا"],[93,"الشَّارِعِ."],[94,"فِي"],[95,"الْيَوْمِ"],[96,"الْأَوَّلِ،"],[97,"كَانَتْ"],[98,"أَمَل"],[99,"مُتَشَوِّقَةً"],[100,"لِبَدْءِ"],[101,"التَّعَلُّمِ."],[102,"وَلَكِنْ..."]]},{"n":5,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/32652/size6/6c4d108524e227f5d997461b7c1ce651.jpg","text":"دُممممممممممم!\nوَقَعَتْ أَمَل عَلَى الْأَرْضِ.\nأُصِيبَتْ رُكْبَتَاهَا، وَرَغْمَ ذَلِكَ لَمْ تَرْغَبْ فِي الْبُكَاءِ. \nلَكِنَّهَا فَعَلَتْ! \nوَانْطَلَقَتِ التَّنْهِيدَاتُ الْعَالِيَةُ مِنْ فَمِهَا.","words":[[103,"دُممممممممممم!"],[104,"وَقَعَتْ"],[105,"أَمَل"],[106,"عَلَى"],[107,"الْأَرْضِ."],[108,"أُصِيبَتْ"],[109,"رُكْبَتَاهَا،"],[110,"وَرَغْمَ"],[111,"ذَلِكَ"],[112,"لَمْ"],[113,"تَرْغَبْ"],[114,"فِي"],[115,"الْبُكَاءِ."],[116,"لَكِنَّهَا"],[117,"فَعَلَتْ!"],[118,"وَانْطَلَقَتِ"],[119,"التَّنْهِيدَاتُ"],[120,"الْعَالِيَةُ"],[121,"مِنْ"],[122,"فَمِهَا."]]},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/32663/size6/cf20f113bf2338d35bdde98fa1fccc24.jpg","text":"شَعَرَتْ بِحَرَارَةٍ فِي أُذُنَيْهَا، بَيْنَمَا كَانَتْ تَسْمَعُ ضَحِكَاتِ الْأَوْلَادِ عَلَيْهَا. \nنَهَضَتْ أَمَل وَعَادَتْ مُسْرِعَةً إِلَى الْمَنْزِلِ، تَارِكَةً وَرَاءَهَا الدَّرَّاجَةَ حَيْثُ سَقَطَتْ. \nعَامِرٌ سَيَرْكَبُ الدَّرَّاجَةَ وَيَعُودُ بِهَا؛ فَهُوَ يَعْرِفُ كَيْفَ يَقُودُهَا.\nبَعْدَمَا يَنْتَهِي مِنْ لَعِبِ الْكُرِيكِيتْ مَعَ أَصْدِقَائِهِ. \nأَوْ بَعْدَمَا تَغْرُبُ الشَّمْسُ. \nأَوْ عِنْدَمَا يَرْجِعُ أَبُوهَا إِلَى الْمَنْزِلِ عَائِدًا مِنْ وَرْشَةِ الْمِيكَانِيكَا.","words":[[123,"شَعَرَتْ"],[124,"بِحَرَارَةٍ"],[125,"فِي"],[126,"أُذُنَيْهَا،"],[127,"بَيْنَمَا"],[128,"كَانَتْ"],[129,"تَسْمَعُ"],[130,"ضَحِكَاتِ"],[131,"الْأَوْلَادِ"],[132,"عَلَيْهَا."],[133,"نَهَضَتْ"],[134,"أَمَل"],[135,"وَعَادَتْ"],[136,"مُسْرِعَةً"],[137,"إِلَى"],[138,"الْمَنْزِلِ،"],[139,"تَارِكَةً"],[140,"وَرَاءَهَا"],[141,"الدَّرَّاجَةَ"],[142,"حَيْثُ"],[143,"سَقَطَتْ."],[144,"عَامِرٌ"],[145,"سَيَرْكَبُ"],[146,"الدَّرَّاجَةَ"],[147,"وَيَعُودُ"],[148,"بِهَا؛"],[149,"فَهُوَ"],[150,"يَعْرِفُ"],[151,"كَيْفَ"],[152,"يَقُودُهَا."],[153,"بَعْدَمَا"],[154,"يَنْتَهِي"],[155,"مِنْ"],[156,"لَعِبِ"],[157,"الْكُرِيكِيتْ"],[158,"مَعَ"],[159,"أَصْدِقَائِهِ."],[160,"أَوْ"],[161,"بَعْدَمَا"],[162,"تَغْرُبُ"],[163,"الشَّمْسُ."],[164,"أَوْ"],[165,"عِنْدَمَا"],[166,"يَرْجِعُ"],[167,"أَبُوهَا"],[168,"إِلَى"],[169,"الْمَنْزِلِ"],[170,"عَائِدًا"],[171,"مِنْ"],[172,"وَرْشَةِ"],[173,"الْمِيكَانِيكَا."]]},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/32654/size6/ea8ec61d48517dc8e0a8aef942e9a493.jpg","text":"سَأَلَتْهُا أُمُّهَا عِنْدَ رُؤْيَتِهَا: \"كَيْفَ مَزَّقْتِ تَنُّورَتَكِ\"؟\nفَأَجَابَتْ أَمَل: \"لَقَدْ سَقَطْتُ عَنِ الدَّرَّاجَةِ\". فَتَنَهَّدَتْ أُمُّهَا.","words":[[174,"سَأَلَتْهُا"],[175,"أُمُّهَا"],[176,"عِنْدَ"],[177,"رُؤْيَتِهَا:"],[178,"\"كَيْفَ"],[179,"مَزَّقْتِ"],[180,"تَنُّورَتَكِ\"؟"],[181,"فَأَجَابَتْ"],[182,"أَمَل:"],[183,"\"لَقَدْ"],[184,"سَقَطْتُ"],[185,"عَنِ"],[186,"الدَّرَّاجَةِ\"."],[187,"فَتَنَهَّدَتْ"],[188,"أُمُّهَا."]]},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/32655/size6/96b87660694c0cc4be4296be68853e35.jpg","text":"الْيَوْمُ هُوَ الْيَوْمُ السَّابِعُ مِنْ دُرُوسِ أَمَل. \nوَمَا زَالَتْ لَا تَسْتَطِيعُ تَعَلُّمَ رُكُوبِ الدَّرَّاجَةِ. مَاذَا قَالَ عَامِرٌ؟\nإِنَّهَا أَقْصَرُ مِنْ أَنْ تَرْكَبَ هَذِهِ الدَّرَّاجَةَ. \nتُرَى مَاذَا عَرَفَ عَامِرٌ أَيْضًا؟","words":[[189,"الْيَوْمُ"],[190,"هُوَ"],[191,"الْيَوْمُ"],[192,"السَّابِعُ"],[193,"مِنْ"],[194,"دُرُوسِ"],[195,"أَمَل."],[196,"وَمَا"],[197,"زَالَتْ"],[198,"لَا"],[199,"تَسْتَطِيعُ"],[200,"تَعَلُّمَ"],[201,"رُكُوبِ"],[202,"الدَّرَّاجَةِ."],[203,"مَاذَا"],[204,"قَالَ"],[205,"عَامِرٌ؟"],[206,"إِنَّهَا"],[207,"أَقْصَرُ"],[208,"مِنْ"],[209,"أَنْ"],[210,"تَرْكَبَ"],[211,"هَذِهِ"],[212,"الدَّرَّاجَةَ."],[213,"تُرَى"],[214,"مَاذَا"],[215,"عَرَفَ"],[216,"عَامِرٌ"],[217,"أَيْضًا؟"]]},{"n":9,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/32756/size6/98ebc158343839886e7b268d5133b4dc.jpg","text":"عِنْدَ الْمَسَاءِ، طَلَبَتْ أَمَل مِنْ أُمِّهَا كُوبًا مِنَ الْحَلِيبِ. \nكَانَتْ مُعَلِّمَتُهَا فِي الْمَدْرَسَةِ قَدْ أَخْبَرَتْهَا أَنَّ شُرْبَ الْحَلِيبِ يَجْعَلُ الْأَطْفَالَ طِوَالَ الْقَامَةِ. \nكَمَا أَنَّ أَمَل كَانَتْ بِالْفِعْلِ ثَانِيَ أَطْوَلِ بِنْتٍ فِي فَصْلِ (ب-2).","words":[[218,"عِنْدَ"],[219,"الْمَسَاءِ،"],[220,"طَلَبَتْ"],[221,"أَمَل"],[222,"مِنْ"],[223,"أُمِّهَا"],[224,"كُوبًا"],[225,"مِنَ"],[226,"الْحَلِيبِ."],[227,"كَانَتْ"],[228,"مُعَلِّمَتُهَا"],[229,"فِي"],[230,"الْمَدْرَسَةِ"],[231,"قَدْ"],[232,"أَخْبَرَتْهَا"],[233,"أَنَّ"],[234,"شُرْبَ"],[235,"الْحَلِيبِ"],[236,"يَجْعَلُ"],[237,"الْأَطْفَالَ"],[238,"طِوَالَ"],[239,"الْقَامَةِ."],[240,"كَمَا"],[241,"أَنَّ"],[242,"أَمَل"],[243,"كَانَتْ"],[244,"بِالْفِعْلِ"],[245,"ثَانِيَ"],[246,"أَطْوَلِ"],[247,"بِنْتٍ"],[248,"فِي"],[249,"فَصْلِ"],[250,"(ب-2)."]]},{"n":10,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/32760/size6/57b7715cf64f9160d2b477751bec6dcc.jpg","text":"أَرَادَتْ أَمَل أَنْ تُصْبِحَ مِثْلَ فِينُوسْ وِيلْيَامْزْ.\nلَمْ تَكُنْ تَعْرِفُ أَيَّ شَيْءٍ عَنِ التِّنِسِ. لَكِنَّ عَامِرًا عَرَضَ عَلَيْهَا ذَاتَ مَرَّةٍ مُلْصَقًا لِصُورَةِ فِينُوسْ. \nفَقَالَتْ أَمَل حِينَهَا: \"كَمْ هِيَ قَوِيَّةٌ\"! \nبَدَأَتْ أَمَل تَدْعُو اللَّهَ قَبْلَ أَنْ تَخْلُدَ إِلَى النَّوْمِ قَائِلَةً: \"إِذَا أَصْبَحَتْ أَمَل قَوِيَّةً، فَلَنْ يُزْعِجَهَا أَيُّ شَخْصٍ!\" \nكَانَ ذَلِكَ عَلَى غَيْرِ الْعَادَةِ أَنْ تَدْعُوَ قَبْلَ النَّوْمِ.","words":[[251,"أَرَادَتْ"],[252,"أَمَل"],[253,"أَنْ"],[254,"تُصْبِحَ"],[255,"مِثْلَ"],[256,"فِينُوسْ"],[257,"وِيلْيَامْزْ."],[258,"لَمْ"],[259,"تَكُنْ"],[260,"تَعْرِفُ"],[261,"أَيَّ"],[262,"شَيْءٍ"],[263,"عَنِ"],[264,"التِّنِسِ."],[265,"لَكِنَّ"],[266,"عَامِرًا"],[267,"عَرَضَ"],[268,"عَلَيْهَا"],[269,"ذَاتَ"],[270,"مَرَّةٍ"],[271,"مُلْصَقًا"],[272,"لِصُورَةِ"],[273,"فِينُوسْ."],[274,"فَقَالَتْ"],[275,"أَمَل"],[276,"حِينَهَا:"],[277,"\"كَمْ"],[278,"هِيَ"],[279,"قَوِيَّةٌ\"!"],[280,"بَدَأَتْ"],[281,"أَمَل"],[282,"تَدْعُو"],[283,"اللَّهَ"],[284,"قَبْلَ"],[285,"أَنْ"],[286,"تَخْلُدَ"],[287,"إِلَى"],[288,"النَّوْمِ"],[289,"قَائِلَةً:"],[290,"\"إِذَ"],[291,"ا"],[292,"أَصْبَحَتْ"],[293,"أَمَل"],[294,"قَوِيَّةً،"],[295,"فَلَنْ"],[296,"يُزْعِجَهَا"],[297,"أَيُّ"],[298,"شَخْصٍ!\""],[299,"كَانَ"],[300,"ذَلِكَ"],[301,"عَلَى"],[302,"غَيْرِ"],[303,"الْعَادَةِ"],[304,"أَنْ"],[305,"تَدْعُوَ"],[306,"قَبْلَ"],[307,"النَّوْمِ."]]},{"n":11,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/32664/size6/ff024a1427950f263dbc0e0234ae5686.jpg","text":"فِي الْمَسَاءِ التَّالِي، كَانَتْ أَمَل مُتَأَكِّدَةً مِنْ أَنَّهَا سَتَكُونُ قَادِرَةً عَلَى رُكُوبِ الدَّرَّاجَةِ، كَمَا أَنَّهَا ارْتَدَتْ مِشْبَكَ شَعْرِهَا الْأَحْمَرَ الْجَالِبَ لِلْحَظِّ! \nقَالَتْ لِعَامِرٍ: \"ادْفَعْنِي وَاتْرُكْنِي أَذْهَبُ\"، فَفَعَلَ ذَلِكَ تَمَامًا.\nأَغْمَضَتْ أَمَل عَيْنَيْهَا وَحَاوَلَتِ الْعُثُورَ عَلَى الدَّوَّاسَاتِ. تَطَايَرَ غُبَارُ الرِّيحِ فِي أُذُنَيْهَا، وَانْحَرَفَتِ الدَّرَّاجَةُ عَنْ مَسَارِهَا، ثُمَّ...\nدُممممممممممممممم!\nلَقَدْ سَقَطَتْ مَرَّةً أُخْرَى!","words":[[308,"فِي"],[309,"الْمَسَاءِ"],[310,"التَّالِي،"],[311,"كَانَتْ"],[312,"أَمَل"],[313,"مُتَأَكِّدَةً"],[314,"مِنْ"],[315,"أَنَّهَا"],[316,"سَتَكُونُ"],[317,"قَادِرَةً"],[318,"عَلَى"],[319,"رُكُوبِ"],[320,"الدَّرَّاجَةِ،"],[321,"كَمَا"],[322,"أَنَّهَا"],[323,"ارْتَدَتْ"],[324,"مِشْبَكَ"],[325,"شَعْرِهَا"],[326,"الْأَحْمَرَ"],[327,"الْجَالِبَ"],[328,"لِلْحَظِّ!"],[329,"قَالَتْ"],[330,"لِعَامِرٍ:"],[331,"\"ادْفَعْنِي"],[332,"وَاتْرُكْنِي"],[333,"أَذْهَبُ\"،"],[334,"فَفَعَلَ"],[335,"ذَلِكَ"],[336,"تَمَامًا."],[337,"أَغْمَضَتْ"],[338,"أَمَل"],[339,"عَيْنَيْهَا"],[340,"وَحَاوَلَتِ"],[341,"الْعُثُورَ"],[342,"عَلَى"],[343,"الدَّوَّاسَاتِ."],[344,"تَطَايَرَ"],[345,"غُبَارُ"],[346,"الرِّيحِ"],[347,"فِي"],[348,"أُذُنَيْهَا،"],[349,"وَانْحَرَفَتِ"],[350,"الدَّرَّاجَةُ"],[351,"عَنْ"],[352,"مَسَارِهَا،"],[353,"ثُمَّ..."],[354,"دُممممممممممممممم!"],[355,"لَقَدْ"],[356,"سَقَطَتْ"],[357,"مَرَّةً"],[358,"أُخْرَى!"]]},{"n":12,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/32660/size6/ab4bd940cf20ebe0e608bb1a88a5d5bc.jpg","text":"هَذِهِ الْمَرَّةَ، كَانَ الْأَلَمُ مُبْرِّحًا لِلْغَايَةِ، لِدَرَجَةِ أَنَّهَا لَمْ تَسْتَطِعِ التَّنَفُّسَ.\nلَمْ يَضْحَكْ أَحَدٌ مِنْ سُقُوطِهَا، حَتَّى مَانِيكْدَانَ الَّذِي كَانَ دَوْمًا مَا يُظْهِرُ لُؤْمَهُ فِي هَذِهِ اللَّحَظَاتِ.","words":[[359,"هَذِهِ"],[360,"الْمَرَّةَ،"],[361,"كَانَ"],[362,"الْأَلَمُ"],[363,"مُبْرِّحًا"],[364,"لِلْغَايَةِ،"],[365,"لِدَرَجَةِ"],[366,"أَنَّهَا"],[367,"لَمْ"],[368,"تَسْتَطِعِ"],[369,"التَّنَفُّسَ."],[370,"لَمْ"],[371,"يَضْحَكْ"],[372,"أَحَدٌ"],[373,"مِنْ"],[374,"سُقُوطِهَا،"],[375,"حَتَّى"],[376,"مَانِيكْدَانَ"],[377,"الَّذِي"],[378,"كَانَ"],[379,"دَوْمًا"],[380,"مَا"],[381,"يُظْهِرُ"],[382,"لُؤْمَهُ"],[383,"فِي"],[384,"هَذِهِ"],[385,"اللَّحَظَاتِ."]]},{"n":13,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/32665/size6/ab19903177168b1e19bd2727a139f97a.jpg","text":"كَانَ الطَّبِيبُ صَارِمًا جِدًّا، تَمَامًا مِثْلُ مُدِيرَ مَدْرَسَتِهَا. \nأَخْبَرَ أَمَل أَنَّهَا أُصِيبَتْ بِكَدَمَاتٍ شَدِيدَةٍ فِي سَاقِهَا. \nقَالَ لَهَا: \"يَجِبُ أَنْ تَعْتَنِي بِهَا جَيِّدًا حَتَّى تُشْفَى\"، وَأَعْطَى أُمَّهَا قَائِمَةً طَوِيلَةً مِنَ الْأَدْوِيَةِ.\nقَالَتْ لَهَا أُمُّهَا: \"لَا مَزِيدَ مِنْ رُكُوبِ الدَّرَّاجَاتِ، حَتَّى تَخْتَفِيَ هَذِهِ الْكَدَمَاتُ تَمَامًا\"، فَأَوْمَأَتْ أَمَل بِرَأْسِهَا مُوَافِقَةً. \nوَقَالَ لَهَا عَامِرٌ: \"لَا يَزَالُ بِإِمْكَانِكِ الْجُلُوسُ عَلَى الدَّرَّاجَةِ\". \nتَسَاءَلَتْ أَمَل بِتَعَجُّبٍ: \"كَيْفَ\"؟","words":[[386,"كَانَ"],[387,"الطَّبِيبُ"],[388,"صَارِمًا"],[389,"جِدًّا،"],[390,"تَمَامًا"],[391,"مِثْلُ"],[392,"مُدِيرَ"],[393,"مَدْرَسَتِهَا."],[394,"أَخْبَرَ"],[395,"أَمَل"],[396,"أَنَّهَا"],[397,"أُصِيبَتْ"],[398,"بِكَدَمَاتٍ"],[399,"شَدِيدَةٍ"],[400,"فِي"],[401,"سَاقِهَا."],[402,"قَالَ"],[403,"لَهَا:"],[404,"\"يَجِبُ"],[405,"أَنْ"],[406,"تَعْتَنِي"],[407,"بِهَا"],[408,"جَيِّدًا"],[409,"حَتَّى"],[410,"تُشْفَى\"،"],[411,"وَأَعْطَى"],[412,"أُمَّهَا"],[413,"قَائِمَةً"],[414,"طَوِيلَةً"],[415,"مِنَ"],[416,"الْأَدْوِيَةِ."],[417,"قَالَتْ"],[418,"لَهَا"],[419,"أُمُّهَا:"],[420,"\"لَا"],[421,"مَزِيدَ"],[422,"مِنْ"],[423,"رُكُوبِ"],[424,"الدَّرَّاجَاتِ،"],[425,"حَتَّى"],[426,"تَخْتَفِيَ"],[427,"هَذِهِ"],[428,"الْكَدَمَاتُ"],[429,"تَمَامًا\"،"],[430,"فَأَوْمَأَتْ"],[431,"أَمَل"],[432,"بِرَأْسِهَا"],[433,"مُوَافِقَةً."],[434,"وَقَالَ"],[435,"لَهَا"],[436,"عَامِرٌ:"],[437,"\"لَا"],[438,"يَزَالُ"],[439,"بِإِمْكَانِكِ"],[440,"الْجُلُوسُ"],[441,"عَلَى"],[442,"الدَّرَّاجَةِ\"."],[443,"تَسَاءَلَتْ"],[444,"أَمَل"],[445,"بِتَعَجُّبٍ:"],[446,"\"كَيْفَ\"؟"]]},{"n":14,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/32657/size6/42d63bbdd8efdf856c616c66f3c93732.jpg","text":"أَرَاهَا وَالِدُهَا الدَّرَّاجَةَ، وَكَانَ لَهَا مِقْعَدٌ جَدِيدٌ.\nقَالَ عَامِرٌ: \"لَقَدْ أَصْلَحْنَا الدَّرَّاجَةَ عِنْدَمَا كُنْتِ فِي عِيَادَةِ الطَّبِيبِ\"، وَابْتَسَمَ ابْتِسَامَةً عَرِيضَةً. \nفَقَالَتْ أَمَل: \"لَكِنَّنِي سَأَقُودُ الدَّرَّاجَةَ بِنَفْسِي قَرِيبًا\".\nفَرَدَّ عَامِرٌ: \"نَعَمْ، بِالتَّأْكِيدِ سَوْفَ تَسْتَطِيعِينَ\".","words":[[447,"أَرَاهَا"],[448,"وَالِدُهَا"],[449,"الدَّرَّاجَةَ،"],[450,"وَكَانَ"],[451,"لَهَا"],[452,"مِقْعَدٌ"],[453,"جَدِيدٌ."],[454,"قَالَ"],[455,"عَامِرٌ:"],[456,"\"لَقَدْ"],[457,"أَصْلَحْنَا"],[458,"الدَّرَّاجَةَ"],[459,"عِنْدَمَا"],[460,"كُنْتِ"],[461,"فِي"],[462,"عِيَادَةِ"],[463,"الطَّبِيبِ\"،"],[464,"وَابْتَسَمَ"],[465,"ابْتِسَامَةً"],[466,"عَرِيضَةً."],[467,"فَقَالَتْ"],[468,"أَمَل:"],[469,"\"لَكِنَّنِي"],[470,"سَأَقُودُ"],[471,"الدَّرَّاجَةَ"],[472,"بِنَفْسِي"],[473,"قَرِيبًا\"."],[474,"فَرَدَّ"],[475,"عَامِرٌ:"],[476,"\"نَعَمْ،"],[477,"بِالتَّأْكِيدِ"],[478,"سَوْفَ"],[479,"تَسْتَطِيعِينَ\"."]]},{"n":15,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/32658/size6/8c9abfb3a28ab7e6e96e174471018d36.jpg","text":"16/17","words":null},{"n":16,"img":null,"text":"سَقَطَتْ أَمَل عَنِ الدَّرَّاجَةِ، لَكِنْ هَلْ هَذِهِ هِيَ النِّهَايَةُ؟ \nدَائِمًا مَا يُخْبِرُكَ الْجَمِيعُ بِأَنْ تَسْتَمِرَّ فِي الْمُحَاوَلَةِ حَتَّى لَوْ لَمْ تَنْجَحْ مِنْ أَوَّلِ مَرَّةٍ، لِمَاذَا؟ \nإِنَّ الْمُحَاوَلَةَ فِي تَجْرِبَةِ شَيْءٍ جَدِيدٍ تَمْنَحُكَ نَتَائِجَ لَمْ تَكُنْ تَبْحَثُ عَنْهَا مُنْذُ الْبِدَايَةِ، كَمَا أَنَّهَا تَجْعَلُكَ تَتَعَرَّفُ عَلَى ذَاتِكَ بِشَكْلٍ لَمْ تَعْرِفْهُ مِنْ قَبْلُ. \nلَوْ كَانَتْ أَمَل قَدْ تَعَلَّمَتْ رُكُوبَ الدَّرَّاجَةِ مِنْ أَوَّلِ يَوْمٍ لَهَا، لَكَانَ مِنَ الْمُمْكِنِ أَلَّا تَسْتَكْشِفَ جَانِبَ شَخْصِيَّتِهَا الْمُتَحَدِّي وَأَنَّهَا صَاحِبَةُ إِرَادَةٍ قَوِيَّةٍ، وَرُبَّمَا حَتَّى عَائِلَتُهَا مَا كَانَتْ لِتَعْرِفَ ذَلِكَ عَنْهَا. \nرُبَّمَا فِي يَوْمٍ مَا مُسْتَقْبَلًا، عِنْدَمَا تُصْبِحُ أَمَل طَوِيلَةً وَقَوِيَّةً بَعْدَ شُرْبِهَا أَكْوَابًا كَثِيرَةً مِنَ الْحَلِيبِ، \nسَتُفَكِّرُ مَرَّةً أُخْرَى فِي الْيَوْمِ الَّذِي سَقَطَتْ فِيهِ عَنِ الدَّرَّاجَةِ. \nرُبَّمَا سَتُفَكِّرُ فِي هَذِهِ الْحَادِثَةِ عِنْدَمَا تُوَاجِهُ أَمَل صُعُوبَاتٍ أَثْنَاءَ اخْتِبَارِ الْكِتَابَةِ أَوْ خِلَالَ تَسَلُّقِ جَبَلٍ. \nوَرُبَّمَا سَتَتَذَكَّرُ سُقُوطَهَا أَثْنَاءَ خَبْزِهَا كَعْكَةً أَوْ أَثْنَاءَ الْتِقَاطِ صُورَةٍ مَعَ نَمِرٍ مُفْتَرِسٍ! \nوَقْتَهَا رُبَّمَا سَتُقَرِّرُ أَمَل عَدَمَ الِاسْتِسْلَامِ لِأَنَّهَا مَا زَالَتْ تَتَذَكَّرُ مَا تَعَلَّمَتْهُ يَوْمَ سُقُوطِهَا عَنِ الدَّرَّاجَةِ.","words":[[480,"سَقَطَتْ"],[481,"أَمَل"],[482,"عَنِ"],[483,"الدَّرَّاجَةِ،"],[484,"لَكِنْ"],[485,"هَلْ"],[486,"هَذِهِ"],[487,"هِيَ"],[488,"النِّهَايَةُ؟"],[489,"دَائِمًا"],[490,"مَا"],[491,"يُخْبِرُكَ"],[492,"الْجَمِيعُ"],[493,"بِأَنْ"],[494,"تَسْتَمِرَّ"],[495,"فِي"],[496,"الْمُحَاوَلَةِ"],[497,"حَتَّى"],[498,"لَوْ"],[499,"لَمْ"],[500,"تَنْجَحْ"],[501,"مِنْ"],[502,"أَوَّلِ"],[503,"مَرَّةٍ،"],[504,"لِمَاذَا؟"],[505,"إِنَّ"],[506,"الْمُحَاوَلَةَ