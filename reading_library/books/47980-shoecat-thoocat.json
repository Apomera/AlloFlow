er.org.in/illustration_crops/85280/size6/55b03b543326d6f18e2da2e0c807a4f4.gif","text":"The shop put up a sign, too: CATS NOT ALLOWED","words":[[188,"The"],[189,"shop"],[190,"put"],[191,"up"],[192,"a"],[193,"sign,"],[194,"too:"],[195,"CATS"],[196,"NOT"],[197,"ALLOWED"]]},{"n":9,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/85281/size6/c1c68cbee179d0f190ed6916854123da.gif","text":"Even the playground got a sign: CATS STAY OUT","words":[[198,"Even"],[199,"the"],[200,"playground"],[201,"got"],[202,"a"],[203,"sign:"],[204,"CATS"],[205,"STAY"],[206,"OUT"]]},{"n":10,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/85282/size6/92014d771421223ca08fd051bcb5a484.gif","text":"Kamala and the shoecat went home, sadly.\nThey found Thatha putting up his own sign: CAT GO BACK","words":[[207,"Kamala"],[208,"and"],[209,"the"],[210,"shoecat"],[211,"went"],[212,"home,"],[213,"sadly."],[214,"They"],[215,"found"],[216,"Thatha"],[217,"putting"],[218,"up"],[219,"his"],[220,"own"],[221,"sign:"],[222,"CAT"],[223,"GO"],[224,"BACK"]]},{"n":11,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/85283/size6/10a3c93c69ca4243f27cbe1ef011c73d.gif","text":"That night, Kamala and the shoecat climbed up to the roof to watch the skies. The moon glowed green and warm.\nThe shoecat turned its head up and yowled, “Owoooo!”","words":[[225,"That"],[226,"night,"],[227,"Kamala"],[228,"and"],[229,"the"],[230,"shoecat"],[231,"climbed"],[232,"up"],[233,"to"],[234,"the"],[235,"roof"],[236,"to"],[237,"watch"],[238,"the"],[239,"skies."],[240,"The"],[241,"moon"],[242,"glowed"],[243,"green"],[244,"and"],[245,"warm."],[246,"The"],[247,"shoecat"],[248,"turned"],[249,"its"],[250,"head"],[251,"up"],[252,"and"],[253,"yowled,"],[254,"“Owoooo!”"]]},{"n":12,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/85284/size6/a73003c35977a29887c13e5b3f39b1a2.gif","text":"In the goat shed, seventeen goats turned their heads up and howled: Owoooo!\nIn his bedroom, Thatha sat up and put on his glasses. Sleepily, he said, “Owoo?”","words":[[255,"In"],[256,"the"],[257,"goat"],[258,"shed,"],[259,"seventeen"],[260,"goats"],[261,"turned"],[262,"their"],[263,"heads"],[264,"up"],[265,"and"],[266,"howled:"],[267,"Owoooo!"],[268,"In"],[269,"his"],[270,"bedroom,"],[271,"Thatha"],[272,"sat"],[273,"up"],[274,"and"],[275,"put"],[276,"on"],[277,"his"],[278,"glasses."],[279,"Sleepily,"],[280,"he"],[281,"said,"],[282,"“Owoo?”"]]},{"n":13,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/85285/size6/ae16507fbb7899e9c5c14f35f42b8c2c.gif","text":"Across the village, Kamala’s teacher, her classmates, the newspaper man, thirteen hens, and three dogs lifted their faces to the green moon and howled: “Owoooo!”\nOn the roof, Kamala bellowed:\n“OWOOO!”","words":[[283,"Across"],[284,"the"],[285,"village,"],[286,"Kamala’s"],[287,"teacher,"],[288,"her"],[289,"classmates,"],[290,"the"],[291,"newspaper"],[292,"man,"],[293,"thirteen"],[294,"hens,"],[295,"and"],[296,"three"],[297,"dogs"],[298,"lifted"],[299,"their"],[300,"faces"],[301,"to"],[302,"the"],[303,"green"],[304,"moon"],[305,"and"],[306,"howled:"],[307,"“Owoooo!”"],[308,"On"],[309,"the"],[310,"roof,"],[311,"Kamala"],[312,"bellowed:"],[313,"“"],[314,"OWOOO!"],[315,"”"]]},{"n":14,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/85286/size6/fbba37d8dcb89f59f4cd013dcdc1fcfe.gif","text":"With a flash of lightning, it began to rain. The no-cat signs melted away.","words":[[316,"With"],[317,"a"],[318,"flash"],[319,"of"],[320,"lightning,"],[321,"it"],[322,"began"],[323,"to"],[324,"rain."],[325,"The"],[326,"no-cat"],[327,"signs"],[328,"melted"],[329,"away."]]},{"n":15,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/85287/size6/e2c0fa7fd1869ab939865d2ea4fb8532.gif","text":"Then the thunder started, BA-DUM DUM-DUM! Every piece of glass in the village broke. PUTT! went the light bulbs. Pop-POP went the pickle jars. Mirrors CRACKED and crumbled. \nWindows slammed against walls and smashed glass flew everywhere, even on the roof.","words":[[330,"Then"],[331,"the"],[332,"thunder"],[333,"started,"],[334,"BA-DUM"],[335,"DUM-DUM!"],[336,"Every"],[337,"piece"],[338,"of"],[339,"glass"],[340,"in"],[341,"the"],[342,"village"],[343,"broke."],[344,"PUTT!"],[345,"went"],[346,"the"],[347,"light"],[348,"bulbs."],[349,"Pop-POP"],[350,"went"],[351,"the"],[352,"pickle"],[353,"jars."],[354,"Mirrors"],[355,"CRACKED"],[356,"and"],[357,"crumbled."],[358,"Windows"],[359,"slammed"],[360,"against"],[361,"walls"],[362,"and"],[363,"smashed"],[364,"glass"],[365,"flew"],[366,"everywhere,"],[367,"even"],[368,"on"],[369,"the"],[370,"roof."]]},{"n":16,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/85288/size6/01d490ddf57233472977e46f67aed6ab.gif","text":"Kamala hid under her bed.","words":[[371,"Kamala"],[372,"hid"],[373,"under"],[374,"her"],[375,"bed."]]},{"n":17,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/85289/size6/bf1f3bdb80788043d92393cf6a9b8feb.gif","text":"The next morning, Kamala crawled out from under her bed. Thatha was sitting on the steps.\nHe was eating a furry green tomato.\n“Wonderful! Thank your thoocat,” Thatha said. “What a good shoecat!”","words":[[376,"The"],[377,"next"],[378,"morning,"],[379,"Kamala"],[380,"crawled"],[381,"out"],[382,"from"],[383,"under"],[384,"her"],[385,"bed."],[386,"Thatha"],[387,"was"],[388,"sitting"],[389,"on"],[390,"the"],[391,"steps."],[392,"He"],[393,"was"],[394,"eating"],[395,"a"],[396,"furry"],[397,"green"],[398,"tomato."],[399,"“Wonderful!"],[400,"Thank"],[401,"your"],[402,"thoocat,”"],[403,"Thatha"],[404,"said."],[405,"“What"],[406,"a"],[407,"good"],[408,"shoecat!”"]]},{"n":18,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/85290/size6/c47696d554060b2745f83821972c07d9.gif","text":"In the field were lots of tall tomato plants, some medium-sized goats, and one short shoecat.","words":[[409,"In"],[410,"the"],[411,"field"],[412,"were"],[413,"lots"],[414,"of"],[415,"tall"],[416,"tomato"],[417,"plants,"],[418,"some"],[419,"medium-sized"],[420,"goats,"],[421,"and"],[422,"one"],[423,"short"],[424,"shoecat."]]},{"n":19,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/85291/size6/e8603db85d93fce349ba0647d55e844f.gif","text":"“Thoo!” said the shoecat, in a friendly way.\n“Thoo!” Kamala agreed as she bit into a green tomato.","words":[[425,"“Thoo!”"],[426,"said"],[427,"the"],[428,"shoecat,"],[429,"in"],[430,"a"],[431,"friendly"],[432,"way."],[433,"“Thoo!”"],[434,"Kamala"],[435,"agreed"],[436,"as"],[437,"she"],[438,"bit"],[439,"into"],[440,"a"],[441,"green"],[442,"tomato."]]}],"stats":{"pages":19,"words":440}}