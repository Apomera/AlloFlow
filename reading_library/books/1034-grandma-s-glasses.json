92],[275,178.92,179.08],[276,179.08,179.6],[277,179.6,179.88],[278,179.88,180.12],[279,180.12,180.46],[280,180.46,181.16],[281,181.16,181.48],[282,181.48,181.8],[283,181.8,185.76],[284,185.76,187.04],[285,187.04,187.52],[286,187.52,187.8],[287,187.8,188.44],[288,188.44,189.84],[289,189.84,191.24],[290,191.24,191.6],[291,191.6,191.88],[292,191.88,192.4],[293,192.4,192.8],[294,192.8,252.8]]},"pages":[{"n":1,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/12867/size6/60f8ecdd584530d45abcaa683b9f7bbe.jpg","text":"Nani keeps losing her glasses.\n“Where did I keep them?” she always asks. Without her glasses, she cannot find her glasses.","words":[[1,"Nani"],[2,"keeps"],[3,"losing"],[4,"her"],[5,"glasses."],[6,"“Where"],[7,"did"],[8,"I"],[9,"keep"],[10,"them?”"],[11,"she"],[12,"always"],[13,"asks."],[14,"Without"],[15,"her"],[16,"glasses,"],[17,"she"],[18,"cannot"],[19,"find"],[20,"her"],[21,"glasses."]]},{"n":2,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/12868/size6/66f4834f1c4f3ee1ffb5dc6611f5c119.jpg","text":"So she needs me. To be her eyes, to find her own eyes!","words":[[22,"So"],[23,"she"],[24,"needs"],[25,"me."],[26,"To"],[27,"be"],[28,"her"],[29,"eyes,"],[30,"to"],[31,"find"],[32,"her"],[33,"own"],[34,"eyes!"]]},{"n":3,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/12869/size6/c76b1e5972f0634299b0c251f2eb851d.jpg","text":"Sometimes her spectacles are in the bathroom. Or on her bed. Or on her head.\n“Nani,” I say, “they are on your head!”","words":[[35,"Sometimes"],[36,"her"],[37,"spectacles"],[38,"are"],[39,"in"],[40,"the"],[41,"bathroom."],[42,"Or"],[43,"on"],[44,"her"],[45,"bed."],[46,"Or"],[47,"on"],[48,"her"],[49,"head."],[50,"“Nani,”"],[51,"I"],[52,"say,"],[53,"“they"],[54,"are"],[55,"on"],[56,"your"],[57,"head!”"]]},{"n":4,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/12870/size6/8f9876f57428b5858cce4c40cdca173d.jpg","text":"“Of course! How silly of me. Thank you, Richa dear,” she says with a giggle.\nThis time, though, I cannot find Nani’s glasses. Not yet.","words":[[58,"“Of"],[59,"course!"],[60,"How"],[61,"silly"],[62,"of"],[63,"me."],[64,"Thank"],[65,"you,"],[66,"Richa"],[67,"dear,”"],[68,"she"],[69,"says"],[70,"with"],[71,"a"],[72,"giggle."],[73,"This"],[74,"time,"],[75,"though,"],[76,"I"],[77,"cannot"],[78,"find"],[79,"Nani’s"],[80,"glasses."],[81,"Not"],[82,"yet."]]},{"n":5,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/12871/size6/1d8be1fc2772c5d70cddf0dc5c661fd2.jpg","text":"I have looked everywhere. In all the usual places. On her head, in the bathroom, inside her cupboard, and on the puja shelf. I have looked under her favourite chair and on the dining table.\nNothing. No glasses. Where could they be ?","words":[[83,"I"],[84,"have"],[85,"looked"],[86,"everywhere."],[87,"In"],[88,"all"],[89,"the"],[90,"usual"],[91,"places."],[92,"On"],[93,"her"],[94,"head,"],[95,"in"],[96,"the"],[97,"bathroom,"],[98,"inside"],[99,"her"],[100,"cupboard,"],[101,"and"],[102,"on"],[103,"the"],[104,"puja"],[105,"shelf."],[106,"I"],[107,"have"],[108,"looked"],[109,"under"],[110,"her"],[111,"favourite"],[112,"chair"],[113,"and"],[114,"on"],[115,"the"],[116,"dining"],[117,"table."],[118,"Nothing."],[119,"No"],[120,"glasses."],[121,"Where"],[122,"could"],[123,"they"],[124,"be"],[125,"?"]]},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/12872/size6/92e64c70cc4c46ba62f5826491c388a6.jpg","text":"I decided to be a good detective. I decided to find out what she had done all day.","words":[[126,"I"],[127,"decided"],[128,"to"],[129,"be"],[130,"a"],[131,"good"],[132,"detective."],[133,"I"],[134,"decided"],[135,"to"],[136,"find"],[137,"out"],[138,"what"],[139,"she"],[140,"had"],[141,"done"],[142,"all"],[143,"day."]]},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/12873/size6/a9a2e9e4e2d2ac6978fda4819c20809c.jpg","text":"“I did nothing much today. Except that Veena’s mother-in-law came, you know. And how much she gossips! We had many cups of tea. And she ate all the laddoos your mother had made,” said Nani.","words":[[144,"“I"],[145,"did"],[146,"nothing"],[147,"much"],[148,"today."],[149,"Except"],[150,"that"],[151,"Veena’s"],[152,"mother-in-law"],[153,"came,"],[154,"you"],[155,"know."],[156,"And"],[157,"how"],[158,"much"],[159,"she"],[160,"gossips!"],[161,"We"],[162,"had"],[163,"many"],[164,"cups"],[165,"of"],[166,"tea."],[167,"And"],[168,"she"],[169,"ate"],[170,"all"],[171,"the"],[172,"laddoos"],[173,"your"],[174,"mother"],[175,"had"],[176,"made,”"],[177,"said"],[178,"Nani."]]},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/13037/size6/f60ccfe9777ab7e4b5c8b86ca5685332.jpg","text":"Raju said, “Nani was very busy today. She wrote a letter to the Chief Minister about her pension.”","words":[[179,"Raju"],[180,"said,"],[181,"“Nani"],[182,"was"],[183,"very"],[184,"busy"],[185,"today."],[186,"She"],[187,"wrote"],[188,"a"],[189,"letter"],[190,"to"],[191,"the"],[192,"Chief"],[193,"Minister"],[194,"about"],[195,"her"],[196,"pension.”"]]},{"n":9,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/13038/size6/207303b294755d694a7fd0df9f0afbb3.jpg","text":"Amma said, “She spoke for a long time to your Masi. She finished knitting the sweater for Raju. And then she went for a short walk.”\nI now had many clues. I quickly looked around new places in the house.\n \nAha! I have found the missing glasses!","words":[[197,"Amma"],[198,"said,"],[199,"“She"],[200,"spoke"],[201,"for"],[202,"a"],[203,"long"],[204,"time"],[205,"to"],[206,"your"],[207,"Masi."],[208,"She"],[209,"finished"],[210,"knitting"],[211,"the"],[212,"sweater"],[213,"for"],[214,"Raju."],[215,"And"],[216,"then"],[217,"she"],[218,"went"],[219,"for"],[220,"a"],[221,"short"],[222,"walk.”"],[223,"I"],[224,"now"],[225,"had"],[226,"many"],[227,"clues."],[228,"I"],[229,"quickly"],[230,"looked"],[231,"around"],[232,"new"],[233,"places"],[234,"in"],[235,"the"],[236,"house."],[237,"Aha!"],[238,"I"],[239,"have"],[240,"found"],[241,"the"],[242,"missing"],[243,"glasses!"]]},{"n":10,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/12880/size6/d8fcf8f117c2b72dbb0e125d4243b947.jpg","text":"The spectacles were wrapped in wool, kept next to her pen, under the phone, on her desk. And I found a half-eaten laddoo there as well. For Nani's next birthday, I will save money for an extra pair of glasses!\nNani: Hindi word for grandmother\nMasi: Hindi word for mother's sister","words":[[244,"The"],[245,"spectacles"],[246,"were"],[247,"wrapped"],[248,"in"],[249,"wool,"],[250,"kept"],[251,"next"],[252,"to"],[253,"her"],[254,"pen,"],[255,"under"],[256,"the"],[257,"phone,"],[258,"on"],[259,"her"],[260,"desk."],[261,"And"],[262,"I"],[263,"found"],[264,"a"],[265,"half-eaten"],[266,"laddoo"],[267,"there"],[268,"as"],[269,"well."],[270,"For"],[271,"Nani's"],[272,"next"],[273,"birthday,"],[274,"I"],[275,"will"],[276,"save"],[277,"money"],[278,"for"],[279,"an"],[280,"extra"],[281,"pair"],[282,"of"],[283,"glasses!"],[284,"Nani:"],[285,"Hindi"],[286,"word"],[287,"for"],[288,"grandmother"],[289,"Masi:"],[290,"Hindi"],[291,"word"],[292,"for"],[293,"mother's"],[294,"sister"]]}],"stats":{"pages":10,"words":294}}