,"Janice"],[313,"sees"],[314,"a"],[315,"woman"],[316,"reading"],[317,"a"],[318,"newspaper."],[319,"“Is"],[320,"that"],[321,"in"],[322,"Chinese?”"],[323,"Janice"],[324,"asks."],[325,"“Yes!”"],[326,"Grandma"],[327,"Liu"],[328,"says."],[329,"“This"],[330,"is"],[331,"the"],[332,"only"],[333,"Chinese"],[334,"newspaper"],[335,"in"],[336,"India."],[337,"You"],[338,"can"],[339,"only"],[340,"find"],[341,"it"],[342,"here"],[343,"in"],[344,"Kolkata.”"]]},{"n":12,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/54000/size6/4c61adcad17200c4093ec90d8db52224.jpg","text":"At home, Janice starts packing all her gifts.\n“Janice, you have bought gifts for everyone else, but what will you take back?” asks Grandma Liu.\n“Our memories, Grandma,” Janice says. “They were the best gift of all!”","words":[[345,"At"],[346,"home,"],[347,"Janice"],[348,"starts"],[349,"packing"],[350,"all"],[351,"her"],[352,"gifts."],[353,"“Janice,"],[354,"you"],[355,"have"],[356,"bought"],[357,"gifts"],[358,"for"],[359,"everyone"],[360,"else,"],[361,"but"],[362,"what"],[363,"will"],[364,"you"],[365,"take"],[366,"back?”"],[367,"asks"],[368,"Grandma"],[369,"Liu."],[370,"“Our"],[371,"memories,"],[372,"Grandma,”"],[373,"Janice"],[374,"says."],[375,"“They"],[376,"were"],[377,"the"],[378,"best"],[379,"gift"],[380,"of"],[381,"all!”"]]}],"stats":{"pages":12,"words":381}}