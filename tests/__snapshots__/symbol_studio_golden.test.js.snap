<button disabled="" aria-label="Generate word list" style="padding:8px 14px;background:#d1d5db;color:#6b7280;border:none;border-radius:7px;font-weight:600;font-size:12px;cursor:not-allowed;white-space:nowrap">📝 Generate Word List</button>
<div style="display:flex;gap:4px;flex-wrap:wrap;align-items:center">
<span style="font-size:10px;color:#6b7280;font-weight:600">Theme:</span>
<button aria-label="Theme: Default" style="font-size:10px;padding:3px 8px;border-radius:5px;border:2px solid #7c3aed;background:#ede9fe;color:#7c3aed;font-weight:700;cursor:pointer">Default</button>
<button aria-label="Theme: Pastel" style="font-size:10px;padding:3px 8px;border-radius:5px;border:1px solid #d1d5db;background:#f9fafb;color:#374151;font-weight:400;cursor:pointer">Pastel</button>
<button aria-label="Theme: Dark" style="font-size:10px;padding:3px 8px;border-radius:5px;border:1px solid #d1d5db;background:#f9fafb;color:#374151;font-weight:400;cursor:pointer">Dark</button>
<button aria-label="Theme: High Contrast" style="font-size:10px;padding:3px 8px;border-radius:5px;border:1px solid #d1d5db;background:#f9fafb;color:#374151;font-weight:400;cursor:pointer">High Contrast</button>
<button aria-label="Theme: Warm" style="font-size:10px;padding:3px 8px;border-radius:5px;border:1px solid #d1d5db;background:#f9fafb;color:#374151;font-weight:400;cursor:pointer">Warm</button>
<button aria-label="Theme: Cool" style="font-size:10px;padding:3px 8px;border-radius:5px;border:1px solid #d1d5db;background:#f9fafb;color:#374151;font-weight:400;cursor:pointer">Cool</button>
<button aria-label="Theme: Nature" style="font-size:10px;padding:3px 8px;border-radius:5px;border:1px solid #d1d5db;background:#f9fafb;color:#374151;font-weight:400;cursor:pointer">Nature</button>
<button aria-label="Theme: Ocean" style="font-size:10px;padding:3px 8px;border-radius:5px;border:1px solid #d1d5db;background:#f9fafb;color:#374151;font-weight:400;cursor:pointer">Ocean</button>
<button aria-label="Theme: Sunset" style="font-size:10px;padding:3px 8px;border-radius:5px;border:1px solid #d1d5db;background:#f9fafb;color:#374151;font-weight:400;cursor:pointer">Sunset</button>
<button aria-label="Theme: Lavender" style="font-size:10px;padding:3px 8px;border-radius:5px;border:1px solid #d1d5db;background:#f9fafb;color:#374151;font-weight:400;cursor:pointer">Lavender</button>
<button aria-label="Theme: Candy" style="font-size:10px;padding:3px 8px;border-radius:5px;border:1px solid #d1d5db;background:#f9fafb;color:#374151;font-weight:400;cursor:pointer">Candy</button>
<button aria-label="Theme: Earth" style="font-size:10px;padding:3px 8px;border-radius:5px;border:1px solid #d1d5db;background:#f9fafb;color:#374151;font-weight:400;cursor:pointer">Earth</button>
</div>
<div style="display:flex;align-items:center;gap:4px">
<span style="font-size:10px;color:#6b7280;font-weight:600">🌐</span>
<select aria-label="Board language" style="font-size:11px;border:1px solid #d1d5db;border-radius:6px;padding:3px 6px;background:#fff;cursor:pointer">
<option value="en" selected="">English</option>
<option value="es">Español</option>
<option value="fr">Français</option>
<option value="de">Deutsch</option>
<option value="pt">Português</option>
<option value="zh">中文</option>
<option value="ar">العربية</option>
<option value="hi">हिन्दी</option>
<option value="ja">日本語</option>
<option value="ko">한국어</option>
<option value="vi">Tiếng Việt</option>
<option value="tl">Tagalog</option>
<option value="ru">Русский</option>
<option value="sw">Kiswahili</option>
<option value="so">Soomaali</option>
<option value="my">မြန်မာ</option>
<option value="am">አማርኛ</option>
</select>
</div>
<button aria-label="From Sentence" style="padding:8px 14px;background:#f3f4f6;color:#374151;border:none;border-radius:7px;font-weight:600;font-size:12px;cursor:pointer;white-space:nowrap" title="Type a sentence and let AI map each word to an AAC symbol">🔤 From Sentence</button>
<button aria-label="From Gallery" style="padding:8px 14px;background:#f3f4f6;color:#374151;border:none;border-radius:7px;font-weight:600;font-size:12px;cursor:pointer;white-space:nowrap" title="Add a symbol from your gallery directly to the board">🖼️ From Gallery</button>
<button aria-label="Import Board" style="padding:8px 14px;background:#f3f4f6;color:#374151;border:none;border-radius:7px;font-weight:600;font-size:12px;cursor:pointer;white-space:nowrap" title="Import a board from a .json, .obf, or .obz (Cboard / Open Board Format) file">📥 Import Board</button>
<input type="file" accept=".json,.obf,.obz" style="display:none"/>
</div>
<div style="flex:1;display:flex;align-items:center;justify-content:center;color:#6b7280;flex-direction:column;gap:10px">
<div style="font-size:48px">📋</div>
<p style="font-weight:600">Enter a topic and generate a complete communication board</p>
<p style="font-size:12px;max-width:380px;text-align:center">AI writes the word list, you generate symbols, and export a print-ready board. Drag cells to reorder, or focus Speak and press Alt plus an Arrow key. Color coding follows AAC conventions.</p>
</div>
</div>
</div>
</div>
</div>
</div>"
`;

