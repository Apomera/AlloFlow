:"قَالَتْ رُوجَا: \"هَيَّا نَذْهَبُ لِشِرَاءِ الْبَطَاطَا يَا جَدِّي\"!\nقَالَ جَدُّهَا: \"وَلَكِنَّنَا أَكَلْنَا الْبَطَاطَا الْبَارِحَةَ. مَا رَأْيُكِ أَنْ نَشْتَرِيَ الْبَاذِنْجَانَ الْيَوْمَ\"؟\nتِيكْ تُوكْ! تِيكْ تُوكْ! إِنَّهَا السَّاعَةُ 10 صَبَاحًا.","words":[[56,"قَالَتْ"],[57,"رُوجَا:"],[58,"\"هَيَّا"],[59,"نَذْهَبُ"],[60,"لِشِرَاءِ"],[61,"الْبَطَاطَا"],[62,"يَا"],[63,"جَدِّي\"!"],[64,"قَالَ"],[65,"جَدُّهَا:"],[66,"\"وَلَكِنَّنَا"],[67,"أَكَلْنَا"],[68,"الْبَطَاطَا"],[69,"الْبَارِحَةَ."],[70,"مَا"],[71,"رَأْيُكِ"],[72,"أَنْ"],[73,"نَشْتَرِيَ"],[74,"الْبَاذِنْجَانَ"],[75,"الْيَوْمَ\"؟"],[76,"تِيكْ"],[77,"تُوكْ!"],[78,"تِيكْ"],[79,"تُوكْ!"],[80,"إِنَّهَا"],[81,"السَّاعَةُ"],[82,"10"],[83,"صَبَاحًا."]]},{"n":5,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/56076/size6/289aceacb4665b3ad1805faa4aa6991b.jpg","text":"نَادَتْ رُوجَا عَلَى أَبِيهَا قَائِلَةً: \"أَبِي، هَيَّا لِنَأْكُلَ. جَدِّي يَصْنَعُ الْخُبْزَ\" !\nتِيكْ تُوكْ! تِيكْ تُوكْ! إِنَّهَا السَّاعَةُ 1 بَعْدَ الظُّهْرِ.","words":[[84,"نَادَتْ"],[85,"رُوجَا"],[86,"عَلَى"],[87,"أَبِيهَا"],[88,"قَائِلَةً:"],[89,"\"أَبِي،"],[90,"هَيَّا"],[91,"لِنَأْكُلَ."],[92,"جَدِّي"],[93,"يَصْنَعُ"],[94,"الْخُبْزَ\""],[95,"!"],[96,"تِيكْ"],[97,"تُوكْ!"],[98,"تِيكْ"],[99,"تُوكْ!"],[100,"إِنَّهَا"],[101,"السَّاعَةُ"],[102,"1"],[103,"بَعْدَ"],[104,"الظُّهْرِ."]]},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/56008/size6/04c6373f023249896334611690a156f7.jpg","text":"هُونْكْ! هُونْكْ! عَادَتْ أُخْتُ رُوجَا مِنَ الْمَدْرَسَةِ.\nقَالَتْ رُوجَا بِحَمَاسٍ: \"يَقُولُ أَبِي إِنَّنِي سَأَذْهَبُ مَعَكِ إِلَى الْمَدْرَسَةِ بَعْدَ الْعُطْلَةِ الصَّيْفِيَّةِ. سَيَكُونُ هَذَا مُمْتِعًا جِدًّا، أَلَيْسَ كَذَلِكَ يَا أُخْتِي\"؟\nتِيكْ تُوكْ! تِيكْ تُوكْ! إِنَّهَا السَّاعَةْ 3 عَصْرًا.","words":[[105,"هُونْكْ!"],[106,"هُونْكْ!"],[107,"عَادَتْ"],[108,"أُخْتُ"],[109,"رُوجَا"],[110,"مِنَ"],[111,"الْمَدْرَسَةِ."],[112,"قَالَتْ"],[113,"رُوجَا"],[114,"بِحَمَاسٍ:"],[11