ं"],[104,"गयी"],[105,"थी,"],[106,"वहाँ"],[107,"तो"],[108,"कोई"],[109,"भी"],[110,"नहीं"],[111,"था!”"],[112,"अम्मा"],[113,"बोलीं।"]]},{"n":4,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/8575/size6/faacff67823d26d71b1afee168bf193c.jpg","text":"“हम सब तो शिक्षकों के कमरे में छुपे हुए थे,” मीरा ने कहा। “क्योंकि\nरोहन का साँप हमारी कक्षा में जो था!”\n“पर मीरा जब मैं शिक्षकों के कमरे में गयी, मुझे तो वहाँ कोई नहीं दिखा!”","words":[[114,"“हम"],[115,"सब"],[116,"तो"],[117,"शिक्षकों"],[118,"के"],[119,"कमरे"],[120,"में"],[121,"छुपे"],[122,"हुए"],[123,"थे,”"],[124,"मीरा"],[125,"ने"],[126,"कहा।"],[127,"“क्योंकि"],[128,"रोहन"],[129,"का"],[130,"साँप"],[131,"हमारी"],[132,"कक्षा"],[133,"में"],[134,"जो"],[135,"था!”"],[136,"“पर"],[137,"मीरा"],[138,"जब"],[139,"मैं"],[140,"शिक्षकों"],[141,"के"],[142,"कमरे"],[143,"में"],[144,"गयी,"],[145,"मुझे"],[146,"तो"],[147,"वहाँ"],[148,"कोई"],[149,"नहीं"],[150,"दिखा!”"]]},{"n":5,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/8576/size6/58eec0438199a3499bc67486873f0cec.jpg","text":"“वह इसलिए अम्मा कि हम सब बड़ी दीदी के कमरे की ओर भाग गए थे,” मीरा ने\nकहा।\n“क्योंकि रोहन का साँप हमारे पीछे लगा हुआ था!”\n“जब मैं बड़ी दीदी के कमरे में गयी, वह तो खाली था!” अम्मा ने कहा।","words":[[151,"“वह"],[152,"इसलिए"],[153,"अम्मा"],[154,"कि"],[155,"हम"],[156,"सब"],[157,"बड़ी"],[158,"दीदी"],[159,"के"],[160,"कमरे"],[161,"की"],[162,"ओर"],[163,"भाग"],[164,"गए"],[165,"थे,”"],[166,"मीरा"],[167,"ने"],[168,"कहा।"],[169,"“क्योंकि"],[170,"रोहन"],[171,"का"],[172,"साँप"],[173,"हमारे"],[174,"पीछे"],[175,"लगा"],[176,"हुआ"],[177,"था!”"],[178,"“जब"],[179,"मैं"],[180,"बड़ी"],[181,"दीदी"],[182,"के"],[183,"कमरे"],[184,"में"],[185,"गयी,"],[186,"वह"],[187,"तो"],[188,"खाली"],[189,"था!”"],[190,"अम्मा"],[191,"ने"],[192,"कहा।"]]},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/8577/size6/4759a3f4413b8d78b5cd76f9bd6aebe9.jpg","text":"“हम वहाँ रुक नहीं पाए,” मीरा ने कहा। “क्योंकि रोहन