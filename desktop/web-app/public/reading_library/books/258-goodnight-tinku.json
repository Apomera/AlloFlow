"],[50,"back."],[51,"But"],[52,"he"],[53,"could"],[54,"not"],[55,"sleep!"]]},{"n":3,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/3059/size6/2ceac3562ae13e343c012a75777ce08d.jpg","text":"So he set off into the night to see what he could find. Up in the sky, Tinku saw the moon, white and round, smiling down at him. He felt very happy.\n‘Night is beautiful,’ thought Tinku.","words":[[56,"So"],[57,"he"],[58,"set"],[59,"off"],[60,"into"],[61,"the"],[62,"night"],[63,"to"],[64,"see"],[65,"what"],[66,"he"],[67,"could"],[68,"find."],[69,"Up"],[70,"in"],[71,"the"],[72,"sky,"],[73,"Tinku"],[74,"saw"],[75,"the"],[76,"moon,"],[77,"white"],[78,"and"],[79,"round,"],[80,"smiling"],[81,"down"],[82,"at"],[83,"him."],[84,"He"],[85,"felt"],[86,"very"],[87,"happy."],[88,"‘Night"],[89,"is"],[90,"beautiful,’"],[91,"thought"],[92,"Tinku."]]},{"n":4,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/3060/size6/8c0ad9c3e2285aee64294133d917cb81.jpg","text":"Far away on the top of a tree, there were some tiny lights. One spot of light flew down! “I’m a firefly,” said the spot of light. “I glow in the dark!”\n“Will you be my friend?” asked Tinku.\n“Yes, I will!” said the firefly.","words":[[93,"Far"],[94,"away"],[95,"on"],[96,"the"],[97,"top"],[98,"of"],[99,"a"],[100,"tree,"],[101,"there"],[102,"were"],[103,"some"],[104,"tiny"],[105,"lights."],[106,"One"],[107,"spot"],[108,"of"],[109,"light"],[110,"flew"],[111,"down!"],[112,"“I’m"],[113,"a"],[114,"firefly,”"],[115,"said"],[116,"the"],[117,"spot"],[118,"of"],[119,"light."],[120,"“I"],[121,"glow"],[122,"in"],[123,"the"],[124,"dark!”"],[125,"“Will"],[126,"you"],[127,"be"],[128,"my"],[129,"friend?”"],[130,"asked"],[131,"Tinku."],[132,"“Yes,"],[133,"I"],[134,"will!”"],[135,"said"],[136,"the"],[137,"firefly."]]},{"n":5,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/6197/size6/ff2394baca049e4155eceb39f82fe8b9.jpg","text":"Something flew by and hung upside down on a tree.\n“What is your name, bird?” asked Tinku.\n“I am not a bird, I am a bat. I can see during the night!” said the bat.\n“Will you be my friend?” asked Tinku.\n“Yes, I will!” said the bat.","words":[[138,"Something"],[139,"flew"],[140,"by"],[141,"and"],[142,"hung"],[143,"upside"],[144,"down"],[145,"on"],[146,"a"],[147,"tree."],[148,"“What"],[149,"is"],[150,"your"],[151,"name,"],[152,"bird?”"],[153,"asked"],[154,"Tinku."],[155,"“I"],[156,"am"],[157,"not"],[158,"a"],[159,"bird,"],[160,"I"],[161,"am"],[162,"a"],[163,"bat."],[164,"I"],[165,"can"],[166,"see"],[167,"during"],[168,"the"],[169,"night!”"],[170,"said"],[171,"the"],[172,"bat."],[173,"“Will"],[174,"you"],[175,"be"],[176,"my"],[177,"friend?”"],[178,"asked"],[179,"Tinku."],[180,"“Yes,"],[181,"I"],[182,"will!”"],[183,"said"],[184,"the"],[185,"bat."]]},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/3062/size6/4f3808dc48f5f8506e39fd604ced1df4.jpg","text":"A few leaves moved in the bushes. Someone was hiding! “Who are you?” asked Tinku.\n“I am a fox,” said the fox. “I go strolling out at night.”\n“Will you be my friend?” asked Tinku.\n“Yes, I will!” said the fox.","words":[[186,"A"],[187,"few"],[188,"leaves"],[189,"moved"],[190,"in"],[191,"the"],[192,"bushes."],[193,"Someone"],[194,"was"],[195,"hiding!"],[196,"“Who"],[197,"are"],[198,"you?”"],[199,"asked"],[200,"Tinku."],[201,"“I"],[202,"am"],[203,"a"],[204,"fox,”"],[205,"said"],[206,"the"],[207,"fox."],[208,"“I"],[209,"go"],[210,"strolling"],[211,"out"],[212,"at"],[213,"night.”"],[214,"“Will"],[215,"you"],[216,"be"],[217,"my"],[218,"friend?”"],[219,"asked"],[220,"Tinku."],[221,"“Yes,"],[222,"I"],[223,"will!”"],[224,"said"],[225,"the"],[226,"fox."]]},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/3063/size6/ad704ce0c3388b34b8d5683ad876151c.jpg","text":"Two shiny eyes looked at him from a tree. “Who are you?” asked Tinku.\n“I’m an owl,” said the owl. “I hunt for food during the night.”\n“Will you be my friend?” asked Tinku.\n“Yes, I will!” said the owl.","words":[[227,"Two"],[228,"shiny"],[229,"eyes"],[230,"looked"],[231,"at"],[232,"him"],[233,"from"],[234,"a"],[235,"tree."],[236,"“Who"],[237,"are"],[238,"you?”"],[239,"asked"],[240,"Tinku."],[241,"“I’m"],[242,"an"],[243,"owl,”"],[244,"said"],[245,"the"],[246,"owl."],[247,"“I"],[248,"hunt"],[249,"for"],[250,"food"],[251,"during"],[252,"the"],[253,"night.”"],[254,"“Will"],[255,"you"],[256,"be"],[257,"my"],[258,"friend?”"],[259,"asked"],[260,"Tinku."],[261,"“Yes,"],[262,"I"],[263,"will!”"],[264,"said"],[265,"the"],[266,"owl."]]},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/3064/size6/7cb1530db2d20407104349cc18546aa4.jpg","text":"“CHIRRRRRP! CHIRRRRRP!”\n“Who is here?” Tinku asked.\n“I’m a cricket,” said the cricket. “I chirp when it is dark.”\n“Will you be my friend?” asked Tinku.\n“Yes, I will!” said the cricket.","words":[[267,"“CHIRRRRRP!"],[268,"CHIRRRRRP!”"],[269,"“Who"],[270,"is"],[271,"here?”"],[272,"Tinku"],[273,"asked."],[274,"“I’m"],[275,"a"],[276,"cricket,”"],[277,"said"],[278,"the"],[279,"cricket."],[280,"“I"],[281,"chirp"],[282,"when"],[283,"it"],[284,"is"],[285,"dark.”"],[286,"“Will"],[287,"you"],[288,"be"],[289,"my"],[290,"friend?”"],[291,"asked"],[292,"Tinku."],[293,"“Yes,"],[294,"I"],[295,"will!”"],[296,"said"],[297,"the"],[298,"cricket."]]},{"n":9,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/3065/size6/fd5691f568ab123e75082a2878692a4a.jpg","text":"Tinku and his friends jumped and tossed and rolled until Tinku yawned. “I am sleepy. I have to go home now,” said Tinku. He was happy that he had many new friends.\n \nSnuggling close to Ma, he said, “Night is not a lonely place, Ma. Night is full of wonderful beings.”\n“Yes!” replied Ma. “Your new friends are nocturnal, just like wild dogs.”","words":[[299,"Tinku"],[300,"and"],[301,"his"],[302,"friends"],[303,"jumped"],[304,"and"],[30