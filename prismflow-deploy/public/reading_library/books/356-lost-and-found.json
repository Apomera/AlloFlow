[16,"cot."]]},{"n":3,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/4357/size6/226e15b7017b30e23c3c382790b6b683.jpg","text":"Not in the box.\nNot under my sister's frock.","words":[[17,"Not"],[18,"in"],[19,"the"],[20,"box."],[21,"Not"],[22,"under"],[23,"my"],[24,"sister's"],[25,"frock."]]},{"n":4,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/4358/size6/1364e4a6391bdb15c1be7aa264b31951.jpg","text":"Not under the pillow.\nNot in my bag.\nSob, sob, where have you gone?","words":[[26,"Not"],[27,"under"],[28,"the"],[29,"pillow."],[30,"Not"],[31,"in"],[32,"my"],[33,"bag."],[34,"Sob,"],[35,"sob,"],[36,"where"],[37,"have"],[38,"you"],[39,"gone?"]]},{"n":5,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/4359/size6/fec3256b52d1d0ab91ad2bdddced791a.jpg","text":"I have looked in every room,\nl have looked under every book.","words":[[40,"I"],[41,"have"],[42,"looked"],[43,"in"],[44,"every"],[45,"room,"],[46,"l"],[47,"have"],[48,"looked"],[49,"under"],[50,"every"],[51,"book."]]},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/4360/size6/dbef9cebc51fe64c9fb9301cf170928d.jpg","text":"I have looked under the chair,\nI have looked under the stool.\nWhere have you gone?","words":[[52,"I"],[53,"have"],[54,"looked"],[55,"under"],[56,"the"],[57,"chair,"],[58,"I"],[59,"have"],[60,"looked"],[61,"under"],[62,"the"],[63,"stool."],[64,"Where"],[65,"have"],[66,"you"],[67,"gone?"]]},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/4361/size6/8db6b1bf9853fe293b13b72a50d6f1de.jpg","text":"Soon granny came back from her walk.\n\"Look what I found in the park.\"","words":[[68,"Soon"],[69,"granny"],[70,"came"],[71,"back"],[72,"from"],[73,"her"],[74,"walk."],[75,"\"Look"],[76,"what"],[77,"I"],[78,"found"],[79,"in"],[80,"the"],[81,"park.\""]]},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/4362/size6/c0452bea31292c39aaf3a68b9e4c5c2b.jpg","text":"\"It can sway, it can bounce.\nIt can spin, it can dangle.\nHa-ha, hee-hee,\" said Granny with a giggle.","words":[[82,"\"It"],[83,"can"],[84,"sway,"],[85,"it"],[86,"can"],[87,"bounce."],[88,"It"],[89,"can"],[90,"spin,"],[91,"it"],[92,"can"],[93,"dangle."],[94,"Ha-ha,"],[95,"hee-hee,\""],[96,"said"],[97,"Granny"],[98,"with"],[99,"a"],[100,"giggle."]]},{"n":9,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/4363/size6/0e2508ca2706df242be6399e32bf4078.jpg","text":"Oh Granny! Thank you so much!\nYou have found my dear yo-yo!","words":[[101,"Oh"],[102,"Granny!"],[103,"Thank"],[104,"you"],[105,"so"],[106,"much!"],[107,"You"],[108,"have"],[109,"found"],[110,"my"],[111,"dear"],[112,"yo-yo!"]]},{"n":10,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/4364/size6/145214864074aa8884d2a86d02eb8457.jpg","text":"\"Yo-yo? What a funny name!\nWhat a funny toy!\nI want to play with it,\nIt gives me so much joy!\"","words":[[113,"\"Yo-yo?"],[114,"What"],[115,"a"],[116,"funny"],[117,"name!"],[118,"What"],[119,"a"],[120,"funny"],[121,"toy!"],[122,"I"],[123,"want"],[124,"to"],[125,"play"],[126,"with"],[127,"it,"],[128,"It"],[129,"gives"],[130,"me"],[131,"so"],[132,"much"],[133,"joy!\""]]},{"n":11,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/4365/size6/dd29b24c1af5eb00337353345140bead.jpg","text":"Giggle, giggle, giggling away,\nGranny played, with my little toy.\nFor the rest of the day!","words":[[134,"Giggle,"],[135,"giggle,"],[136,"giggling"],[137,"away,"],[138,"Granny"],[139,"played,"],[140,"with"],[141,"my"],[142,"little"],[143,"toy."],[144,"For"],[145,"the"],[146,"rest"],[147,"of"],[148,"the"],[149,"day!"]]}],"stats":{"pages":11,"words":149}}