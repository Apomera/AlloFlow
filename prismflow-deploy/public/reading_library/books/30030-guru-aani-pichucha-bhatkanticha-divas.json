ge.googleapis.com/static.storyweaver.org.in/illustration_crops/54461/size6/0de396d23454a8aac2e094757a6fb1ff.jpg","text":"गुरू\nआणि त्याची कुत्री पिचू या दोघांनाही खेळायला खूप आवडतं.\nती दोघं चेंडूशी खेळतात\nआणि इकडे तिकडे धावत सुटतात.","words":[[1,"गुरू"],[2,"आणि"],[3,"त्याची"],[4,"कुत्री"],[5,"पिचू"],[6,"या"],[7,"दोघांनाही"],[8,"खेळायला"],[9,"खूप"],[10,"आवडतं."],[11,"ती"],[12,"दोघं"],[13,"चेंडूशी"],[14,"खेळतात"],[15,"आणि"],[16,"इकडे"],[17,"तिकडे"],[18,"धावत"],[19,"सुटतात."]]},{"n":2,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/54462/size6/ad996bb9e4c5317367f34d813340f562.jpg","text":"एकदा गुरू\nआणि पिचू त्यांच्या खोलीत खेळत होते.\nत्यामुळं आई खूप चिडली. ती वैतागून ओरडली, \n“पिचू घरात पसारा करू नकोस गं! गुरू तिला बाहेर घेऊन जा बरं.”","words":[[20,"एकदा"],[21,"गुरू"],[22,"आणि"],[23,"पिचू"],[24,"त्यांच्या"],[25,"खोलीत"],[26,"खेळत"],[27,"होते."],[28,"त्यामुळं"],[29,"आई"],[30,"खूप"],[31,"चिडली."],[32,"ती"],[33,"वैतागून"],[34,"ओरडली,"],[35,"“पिचू"],[36,"घरात"],[37,"पसारा"],[38,"करू"],[39,"नकोस"],[40,"गं!"],[41,"गुरू"],[42,"तिला"],[43,"बाहेर"],[44,"घेऊन"],[45,"जा"],[46,"बरं.”"]]},{"n":3,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/54262/size6/826f378f11d2896c39a2a65bc953bd99.jpg","text":"गुरू आणि पिचू घराबाहेर\nखेळायला गेले.\nवैतागलेले मनोहर काका म्हणाले, \n“गुरू. किती\nरे तुम्ही दोघं गोंधळ करता! शूऽऽऽ!”","words":[[47,"गुरू"],[48,"आणि"],[49,"पिचू"],[50,"घराबाहेर"],[51,"खेळायला"],[52,"गेले."],[53,"वैतागलेले"],[54,"मनोहर"],[55,"काका"],[56,"म्हणाले,"],[57,"“गुरू."],[58,"किती"],[59,"रे"],[60,"तुम्ही"],[61,"दोघं"],[62,"गोंधळ"],[63,"करता!"],[64,"शूऽऽऽ!”"]]},{"n":4,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/54263/size6/182c7412c69972cb3d36f2be3b812324.jpg","text":"मग गुरू आणि पिचू बागेत\nखेळायला गेले.\nचिडखोर मधुसूदन आजोबा ओरडले, \n“गुरू!\nपिचूला इथं बागेत आणायची परवानगी नाहीये... चल जा इथून... निघा... शूऽऽऽ!”","words":[[65,"मग"],[66,"गुरू"],[67,"आणि"],[68,"पिचू"],[69,"बागेत"],[70,"खेळायला"],[71,"गेले."],[72,"चिडखोर"],[73,"मधुसूदन"],[74,"आजोबा"],[75,"ओरडले,"],[76,"“गुरू!"],[77,"पिचूला"],[78,"इथं"],[79,"बागेत"],[80,"आणायची"],[81,"परवानगी"],[82,"नाहीये..."],[83,"चल"],[84,"जा"],[85,"इथून..."],[86,"निघा..."],[87,"शूऽऽऽ!”"]]},{"n":5,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/54463/size6/28bf2d7d7bc11b48f5a1ed4c58d12675.jpg","text":"गुरू उदास होऊन समुद्राकडे बघत म्हणाला, “आपण खेळायचं तरी कुठे पिचू?”\nमग तो\nम्हणाला, “ओह! मला कळालं आपण कुठे खेळू शकतो ते.”","words":[[88,"गुरू"],[89,"उदास"],[90,"होऊन"],[91,"समुद्राकडे"],[92,"बघत"],[93,"म्हणाला,"],[94,"“आपण"],[95,"खेळायचं"],[96,"तरी"],[97,"कुठे"],[98,"पिचू?”"],[99,"मग"],[100,"तो"],[101,"म्हणाला,"],[102,"“ओह!"],[103,"मला"],[104,"कळालं"],[105,"आपण"],[106,"कुठे"],[107,"खेळू"],[108,"शकतो"],[109,"ते.”"]]},{"n":6,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/54265/size6/1b54373ec2084875d8c49cda538bae8a.jpg","text":"मग गुरू\nआणि पिचू समुद्रकिनाऱ्यावर खेळायला गेले.\nदोघांनी आपापल्या जिभा बाहेर\nकाढल्या आणि चेहर्यावर येणारा वारा पिऊन घेतला. \n“पिचू, हे नाही करायचं!”, असं कुणीही म्हणालं नाही.\n“गुरू, पिचूला दुसरीकडे कुठेतरी घेऊन जा बरं.” असं कुणीही म्हणालं नाही.","words":[[110,"मग"],[111,"गुरू"],[112,"आणि"],[113,"पिचू"],[114,"समुद्रकिनाऱ्यावर"],[115,"खेळायला"],[116,"गेले."],[117,"दोघांनी"],[118,"आपापल्या"],[119,"जिभा"],[120,"बाहेर"],[121,"काढल्या"],[122,"आणि"],[123,"चेहर्यावर"],[124,"येणारा"],[125,"वारा"],[126,"पिऊन"],[127,"घेतला."],[128,"“पिचू,"],[129,"हे"],[130,"नाही"],[131,"करायचं!”,"],[132,"असं"],[133,"कुणीही"],[134,"म्हणालं"],[135,"नाही."],[136,"“गुरू,"],[137,"पिचूला"],[138,"दुसरीकडे"],[139,"कुठेतरी"],[140,"घेऊन"],[141,"जा"],[142,"बरं.”"],[143,"असं"],[144,"कुणीही"],[145,"म्हणालं"],[146,"नाही."]]},{"n":7,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/54266/size6/82d7feda0f63fbed467ed64a7c7d6cca.jpg","text":"“जा! चेंडू आण... पिचू!” गुरू त्याचा लाल चेंडू दूरवर फेकत ओरडला.\nचेंडू दडादडा समुद्राकडे घरंगळत गेला.\nपिचू त्या चेंडूमागे थेट\nपाण्यात धावत गेली.","words":[[147,"“जा!"],[148,"चेंडू"],[149,"आण..."],[150,"पिचू!”"],[151,"गुरू"],[152,"त्याचा"],[153,"लाल"],[154,"चेंडू"],[155,"दूरवर"],[156,"फेकत"],[157,"ओरडला."],[158,"चेंडू"],[159,"दडादडा"],[160,"समुद्राकडे"],[161,"घरंगळत"],[162,"गेला."],[163,"पिचू"],[164,"त्या"],[165,"चेंडूमागे"],[166,"थेट"],[167,"पाण्यात"],[168,"धावत"],[169,"गेली."]]},{"n":8,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/54267/size6/6d3889283a9c11f54e6b90dff0ec8788.jpg","text":"गुरू\nओरडला,\n“नाही पिचू! समुद्रात इतकी आत जाऊ नकोस! इकडे ये!”\nपण पिचूचं केसाळ डोकं आधीच\nपाण्यात गायब झालं होतं.","words":[[170,"गुरू"],[171,"ओरडला,"],[172,"“नाही"],[173,"पिचू!"],[174,"समुद्रात"],[175,"इतकी"],[176,"आत"],[177,"जाऊ"],[178,"नकोस!"],[179,"इकडे"],[180,"ये!”"],[181,"पण"],[182,"पिचूचं"],[183,"केसाळ"],[184,"डोकं"],[185,"आधीच"],[186,"पाण्यात"],[187,"गायब"],[188,"झालं"],[189,"होतं."]]},{"n":9,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/54281/size6/2c5e54941b004d06f16608f25bc3ead8.jpg","text":"गुरू\nघाबरून रडायला लागला.\nपिचूची प्रत्येक आठवण त्याच्या\nडोळ्यासमोर येऊ लागली.","words":[[190,"गुरू"],[191,"घाबरून"],[192,"रडायला"],[193,"लागला."],[194,"पिचूची"],[195,"प्रत्येक"],[196,"आठवण"],[197,"त्याच्या"],[198,"डोळ्यासमोर"],[199,"येऊ"],[200,"लागली."]]},{"n":10,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/54467/size6/7f99d0e63c225eeef1a6b988149254d8.jpg","text":"“भौ भौ!” जबड्यात लाल चेंडू घेऊन पिचू पाण्यातून बाहेर आली.\nगुरू म्हणाला, “पिचू, मला माहीत नव्हतं तुला पोहता पण येतं ते.”\nपिचू म्हणाली, “भौ भौ!”\nपिचूला जणू म्हणायचं होतं, की तिला पोहता येतं हे तिला कायमच ठाऊक होतं.","words":[[201,"“भौ"],[202,"भौ!”"],[203,"जबड्यात"],[204,"लाल"],[205,"चेंडू"],[206,"घेऊन"],[207,"पिचू"],[208,"पाण्यातून"],[209,"बाहेर"],[210,"आली."],[211,"गुरू"],[212,"म्हणाला,"],[213,"“पिचू,"],[214,"मला"],[215,"माहीत"],[216,"नव्हतं"],[217,"तुला"],[218,"पोहता"],[219,"पण"],[220,"येतं"],[221,"ते.”"],[222,"पिचू"],[223,"म्हणाली,"],[224,"“भौ"],[225,"भौ!”"],[226,"पिचूला"],[227,"जणू"],[228,"म्हणायचं"],[229,"होतं,"],[230,"की"],[231,"तिला"],[232,"पोहता"],[233,"येतं"],[234,"हे"],[235,"तिला"],[236,"कायमच"],[237,"ठाऊक"],[238,"होतं."]]},{"n":11,"img":"https://storage.googleapis.com/static.storyweaver.org.in/illustration_crops/54468/size6/7fa462136bbff5512dffe28b4e277902.jpg","text":"गुरू\nआणि पिचू आता रोज समुद्रकिनाऱ्यावर खेळायला जातात.\nगुरू आणि पिचू चेंडू खेळतात आणि\nइकडे तिकडे हुंदडतात.\nगुरू आणि पिचू समुद्राच्या\nलाटांमध्ये जातात.\nलाटांत धपाधप उड्या मारतात आणि एकमेकांवर छपछप पाणीही\nउडवतात.","words":[[239,"गुरू"],[240,"आणि"],[241,"पिचू"],[242,"आता"],[243,"रोज"],[244,"समुद्रकिनाऱ्यावर"],[245,"खेळायला"],[246,"जातात."],[247,"गुरू"],[248,"आणि"],[249,"पिचू"],[250,"चेंडू"],[251,"खेळतात"],[252,"आणि"],[253,"इकडे"],[254,"तिकडे"],[255,"हुंदडतात."],[256,"गुरू"],[257,"आणि"],[258,"पिचू"],[259,"समुद्राच्या"],[260,"लाटांमध्ये"],[261,"जातात."],[262,"लाटांत"],[263,"धपाधप"],[264,"उड्या"],[265,"मारतात"],[266,"आणि"],[267,"एकमेकांवर"],[268,"छपछप"],[269,"पाणीही"],[270,"उडवतात."]]}],"stats":{"pages":11,"words":270}}